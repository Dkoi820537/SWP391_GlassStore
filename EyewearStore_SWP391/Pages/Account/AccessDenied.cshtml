@page
@model EyewearStore_SWP391.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
    Layout = "_Layout";
}

@section Styles {
    <style>
        :root {
            --teal: #00756A;
            --teal-dk: #005a51;
            --teal-lt: #e8f5f4;
            --red: #e53935;
            --text: #1a1a1a;
            --sub: #6b7280;
            --border: #e5e7eb;
        }

        .ad-page {
            min-height: 70vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 24px;
            background: linear-gradient(135deg, #f9fafb 0%, #fef2f2 50%, #e8f5f4 100%);
        }

        .ad-card {
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 8px 48px rgba(0,0,0,0.10);
            padding: 56px 48px 48px;
            max-width: 560px;
            width: 100%;
            text-align: center;
            position: relative;
            overflow: hidden;
            animation: adSlideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        @@keyframes adSlideUp {
            from { opacity: 0; transform: translateY(30px); }
            to   { opacity: 1; transform: translateY(0);    }
        }

        .ad-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, var(--red), #fca5a5, var(--red));
        }

        /* Shield icon */
        .ad-shield {
            position: relative;
            width: 100px;
            height: 100px;
            margin: 0 auto 28px;
            animation: adPulse 2.5s ease-in-out infinite;
        }

        @@keyframes adPulse {
            0%, 100% { transform: scale(1); }
            50%      { transform: scale(1.04); }
        }

        .ad-shield svg {
            width: 100%;
            height: 100%;
        }

        /* Big code */
        .ad-big-number {
            font-size: 80px;
            font-weight: 900;
            line-height: 1;
            margin-bottom: 4px;
            background: linear-gradient(135deg, var(--red), #fb7185);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: adFadeIn 0.6s 0.15s both;
        }

        .ad-label {
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--red);
            margin-bottom: 10px;
            animation: adFadeIn 0.6s 0.25s both;
        }

        .ad-title {
            font-size: 26px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 14px;
            line-height: 1.3;
            animation: adFadeIn 0.6s 0.35s both;
        }

        .ad-desc {
            font-size: 15px;
            color: var(--sub);
            line-height: 1.7;
            margin: 0 0 32px;
            animation: adFadeIn 0.6s 0.45s both;
        }

        @@keyframes adFadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0);    }
        }

        /* Actions */
        .ad-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 28px;
            animation: adFadeIn 0.6s 0.55s both;
        }

        .btn-home {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 13px 28px;
            background: var(--teal);
            color: #fff;
            border-radius: 10px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
            transition: background .2s, transform .15s, box-shadow .2s;
        }

        .btn-home:hover {
            background: var(--teal-dk);
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 117, 106, 0.3);
        }

        .btn-login {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 13px 28px;
            background: #fff;
            color: var(--teal);
            border: 2px solid var(--teal);
            border-radius: 10px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
            transition: background .2s, transform .15s, box-shadow .2s;
        }

        .btn-login:hover {
            background: var(--teal-lt);
            color: var(--teal);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 117, 106, 0.15);
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 13px 28px;
            background: #fff;
            color: var(--sub);
            border: 2px solid var(--border);
            border-radius: 10px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
            transition: background .2s, transform .15s;
            cursor: pointer;
        }

        .btn-back:hover {
            background: #f9fafb;
            color: var(--text);
            transform: translateY(-2px);
        }

        /* Quick links */
        .ad-quick-links {
            border-top: 1px solid var(--border);
            padding-top: 24px;
            animation: adFadeIn 0.6s 0.65s both;
        }

        .ad-quick-label {
            font-size: 12px;
            font-weight: 700;
            color: var(--sub);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 14px;
        }

        .ad-links-row {
            display: flex;
            gap: 10px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .ad-link-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 14px;
            background: var(--teal-lt);
            color: var(--teal);
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: background .15s, transform .15s;
        }

        .ad-link-chip:hover {
            background: #c5e8e5;
            color: var(--teal-dk);
            transform: translateY(-2px);
        }

        /* Background decoration */
        .bg-glasses {
            position: absolute;
            bottom: -14px;
            right: -14px;
            font-size: 100px;
            opacity: 0.04;
            pointer-events: none;
            transform: rotate(-15deg);
        }

        @@media (max-width: 576px) {
            .ad-card {
                padding: 40px 20px 32px;
            }

            .ad-big-number {
                font-size: 60px;
            }

            .ad-title {
                font-size: 20px;
            }

            .ad-actions {
                flex-direction: column;
            }

            .btn-home, .btn-login, .btn-back {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}

<div class="ad-page">
    <div class="ad-card">
        <i class="bi bi-eyeglasses bg-glasses"></i>

        <!-- Shield illustration -->
        <div class="ad-shield">
            <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M50 8L14 24v24c0 22 15.2 42.6 36 48 20.8-5.4 36-26 36-48V24L50 8z"
                      fill="#fff3f3" stroke="#fca5a5" stroke-width="2.5"/>
                <path d="M50 16L20 30v18c0 18.5 12.7 35.6 30 40 17.3-4.4 30-21.5 30-40V30L50 16z"
                      fill="#fef2f2"/>
                <circle cx="50" cy="48" r="16" fill="#fee2e2" stroke="#e53935" stroke-width="2"/>
                <path d="M44 42l12 12M56 42L44 54" stroke="#e53935" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
        </div>

        <div class="ad-big-number">403</div>
        <div class="ad-label">Access Denied</div>
        <h1 class="ad-title">You don't have permission to view this page</h1>
        <p class="ad-desc">
            This area is restricted to authorized personnel only.<br>
            If you believe this is a mistake, please try logging in with a different account
            or contact support for assistance.
        </p>

        <div class="ad-actions">
            <a href="/" class="btn-home">
                <i class="bi bi-house-fill"></i> Go to Homepage
            </a>
            @if (!(User.Identity?.IsAuthenticated ?? false))
            {
                <a href="/Account/Login" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i> Log In
                </a>
            }
            <button onclick="history.back()" class="btn-back">
                <i class="bi bi-arrow-left"></i> Go Back
            </button>
        </div>

        <div class="ad-quick-links">
            <div class="ad-quick-label">Browse instead</div>
            <div class="ad-links-row">
                <a href="/Products?ProductTypeFilter=Frame" class="ad-link-chip">
                    <i class="bi bi-eyeglasses"></i> Frames
                </a>
                <a href="/Products?ProductTypeFilter=Lens" class="ad-link-chip">
                    <i class="bi bi-circle"></i> Lenses
                </a>
                <a href="/Customer/Services/CustomGlasses" class="ad-link-chip">
                    <i class="bi bi-tools"></i> Services
                </a>
            </div>
        </div>
    </div>
</div>
