@page
@model EyewearStore_SWP391.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
    var step = Model.Step;
    if (step == "form" && TempData["Reg_Step"] as string == "otp") step = "otp";
    var resendMsg = TempData["ResendMsg"] as string;
    var email = TempData.Peek("Reg_Email") as string ?? Model.Input.Email;
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --teal-900: #042f2e;
            --teal-800: #134e4a;
            --teal-700: #115e59;
            --teal-600: #0d9488;
            --teal-500: #14b8a6;
            --teal-400: #2dd4bf;
            --teal-100: #ccfbf1;
            --teal-50: #f0fdfa;
            --gold: #c9a96e;
            --gold-lt: #e8d5b0;
            --ink: #0f172a;
            --muted: #64748b;
        }

        /* ── page ── */
        .op-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2.5rem 1rem;
            position: relative;
            overflow: hidden;
            background: linear-gradient(145deg, var(--teal-900) 0%, var(--teal-800) 55%, #0c3b37 100%);
        }

            .op-page::before {
                content: '';
                position: fixed;
                inset: 0;
                background-image: linear-gradient(rgba(45,212,191,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(45,212,191,.04) 1px, transparent 1px);
                background-size: 52px 52px;
                animation: gridDrift 25s linear infinite;
                pointer-events: none;
                z-index: 0;
            }

        @@keyframes gridDrift {
            from

        {
            background-position: 0 0;
        }

        to {
            background-position: 52px 52px;
        }

        }

        .op-blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(90px);
            pointer-events: none;
            z-index: 0;
            animation: blobPulse ease-in-out infinite alternate;
        }

        .op-blob-1 {
            width: 480px;
            height: 480px;
            top: -120px;
            left: -120px;
            background: radial-gradient(circle,rgba(13,148,136,.24),transparent 70%);
            animation-duration: 11s;
        }

        .op-blob-2 {
            width: 360px;
            height: 360px;
            bottom: -80px;
            right: -80px;
            background: radial-gradient(circle,rgba(20,184,166,.18),transparent 70%);
            animation-duration: 14s;
            animation-delay: -5s;
        }

        .op-blob-3 {
            width: 220px;
            height: 220px;
            top: 40%;
            left: 62%;
            background: radial-gradient(circle,rgba(201,169,110,.12),transparent 70%);
            animation-duration: 9s;
            animation-delay: -3s;
        }

        @@keyframes blobPulse {
            from

        {
            transform: translate(0,0) scale(1);
        }

        to {
            transform: translate(22px,-18px) scale(1.07);
        }

        }

        .op-glass {
            position: fixed;
            bottom: -80px;
            opacity: 0;
            pointer-events: none;
            z-index: 0;
            animation: glassRise linear infinite;
        }

        @@keyframes glassRise {
            0%

        {
            transform: translateY(0) rotate(-4deg);
            opacity: 0;
        }

        8% {
            opacity: .18;
        }

        88% {
            opacity: .08;
        }

        100% {
            transform: translateY(-115vh) rotate(14deg);
            opacity: 0;
        }

        }

        /* ── Card ── */
        .op-card {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 490px;
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 32px 80px rgba(4,47,46,.5), 0 0 0 1px rgba(45,212,191,.14);
            animation: cardIn .65s cubic-bezier(.22,1,.36,1) forwards;
        }

        @@keyframes cardIn {
            from

        {
            opacity: 0;
            transform: translateY(24px) scale(.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }

        }

        /* ── Header ── */
        .op-header {
            background: linear-gradient(145deg, var(--teal-800) 0%, var(--teal-700) 55%, var(--teal-600) 100%);
            padding: 2.5rem 2.25rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .op-header::before,
            .op-header::after {
                content: '';
                position: absolute;
                border-radius: 50%;
                border: 1px solid rgba(255,255,255,.08);
                pointer-events: none;
            }

            .op-header::before {
                width: 200px;
                height: 200px;
                top: -70px;
                right: -50px;
            }

            .op-header::after {
                width: 120px;
                height: 120px;
                bottom: -40px;
                left: -30px;
            }

        .op-brand-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 1.1rem;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.22);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            animation: iconPop .7s cubic-bezier(.22,1,.36,1) .15s both;
        }

        @@keyframes iconPop {
            from

        {
            opacity: 0;
            transform: scale(.6) rotate(-12deg);
        }

        to {
            opacity: 1;
            transform: scale(1) rotate(0deg);
        }

        }

        .op-brand-icon::after {
            content: '';
            position: absolute;
            inset: 4px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,.15);
            pointer-events: none;
        }

        .op-title {
            font-family: 'Playfair Display',serif;
            font-size: 1.85rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: .3rem;
            letter-spacing: -.01em;
            animation: fadeUp .6s ease .22s both;
        }

        .op-subtitle {
            color: rgba(255,255,255,.65);
            font-size: .875rem;
            font-family: 'DM Sans',sans-serif;
            animation: fadeUp .6s ease .32s both;
        }

        @@keyframes fadeUp {
            from

        {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        /* ── Progress steps ── */
        .op-steps {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
            margin-top: 1.35rem;
            animation: fadeUp .6s ease .42s both;
        }

        .op-step {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .op-step-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Sans',sans-serif;
            font-size: 11px;
            font-weight: 700;
            border: 1.5px solid rgba(255,255,255,.2);
            color: rgba(255,255,255,.3);
            transition: all .3s;
        }

            .op-step-dot.active {
                background: rgba(255,255,255,.15);
                border-color: rgba(255,255,255,.6);
                color: #fff;
            }

            .op-step-dot.done {
                background: rgba(255,255,255,.2);
                border-color: rgba(255,255,255,.5);
                color: #fff;
            }

        .op-step-label {
            font-family: 'DM Sans',sans-serif;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: .7px;
            text-transform: uppercase;
            color: rgba(255,255,255,.3);
        }

            .op-step-label.active {
                color: rgba(255,255,255,.9);
            }

            .op-step-label.done {
                color: rgba(255,255,255,.6);
            }

        .op-step-line {
            width: 36px;
            height: 1px;
            margin: 0 8px;
            background: rgba(255,255,255,.15);
        }

            .op-step-line.done {
                background: rgba(255,255,255,.4);
            }

        /* ── Body ── */
        .op-body {
            padding: 2rem 2.25rem 2.5rem;
            background: #fff;
        }

        /* errors */
        .op-error-box {
            background: #fff5f5;
            border: 1px solid #fc8181;
            border-radius: 10px;
            padding: .75rem 1rem;
            margin-bottom: 1.5rem;
            font-size: 13px;
            color: #c53030;
            font-family: 'DM Sans',sans-serif;
        }

        .op-alert-ok {
            display: flex;
            align-items: center;
            gap: 9px;
            background: #ecfdf5;
            border: 1px solid #6ee7b7;
            border-radius: 10px;
            padding: .75rem 1rem;
            margin-bottom: 1.5rem;
            font-family: 'DM Sans',sans-serif;
            font-size: 13px;
            color: #065f46;
        }

        /* field */
        .op-field {
            margin-bottom: 1.25rem;
        }

        .op-field-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 1.25rem;
        }

            .op-field-row .op-field {
                margin-bottom: 0;
            }

        .op-label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-family: 'DM Sans',sans-serif;
            font-size: 11.5px;
            font-weight: 600;
            letter-spacing: .7px;
            text-transform: uppercase;
            color: var(--teal-700);
            margin-bottom: .45rem;
        }

        .op-label-opt {
            font-weight: 400;
            letter-spacing: 0;
            text-transform: none;
            font-size: 11px;
            color: #94a3b8;
        }

        .op-input {
            width: 100%;
            padding: .875rem 1.1rem;
            background: var(--teal-50);
            border: 1.5px solid #d1fae5;
            border-radius: 11px;
            font-family: 'DM Sans',sans-serif;
            font-size: 14.5px;
            color: var(--ink);
            outline: none;
            transition: border-color .2s,box-shadow .2s,background .2s;
        }

            .op-input::placeholder {
                color: #94a3b8;
            }

            .op-input:focus {
                border-color: var(--teal-500);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(20,184,166,.15);
            }

        .op-validation {
            display: block;
            font-family: 'DM Sans',sans-serif;
            font-size: 12px;
            color: #e53e3e;
            margin-top: 4px;
        }

        .op-hint {
            display: block;
            font-family: 'DM Sans',sans-serif;
            font-size: 11px;
            color: #94a3b8;
            margin-top: 4px;
        }

        /* btn */
        .op-btn {
            width: 100%;
            padding: 1rem;
            background: linear-gradient(135deg,var(--teal-600) 0%,var(--teal-800) 100%);
            color: #fff;
            border: none;
            border-radius: 12px;
            font-family: 'DM Sans',sans-serif;
            font-size: 13.5px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: transform .2s,box-shadow .2s;
            margin-top: .25rem;
        }

            .op-btn::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(180deg,rgba(255,255,255,.1) 0%,transparent 50%);
                pointer-events: none;
            }

            .op-btn:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 10px 28px rgba(13,148,136,.4);
            }

            .op-btn:disabled {
                background: #e2e8f0;
                color: #94a3b8;
                cursor: not-allowed;
            }

        .op-btn-ghost {
            width: 100%;
            padding: .8rem;
            background: transparent;
            color: var(--muted);
            border: 1.5px solid #e2e8f0;
            border-radius: 12px;
            font-family: 'DM Sans',sans-serif;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            margin-top: 10px;
            text-decoration: none;
            display: block;
            text-align: center;
            transition: all .2s;
        }

            .op-btn-ghost:hover {
                border-color: var(--teal-500);
                color: var(--teal-700);
            }

        /* divider */
        .op-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 1.6rem 0;
        }

            .op-divider::before,
            .op-divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #e2e8f0;
            }

            .op-divider span {
                font-family: 'DM Sans',sans-serif;
                font-size: 11px;
                color: #94a3b8;
                letter-spacing: .3px;
            }

        /* login CTA */
        .op-cta {
            background: linear-gradient(135deg,var(--teal-50) 0%,#ecfdf5 100%);
            border: 1px solid #d1fae5;
            border-radius: 12px;
            padding: 1.1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

            .op-cta span {
                font-family: 'DM Sans',sans-serif;
                font-size: 13.5px;
                color: var(--muted);
            }

            .op-cta a {
                font-family: 'DM Sans',sans-serif;
                font-size: 13.5px;
                font-weight: 700;
                color: var(--teal-600);
                text-decoration: none;
                white-space: nowrap;
                transition: color .2s;
            }

                .op-cta a:hover {
                    color: var(--teal-800);
                }

        /* card footer */
        .op-card-foot {
            background: var(--teal-50);
            border-top: 1px solid #d1fae5;
            padding: 1rem 2.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .op-secure {
            display: flex;
            align-items: center;
            gap: 7px;
            font-family: 'DM Sans',sans-serif;
            font-size: 11px;
            color: #64748b;
        }

        .op-secure-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--teal-500);
            animation: dotPulse 2.2s ease-in-out infinite;
        }

        @@keyframes dotPulse {
            0%,100%

        {
            box-shadow: 0 0 0 0 rgba(20,184,166,.5);
        }

        50% {
            box-shadow: 0 0 0 4px rgba(20,184,166,0);
        }

        }

        /* ══ OTP STEP ══════════════════════════════════════ */
        .otp-info {
            text-align: center;
            margin-bottom: 1.75rem;
        }

        .otp-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 1.1rem;
            background: linear-gradient(145deg,var(--teal-50),#ecfdf5);
            border: 1.5px solid #d1fae5;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .otp-heading {
            font-family: 'Playfair Display',serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: .45rem;
        }

        .otp-desc {
            font-family: 'DM Sans',sans-serif;
            font-size: 13.5px;
            color: var(--muted);
            line-height: 1.65;
        }

        .otp-email-badge {
            display: inline-block;
            background: var(--teal-50);
            border: 1px solid #d1fae5;
            border-radius: 8px;
            padding: 2px 10px;
            font-weight: 700;
            color: var(--teal-700);
            font-size: 13.5px;
        }

        /* OTP boxes */
        .otp-inputs {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin: 1.75rem 0 .75rem;
        }

        .otp-digit {
            width: 52px;
            height: 60px;
            border: 1.5px solid #d1fae5;
            border-radius: 13px;
            font-family: 'DM Sans',sans-serif;
            font-size: 22px;
            font-weight: 700;
            text-align: center;
            color: var(--ink);
            background: var(--teal-50);
            outline: none;
            transition: border-color .2s,box-shadow .2s,transform .15s,background .2s;
            caret-color: var(--teal-600);
        }

            .otp-digit:focus {
                border-color: var(--teal-500);
                background: #fff;
                box-shadow: 0 0 0 3px rgba(20,184,166,.15);
                transform: scale(1.06);
            }

            .otp-digit.filled {
                border-color: var(--teal-500);
                background: #fff;
            }

            .otp-digit.error {
                border-color: #fc8181;
                background: #fff5f5;
                animation: shake .3s ease;
            }

        @@keyframes shake {
            0%,100%

        {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-5px);
        }

        75% {
            transform: translateX(5px);
        }

        }

        #OtpCode {
            display: none;
        }

        .otp-timer {
            text-align: center;
            margin: .75rem 0;
            font-family: 'DM Sans',sans-serif;
            font-size: 12.5px;
            color: var(--muted);
        }

        .timer-value {
            font-weight: 700;
            color: var(--teal-600);
            font-variant-numeric: tabular-nums;
        }

        .timer-expired {
            color: #e53e3e !important;
        }

        .otp-resend {
            text-align: center;
            margin-bottom: 1.25rem;
            font-family: 'DM Sans',sans-serif;
            font-size: 13px;
            color: var(--muted);
        }

        .btn-resend {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--teal-600);
            font-weight: 700;
            font-size: 13px;
            font-family: 'DM Sans',sans-serif;
            padding: 0;
            text-decoration: underline;
            transition: color .2s;
        }

            .btn-resend:hover {
                color: var(--teal-800);
            }

            .btn-resend:disabled {
                color: #94a3b8;
                cursor: not-allowed;
                text-decoration: none;
            }

        .resend-ok {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #ecfdf5;
            border: 1px solid #6ee7b7;
            border-radius: 8px;
            padding: 5px 12px;
            font-family: 'DM Sans',sans-serif;
            font-size: 12px;
            color: #065f46;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        @@media (max-width:480px) {
            .op-field-row

        {
            grid-template-columns: 1fr;
        }

        .op-body {
            padding: 1.75rem 1.5rem 2rem;
        }

        .op-header {
            padding: 2rem 1.5rem 1.75rem;
        }

        .otp-digit {
            width: 44px;
            height: 52px;
            font-size: 18px;
        }

        }
    </style>
}

<!-- Background layers -->
<div class="op-blob op-blob-1"></div>
<div class="op-blob op-blob-2"></div>
<div class="op-blob op-blob-3"></div>
<div id="glassLayer"></div>

<div class="op-page">
    <div class="op-card">

        <!-- Header -->
        <div class="op-header">
            <div class="op-brand-icon">
                <svg width="42" height="22" viewBox="0 0 48 24" fill="none">
                    <rect x="1" y="4" width="18" height="16" rx="8" stroke="rgba(255,255,255,.9)" stroke-width="2" fill="rgba(255,255,255,.1)" />
                    <rect x="29" y="4" width="18" height="16" rx="8" stroke="rgba(255,255,255,.9)" stroke-width="2" fill="rgba(255,255,255,.1)" />
                    <ellipse cx="6.5" cy="9" rx="4" ry="2.5" fill="rgba(255,255,255,.18)" transform="rotate(-15 6.5 9)" />
                    <ellipse cx="34.5" cy="9" rx="4" ry="2.5" fill="rgba(255,255,255,.18)" transform="rotate(-15 34.5 9)" />
                    <path d="M19 12L29 12" stroke="rgba(255,255,255,.9)" stroke-width="2" stroke-linecap="round" />
                    <path d="M1  12L-4  9" stroke="rgba(255,255,255,.75)" stroke-width="1.8" stroke-linecap="round" />
                    <path d="M47 12L52  9" stroke="rgba(255,255,255,.75)" stroke-width="1.8" stroke-linecap="round" />
                </svg>
            </div>
            <h1 class="op-title">Join OptiPlus</h1>
            <p class="op-subtitle">Create your account and discover perfect eyewear</p>

            <!-- Steps -->
            <div class="op-steps">
                <div class="op-step">
                    <div class="op-step-dot @(step == "otp" ? "done" : "active")">
                        @if (step == "otp")
                        {
                            <text>✓</text>
                        }
                        else
                        {

                            <text>1</text>
                        }
                    </div>
                    <span class="op-step-label @(step == "form" ? "active" : step == "otp" ? "done" : "")">Details</span>
                </div>
                <div class="op-step-line @(step == "otp" ? "done" : "")"></div>
                <div class="op-step">
                    <div class="op-step-dot @(step == "otp" ? "active" : "")">2</div>
                    <span class="op-step-label @(step == "otp" ? "active" : "")">Verify</span>
                </div>
                <div class="op-step-line"></div>
                <div class="op-step">
                    <div class="op-step-dot">3</div>
                    <span class="op-step-label">Done</span>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="op-body">

            @* ── STEP 1: Form ── *@
            @if (step == "form")
            {
                <form method="post" asp-page-handler="SendOtp" id="regForm">
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="op-error-box">
                            @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div style="display:flex;align-items:center;gap:6px;margin-bottom:2px;">
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                        <circle cx="6" cy="6" r="5" stroke="#e53e3e" stroke-width="1.2" />
                                        <path d="M6 3.5v3M6 8.5v.5" stroke="#e53e3e" stroke-width="1.3" stroke-linecap="round" />
                                    </svg>
                                    @e.ErrorMessage
                                </div>
                            }
                        </div>
                    }

                    <div class="op-field-row">
                        <div class="op-field">
                            <label class="op-label">
                                <svg width="12" height="11" viewBox="0 0 13 11" fill="none">
                                    <rect x=".5" y=".5" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.25" />
                                    <path d="M.5 3l6 4 6-4" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round" />
                                </svg>
                                Email
                            </label>
                            <input asp-for="Input.Email" class="op-input" placeholder="you@example.com" autocomplete="email" />
                            <span asp-validation-for="Input.Email" class="op-validation"></span>
                        </div>
                        <div class="op-field">
                            <label class="op-label">
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                    <circle cx="6" cy="4" r="2.5" stroke="currentColor" stroke-width="1.25" />
                                    <path d="M1.5 11c0-2.5 2-4 4.5-4s4.5 1.5 4.5 4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
                                </svg>
                                Full Name
                            </label>
                            <input asp-for="Input.FullName" class="op-input" placeholder="Your full name" />
                            <span asp-validation-for="Input.FullName" class="op-validation"></span>
                        </div>
                    </div>

                    <div class="op-field-row">
                        <div class="op-field">
                            <label class="op-label">
                                <svg width="11" height="12" viewBox="0 0 12 13" fill="none">
                                    <rect x=".5" y="5.5" width="11" height="7" rx="1.5" stroke="currentColor" stroke-width="1.25" />
                                    <path d="M3 5.5V3.5a3 3 0 016 0v2" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
                                    <circle cx="6" cy="9" r="1" fill="currentColor" />
                                </svg>
                                Password
                            </label>
                            <input asp-for="Input.Password" type="password" class="op-input" placeholder="Min. 6 characters" autocomplete="new-password" />
                            <span asp-validation-for="Input.Password" class="op-validation"></span>
                            <span class="op-hint">At least 6 characters</span>
                        </div>
                        <div class="op-field">
                            <label class="op-label">
                                Phone <span class="op-label-opt">(optional)</span>
                            </label>
                            <input asp-for="Input.Phone" class="op-input" placeholder="+84 123 456 789" />
                            <span asp-validation-for="Input.Phone" class="op-validation"></span>
                        </div>
                    </div>

                    <button type="submit" class="op-btn" id="btnSendOtp">
                        <span id="btnText">Send Verification Code →</span>
                    </button>

                    <div class="op-divider"><span>or</span></div>

                    <div class="op-cta">
                        <span>Already have an account?</span>
                        <a asp-page="/Account/Login">Sign in →</a>
                    </div>
                </form>
            }

            @* ── STEP 2: OTP ── *@
            else
            {
                <div class="otp-info">
                    <div class="otp-icon">
                        <svg width="32" height="28" viewBox="0 0 32 28" fill="none">
                            <rect x="1" y="5" width="30" height="22" rx="3" stroke="var(--teal-500)" stroke-width="1.8" fill="rgba(20,184,166,.07)" />
                            <path d="M1 9l15 9 15-9" stroke="var(--teal-500)" stroke-width="1.8" stroke-linejoin="round" />
                            <circle cx="26" cy="6" r="5" fill="var(--teal-600)" stroke="var(--teal-100)" stroke-width="1.5" />
                            <path d="M23.5 6l1.5 1.5L28.5 4" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <div class="otp-heading">Check your inbox</div>
                    <p class="otp-desc">
                        We sent a 6-digit code to<br>
                        <span class="otp-email-badge">@email</span>
                    </p>
                </div>

                @if (!string.IsNullOrEmpty(resendMsg))
                {
                    <div style="text-align:center;margin-bottom:1rem;">
                        <span class="resend-ok">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                <circle cx="6" cy="6" r="5" stroke="#059669" stroke-width="1.2" />
                                <path d="M3.5 6l2 2 3.5-3.5" stroke="#059669" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            @resendMsg
                        </span>
                    </div>
                }

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("OtpCode"))
                {
                    <div class="op-error-box" id="otpErrorBox">
                        @ViewData.ModelState["OtpCode"]!.Errors.First().ErrorMessage
                    </div>
                }

                <!-- OTP boxes -->
                <div class="otp-inputs" id="otpInputs">
                    @for (int i = 0; i < 6; i++)
                    {
                        <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]"
                               class="otp-digit" data-idx="@i"
                               autocomplete="@(i == 0 ? "one-time-code" : "off")" />
                    }
                </div>

                <div class="otp-timer">
                    Code expires in <span class="timer-value" id="timerDisplay">10:00</span>
                </div>

                <div class="otp-resend">
                    Didn't receive it?&nbsp;
                    <form method="post" asp-page-handler="ResendOtp" style="display:inline;">
                        <button type="submit" class="btn-resend" id="btnResend">Resend code</button>
                    </form>
                </div>

                <form method="post" asp-page-handler="VerifyOtp" id="verifyForm">
                    <input type="hidden" asp-for="OtpCode" id="OtpCode" />
                    <button type="submit" class="op-btn" id="btnVerify" disabled>
                        Verify &amp; Create Account
                    </button>
                </form>

                <a asp-page="/Account/Register" class="op-btn-ghost">← Back to registration</a>
            }
        </div>

        <div class="op-card-foot">
            <div class="op-secure">
                <div class="op-secure-dot"></div>
                SSL Encrypted &nbsp;·&nbsp; Your data is protected
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        /* ── Floating glasses ───────────────────────────────────────── */
        (function () {
            const layer = document.getElementById('glassLayer');
            const frames = [
                (op) => `<svg width="56" height="28" viewBox="0 0 48 24" fill="none">
                    <rect x="1"  y="4" width="18" height="16" rx="8" stroke="rgba(45,212,191,${op})" stroke-width="1.8" fill="none"/>
                    <rect x="29" y="4" width="18" height="16" rx="8" stroke="rgba(45,212,191,${op})" stroke-width="1.8" fill="none"/>
                    <path d="M19 12L29 12" stroke="rgba(45,212,191,${op})" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M1 12L-4 9"  stroke="rgba(45,212,191,${op})" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M47 12L52 9" stroke="rgba(45,212,191,${op})" stroke-width="1.5" stroke-linecap="round"/>
                </svg>`,
                (op) => `<svg width="52" height="26" viewBox="0 0 48 24" fill="none">
                    <circle cx="11" cy="12" r="9" stroke="rgba(201,169,110,${op})" stroke-width="1.8" fill="none"/>
                    <circle cx="37" cy="12" r="9" stroke="rgba(201,169,110,${op})" stroke-width="1.8" fill="none"/>
                    <path d="M20 12L28 12" stroke="rgba(201,169,110,${op})" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M2 12L-3 9"  stroke="rgba(201,169,110,${op})" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M46 12L51 9" stroke="rgba(201,169,110,${op})" stroke-width="1.5" stroke-linecap="round"/>
                </svg>`,
                (op) => `<svg width="58" height="24" viewBox="0 0 50 20" fill="none">
                    <path d="M1 15Q1 3 10 2Q18 1 19 10Q18 17 10 16Z" stroke="rgba(255,255,255,${op})" stroke-width="1.8" fill="none"/>
                    <path d="M31 15Q31 3 40 2Q48 1 49 10Q48 17 40 16Z" stroke="rgba(255,255,255,${op})" stroke-width="1.8" fill="none"/>
                    <path d="M19 10L31 10" stroke="rgba(255,255,255,${op})" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M1 15L-3 12"  stroke="rgba(255,255,255,${op})" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M49 10L53 7"  stroke="rgba(255,255,255,${op})" stroke-width="1.5" stroke-linecap="round"/>
                </svg>`,
            ];

            for (let i = 0; i < 16; i++) {
                const d = document.createElement('div');
                d.className = 'op-glass';
                const scale = (.55 + Math.random() * 1.1).toFixed(2);
                const op    = (.07 + Math.random() * .11).toFixed(2);
                d.style.cssText =
                    `left:${2 + Math.random() * 92}%;bottom:-80px;` +
                    `transform:scale(${scale});` +
                    `animation-duration:${10 + Math.random() * 16}s;` +
                    `animation-delay:${Math.random() * 15}s;`;
                d.innerHTML = frames[i % 3](op);
                layer.appendChild(d);
            }
        })();

        /* ── Step 1 loading state ───────────────────────────────────── */
        const regForm = document.getElementById('regForm');
        if (regForm) {
            regForm.addEventListener('submit', () => {
                const btn = document.getElementById('btnSendOtp');
                const txt = document.getElementById('btnText');
                btn.disabled = true;
                txt.textContent = 'Sending code…';
            });
        }

        /* ── Step 2 OTP boxes ───────────────────────────────────────── */
        const digits  = document.querySelectorAll('.otp-digit');
        const hidden  = document.getElementById('OtpCode');
        const btnVfy  = document.getElementById('btnVerify');

        if (digits.length) {
            digits[0].focus();

            digits.forEach((box, idx) => {
                box.addEventListener('input', (e) => {
                    const v = e.target.value.replace(/\D/g,'');
                    e.target.value = v;
                    box.classList.toggle('filled', !!v);
                    if (v && idx < 5) digits[idx+1].focus();
                    sync();
                });

                box.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && !box.value && idx > 0) {
                        digits[idx-1].focus();
                        digits[idx-1].value = '';
                        digits[idx-1].classList.remove('filled');
                        sync();
                    }
                });

                box.addEventListener('paste', (e) => {
                    e.preventDefault();
                    const paste = (e.clipboardData||window.clipboardData)
                        .getData('text').replace(/\D/g,'').slice(0,6);
                    paste.split('').forEach((ch,i) => {
                        if (digits[i]) { digits[i].value=ch; digits[i].classList.add('filled'); }
                    });
                    sync();
                    digits[Math.min(paste.length,5)].focus();
                });
            });

            function sync() {
                const code = Array.from(digits).map(d=>d.value).join('');
                if (hidden) hidden.value = code;
                if (btnVfy) btnVfy.disabled = code.length !== 6;
            }

            if (document.getElementById('otpErrorBox')) {
                digits.forEach(d => d.classList.add('error'));
            }
        }

        /* ── Countdown ──────────────────────────────────────────────── */
        const timerEl = document.getElementById('timerDisplay');
        if (timerEl) {
            let sec = 600;
            const tick = setInterval(() => {
                sec--;
                if (sec <= 0) {
                    clearInterval(tick);
                    timerEl.textContent = 'Expired';
                    timerEl.classList.add('timer-expired');
                    if (btnVfy) btnVfy.disabled = true;
                    return;
                }
                const m = Math.floor(sec/60).toString().padStart(2,'0');
                const s = (sec%60).toString().padStart(2,'0');
                timerEl.textContent = `${m}:${s}`;
                if (sec <= 60) timerEl.classList.add('timer-expired');
            }, 1000);
        }
    </script>
}
