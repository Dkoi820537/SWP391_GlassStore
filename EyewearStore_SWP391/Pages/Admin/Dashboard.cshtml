@page
@model EyewearStore_SWP391.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f5f6fa;
            --surf: #fff;
            --surf2: #f0f2f8;
            --bdr: rgba(99,102,141,.13);
            --navy: #0d1b2a;
            --gold: #b8862a;
            --ok: #059669;
            --ok-bg: rgba(5,150,105,.08);
            --ok-bdr: rgba(5,150,105,.22);
            --warn: #d97706;
            --warn-bg: rgba(217,119,6,.09);
            --warn-bdr: rgba(217,119,6,.25);
            --info: #2563eb;
            --info-bg: rgba(37,99,235,.08);
            --info-bdr: rgba(37,99,235,.22);
            --err: #dc2626;
            --err-bg: rgba(220,38,38,.08);
            --err-bdr: rgba(220,38,38,.22);
            --muted: #8b8da8;
            --txt: #12132a;
            --txt2: #40415e;
            --sh: 0 2px 12px rgba(18,19,42,.07);
            --sh-md: 0 4px 24px rgba(18,19,42,.1)
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        body {
            background: var(--bg);
            font-family: 'Plus Jakarta Sans',sans-serif;
            color: var(--txt)
        }

        .db-wrap {
            max-width: 1380px;
            margin: 0 auto;
            padding: 32px 24px 80px
        }

        /* HERO STRIP */
        .db-hero {
            background: linear-gradient(135deg,#0a0a1a 0%,#1a2332 60%,#0f2744 100%);
            border-radius: 20px;
            padding: 32px 36px;
            margin-bottom: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px
        }

            .db-hero h1 {
                font-size: 1.75rem;
                font-weight: 800;
                color: #fff;
                margin: 0 0 5px
            }

            .db-hero p {
                font-size: 13px;
                color: rgba(255,255,255,.45);
                margin: 0
            }

            .db-hero .rev {
                text-align: right
            }

        .rev-lbl {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,.35);
            text-transform: uppercase;
            margin-bottom: 4px
        }

        .rev-val {
            font-family: 'DM Mono',monospace;
            font-size: 28px;
            font-weight: 500;
            color: #f0c860
        }

        .rev-sub {
            font-size: 12px;
            color: rgba(255,255,255,.35);
            margin-top: 2px
        }

        /* ALERTS */
        .alert-list {
            display: flex;
            flex-direction: column;
            gap: 9px;
            margin-bottom: 20px
        }

        .al {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 11px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s;
            animation: sli .3s ease
        }
        @@keyframes sli {
            from

        {
            opacity: 0;
            transform: translateY(-4px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }

        }

        .al:hover {
            filter: brightness(.96);
            transform: translateX(3px)
        }

        .al.ok {
            background: var(--ok-bg);
            border: 1px solid var(--ok-bdr);
            color: var(--ok)
        }

        .al.warn {
            background: var(--warn-bg);
            border: 1px solid var(--warn-bdr);
            color: var(--warn)
        }

        .al.info {
            background: var(--info-bg);
            border: 1px solid var(--info-bdr);
            color: var(--info)
        }

        .al i {
            font-size: 16px;
            flex-shrink: 0
        }

        .al-arrow {
            margin-left: auto;
            font-size: 16px;
            opacity: .5
        }

        /* STATS GRID */
        .stats-g {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 20px
        }

        .sc {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 16px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: var(--sh);
            text-decoration: none;
            transition: all .2s;
            color: inherit
        }

            .sc:hover {
                box-shadow: var(--sh-md);
                transform: translateY(-2px)
            }

        .sc-ico {
            width: 48px;
            height: 48px;
            border-radius: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0
        }

        .i-navy {
            background: rgba(13,27,42,.08);
            color: var(--navy)
        }

        .i-ok {
            background: var(--ok-bg);
            color: var(--ok)
        }

        .i-warn {
            background: var(--warn-bg);
            color: var(--warn)
        }

        .i-info {
            background: var(--info-bg);
            color: var(--info)
        }

        .i-gold {
            background: rgba(184,134,42,.1);
            color: var(--gold)
        }

        .sc-lbl {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 3px
        }

        .sc-val {
            font-family: 'DM Mono',monospace;
            font-size: 24px;
            font-weight: 500;
            color: var(--txt)
        }

        .sc-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px
        }

        /* SECTION LABEL */
        .sec-lbl {
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.8px;
            color: var(--muted);
            margin-bottom: 12px
        }

        /* 2-COL LAYOUT */
        .two-col {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 18px;
            margin-top: 20px
        }

        /* CARD */
        .card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: var(--sh)
        }

        .card-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            border-bottom: 1px solid var(--bdr)
        }

            .card-hdr h3 {
                font-size: 14px;
                font-weight: 800;
                color: var(--txt);
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px
            }

            .card-hdr a {
                font-size: 12px;
                font-weight: 700;
                color: var(--info);
                text-decoration: none
            }

                .card-hdr a:hover {
                    text-decoration: underline
                }

        /* ORDER LIST */
        .ord-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 20px;
            border-bottom: 1px solid var(--bdr)
        }

            .ord-row:last-child {
                border-bottom: none
            }

        .ord-id {
            font-family: 'DM Mono',monospace;
            font-size: 12px;
            color: var(--muted);
            width: 52px
        }

        .ord-name {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt);
            flex: 1;
            margin: 0 12px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        .ord-amt {
            font-family: 'DM Mono',monospace;
            font-size: 12px;
            font-weight: 500;
            color: var(--gold);
            white-space: nowrap
        }

        .bd {
            display: inline-flex;
            align-items: center;
            padding: 3px 9px;
            border-radius: 100px;
            font-size: 10px;
            font-weight: 700;
            margin-left: 8px
        }

        .bd-Pending {
            background: var(--warn-bg);
            color: var(--warn);
            border: 1px solid var(--warn-bdr)
        }

        .bd-Processing {
            background: var(--info-bg);
            color: var(--info);
            border: 1px solid var(--info-bdr)
        }

        .bd-Completed, .bd-Done {
            background: rgba(15,23,42,.07);
            color: #0f172a;
            border: 1px solid rgba(15,23,42,.18)
        }

        .bd-Cancelled {
            background: var(--err-bg);
            color: var(--err);
            border: 1px solid var(--err-bdr)
        }

        .bd-Confirmed, .bd-Ready {
            background: var(--ok-bg);
            color: var(--ok);
            border: 1px solid var(--ok-bdr)
        }

        /* APPT LIST */
        .appt-row {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            border-bottom: 1px solid var(--bdr)
        }

            .appt-row:last-child {
                border-bottom: none
            }

        .av {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: linear-gradient(135deg,#e0e7ff,#c7d2fe);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            color: var(--info);
            flex-shrink: 0
        }

        .appt-name {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt)
        }

        .appt-dt {
            font-size: 11px;
            color: var(--muted);
            margin-top: 1px
        }

        .appt-today {
            font-size: 10px;
            font-weight: 700;
            color: var(--ok);
            background: var(--ok-bg);
            border: 1px solid var(--ok-bdr);
            border-radius: 4px;
            padding: 1px 5px;
            margin-left: 4px
        }

        /* SVC PENDING */
        .svc-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 20px;
            border-bottom: 1px solid var(--bdr)
        }

            .svc-row:last-child {
                border-bottom: none
            }

        .svc-name {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt)
        }

        .svc-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px
        }

        .btn-sm {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--surf2);
            border: 1px solid var(--bdr);
            border-radius: 7px;
            padding: 5px 10px;
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-decoration: none;
            transition: all .2s
        }

            .btn-sm:hover {
                border-color: var(--info);
                color: var(--info)
            }

        .empty-card {
            text-align: center;
            padding: 36px 20px;
            color: var(--muted);
            font-size: 13px
        }

        @@media(max-width:1100px) {
            .stats-g {
                grid-template-columns: repeat(2,1fr)
            }
        }

        @@media(max-width:900px) {
            .two-col {
                grid-template-columns: 1fr
            }
        }

        @@media(max-width:600px) {
            .stats-g {
                grid-template-columns: 1fr
            }

            .db-wrap {
                padding: 16px 12px 60px
            }

            .db-hero {
                padding: 24px 20px
            }
        }
    </style>
}

<div class="db-wrap">

    <!-- HERO -->
    <div class="db-hero">
        <div>
            <h1>👓 Admin Dashboard</h1>
            <p>@DateTime.Now.ToString("dddd, dd MMMM yyyy") — Overview of store activity</p>
        </div>
        <div class="rev">
            <div class="rev-lbl">Total Revenue</div>
            <div class="rev-val">@Model.Revenue.ToString("N0") ₫</div>
            <div class="rev-sub">+@Model.RevenueToday.ToString("N0") ₫ today</div>
        </div>
    </div>

    <!-- ALERTS -->
    @if (Model.Alerts.Any())
    {
        <div class="alert-list">
            @foreach (var a in Model.Alerts)
            {
                var (ico, cls) = a.Type switch
                {
                    "ok" => ("bi-check-circle-fill", "ok"),
                    "warn" => ("bi-exclamation-triangle-fill", "warn"),
                    _ => ("bi-info-circle-fill", "info")
                };
                <a href="@a.Link" class="al @cls">
                    <i class="bi @ico"></i>
                    @a.Message
                    <i class="bi bi-arrow-right al-arrow"></i>
                </a>
            }
        </div>
    }

    <!-- STATS ROW 1: Orders -->
    <div class="sec-lbl" style="margin-top:4px">📦 Orders</div>
    <div class="stats-g">
        <a class="sc" href="/Admin/Orders">
            <div class="sc-ico i-navy"><i class="bi bi-bag-fill"></i></div>
            <div>
                <div class="sc-lbl">Total Orders</div>
                <div class="sc-val">@Model.OrderTotal</div>
                <div class="sc-sub">@Model.OrderToday new today</div>
            </div>
        </a>
        <a class="sc" href="/Admin/Orders?StatusFilter=Pending">
            <div class="sc-ico i-warn"><i class="bi bi-hourglass-split"></i></div>
            <div>
                <div class="sc-lbl">Pending</div>
                <div class="sc-val">@Model.OrderPending</div>
                <div class="sc-sub">Need fulfillment</div>
            </div>
        </a>
        <a class="sc" href="/Admin/ServiceOrders">
            <div class="sc-ico i-info"><i class="bi bi-tools"></i></div>
            <div>
                <div class="sc-lbl">Service Orders</div>
                <div class="sc-val">@Model.SvcTotal</div>
                <div class="sc-sub">@Model.SvcPending pending · @Model.SvcReady ready</div>
            </div>
        </a>
        <a class="sc" href="/Admin/ServiceOrders?StatusFilter=Processing">
            <div class="sc-ico i-gold"><i class="bi bi-wrench-adjustable"></i></div>
            <div>
                <div class="sc-lbl">In Progress</div>
                <div class="sc-val">@Model.SvcProcessing</div>
                <div class="sc-sub">Service orders active</div>
            </div>
        </a>
    </div>

    <!-- STATS ROW 2: Appointments -->
    <div class="sec-lbl" style="margin-top:20px">📅 Eye Exam Appointments</div>
    <div class="stats-g">
        <a class="sc" href="/Admin/Appointments">
            <div class="sc-ico i-info"><i class="bi bi-calendar2-week"></i></div>
            <div>
                <div class="sc-lbl">Total Bookings</div>
                <div class="sc-val">@Model.ApptTotal</div>
                <div class="sc-sub">All time</div>
            </div>
        </a>
        <a class="sc" href="/Admin/Appointments?StatusFilter=Pending">
            <div class="sc-ico i-warn"><i class="bi bi-hourglass-split"></i></div>
            <div>
                <div class="sc-lbl">Awaiting Confirm</div>
                <div class="sc-val">@Model.ApptPending</div>
                <div class="sc-sub">Need action</div>
            </div>
        </a>
        <a class="sc" href="/Admin/Appointments?StatusFilter=Confirmed">
            <div class="sc-ico i-ok"><i class="bi bi-check-circle-fill"></i></div>
            <div>
                <div class="sc-lbl">Confirmed</div>
                <div class="sc-val">@Model.ApptConfirmed</div>
                <div class="sc-sub">Upcoming confirmed</div>
            </div>
        </a>
        <a class="sc" href="/Admin/Appointments?DateFilter=@DateTime.Today.ToString("yyyy-MM-dd")">
            <div class="sc-ico i-navy"><i class="bi bi-calendar-day"></i></div>
            <div>
                <div class="sc-lbl">Today</div>
                <div class="sc-val">@Model.ApptToday</div>
                <div class="sc-sub">Appointments today</div>
            </div>
        </a>
    </div>

    <!-- LOWER 2-COL -->
    <div class="two-col">
        <!-- Recent orders -->
        <div class="card">
            <div class="card-hdr">
                <h3><i class="bi bi-bag" style="color:var(--info)"></i> Recent Orders</h3>
                <a href="/Admin/Orders">View all →</a>
            </div>
            @if (Model.RecentOrders.Any())
            {
                @foreach (var o in Model.RecentOrders)
                {
                    <div class="ord-row">
                        <span class="ord-id">#@o.OrderId</span>
                        <span class="ord-name">@(o.CustomerName ?? "Guest")</span>
                        <span class="ord-amt">@o.Total.ToString("N0") ₫</span>
                        <span class="bd bd-@o.Status">@o.Status</span>
                    </div>
                }
            }
            else
            {
                <div class="empty-card">No orders yet</div>
            }
        </div>

        <!-- Right col: upcoming appointments + pending service orders -->
        <div style="display:flex;flex-direction:column;gap:18px">
            <div class="card">
                <div class="card-hdr">
                    <h3><i class="bi bi-calendar-check" style="color:var(--ok)"></i> Upcoming Appointments</h3>
                    <a href="/Admin/Appointments">View all →</a>
                </div>
                @if (Model.UpcomingAppts.Any())
                {
                    @foreach (var a in Model.UpcomingAppts)
                    {
                        bool isToday = a.AppointmentDate == DateOnly.FromDateTime(DateTime.Today);
                        var ini = string.Concat(a.FullName.Split(' ').Take(2)
                        .Select(w => char.ToUpper(w.FirstOrDefault())));
                        <div class="appt-row">
                            <div class="av">@ini</div>
                            <div>
                                <div class="appt-name">
                                    @a.FullName
                                    @if (isToday)
                                    {
                                        <span class="appt-today">TODAY</span>
                                    }
                                </div>
                                <div class="appt-dt">@a.AppointmentDate.ToString("dd/MM/yyyy") ⏰ @a.TimeSlot</div>
                            </div>
                            <span class="bd bd-@a.Status" style="margin-left:auto">@a.Status</span>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-card">No upcoming appointments</div>
                }
            </div>

            <div class="card">
                <div class="card-hdr">
                    <h3><i class="bi bi-tools" style="color:var(--warn)"></i> Pending Service Jobs</h3>
                    <a href="/Admin/ServiceOrders">View all →</a>
                </div>
                @if (Model.PendingSvcOrders.Any())
                {
                    @foreach (var s in Model.PendingSvcOrders)
                    {
                        <div class="svc-row">
                            <div>
                                <div class="svc-name">@(string.IsNullOrEmpty(s.FrameName) ? $"Order #{s.OrderId}" : s.FrameName)</div>
                                <div class="svc-sub">@s.ServiceName · #@s.OrderId</div>
                            </div>
                            <a href="/Admin/ServiceOrders/@s.OrderId" class="btn-sm">
                                <i class="bi bi-arrow-right"></i> Assign
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-card">🎉 No pending service jobs</div>
                }
            </div>
        </div>
    </div>
</div>
