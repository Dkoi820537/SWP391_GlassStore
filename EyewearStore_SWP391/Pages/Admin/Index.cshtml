                <div class="legend-row">
                    <span class="leg-item"><span class="leg-dot" style="background:#185FA5"></span>Sản phẩm</span>
                    <span class="leg-item"><span class="leg-dot" style="background:#0F6E56"></span>Dịch vụ</span>
                </div>
            </div>

            <div class="ch-card">
                <div class="ch-hdr">
                    <div>
                        <div class="ch-title">Cơ cấu doanh thu</div>
                        <div class="ch-sub">Theo danh mục</div>
                    </div>
                </div>
                <div class="ch-wrap" style="height:140px"><canvas id="revDonut"></canvas></div>

                <div class="breakdown">
                @{
                        var totalBreakdown = breakdownValues.Sum();
                    }
                    @for (int i = 0; i < breakdownLabels.Count && i < breakdownValues.Count; i++)
                    {
                        var pct = totalBreakdown > 0 ? (breakdownValues[i] / totalBreakdown * 100m) : 0m;
                        <div>
                            <div class="bk-row">
                                <span class="bk-lbl">
                                    <span class="leg-dot" style="background:@breakdownColors[i];width:8px;height:8px"></span>
                                    @breakdownLabels[i]
                                </span>
                                <span class="bk-val">@pct.ToString("0")%</span>
                            </div>
                            <div class="bk-bar">
                                <div class="bk-fill" style="width:@pct.ToString("0")%;background:@breakdownColors[i]"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="charts-row2">
            <div class="ch-card">
                <div class="ch-hdr">
                    <div>
