                    </div>
                </div>
                <div class="ch-wrap" style="height:160px"><canvas id="barWeek"></canvas></div>
            </div>
            <div class="ch-card">
                <div class="ch-hdr">
                    <div>
                        <div class="ch-title">Top sản phẩm bán chạy</div>
                        <div class="ch-sub">Theo doanh thu (triệu ₫)</div>
                    </div>
                </div>
                <div class="ch-wrap" style="height:160px"><canvas id="barProd"></canvas></div>
            </div>
        </div>
    }

    <div class="sec-lbl" style="margin-top:8px">📦 Orders</div>
    <div class="stats-g">
