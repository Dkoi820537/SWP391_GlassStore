</div>

@section Scripts {
    @if (Model.IsAdmin)
    {
        <script>
            const _revenueByDay = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueByDay ?? new List<decimal>()));
            const _serviceRevenueByDay = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ServiceRevenueByDay ?? new List<decimal>()));
            const _dayLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueByDayLabels ?? new List<string>()));
            const _topProducts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopProducts ?? new List<decimal>()));
            const _topProdNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopProductNames ?? new List<string>()));
            const _breakdownLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(breakdownLabels));
            const _breakdownValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(breakdownValues));
            const _todayRevPct = "@Model.TodayVsYesterdayPct";
        </script>

        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script>
            (function () {
                var gc = '#e2e8f0', tc = '#94a3b8';

                var base = {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } }
                };

                function zeroSeries(n) {
                    return Array.from({ length: n }, function () { return 0; });
                }

                var data7d = {
                    labels: _dayLabels.length ? _dayLabels : ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
                    prod: _revenueByDay.length ? _revenueByDay.map(function (v) { return +(v / 1e6).toFixed(1); }) : zeroSeries(_dayLabels.length || 7),
                    svc: _serviceRevenueByDay.length ? _serviceRevenueByDay.map(function (v) { return +(v / 1e6).toFixed(1); }) : zeroSeries(_dayLabels.length || 7)
                };

                var data30d = {
                    labels: ['Tuần 1', 'Tuần 2', 'Tuần 3', 'Tuần 4'],
                    prod: zeroSeries(4),
                    svc: zeroSeries(4)
                };

                var lineCtx = document.getElementById('revLine');
                var lineChart;

                function buildLine(d) {
                    if (lineChart) lineChart.destroy();
                    lineChart = new Chart(lineCtx, {
                        type: 'line',
                        data: {
                            labels: d.labels,
                            datasets: [
                                {
                                    label: 'Sản phẩm',
                                    data: d.prod,
                                    borderColor: '#185FA5',
                                    backgroundColor: 'rgba(24,95,165,0.08)',
                                    fill: true,
                                    tension: 0.4,
                                    pointRadius: 3,
                                    pointHoverRadius: 6,
                                    borderWidth: 2.5,
                                    pointBackgroundColor: '#185FA5'
                                },
                                {
                                    label: 'Dịch vụ',
                                    data: d.svc,
                                    borderColor: '#0F6E56',
                                    backgroundColor: 'rgba(15,110,86,0.06)',
                                    fill: true,
                                    tension: 0.4,
                                    pointRadius: 3,
                                    pointHoverRadius: 6,
                                    borderWidth: 2.5,
                                    pointBackgroundColor: '#0F6E56'
                                }
                            ]
                        },
                        options: {
                            ...base,
                            interaction: { mode: 'index', intersect: false },
                            scales: {
                                x: { grid: { color: gc }, ticks: { color: tc, font: { size: 11 } } },
                                y: {
                                    grid: { color: gc },
                                    beginAtZero: true,
                                    ticks: { color: tc, font: { size: 11 }, callback: function (v) { return v + 'M'; } }
                                }
                            },
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    callbacks: {
                                        label: function (ctx) {
                                            return ctx.dataset.label + ': ' + ctx.parsed.y.toFixed(1) + 'M ₫';
                                        }
                                    }
                                }
                            }
                        }
                    });
                }

                buildLine(data7d);

                window.switchPeriod = function (p, btn) {
                    document.querySelectorAll('.ch-tab').forEach(function (t) { t.classList.remove('active'); });
                    btn.classList.add('active');
                    buildLine(p === '7d' ? data7d : data30d);
                };

                new Chart(document.getElementById('revDonut'), {
                    type: 'doughnut',
                    data: {
                        labels: _breakdownLabels,
                        datasets: [{
                            data: _breakdownValues,
                            backgroundColor: ['#185FA5', '#0F6E56', '#BA7517'],
                            borderWidth: 0,
                            hoverOffset: 6
                        }]
                    },
                    options: {
                        ...base,
                        cutout: '70%',
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        return ctx.label + ': ' + Number(ctx.parsed).toLocaleString('vi-VN') + ' ₫';
                                    }
                                }
                            }
                        }
                    }
                });

                var dayData = _revenueByDay.length
                    ? _revenueByDay.map(function (v) { return +(v / 1e6).toFixed(1); })
                    : zeroSeries(_dayLabels.length || 7);

                var dayLbls = _dayLabels.length ? _dayLabels : ['01/04', '02/04', '03/04', '04/04', '05/04', '06/04', '07/04'];

                new Chart(document.getElementById('barWeek'), {
                    type: 'bar',
                    data: {
                        labels: dayLbls,
                        datasets: [{
                            label: 'Doanh thu (M₫)',
                            data: dayData,
                            backgroundColor: function (ctx) {
                                var max = Math.max.apply(null, dayData);
                                return ctx.parsed.y === max ? '#185FA5' : 'rgba(24,95,165,0.45)';
                            },
                            borderRadius: 6,
                            barPercentage: 0.65
                        }]
                    },
                    options: {
                        ...base,
                        scales: {
                            x: { grid: { display: false }, ticks: { color: tc, font: { size: 10 } } },
                            y: {
                                grid: { color: gc },
                                beginAtZero: true,
                                ticks: { color: tc, font: { size: 10 }, callback: function (v) { return v + 'M'; } }
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: { callbacks: { label: function (ctx) { return ctx.parsed.y.toFixed(1) + 'M ₫'; } } }
                        }
                    }
                });

                var prodData = _topProducts.length ? _topProducts.map(function (v) { return +(v / 1e6).toFixed(1); }) : [];
                var prodNames = _topProdNames.length ? _topProdNames : [];
                var prodColors = ['#185FA5', '#0F6E56', '#BA7517', '#534AB7', '#7c3aed'];

                new Chart(document.getElementById('barProd'), {
                    type: 'bar',
                    data: {
                        labels: prodNames,
                        datasets: [{
                            label: 'Doanh thu (M₫)',
                            data: prodData,
                            backgroundColor: prodColors,
                            borderRadius: 5,
                            barPercentage: 0.65
                        }]
                    },
                    options: {
                        ...base,
                        indexAxis: 'y',
                        scales: {
                            x: {
                                grid: { color: gc },
                                beginAtZero: true,
                                ticks: { color: tc, font: { size: 10 }, callback: function (v) { return v + 'M'; } }
                            },
                            y: {
                                grid: { display: false },
                                ticks: { color: tc, font: { size: 10 }, maxTicksLimit: 5 }
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: { callbacks: { label: function (ctx) { return ctx.parsed.x.toFixed(1) + 'M ₫'; } } }
                        }
                    }
                });

                var todayBadge = document.getElementById('today-badge');
                if (todayBadge) {
                    var pct = parseFloat(_todayRevPct);
                    if (!isNaN(pct)) {
                        todayBadge.textContent = (pct >= 0 ? '↑ +' : '↓ ') + Math.abs(pct).toFixed(1) + '% so hôm qua';
                        todayBadge.className = 'kpi-delta ' + (pct >= 0 ? 'delta-up' : 'delta-dn');
                    }
                }
            })();
        </script>
    }
}