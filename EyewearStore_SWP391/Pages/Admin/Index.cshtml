@page
@model EyewearStore_SWP391.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";

    var breakdownLabels = (Model.RevenueBreakdownLabels != null && Model.RevenueBreakdownLabels.Any())
        ? Model.RevenueBreakdownLabels
        : new List<string> { "Gọng kính", "Tròng kính", "Dịch vụ" };

    var breakdownValues = (Model.RevenueBreakdownValues != null && Model.RevenueBreakdownValues.Any())
        ? Model.RevenueBreakdownValues
        : new List<decimal> { 0m, 0m, 0m };

    var breakdownColors = new[] { "#185FA5", "#0F6E56", "#BA7517" };
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            background: #ffffff;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: #0f172a;
        }

        .adm-wrap {
            max-width: 1160px;
            margin: 0 auto;
            padding: 28px 28px 80px;
        }

        .adm-bc {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 500;
            color: #64748b;
            margin-bottom: 20px;
        }

            .adm-bc a {
                color: #64748b;
                text-decoration: none;
                transition: color .18s;
            }

                .adm-bc a:hover {
                    color: #0f172a;
                }

            .adm-bc .bc-sep {
                color: #94a3b8;
                font-size: 14px;
            }

            .adm-bc .bc-cur {
                color: #0f172a;
                font-weight: 600;
            }

        .adm-banner {
            background: #0d1b3e;
            border-radius: 16px;
            padding: 22px 32px;
            display: flex;
            align-items: center;
            gap: 18px;
            margin-bottom: 32px;
            box-shadow: 0 4px 20px rgba(13,27,62,.22);
        }

            .adm-banner .wave-emoji {
                font-size: 32px;
                line-height: 1;
                flex-shrink: 0;
            }

            .adm-banner .banner-text h2 {
                margin: 0 0 4px;
                font-size: 18px;
                font-weight: 700;
                color: #ffffff;
                letter-spacing: -.01em;
            }

            .adm-banner .banner-text p {
                margin: 0;
                font-size: 13.5px;
                color: rgba(255,255,255,.65);
                font-weight: 400;
            }

        .adm-page-title {
            text-align: center;
            font-size: 26px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -.02em;
            margin: 0 0 28px;
        }

        .feat-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }

        .feat-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 22px 24px 20px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 1px 8px rgba(0,0,0,.06);
            transition: box-shadow .22s, transform .22s;
            text-decoration: none;
            color: inherit;
        }

            .feat-card:hover {
                box-shadow: 0 6px 24px rgba(0,0,0,.1);
                transform: translateY(-2px);
            }

        .feat-card-top {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 10px;
        }

        .feat-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .feat-icon.teal {
                background: #e6f7f5;
            }

            .feat-icon.navy {
                background: #e8edf6;
            }

            .feat-icon.dkgreen {
                background: #e8f5ee;
            }

            .feat-icon.blue {
                background: #e8f0fb;
            }

        .feat-card-top h3 {
            flex: 1;
            font-size: 16px;
            font-weight: 700;
            color: #0f172a;
            margin: 0;
            letter-spacing: -.01em;
        }

        .feat-badge {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            padding: 3px 9px;
            border-radius: 6px;
            background: #f1f5f9;
            color: #64748b;
            border: 1px solid #e2e8f0;
            white-space: nowrap;
        }

        .feat-desc {
            font-size: 13px;
            color: #64748b;
            line-height: 1.65;
            margin: 0 0 14px;
            flex: 1;
        }

        .feat-spark-row {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 16px;
        }

        .feat-spark {
            flex: 1;
            height: 40px;
            min-width: 0;
        }

            .feat-spark svg {
                width: 100%;
                height: 100%;
                overflow: visible;
            }

        .feat-stat {
            font-size: 12.5px;
            font-weight: 700;
            color: #0f172a;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 4px;
        }

            .feat-stat .stat-arrow {
                font-size: 14px;
                color: #64748b;
            }

        .feat-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            width: 100%;
            padding: 10px 0;
            background: #0d1b3e;
            color: #ffffff;
            border: none;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background .18s;
            letter-spacing: .01em;
        }

            .feat-btn:hover {
                background: #162045;
                color: #fff;
            }

            .feat-btn .btn-arrow {
                font-size: 15px;
                line-height: 1;
                transition: transform .18s;
            }

        .feat-card:hover .feat-btn .btn-arrow {
            transform: translateX(3px);
        }

        .sec-lbl {
            font-size: 10.5px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.6px;
            color: #94a3b8;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .sec-lbl::after {
                content: '';
                flex: 1;
                height: 0.5px;
                background: #e2e8f0;
            }

        .stats-g {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 20px;
        }

        .sc {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 16px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 1px 6px rgba(0,0,0,.05);
            text-decoration: none;
            transition: all .2s;
            color: inherit;
        }

            .sc:hover {
                box-shadow: 0 4px 16px rgba(0,0,0,.1);
                transform: translateY(-1px);
            }

        .sc-ico {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .i-navy {
            background: rgba(13,27,62,.08);
            color: #0d1b3e;
        }

        .i-ok {
            background: rgba(5,150,105,.08);
            color: #059669;
        }

        .i-warn {
            background: rgba(217,119,6,.09);
            color: #d97706;
        }

        .i-info {
            background: rgba(37,99,235,.08);
            color: #2563eb;
        }

        .i-gold {
            background: rgba(184,134,42,.10);
            color: #b8862a;
        }

        .sc-lbl {
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1.1px;
            margin-bottom: 3px;
        }

        .sc-val {
            font-size: 22px;
            font-weight: 700;
            color: #0f172a;
        }

        .sc-sub {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 2px;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 12px;
            margin-bottom: 20px;
        }

        .kpi {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 16px 18px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            transition: box-shadow .2s, transform .2s;
        }

            .kpi:hover {
                box-shadow: 0 4px 16px rgba(0,0,0,.08);
                transform: translateY(-1px);
            }

        .kpi-ico {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .ico-gold {
            background: #FAEEDA;
            color: #854F0B;
        }

        .ico-teal {
            background: #E1F5EE;
            color: #0F6E56;
        }

        .ico-blue {
            background: #E6F1FB;
            color: #185FA5;
        }

        .ico-purple {
            background: #EEEDFE;
            color: #534AB7;
        }

        .kpi-lbl {
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1.1px;
            margin-bottom: 4px;
        }

        .kpi-val {
            font-size: 20px;
            font-weight: 700;
            color: #0f172a;
            line-height: 1.1;
        }

        .kpi-sub {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 3px;
        }

        .kpi-delta {
            font-size: 11px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 3px;
            padding: 2px 7px;
            border-radius: 5px;
            margin-top: 5px;
        }

        .delta-up {
            background: rgba(5,150,105,.1);
            color: #059669;
        }

        .delta-dn {
            background: rgba(220,38,38,.08);
            color: #dc2626;
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1.55fr 1fr;
            gap: 14px;
            margin-bottom: 14px;
        }

        .charts-row2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 28px;
        }

        .ch-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 18px 20px;
            box-shadow: 0 1px 6px rgba(0,0,0,.05);
        }

        .ch-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .ch-title {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
        }

        .ch-sub {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 2px;
        }

        .ch-tabs {
            display: flex;
            gap: 4px;
        }

        .ch-tab {
            font-size: 11px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 7px;
            border: 1px solid #e2e8f0;
            background: transparent;
            color: #94a3b8;
            cursor: pointer;
            transition: all .15s;
        }

            .ch-tab.active, .ch-tab:hover {
                background: #f1f5f9;
                color: #0f172a;
                border-color: #cbd5e1;
            }

        .ch-wrap {
            position: relative;
        }

        .legend-row {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .leg-item {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 11px;
            color: #64748b;
        }

        .leg-dot {
            width: 10px;
            height: 10px;
            border-radius: 2px;
            flex-shrink: 0;
        }

        .breakdown {
            display: flex;
            flex-direction: column;
            gap: 9px;
            margin-top: 14px;
        }

        .bk-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 12px;
        }

        .bk-lbl {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #64748b;
        }

        .bk-val {
            font-weight: 700;
            color: #0f172a;
        }

        .bk-bar {
            height: 4px;
            border-radius: 2px;
            background: #f1f5f9;
            margin-top: 3px;
            overflow: hidden;
        }

        .bk-fill {
            height: 100%;
            border-radius: 2px;
        }

        .alert-list {
            display: flex;
            flex-direction: column;
            gap: 9px;
            margin-bottom: 20px;
        }

        .al {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s;
        }

            .al:hover {
                filter: brightness(.96);
                transform: translateX(3px);
            }

            .al.ok {
                background: rgba(5,150,105,.08);
                border: 1px solid rgba(5,150,105,.22);
                color: #059669;
            }

            .al.warn {
                background: rgba(217,119,6,.09);
                border: 1px solid rgba(217,119,6,.25);
                color: #d97706;
            }

            .al.info {
                background: rgba(37,99,235,.08);
                border: 1px solid rgba(37,99,235,.22);
                color: #2563eb;
            }

            .al i {
                font-size: 16px;
                flex-shrink: 0;
            }

        .al-arrow {
            margin-left: auto;
            font-size: 16px;
            opacity: .5;
        }

        .two-col {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 18px;
            margin-top: 20px;
        }

        .card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 1px 6px rgba(0,0,0,.05);
        }

        .card-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 20px;
            border-bottom: 1px solid #e2e8f0;
        }

            .card-hdr h3 {
                font-size: 14px;
                font-weight: 700;
                color: #0f172a;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .card-hdr a {
                font-size: 12px;
                font-weight: 600;
                color: #2563eb;
                text-decoration: none;
            }

                .card-hdr a:hover {
                    text-decoration: underline;
                }

        .ord-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 20px;
            border-bottom: 1px solid #f1f5f9;
        }

            .ord-row:last-child {
                border-bottom: none;
            }

        .ord-id {
            font-size: 12px;
            color: #94a3b8;
            width: 52px;
        }

        .ord-name {
            font-size: 13px;
            font-weight: 600;
            color: #0f172a;
            flex: 1;
            margin: 0 12px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ord-amt {
            font-size: 12px;
            font-weight: 600;
            color: #b8862a;
            white-space: nowrap;
        }

        .bd {
            display: inline-flex;
            align-items: center;
            padding: 3px 9px;
            border-radius: 100px;
            font-size: 10px;
            font-weight: 700;
            margin-left: 8px;
        }

        .bd-Pending {
            background: rgba(217,119,6,.09);
            color: #d97706;
            border: 1px solid rgba(217,119,6,.25);
        }

        .bd-Processing {
            background: rgba(37,99,235,.08);
            color: #2563eb;
            border: 1px solid rgba(37,99,235,.22);
        }

        .bd-Completed, .bd-Done {
            background: rgba(15,23,42,.07);
            color: #0f172a;
            border: 1px solid rgba(15,23,42,.18);
        }

        .bd-Cancelled {
            background: rgba(220,38,38,.08);
            color: #dc2626;
            border: 1px solid rgba(220,38,38,.22);
        }

        .bd-Confirmed, .bd-Ready {
            background: rgba(5,150,105,.08);
            color: #059669;
            border: 1px solid rgba(5,150,105,.22);
        }

        .appt-row {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            border-bottom: 1px solid #f1f5f9;
        }

            .appt-row:last-child {
                border-bottom: none;
            }

        .av {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: linear-gradient(135deg,#e0e7ff,#c7d2fe);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            color: #2563eb;
            flex-shrink: 0;
        }

        .appt-name {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
        }

        .appt-dt {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 1px;
        }

        .appt-today {
            font-size: 10px;
            font-weight: 700;
            color: #059669;
            background: rgba(5,150,105,.08);
            border: 1px solid rgba(5,150,105,.22);
            border-radius: 4px;
            padding: 1px 5px;
            margin-left: 4px;
        }

        .svc-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 20px;
            border-bottom: 1px solid #f1f5f9;
        }

            .svc-row:last-child {
                border-bottom: none;
            }

        .svc-name {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
        }

        .svc-sub {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 2px;
        }

        .btn-sm {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 7px;
            padding: 5px 10px;
            font-size: 11px;
            font-weight: 700;
            color: #94a3b8;
            text-decoration: none;
            transition: all .2s;
        }

            .btn-sm:hover {
                border-color: #2563eb;
                color: #2563eb;
            }

        .empty-card {
            text-align: center;
            padding: 36px 20px;
            color: #94a3b8;
            font-size: 13px;
        }

        @@media(max-width:1000px) {
            .kpi-grid {
                grid-template-columns: repeat(2,1fr);
            }

            .charts-row {
                grid-template-columns: 1fr;
            }

            .charts-row2 {
                grid-template-columns: 1fr;
            }
        }

        @@media(max-width:900px) {
            .feat-grid {
                grid-template-columns: 1fr;
            }

            .stats-g {
                grid-template-columns: repeat(2,1fr);
            }

            .two-col {
                grid-template-columns: 1fr;
            }
        }

        @@media(max-width:600px) {
            .stats-g {
                grid-template-columns: 1fr;
            }

            .kpi-grid {
                grid-template-columns: 1fr;
            }

            .adm-wrap {
                padding: 16px 14px 60px;
            }
        }
    </style>
}

<div class="adm-wrap">

    <nav class="adm-bc">
        <a href="/">Home</a>
        <span class="bc-sep">›</span>
        <span class="bc-cur">Admin Dashboard</span>
    </nav>

    <div class="adm-banner">
        <span class="wave-emoji">👋</span>
        <div class="banner-text">
            <h2>Welcome, @(User.Identity?.Name ?? "admin")!</h2>
            <p>Manage your OptiPlus eyewear store from this central dashboard.</p>
        </div>
    </div>

    <h1 class="adm-page-title">Admin Dashboard</h1>

    <div class="feat-grid">
        <div class="feat-card">
            <div class="feat-card-top">
                <div class="feat-icon teal">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="8" />
                        <circle cx="12" cy="12" r="3" />
                        <line x1="12" y1="2" x2="12" y2="6" />
                        <line x1="12" y1="18" x2="12" y2="22" />
                        <line x1="2" y1="12" x2="6" y2="12" />
                        <line x1="18" y1="12" x2="22" y2="12" />
                    </svg>
                </div>
                <h3>Lens Management</h3>
                <span class="feat-badge">CRUD</span>
            </div>
            <p class="feat-desc">Create, view, update, and manage lens products, types, and stock levels.</p>
            <div class="feat-spark-row">
                <div class="feat-spark">
                    <svg viewBox="0 0 120 40" preserveAspectRatio="none">
                        <polyline points="0,35 15,28 30,31 45,22 60,26 75,16 90,20 105,12 120,8" fill="none" stroke="#0d9488" stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round" />
                    </svg>
                </div>
                <span class="feat-stat">+15 today <span class="stat-arrow">↗</span></span>
            </div>
            <a href="/Lenses" class="feat-btn">Manage Lenses <span class="btn-arrow">→</span></a>
        </div>

        <div class="feat-card">
            <div class="feat-card-top">
                <div class="feat-icon navy">
                    <svg width="28" height="26" viewBox="0 0 28 18" fill="none" stroke="#1e3a8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="10" height="9" rx="4.5" />
                        <rect x="17" y="4" width="10" height="9" rx="4.5" />
                        <line x1="11" y1="8.5" x2="17" y2="8.5" />
                        <line x1="1" y1="8.5" x2="0" y2="5" />
                        <line x1="27" y1="8.5" x2="28" y2="5" />
                    </svg>
                </div>
                <h3>Frame Management</h3>
                <span class="feat-badge">CRUD</span>
