                    <a href="/Appointments">View all →</a>
                </div>
                @if (Model.UpcomingAppts.Any())
                {
                    @foreach (var a in Model.UpcomingAppts)
                    {
                        bool isToday = a.AppointmentDate == DateOnly.FromDateTime(DateTime.Today);
                        var ini = string.Concat(a.FullName.Split(' ').Take(2).Select(w => char.ToUpper(w.FirstOrDefault())));
                        <div class="appt-row">
                            <div class="av">@ini</div>
