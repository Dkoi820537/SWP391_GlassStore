                <h3><i class="bi bi-bag" style="color:#2563eb"></i> Recent Orders</h3>
                <a href="/Admin/Orders">View all →</a>
            </div>
            @if (Model.RecentOrders.Any())
            {
                @foreach (var o in Model.RecentOrders)
                {
                    <div class="ord-row">
                        <span class="ord-id">#@o.OrderId</span>
