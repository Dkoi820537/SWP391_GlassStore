                    <i class="bi bi-graph-up-arrow" style="font-size:18px"></i>
                </div>
                <div>
                    <div class="kpi-lbl">Hôm nay</div>
                    <div class="kpi-val">
                        @(Model.RevenueToday >= 1_000_000
                                            ? (Model.RevenueToday / 1_000_000M).ToString("N1") + "M"
                                            : Model.RevenueToday.ToString("N0")) ₫
                                                                            </div>
                                                                            <div class="kpi-sub">Doanh thu trong ngày</div>
