@page
@model EyewearStore_SWP391.Pages.Admin.Orders.DetailsModel
@{
    ViewData["Title"] = $"Order #{Model.Order?.OrderId} — Admin";
    Layout = "_Layout";
    var o = Model.Order!;
    var shipment = o.Shipments?.OrderByDescending(s => s.ShipmentId).FirstOrDefault();
}

@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: #f1f5f9; font-family: 'Inter', system-ui, sans-serif; color: #0f172a; }

    .ao-wrap { max-width: 1180px; margin: 0 auto; padding: 28px 20px 80px; }

    /* HEADER */
    .det-hdr {
        background: linear-gradient(135deg, #0d1b3e 0%, #1a2f54 100%);
        border-radius: 16px; padding: 22px 28px;
        display: flex; align-items: center; justify-content: space-between;
        gap: 16px; flex-wrap: wrap; margin-bottom: 22px;
        box-shadow: 0 4px 24px rgba(13,27,62,.28);
    }
    .det-hdr h1 { font-size: 1.3rem; font-weight: 900; color: #fff; margin: 0 0 3px; }
    .det-hdr p  { font-size: 12.5px; color: rgba(255,255,255,.45); margin: 0; }
    .hdr-bc { font-size: 12px; }
    .hdr-bc a { color: rgba(255,255,255,.55); text-decoration: none; }
    .hdr-bc a:hover { color: #fff; }
    .hdr-bc span { color: rgba(255,255,255,.3); margin: 0 5px; }
    .back-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 16px; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
        color: rgba(255,255,255,.85); border-radius: 9px; font-size: 12.5px; font-weight: 600;
        text-decoration: none; transition: all .2s;
    }
    .back-btn:hover { background: rgba(255,255,255,.18); color: #fff; }

    /* STATUS PILL */
    .spill { display: inline-flex; align-items: center; gap: 4px; padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 700; }
    .s-pending     { background: rgba(217,119,6,.09); color: #b45309; border: 1px solid rgba(217,119,6,.22); }
    .s-confirmed   { background: rgba(29,78,216,.08); color: #1d4ed8; border: 1px solid rgba(29,78,216,.2); }
    .s-processing  { background: rgba(13,27,62,.08); color: #1a2f54; border: 1px solid rgba(13,27,62,.18); }
    .s-shipped     { background: rgba(13,148,136,.08); color: #0d9488; border: 1px solid rgba(13,148,136,.2); }
    .s-delivered   { background: rgba(5,150,105,.08); color: #059669; border: 1px solid rgba(5,150,105,.2); }
    .s-completed   { background: rgba(15,23,42,.07); color: #0f172a; border: 1px solid rgba(15,23,42,.18); }
    .s-cancelled   { background: rgba(220,38,38,.08); color: #dc2626; border: 1px solid rgba(220,38,38,.2); }

    /* ══ STEPPER ══ */
    .stepper-card {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 14px;
        padding: 24px 28px; margin-bottom: 20px;
        box-shadow: 0 1px 8px rgba(0,0,0,.06);
    }
    .stepper-card h3 { font-size: 12px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1.2px; margin: 0 0 20px; }
    .stepper { display: flex; align-items: flex-start; gap: 0; }
    .step-item {
        flex: 1; display: flex; flex-direction: column; align-items: center; position: relative;
    }
    .step-item:not(:last-child)::after {
        content: ''; position: absolute; top: 17px; left: 50%; width: 100%; height: 3px;
        background: #e2e8f0; z-index: 0;
    }
    .step-item.done::after, .step-item.active::after { background: #0d9488; }
    .step-item.cancelled::after { background: #fca5a5; }
    .step-dot {
        width: 36px; height: 36px; border-radius: 50%; border: 3px solid #e2e8f0;
        background: #fff; display: flex; align-items: center; justify-content: center;
        font-size: 14px; position: relative; z-index: 1;
        transition: all .3s; flex-shrink: 0;
    }
    .step-item.done   .step-dot { border-color: #0d9488; background: #0d9488; color: #fff; }
    .step-item.active .step-dot { border-color: #0d1b3e; background: #0d1b3e; color: #fff; box-shadow: 0 0 0 4px rgba(13,27,62,.15); }
    .step-item.cancelled .step-dot { border-color: #dc2626; background: rgba(220,38,38,.1); color: #dc2626; }
    .step-lbl { font-size: 11px; font-weight: 700; color: #94a3b8; margin-top: 8px; text-align: center; }
    .step-item.done   .step-lbl { color: #0d9488; }
    .step-item.active .step-lbl { color: #0d1b3e; font-weight: 800; }
    .step-item.cancelled .step-lbl { color: #dc2626; }

    /* Sub-status label under stepper */
    .sub-status-bar {
        margin-top: 16px; padding: 8px 16px; border-radius: 9px;
        background: rgba(13,27,62,.05); border: 1px solid rgba(13,27,62,.1);
        font-size: 12px; font-weight: 600; color: #1a2f54; text-align: center;
    }
    .cancelled-bar {
        background: rgba(220,38,38,.07); border-color: rgba(220,38,38,.2); color: #dc2626;
    }

    /* ══ BODY GRID ══ */
    .body-grid { display: grid; grid-template-columns: 1fr 400px; gap: 18px; }

    /* ══ TABS ══ */
    .tab-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; overflow: hidden; box-shadow: 0 1px 8px rgba(0,0,0,.06); }
    .tab-nav { display: flex; border-bottom: 1px solid #e2e8f0; background: #f8fafc; }
    .tab-btn {
        flex: 1; padding: 13px 16px; border: none; background: transparent; cursor: pointer;
        font-size: 13px; font-weight: 700; color: #94a3b8; transition: all .18s;
        border-bottom: 3px solid transparent; font-family: inherit;
    }
    .tab-btn:hover { color: #0d1b3e; background: rgba(13,27,62,.03); }
    .tab-btn.active { color: #0d1b3e; border-bottom-color: #0d1b3e; background: #fff; }
    .tab-pane { display: none; padding: 22px; }
    .tab-pane.active { display: block; }

    /* FIELD GROUPS */
    .fg { margin-bottom: 18px; }
    .fg-label { font-size: 10.5px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
    .fg-val { font-size: 14px; font-weight: 600; color: #0f172a; }
    .fg-val-sm { font-size: 13px; color: #475569; }
    .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    /* ORDER ITEMS TABLE */
    .items-tbl { width: 100%; border-collapse: collapse; margin-top: 4px; }
    .items-tbl th { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: .8px; color: #94a3b8; padding: 8px 10px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; text-align: left; }
    .items-tbl td { padding: 10px; border-bottom: 1px solid #f1f5f9; font-size: 13px; color: #475569; vertical-align: middle; }
    .items-tbl tbody tr:last-child td { border-bottom: none; }
    .prod-name { font-weight: 700; color: #0f172a; }
    .prod-sub  { font-size: 11px; color: #94a3b8; margin-top: 2px; }
    .rx-tag { background: rgba(124,58,237,.08); color: #7c3aed; border: 1px solid rgba(124,58,237,.2); border-radius: 5px; font-size: 10px; font-weight: 700; padding: 1px 6px; margin-left: 5px; }

    /* Totals row */
    .totals-row { display: flex; justify-content: flex-end; padding: 12px 10px 4px; }
    .totals-tbl { min-width: 220px; }
    .totals-tbl td { padding: 4px 10px; font-size: 13px; color: #475569; }
    .totals-tbl .grand td { font-size: 15px; font-weight: 800; color: #0f172a; border-top: 1.5px solid #e2e8f0; padding-top: 10px; }

    /* Shipment history timeline (in ops tab) */
    .ship-timeline { list-style: none; margin: 0; padding: 0; }
    .ship-tl-item { display: flex; gap: 14px; padding-bottom: 16px; position: relative; }
    .ship-tl-item:not(:last-child)::before {
        content:''; position:absolute; left:14px; top:28px; bottom:0; width:2px; background:#e2e8f0;
    }
    .tl-dot { width:28px; height:28px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:12px; background:#e2e8f0; color:#94a3b8; }
    .tl-dot.shipped { background:rgba(13,148,136,.1); color:#0d9488; }
    .tl-dot.info    { background:rgba(13,27,62,.08); color:#1a2f54; }
    .tl-txt { font-size: 13px; font-weight: 600; color: #0f172a; }
    .tl-ts  { font-size: 11px; color: #94a3b8; margin-top: 2px; }

    /* ══ RIGHT COLUMN ══ */
    .right-col { display: flex; flex-direction: column; gap: 18px; }

    /* ── ADMIN OVERRIDE CARD ── */
    .override-card {
        background: linear-gradient(135deg, #0d1b3e 0%, #1a2f54 100%);
        border-radius: 14px; padding: 20px 22px;
        box-shadow: 0 4px 20px rgba(13,27,62,.22);
    }
    .override-card h4 { font-size: 13px; font-weight: 800; color: #fff; margin: 0 0 4px; display: flex; align-items: center; gap: 8px; }
    .override-card .oc-sub { font-size: 11.5px; color: rgba(255,255,255,.45); margin-bottom: 16px; }
    .oc-note {
        width: 100%; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
        border-radius: 9px; padding: 9px 12px; font-size: 12.5px; color: #fff;
        font-family: inherit; outline: none; resize: none; margin-bottom: 14px; transition: border-color .2s;
    }
    .oc-note::placeholder { color: rgba(255,255,255,.3); }
    .oc-note:focus { border-color: rgba(255,255,255,.4); }

    .oc-btn-row { display: flex; gap: 8px; margin-bottom: 14px; }
    .oc-btn {
        flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 6px;
        padding: 10px 14px; border-radius: 9px; font-size: 12.5px; font-weight: 700;
        border: none; cursor: pointer; font-family: inherit; transition: all .2s;
    }
    .oc-advance { background: #0d9488; color: #fff; }
    .oc-advance:hover { background: #0f766e; }
    .oc-revert  { background: rgba(255,255,255,.12); color: rgba(255,255,255,.85); border: 1px solid rgba(255,255,255,.2); }
    .oc-revert:hover { background: rgba(255,255,255,.2); color: #fff; }

    .oc-sep { border: none; border-top: 1px solid rgba(255,255,255,.1); margin: 6px 0 14px; }
    .oc-label { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,.4); margin-bottom: 8px; }
    .oc-select {
        width: 100%; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
        border-radius: 9px; padding: 9px 12px; font-size: 12.5px; color: #fff;
        font-family: inherit; outline: none; margin-bottom: 10px;
        appearance: none; -webkit-appearance: none;
    }
    .oc-select option { background: #1a2f54; color: #fff; }
    .oc-force {
        width: 100%; padding: 10px; border-radius: 9px; background: rgba(220,38,38,.8);
        border: 1px solid rgba(220,38,38,.4); color: #fff; font-size: 12.5px; font-weight: 700;
        cursor: pointer; font-family: inherit; transition: all .2s;
        display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .oc-force:hover { background: #dc2626; }

    /* ── AUDIT LOG CARD ── */
    .audit-card {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; overflow: hidden;
        box-shadow: 0 1px 8px rgba(0,0,0,.06);
    }
    .audit-hdr { padding: 14px 18px; border-bottom: 1px solid #e2e8f0; background: #f8fafc; display: flex; align-items: center; gap: 8px; }
    .audit-hdr h4 { font-size: 13px; font-weight: 800; color: #0f172a; margin: 0; }
    .audit-hdr .cnt { font-size: 10px; font-weight: 700; background: #e2e8f0; color: #64748b; border-radius: 6px; padding: 2px 8px; }
    .audit-body { padding: 16px 18px; max-height: 340px; overflow-y: auto; }
    .audit-item { display: flex; gap: 12px; padding-bottom: 14px; position: relative; }
    .audit-item:not(:last-child)::before { content:''; position:absolute; left:15px; top:30px; bottom:0; width:2px; background:#f1f5f9; }
    .audit-dot { width:30px; height:30px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:13px; }
    .ad-ok    { background:rgba(5,150,105,.1); color:#059669; }
    .ad-info  { background:rgba(13,27,62,.07); color:#1a2f54; }
    .ad-warn  { background:rgba(217,119,6,.09); color:#d97706; }
    .ad-admin { background:rgba(220,38,38,.08); color:#dc2626; border: 1.5px solid rgba(220,38,38,.2); }
    .audit-txt { font-size: 12.5px; font-weight: 600; color: #0f172a; line-height: 1.4; word-break: break-word; }
    .audit-meta { font-size: 10.5px; color: #94a3b8; margin-top: 2px; }
    .audit-meta strong { color: #475569; }

    /* Flash messages */
    .al-ok  { display:flex; align-items:center; gap:8px; border-radius:10px; padding:11px 16px; font-size:13px; font-weight:600; margin-bottom:14px; background:rgba(5,150,105,.08); border:1px solid rgba(5,150,105,.2); color:#059669; }
    .al-err { display:flex; align-items:center; gap:8px; border-radius:10px; padding:11px 16px; font-size:13px; font-weight:600; margin-bottom:14px; background:rgba(220,38,38,.08); border:1px solid rgba(220,38,38,.2); color:#dc2626; }

    @@media(max-width: 960px) { .body-grid { grid-template-columns: 1fr; } }
    @@media(max-width: 600px) { .row2 { grid-template-columns: 1fr; } .stepper { gap: 0; } .step-lbl { font-size: 9px; } }
</style>
}

<div class="ao-wrap">

    <!-- HEADER -->
    <div class="det-hdr">
        <div>
            <div class="hdr-bc" style="margin-bottom:8px">
                <a href="/Admin">Admin</a>
                <span>›</span>
                <a href="/Admin/Orders">Orders</a>
                <span>›</span>
                <span style="color:#fff;font-weight:700">Order #@o.OrderId</span>
            </div>
            <h1><i class="bi bi-receipt me-2"></i>Order #@o.OrderId — Detail View</h1>
            <p>@o.CreatedAt.ToString("dddd, dd MMM yyyy HH:mm") &nbsp;·&nbsp; @(o.User?.Email ?? "Guest")</p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
            @{
                string hdrCss = o.Status switch {
                    "Pending"   => "s-pending",
                    "Confirmed" => "s-confirmed",
                    var s when s != null && s.StartsWith("Processing") => "s-processing",
                    "Shipped"   => "s-shipped",
                    "Delivered" => "s-delivered",
                    "Completed" => "s-completed",
                    "Cancelled" => "s-cancelled",
                    _           => ""
                };
            }
            <span class="spill @hdrCss" style="font-size:13px">@o.Status</span>
            <a href="/Admin/Orders" class="back-btn"><i class="bi bi-arrow-left"></i> Back</a>
        </div>
    </div>

    @if (TempData["Success"] is string ok2)
    {
        <div class="al-ok"><i class="bi bi-check-circle-fill"></i> @ok2</div>
    }
    @if (TempData["Error"] is string err2)
    {
        <div class="al-err"><i class="bi bi-exclamation-circle-fill"></i> @err2</div>
    }

    <!-- ══ STEPPER ══ -->
    <div class="stepper-card">
        <h3><i class="bi bi-signpost-2 me-1"></i>Order Lifecycle</h3>
        @if (Model.IsCancelled)
        {
            <div class="stepper">
                @for (int i = 0; i < DetailsModel.LifecycleSteps.Count; i++)
                {
                    <div class="step-item cancelled">
                        <div class="step-dot"><i class="bi bi-x-lg"></i></div>
                        <div class="step-lbl">@DetailsModel.LifecycleSteps[i]</div>
                    </div>
                }
            </div>
            <div class="sub-status-bar cancelled-bar">
                <i class="bi bi-x-circle-fill me-2"></i>Order was <strong>Cancelled</strong>
            </div>
        }
        else
        {
            var activeIdx = Model.ActiveStepIndex;
            <div class="stepper">
                @for (int i = 0; i < DetailsModel.LifecycleSteps.Count; i++)
                {
                    string stepClass = i < activeIdx ? "done" : (i == activeIdx ? "active" : "");
                    string icon      = i < activeIdx ? "bi-check-lg" : (i == activeIdx ? "bi-circle-fill" : "bi-circle");
                    <div class="step-item @stepClass">
                        <div class="step-dot">
                            <i class="bi @icon"></i>
                        </div>
                        <div class="step-lbl">@DetailsModel.LifecycleSteps[i]</div>
                    </div>
                }
            </div>
            @if (o.Status != null && o.Status.StartsWith("Processing") && o.Status != "Processing")
            {
                <div class="sub-status-bar">
                    <i class="bi bi-arrow-right-circle me-2"></i>Sub-step: <strong>@o.Status</strong>
                </div>
            }
        }
    </div>

    <!-- ══ BODY GRID ══ -->
    <div class="body-grid">

        <!-- LEFT — Tabs -->
        <div class="tab-card">
            <div class="tab-nav">
                <button class="tab-btn active" onclick="switchTab('sales', this)">
                    <i class="bi bi-receipt me-1"></i> Sales Data
                </button>
                <button class="tab-btn" onclick="switchTab('ops', this)">
                    <i class="bi bi-truck me-1"></i> Ops / Shipping
                </button>
            </div>

            <!-- TAB: SALES DATA -->
            <div id="tab-sales" class="tab-pane active">
                <div class="row2">
                    <div class="fg">
                        <div class="fg-label">Customer</div>
                        <div class="fg-val">@(o.User?.FullName ?? o.ReceiverName ?? "—")</div>
                        <div class="fg-val-sm">@(o.User?.Email ?? "—")</div>
                    </div>
                    <div class="fg">
                        <div class="fg-label">Receiver</div>
                        <div class="fg-val">@(o.ReceiverName ?? "—")</div>
                        <div class="fg-val-sm">@(o.Phone ?? "—")</div>
                    </div>
                </div>
                <div class="fg">
                    <div class="fg-label">Delivery Address</div>
                    <div class="fg-val">@(o.AddressLine ?? o.Address?.AddressLine ?? "—")</div>
                </div>
                <div class="row2">
                    <div class="fg">
                        <div class="fg-label">Payment Method</div>
                        <div class="fg-val">@(o.PaymentMethod ?? "—")</div>
                    </div>
                    <div class="fg">
                        <div class="fg-label">Stripe Session</div>
                        <div class="fg-val-sm" style="font-size:11px;word-break:break-all">@(o.StripeSessionId ?? "—")</div>
                    </div>
                </div>

                <div class="fg-label" style="margin-bottom:10px">Order Items</div>
                <table class="items-tbl">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th style="text-align:center">Qty</th>
                            <th style="text-align:right">Unit Price</th>
                            <th style="text-align:right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in o.OrderItems)
                        {
                            string pname = item.Product?.Name ?? $"Product #{item.ProductId}";
                            bool hasRx   = item.PrescriptionId != null;
                            <tr>
                                <td>
                                    <div class="prod-name">
                                        @pname
                                        @if (hasRx) { <span class="rx-tag">Rx</span> }
                                        @if (item.IsBundle) { <span class="rx-tag" style="background:rgba(13,148,136,.08);color:#0d9488;border-color:rgba(13,148,136,.2)">Bundle</span> }
                                    </div>
                                    @if (hasRx && item.Prescription != null)
                                    {
                                        <div class="prod-sub">
                                            R: SPH @item.Prescription.RightSph / CYL @item.Prescription.RightCyl / Axis @item.Prescription.RightAxis &nbsp;|&nbsp;
                                            L: SPH @item.Prescription.LeftSph / CYL @item.Prescription.LeftCyl / Axis @item.Prescription.LeftAxis
                                        </div>
                                    }
                                </td>
                                <td style="text-align:center">@item.Quantity</td>
                                <td style="text-align:right">@item.UnitPrice.ToString("N0") ₫</td>
                                <td style="text-align:right;font-weight:700;color:#0d1b3e">@((item.UnitPrice * item.Quantity + item.PrescriptionFee).ToString("N0")) ₫</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="totals-row">
                    <table class="totals-tbl">
                        <tbody>
                            <tr>
                                <td style="color:#94a3b8">Items Subtotal</td>
                                <td style="text-align:right">@o.OrderItems.Sum(i => i.UnitPrice * i.Quantity).ToString("N0") ₫</td>
                            </tr>
                            @{
                                decimal rxFee = o.OrderItems.Sum(i => i.PrescriptionFee);
                            }
                            @if (rxFee > 0)
                            {
                                <tr>
                                    <td style="color:#94a3b8">Prescription Fee</td>
                                    <td style="text-align:right">@rxFee.ToString("N0") ₫</td>
                                </tr>
                            }
                            <tr class="grand">
                                <td><strong>Total</strong></td>
                                <td style="text-align:right;color:#b8862a"><strong>@o.TotalAmount.ToString("N0") ₫</strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- TAB: OPS / SHIPPING -->
            @{
                var histories = (o.Shipments ?? new List<EyewearStore_SWP391.Models.Shipment>())
                    .SelectMany(s => s.ShipmentStatusHistories ?? new List<EyewearStore_SWP391.Models.ShipmentStatusHistory>())
                    .OrderByDescending(h => h.CreatedAt)
                    .ToList();
            }
            <div id="tab-ops" class="tab-pane">
                @if (shipment != null)
                {
                    <div class="row2" style="margin-bottom:16px">
                        <div class="fg">
                            <div class="fg-label">Carrier</div>
                            <div class="fg-val">@(shipment.Carrier ?? "—")</div>
                        </div>
                        <div class="fg">
                            <div class="fg-label">Tracking Number</div>
                            <div class="fg-val" style="word-break:break-all">@(shipment.TrackingNumber ?? "—")</div>
                        </div>
                        <div class="fg">
                            <div class="fg-label">Shipped At</div>
                            <div class="fg-val">@(shipment.ShippedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                        </div>
                        <div class="fg">
                            <div class="fg-label">Delivered At</div>
                            <div class="fg-val">@(shipment.DeliveredAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                        </div>
                    </div>

                    <div class="fg-label" style="margin-bottom:12px">Shipment History</div>
                    @if (histories.Any())
                    {
                        <ul class="ship-timeline">
                            @foreach (var h in histories)
                            {
                                bool isAdmin = h.Status?.StartsWith("[ADMIN") == true;
                                <li class="ship-tl-item">
                                    <div class="tl-dot @(isAdmin ? "info" : "shipped")">
                                        <i class="bi @(isAdmin ? "bi-shield-fill" : "bi-arrow-right-circle-fill")"></i>
                                    </div>
                                    <div>
                                        <div class="tl-txt">@h.Status</div>
                                        <div class="tl-ts">@h.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p style="font-size:13px;color:#94a3b8">No shipment history yet.</p>
                    }
                }
                else
                {
                    <div style="text-align:center;padding:40px 20px">
                        <i class="bi bi-truck" style="font-size:42px;color:#cbd5e1"></i>
                        <p style="font-size:13px;color:#94a3b8;margin-top:12px">No shipment assigned yet.</p>
                        <p style="font-size:12px;color:#cbd5e1">The Ops team will assign a shipment once the order is in Processing status.</p>
                    </div>
                }
            </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="right-col">

            <!-- ADMIN OVERRIDE CARD -->
            <div class="override-card">
                <h4><i class="bi bi-shield-fill-check"></i> Admin Override Controls</h4>
                <p class="oc-sub">Only admins can see and use these controls.</p>

                <!-- Force to any status -->
                <form method="post" asp-page-handler="ForceStatus">
                    <input type="hidden" name="id" value="@Model.id" />
                    <div class="oc-label">Force to specific status</div>
                    <select name="TargetStatus" class="oc-select">
                        @foreach (var s in DetailsModel.AllStatuses)
                        {
                            if (o.Status == s)
                            {
                                <option value="@s" selected="selected">@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                    <button type="submit" class="oc-force"
                            onclick="return confirm('Force this order to the selected status? This action will be logged.')">
                        <i class="bi bi-exclamation-triangle-fill"></i> Force to Status
                    </button>
                </form>
            </div>

            <!-- AUDIT LOG CARD -->
            <div class="audit-card">
                <div class="audit-hdr">
                    <i class="bi bi-clock-history" style="color:#0d9488;font-size:16px"></i>
                    <h4>Audit Log</h4>
                    <span class="cnt">@Model.AuditLog.Count entries</span>
                </div>
                <div class="audit-body">
                    @if (!Model.AuditLog.Any())
                    {
                        <p style="font-size:13px;color:#94a3b8;text-align:center;padding:20px 0">No history yet.</p>
                    }
                    @foreach (var entry in Model.AuditLog)
                    {
                        string dotCss = entry.Type switch
                        {
                            "ok"    => "ad-ok",
                            "warn"  => "ad-warn",
                            "admin" => "ad-admin",
                            _       => "ad-info"
                        };
                        string dotIcon = entry.Type switch
                        {
                            "ok"    => "bi-check-circle-fill",
                            "warn"  => "bi-exclamation-triangle-fill",
                            "admin" => "bi-shield-fill",
                            _       => "bi-circle-fill"
                        };
                        <div class="audit-item">
                            <div class="audit-dot @dotCss">
                                <i class="bi @dotIcon"></i>
                            </div>
                            <div>
                                <div class="audit-txt">@entry.Event</div>
                                <div class="audit-meta">
                                    <strong>@entry.Actor</strong> · @entry.Timestamp.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    function switchTab(name, btn) {
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + name).classList.add('active');
        btn.classList.add('active');
    }
</script>
}
