@page
@model EyewearStore_SWP391.Pages.Admin.Orders.IndexModel
@{
    ViewData["Title"] = "Orders Management — Admin";
    Layout = "_Layout";
}

@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: #f1f5f9; font-family: 'Inter', system-ui, sans-serif; color: #0f172a; }

    .ao-wrap { max-width: 1380px; margin: 0 auto; padding: 28px 20px 80px; }

    /* ── HEADER ── */
    .ao-hdr {
        background: linear-gradient(135deg, #0d1b3e 0%, #1a2f54 100%);
        border-radius: 16px; padding: 24px 30px;
        display: flex; align-items: center; justify-content: space-between;
        gap: 16px; flex-wrap: wrap; margin-bottom: 22px;
        box-shadow: 0 4px 24px rgba(13,27,62,.28);
    }
    .ao-hdr h1 { font-size: 1.5rem; font-weight: 900; color: #fff; margin: 0 0 3px; letter-spacing: -.5px; }
    .ao-hdr p  { font-size: 13px; color: rgba(255,255,255,.45); margin: 0; }
    .bc-link { font-size: 12px; color: rgba(255,255,255,.55); text-decoration: none; }
    .bc-link:hover { color: #fff; }
    .bc-sep  { font-size: 12px; color: rgba(255,255,255,.3); margin: 0 5px; }

    /* ── STATS GRID ── */
    .stats-row { display: grid; grid-template-columns: repeat(7, 1fr); gap: 12px; margin-bottom: 20px; }
    .stat-c {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 13px;
        padding: 14px 16px; box-shadow: 0 1px 6px rgba(0,0,0,.05);
        text-decoration: none; color: inherit;
        transition: box-shadow .2s, transform .2s;
        position: relative; overflow: hidden;
    }
    .stat-c::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background: var(--sc-clr, #e2e8f0); }
    .stat-c:hover { box-shadow: 0 4px 18px rgba(0,0,0,.1); transform: translateY(-2px); }
    .sc-lbl { font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
    .sc-val { font-size: 1.75rem; font-weight: 900; color: #0f172a; line-height: 1; }
    .sc-sub { font-size: 10.5px; color: #94a3b8; margin-top: 3px; }

    /* ── PHASE TABS ── */
    .phase-tabs { display: flex; gap: 6px; margin-bottom: 16px; }
    .phase-tab {
        padding: 8px 18px; border-radius: 9px; font-size: 12.5px; font-weight: 700;
        text-decoration: none; border: 1.5px solid #e2e8f0; color: #64748b;
        background: #fff; transition: all .18s;
    }
    .phase-tab:hover, .phase-tab.active {
        background: #0d1b3e; border-color: #0d1b3e; color: #fff;
    }
    .phase-tab.sales.active  { background: #1d4ed8; border-color: #1d4ed8; }
    .phase-tab.ops.active    { background: #0d9488; border-color: #0d9488; }

    /* ── FILTER BAR ── */
    .filter-bar {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 13px;
        padding: 14px 18px; margin-bottom: 16px; box-shadow: 0 1px 6px rgba(0,0,0,.04);
    }
    .filter-row { display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap; }
    .fi {
        background: #f8fafc; border: 1.5px solid #e2e8f0; border-radius: 9px;
        padding: 8px 12px; font-size: 13px; color: #0f172a; font-family: inherit;
        transition: border-color .2s; flex: 1; min-width: 160px;
    }
    .fi:focus { outline: none; border-color: #0d9488; box-shadow: 0 0 0 3px rgba(13,148,136,.1); }
    .fi-search { flex: 2; min-width: 240px; }
    .fi-sm { width: 80px; flex: none; }
    .btn-filter {
        padding: 9px 20px; background: linear-gradient(135deg, #0d1b3e, #1a2f54);
        color: #fff; border: none; border-radius: 9px; font-size: 13px;
        font-weight: 700; cursor: pointer; white-space: nowrap; transition: all .2s;
        display: flex; align-items: center; gap: 6px;
    }
    .btn-filter:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(13,27,62,.3); }
    .btn-clear { padding: 9px 14px; background: transparent; border: 1.5px solid #e2e8f0; color: #64748b; border-radius: 9px; font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; display: flex; align-items: center; gap: 5px; transition: all .18s; }
    .btn-clear:hover { border-color: #dc2626; color: #dc2626; }

    /* ── TABLE ── */
    .tbl-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; overflow: hidden; box-shadow: 0 2px 14px rgba(0,0,0,.07); }
    .tbl-top {
        padding: 14px 20px; background: linear-gradient(135deg, #0d1b3e, #1a2f54);
        display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;
    }
    .tbl-top h5 { font-size: 13px; font-weight: 800; color: #fff; margin: 0; display: flex; align-items: center; gap: 8px; }
    .tbl-badge { background: rgba(255,255,255,.15); border-radius: 6px; padding: 2px 10px; font-size: 11px; font-weight: 700; }
    .tbl-info  { font-size: 12px; color: rgba(255,255,255,.5); }
    .tbl-info strong { color: rgba(255,255,255,.9); }

    .ao-tbl { width: 100%; border-collapse: collapse; }
    .ao-tbl th {
        font-size: 10px; font-weight: 800; text-transform: uppercase;
        letter-spacing: .9px; color: #94a3b8; padding: 11px 16px;
        background: #f8fafc; border-bottom: 1px solid #e2e8f0; text-align: left; white-space: nowrap;
    }
    .ao-tbl td { padding: 13px 16px; border-bottom: 1px solid #f1f5f9; font-size: 13px; color: #475569; vertical-align: middle; }
    .ao-tbl tbody tr:last-child td { border-bottom: none; }
    .ao-tbl tbody tr:hover td { background: rgba(13,148,136,.025); }

    .cell-id { font-size: 14px; font-weight: 800; color: #0d1b3e; }
    .cell-rx  { font-size: 10px; font-weight: 700; color: #7c3aed; background: rgba(124,58,237,.08); border: 1px solid rgba(124,58,237,.2); border-radius: 5px; padding: 1px 6px; margin-left: 5px; }
    .cust-name { font-weight: 700; color: #0f172a; }
    .cust-email { font-size: 11px; color: #94a3b8; margin-top: 1px; }
    .price-val { font-size: 13.5px; font-weight: 800; color: #b8862a; }

    /* Phase badge */
    .phase-badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 6px; font-size: 10px; font-weight: 700; }
    .ph-sales     { background: rgba(29,78,216,.08); color: #1d4ed8; border: 1px solid rgba(29,78,216,.2); }
    .ph-ops       { background: rgba(13,148,136,.08); color: #0d9488; border: 1px solid rgba(13,148,136,.2); }
    .ph-done      { background: rgba(15,23,42,.07); color: #0f172a; border: 1px solid rgba(15,23,42,.15); }
    .ph-cancelled { background: rgba(220,38,38,.07); color: #dc2626; border: 1px solid rgba(220,38,38,.2); }

    /* Status pill */
    .spill { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 100px; font-size: 11px; font-weight: 700; white-space: nowrap; }
    .s-pending     { background: rgba(217,119,6,.09); color: #b45309; border: 1px solid rgba(217,119,6,.22); }
    .s-confirmed   { background: rgba(29,78,216,.08); color: #1d4ed8; border: 1px solid rgba(29,78,216,.2); }
    .s-processing  { background: rgba(13,27,62,.08); color: #1a2f54; border: 1px solid rgba(13,27,62,.18); }
    .s-shipped     { background: rgba(13,148,136,.08); color: #0d9488; border: 1px solid rgba(13,148,136,.2); }
    .s-delivered   { background: rgba(5,150,105,.08); color: #059669; border: 1px solid rgba(5,150,105,.2); }
    .s-completed   { background: rgba(15,23,42,.07); color: #0f172a; border: 1px solid rgba(15,23,42,.18); }
    .s-cancelled   { background: rgba(220,38,38,.08); color: #dc2626; border: 1px solid rgba(220,38,38,.2); }

    .btn-view {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 7px 14px; background: linear-gradient(135deg, #0d9488, #0f766e);
        color: #fff; border-radius: 8px; font-size: 12px; font-weight: 700;
        text-decoration: none; transition: all .2s; white-space: nowrap;
    }
    .btn-view:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(13,148,136,.35); color: #fff; }

    /* Empty state */
    .empty-state { text-align: center; padding: 60px 20px; }
    .empty-state .em-ico { font-size: 52px; color: #cbd5e1; margin-bottom: 14px; }
    .empty-state h4 { font-size: 16px; font-weight: 700; color: #475569; margin: 0 0 5px; }
    .empty-state p  { font-size: 13px; color: #94a3b8; margin: 0; }

    /* Pagination */
    .pag-bar { display: flex; justify-content: space-between; align-items: center; padding: 13px 18px; border-top: 1px solid #e2e8f0; background: #f8fafc; }
    .pag-info { font-size: 12px; color: #94a3b8; font-weight: 600; }
    .pag { display: flex; gap: 4px; list-style: none; margin: 0; padding: 0; }
    .pag-item a, .pag-item span {
        display: flex; align-items: center; justify-content: center;
        min-width: 34px; height: 34px; padding: 0 8px; border-radius: 8px;
        font-size: 12px; font-weight: 700; text-decoration: none;
        border: 1.5px solid #e2e8f0; color: #475569; background: #fff; transition: all .15s;
    }
    .pag-item a:hover { border-color: #0d9488; color: #0d9488; }
    .pag-item.active span { background: #0d1b3e; border-color: #0d1b3e; color: #fff; }
    .pag-item.disabled span { opacity: .35; pointer-events: none; }

    /* Alert banners */
    .al-ok  { display:flex; align-items:center; gap:8px; border-radius:10px; padding:11px 16px; font-size:13px; font-weight:600; margin-bottom:14px; background:rgba(5,150,105,.08); border:1px solid rgba(5,150,105,.2); color:#059669; }
    .al-err { display:flex; align-items:center; gap:8px; border-radius:10px; padding:11px 16px; font-size:13px; font-weight:600; margin-bottom:14px; background:rgba(220,38,38,.08); border:1px solid rgba(220,38,38,.2); color:#dc2626; }

    @@media(max-width: 1100px) { .stats-row { grid-template-columns: repeat(4,1fr); } }
    @@media(max-width: 700px)  { .stats-row { grid-template-columns: repeat(2,1fr); } }
    @@media(max-width: 480px)  { .stats-row { grid-template-columns: 1fr; } }
</style>
}

<div class="ao-wrap">

    <!-- HEADER -->
    <div class="ao-hdr">
        <div>
            <div style="margin-bottom:8px;">
                <a href="/Admin" class="bc-link">Admin</a>
                <span class="bc-sep">›</span>
                <span style="color:#fff;font-size:12px;font-weight:600;">Orders Management</span>
            </div>
            <h1><i class="bi bi-bag-check me-2"></i>Orders Management</h1>
            <p>Full lifecycle view — Sales phase &amp; Operations phase</p>
        </div>
        <div style="display:flex;gap:10px;align-items:center;">
            <button class="btn-filter" style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);" onclick="window.location.reload()">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="al-ok"><i class="bi bi-check-circle-fill"></i> @ok</div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="al-err"><i class="bi bi-exclamation-circle-fill"></i> @err</div>
    }

    <!-- STATS ROW -->
    <div class="stats-row">
        <a class="stat-c" href="?" style="--sc-clr:#0d1b3e">
            <div class="sc-lbl">Total</div>
            <div class="sc-val">@Model.StatTotal</div>
            <div class="sc-sub">All orders</div>
        </a>
        <a class="stat-c" href="?StatusFilter=Pending" style="--sc-clr:#d97706">
            <div class="sc-lbl">Pending</div>
            <div class="sc-val">@Model.StatPending</div>
            <div class="sc-sub">Awaiting confirm</div>
        </a>
        <a class="stat-c" href="?StatusFilter=Confirmed" style="--sc-clr:#1d4ed8">
            <div class="sc-lbl">Confirmed</div>
            <div class="sc-val">@Model.StatConfirmed</div>
            <div class="sc-sub">Sales phase</div>
        </a>
        <a class="stat-c" href="?StatusFilter=Processing" style="--sc-clr:#1a2f54">
            <div class="sc-lbl">Processing</div>
            <div class="sc-val">@Model.StatProcessing</div>
            <div class="sc-sub">In ops queue</div>
        </a>
        <a class="stat-c" href="?StatusFilter=Shipped" style="--sc-clr:#0d9488">
            <div class="sc-lbl">Shipped</div>
            <div class="sc-val">@Model.StatShipped</div>
            <div class="sc-sub">In transit</div>
        </a>
        <a class="stat-c" href="?StatusFilter=Completed" style="--sc-clr:#059669">
            <div class="sc-lbl">Completed</div>
            <div class="sc-val">@Model.StatCompleted</div>
            <div class="sc-sub">Fulfilled</div>
        </a>
        <a class="stat-c" href="?StatusFilter=Cancelled" style="--sc-clr:#dc2626">
            <div class="sc-lbl">Cancelled</div>
            <div class="sc-val">@Model.StatCancelled</div>
            <div class="sc-sub">Cancelled</div>
        </a>
    </div>

    <!-- PHASE TABS -->
    <div class="phase-tabs">
        <a href="?" class="phase-tab @(string.IsNullOrEmpty(Model.PhaseFilter) ? "active" : "")">
            <i class="bi bi-list-ul me-1"></i>All Orders
        </a>
        <a href="?PhaseFilter=Sales" class="phase-tab sales @(Model.PhaseFilter == "Sales" ? "active" : "")">
            <i class="bi bi-receipt me-1"></i>Sales Phase
        </a>
        <a href="?PhaseFilter=Ops" class="phase-tab ops @(Model.PhaseFilter == "Ops" ? "active" : "")">
            <i class="bi bi-truck me-1"></i>Ops Phase
        </a>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar">
        <form method="get" class="filter-row">
            @if (!string.IsNullOrEmpty(Model.PhaseFilter))
            {
                <input type="hidden" name="PhaseFilter" value="@Model.PhaseFilter" />
            }
            <input type="text" class="fi fi-search" name="Search" value="@Model.Search"
                   placeholder="Search by Order ID, name, or email…" />
            <select class="fi" name="StatusFilter">
                <option value="">All statuses</option>
                <option value="Pending"    selected="@(Model.StatusFilter == "Pending"   )">Pending</option>
                <option value="Confirmed"  selected="@(Model.StatusFilter == "Confirmed" )">Confirmed</option>
                <option value="Processing" selected="@(Model.StatusFilter == "Processing")">Processing (all)</option>
                <option value="Shipped"    selected="@(Model.StatusFilter == "Shipped"   )">Shipped</option>
                <option value="Delivered"  selected="@(Model.StatusFilter == "Delivered" )">Delivered</option>
                <option value="Completed"  selected="@(Model.StatusFilter == "Completed" )">Completed</option>
                <option value="Cancelled"  selected="@(Model.StatusFilter == "Cancelled" )">Cancelled</option>
            </select>
            <select class="fi fi-sm" name="PageSize">
                <option value="10"  selected="@(Model.PageSize==10 )">10</option>
                <option value="15"  selected="@(Model.PageSize==15 )">15</option>
                <option value="25"  selected="@(Model.PageSize==25 )">25</option>
                <option value="50"  selected="@(Model.PageSize==50 )">50</option>
            </select>
            <input type="hidden" name="PageNumber" value="1" />
            <button type="submit" class="btn-filter"><i class="bi bi-funnel-fill"></i> Filter</button>
            <a href="/Admin/Orders" class="btn-clear"><i class="bi bi-x-lg"></i> Clear</a>
        </form>
    </div>

    <!-- TABLE -->
    <div class="tbl-card">
        <div class="tbl-top">
            <h5>
                <i class="bi bi-list-check"></i> Order List
                <span class="tbl-badge">@Model.TotalOrders orders</span>
            </h5>
            <div class="tbl-info">
                Showing <strong>@Model.FirstIdx–@Model.LastIdx</strong> of <strong>@Model.TotalOrders</strong>
            </div>
        </div>

        @if (!Model.Orders.Any())
        {
            <div class="empty-state">
                <div class="em-ico"><i class="bi bi-inbox"></i></div>
                <h4>No orders found</h4>
                <p>Try adjusting your filters or clearing the search.</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto">
                <table class="ao-tbl">
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Phase</th>
                            <th>Status</th>
                            <th>Tracking</th>
                            <th style="text-align:right">Total</th>
                            <th style="text-align:center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.Orders)
                        {
                            string statusCss = o.Status switch
                            {
                                "Pending"   => "s-pending",
                                "Confirmed" => "s-confirmed",
                                var s when s != null && s.StartsWith("Processing") => "s-processing",
                                "Shipped"   => "s-shipped",
                                "Delivered" => "s-delivered",
                                "Completed" => "s-completed",
                                "Cancelled" => "s-cancelled",
                                _           => ""
                            };
                            string phaseCss = o.Phase switch
                            {
                                "Sales"     => "ph-sales",
                                "Ops"       => "ph-ops",
                                "Done"      => "ph-done",
                                "Cancelled" => "ph-cancelled",
                                _           => ""
                            };
                            <tr>
                                <td>
                                    <div class="cell-id">#@o.OrderId
                                        @if (o.HasPrescription)
                                        {
                                            <span class="cell-rx">Rx</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="cust-name">@(o.CustomerName ?? "Guest")</div>
                                    <div class="cust-email">@o.CustomerEmail</div>
                                </td>
                                <td style="white-space:nowrap">
                                    @o.CreatedAt.ToString("dd/MM/yyyy")<br/>
                                    <span style="font-size:11px;color:#94a3b8">@o.CreatedAt.ToString("HH:mm")</span>
                                </td>
                                <td><span class="phase-badge @phaseCss">@o.Phase</span></td>
                                <td><span class="spill @statusCss">@o.Status</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(o.TrackingNumber))
                                    {
                                        <span style="font-size:12px;color:#0d9488;font-weight:600">@o.TrackingNumber</span>
                                    }
                                    else
                                    {
                                        <span style="font-size:11px;color:#cbd5e1">—</span>
                                    }
                                </td>
                                <td style="text-align:right">
                                    <span class="price-val">@o.TotalAmount.ToString("N0") ₫</span>
                                </td>
                                <td style="text-align:center">
                                    <a href="/Admin/Orders/Details?id=@o.OrderId" class="btn-view">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- PAGINATION -->
            @if (Model.TotalPages > 1)
            {
                <div class="pag-bar">
                    <div class="pag-info">
                        Page @Model.PageNumber of @Model.TotalPages
                    </div>
                    <ul class="pag">
                        <li class="pag-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                            <a href="?PageNumber=@(Model.PageNumber-1)&PageSize=@Model.PageSize&StatusFilter=@Model.StatusFilter&PhaseFilter=@Model.PhaseFilter&Search=@Model.Search">‹</a>
                        </li>
                        @foreach (var p in Model.PageNums)
                        {
                            <li class="pag-item @(p == Model.PageNumber ? "active" : "")">
                                @if (p == Model.PageNumber)
                                {
                                    <span>@p</span>
                                }
                                else
                                {
                                    <a href="?PageNumber=@p&PageSize=@Model.PageSize&StatusFilter=@Model.StatusFilter&PhaseFilter=@Model.PhaseFilter&Search=@Model.Search">@p</a>
                                }
                            </li>
                        }
                        <li class="pag-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                            <a href="?PageNumber=@(Model.PageNumber+1)&PageSize=@Model.PageSize&StatusFilter=@Model.StatusFilter&PhaseFilter=@Model.PhaseFilter&Search=@Model.Search">›</a>
                        </li>
                    </ul>
                </div>
            }
        }
    </div>

</div>
