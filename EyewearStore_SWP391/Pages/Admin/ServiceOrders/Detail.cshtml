@page "{orderId:int}"
@model EyewearStore_SWP391.Pages.Admin.ServiceOrders.DetailModel
@using EyewearStore_SWP391.Pages.Admin.ServiceOrders
@{
    ViewData["Title"] = $"Service Job — Order #{Model.Order?.OrderId}";
    Layout = "_Layout";

    var snap = Model.Snap;
    var order = Model.Order;
    var item = Model.Item;

    string StatusBg(string s) => s switch
    {
        "Pending" => "#fef3c7",
        "Processing" => "#dbeafe",
        "Ready" => "#d1fae5",
        "Done" => "#f3f4f6",
        "Cancelled" => "#fee2e2",
        _ => "#f3f4f6"
    };
    string StatusColor(string s) => s switch
    {
        "Pending" => "#92400e",
        "Processing" => "#1e40af",
        "Ready" => "#065f46",
        "Done" => "#374151",
        "Cancelled" => "#991b1b",
        _ => "#374151"
    };
    string StatusIcon(string s) => s switch
    {
        "Pending" => "bi-hourglass-split",
        "Processing" => "bi-gear-wide-connected",
        "Ready" => "bi-check-circle-fill",
        "Done" => "bi-bag-check-fill",
        "Cancelled" => "bi-x-circle-fill",
        _ => "bi-hourglass-split"
    };
    string StatusEmoji(string s) => s switch
    {
        "Pending" => "⏳",
        "Processing" => "⚙️",
        "Ready" => "✅",
        "Done" => "🎉",
        "Cancelled" => "❌",
        _ => "•"
    };

    var curStatus = snap?.ServiceStatus ?? "Pending";
    string[] steps = { "Pending", "Processing", "Ready", "Done" };
    int stepIdx = curStatus switch { "Processing" => 1, "Ready" => 2, "Done" => 3, _ => 0 };
    bool isCancelled = curStatus == "Cancelled";
}

@section Styles {
    <style>
        :root {
            --navy: #0d1b2a;
            --acc: #2563eb;
            --gold: #b8862a;
            --ok: #059669;
            --warn: #d97706;
            --err: #dc2626;
            --txt: #0f172a;
            --txt2: #475569;
            --muted: #94a3b8;
            --surf: #fff;
            --bg: #f1f5f9;
            --bg2: #e8edf4;
            --bdr: #e2e8f0;
            --shadow: 0 2px 12px rgba(0,0,0,.07);
            --shadow-md: 0 4px 20px rgba(0,0,0,.1);
            --r: 14px
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        body {
            background: var(--bg)
        }

        .det-wrap {
            max-width: 1100px;
            margin: 0 auto;
            padding: 32px 24px 80px
        }

        .bc {
            display: flex;
            gap: 6px;
            align-items: center;
            margin-bottom: 24px;
            font-size: 12px;
            color: var(--muted)
        }

            .bc a {
                color: var(--muted);
                text-decoration: none;
                font-weight: 600
            }

                .bc a:hover {
                    color: var(--acc)
                }

        .bc-sep {
            opacity: .5
        }

        .det-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 28px
        }

            .det-header h1 {
                font-size: 1.65rem;
                font-weight: 900;
                color: var(--navy);
                margin: 0 0 4px;
                letter-spacing: -.5px
            }

            .det-header p {
                font-size: 13px;
                color: var(--muted);
                margin: 0
            }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 18px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 800;
            white-space: nowrap;
            flex-shrink: 0
        }

        .alert-ok {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(5,150,105,.08);
            border: 1px solid rgba(5,150,105,.22);
            color: #059669;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 20px;
            animation: slideIn .3s ease
        }

        .alert-err {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(220,38,38,.08);
            border: 1px solid rgba(220,38,38,.22);
            color: #dc2626;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 20px
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-5px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .det-grid {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 20px
        }

        .dc {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            overflow: hidden;
            box-shadow: var(--shadow);
            margin-bottom: 18px
        }

            .dc:last-child {
                margin-bottom: 0
            }

        .dc-hdr {
            background: linear-gradient(135deg, #0d1b2a, #1a2f54);
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 10px
        }

            .dc-hdr h3 {
                font-size: 14px;
                font-weight: 800;
                color: #fff;
                margin: 0
            }

            .dc-hdr i {
                font-size: 16px;
                color: rgba(255,255,255,.7)
            }

        .dc-body {
            padding: 20px
        }

        .bd-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 13px 0;
            border-bottom: 1px solid var(--bdr)
        }

            .bd-row:last-child {
                border-bottom: none
            }

        .bd-left {
            display: flex;
            align-items: center;
            gap: 12px
        }

        .bd-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: var(--bg2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0
        }

        .bd-lbl {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 2px
        }

        .bd-val {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt)
        }

        .bd-price {
            font-size: 14px;
            font-weight: 700;
            color: var(--navy);
            white-space: nowrap
        }

        .bd-total {
            padding: 14px 0 2px;
            display: flex;
            justify-content: space-between;
            align-items: center
        }

        .bd-total-lbl {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt2)
        }

        .bd-total-val {
            font-size: 19px;
            font-weight: 900;
            color: var(--gold)
        }

        .tl {
            display: flex;
            align-items: center;
            padding: 4px 0
        }

        .tl-step {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 1
        }

            .tl-step:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 16px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: #e0e2f0;
                z-index: 0
            }

            .tl-step.done:not(:last-child)::after {
                background: #059669
            }

            .tl-step.active:not(:last-child)::after {
                background: linear-gradient(90deg,#059669,#e0e2f0)
            }

        .tl-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            border: 2px solid #dde1f0;
            background: #fff;
            position: relative;
            z-index: 2;
            transition: all .3s
        }

        .tl-step.done .tl-circle {
            background: #059669;
            border-color: #059669;
            color: #fff
        }

        .tl-step.active .tl-circle {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
            box-shadow: 0 0 0 4px rgba(37,99,235,.15)
        }

        .tl-lbl {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            margin-top: 7px;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: .5px
        }

        .tl-step.done .tl-lbl {
            color: #059669
        }

        .tl-step.active .tl-lbl {
            color: #2563eb
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px
        }

        .info-item {
            background: var(--bg);
            border-radius: 10px;
            padding: 12px 14px
        }

        .info-lbl {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 4px
        }

        .info-val {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt);
            line-height: 1.45
        }

        .info-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px
        }

        .form-lbl {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 8px;
            display: block
        }

        .form-fi {
            width: 100%;
            background: var(--bg);
            border: 1.5px solid var(--bdr);
            border-radius: 9px;
            padding: 10px 13px;
            font-size: 13px;
            color: var(--txt);
            font-family: inherit;
            transition: border-color .2s
        }

            .form-fi:focus {
                outline: none;
                border-color: var(--acc);
                box-shadow: 0 0 0 3px rgba(37,99,235,.1)
            }

        .st-grid {
            display: flex;
            flex-direction: column;
            gap: 7px;
            margin-bottom: 20px
        }

        .st-radio {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-radius: 10px;
            cursor: pointer;
            border: 2px solid var(--bdr);
            background: var(--surf);
            transition: all .18s;
            user-select: none
        }

            .st-radio:hover {
                border-color: #94a3b8
            }

            .st-radio.selected {
                border-width: 2px;
                font-weight: 800
            }

            .st-radio input {
                display: none
            }

        .st-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0
        }

        .st-radio-lbl {
            font-size: 13px;
            font-weight: 600;
            color: var(--txt)
        }

        .btn-save {
            width: 100%;
            padding: 13px;
            font-size: 14px;
            font-weight: 800;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            background: linear-gradient(135deg, #0d1b2a, #1a2f54);
            color: #fff;
            letter-spacing: .3px;
            transition: all .2s
        }

            .btn-save:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 18px rgba(13,27,42,.25)
            }

        .note-box {
            background: #fffbeb;
            border: 1px solid #fde68a;
            border-radius: 10px;
            padding: 13px 16px;
            margin-top: 14px
        }

            .note-box p {
                margin: 0;
                font-size: 13px;
                color: #78350f;
                line-height: 1.6
            }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 14px;
            font-size: 13px;
            font-weight: 600;
            color: var(--acc);
            text-decoration: none
        }

            .back-link:hover {
                text-decoration: underline
            }

        @@media(max-width: 900px) {
            .det-grid {
                grid-template-columns: 1fr
            }

            .info-grid {
                grid-template-columns: 1fr
            }
        }

        @@media(max-width: 600px) {
            .det-wrap {
                padding: 16px 12px 60px
            }
        }
    </style>
}

<div class="det-wrap">

    <div class="bc">
        <a asp-page="/Admin/Index">Dashboard</a>
        <span class="bc-sep">›</span>
        <a asp-page="/Admin/ServiceOrders/Index">Service Orders</a>
        <span class="bc-sep">›</span>
        <span>Order #@Model.Order?.OrderId</span>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="alert-ok"><i class="bi bi-check-circle-fill"></i> @ok</div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i> @err</div>
    }

    @if (order == null || snap == null || item == null)
    {
        <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i> Service order not found.</div>
    }
    else
    {
        <div class="det-header">
            <div>
                <h1>🔧 Service Job #@order.OrderId</h1>
                <p>Placed @order.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")</p>
            </div>
            <span class="status-pill"
                  style="background:@StatusBg(curStatus);color:@StatusColor(curStatus);">
                <i class="bi @StatusIcon(curStatus)"></i> @curStatus
            </span>
        </div>

        <div class="det-grid">

            <!-- LEFT -->
            <div>
                <!-- Breakdown -->
                <div class="dc">
                    <div class="dc-hdr"><i class="bi bi-tools"></i><h3>Service Breakdown</h3></div>
                    <div class="dc-body">

                        <div class="bd-row">
                            <div class="bd-left">
                                <div class="bd-icon">🕶</div>
                                <div><div class="bd-lbl">Frame</div><div class="bd-val">@(snap.FrameName ?? snap.ProductName ?? "N/A")</div></div>
                            </div>
                            <div class="bd-price">@snap.FramePrice.ToString("N0") ₫</div>
                        </div>

                        @if (!string.IsNullOrEmpty(snap.LensProductName))
                        {
                            <div class="bd-row">
                                <div class="bd-left">
                                    <div class="bd-icon">⭕</div>
                                    <div><div class="bd-lbl">Lens</div><div class="bd-val">@snap.LensProductName</div></div>
                                </div>
                                <div class="bd-price">@snap.LensPrice.ToString("N0") ₫</div>
                            </div>
                        }

                        <div class="bd-row">
                            <div class="bd-left">
                                <div class="bd-icon">⚙️</div>
                                <div><div class="bd-lbl">Service</div><div class="bd-val">@(snap.ServiceName ?? "N/A")</div></div>
                            </div>
                            <div class="bd-price">@snap.ServicePrice.ToString("N0") ₫</div>
                        </div>

                        <div class="bd-total">
                            <div class="bd-total-lbl">Total</div>
                            <div class="bd-total-val">@((item.UnitPrice * item.Quantity).ToString("N0")) ₫</div>
                        </div>
                    </div>
                </div>

                <!-- Timeline -->
                <div class="dc">
                    <div class="dc-hdr"><i class="bi bi-map"></i><h3>Progress</h3></div>
                    <div class="dc-body">
                        @if (isCancelled)
                        {
                            <div style="display:flex;align-items:center;gap:10px;color:#dc2626">
                                <span style="font-size:1.5rem">❌</span>
                                <strong>This service order has been cancelled.</strong>
                            </div>
                        }
                        else
                        {
                            <div class="tl">
                                @for (int i = 0; i < steps.Length; i++)
                                {
                                    string cls = i < stepIdx ? "done" : i == stepIdx ? "active" : "";
                                    string ic = i < stepIdx ? "✓" : i == stepIdx ? "●" : (i + 1).ToString();
                                    <div class="tl-step @cls">
                                        <div class="tl-circle">@ic</div>
                                        <div class="tl-lbl">@steps[i]</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Customer -->
                <div class="dc">
                    <div class="dc-hdr"><i class="bi bi-person-fill"></i><h3>Customer &amp; Order Info</h3></div>
                    <div class="dc-body">
                        <div class="info-grid">
                            <div class="info-item">
                                <div class="info-lbl">Customer</div>
                                <div class="info-val">@(order.User?.FullName ?? "N/A")</div>
                                <div class="info-sub">@(order.User?.Email ?? "")</div>
                            </div>
                            <div class="info-item">
                                <div class="info-lbl">Order Status</div>
                                <div class="info-val">@order.Status</div>
                                <div class="info-sub">@order.PaymentMethod</div>
                            </div>
                            <div class="info-item">
                                <div class="info-lbl">Order Date</div>
                                <div class="info-val">@order.CreatedAt.ToString("dd/MM/yyyy")</div>
                                <div class="info-sub">@order.CreatedAt.ToString("HH:mm")</div>
                            </div>
                            <div class="info-item">
                                <div class="info-lbl">Total Paid</div>
                                <div class="info-val" style="color:var(--gold)">@order.TotalAmount.ToString("N0") ₫</div>
                            </div>
                        </div>
                        @{
                            var addrLine = order.Address?.AddressLine ?? order.AddressLine;
                            var recvName = order.Address?.ReceiverName ?? order.ReceiverName;
                            var phone = order.Address?.Phone ?? order.Phone;
                        }
                        @if (!string.IsNullOrEmpty(addrLine))
                        {
                            <div class="info-item" style="margin-top:14px">
                                <div class="info-lbl">Shipping Address</div>
                                <div class="info-val">@recvName · @phone</div>
                                <div class="info-sub">@addrLine</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- RIGHT -->
            <div>
                <div class="dc" style="position:sticky;top:88px">
                    <div class="dc-hdr"><i class="bi bi-pencil-fill"></i><h3>Update Job</h3></div>
                    <div class="dc-body">
                        <form method="post" asp-page-handler="Update"
                              asp-route-orderId="@Model.Order!.OrderId">
                            <input type="hidden" name="OrderItemId" value="@Model.Item!.OrderItemId" />

                            <div style="margin-bottom:18px">
                                <span class="form-lbl">📊 Service Status</span>
                                <div class="st-grid">
                                    @foreach (var s in DetailModel.Statuses)
                                    {
                                        bool isCur = curStatus == s;
                                        <label class="st-radio @(isCur ? "selected" : "")"
                                               style="@(isCur ? $"background:{StatusBg(s)};border-color:{StatusColor(s)};" : "")">
                                            <input type="radio" name="ServiceStatus" value="@s" @(isCur ? "checked" : "") />
                                            <span class="st-dot" style="background:@StatusColor(s)"></span>
                                            <span style="font-size:15px">@StatusEmoji(s)</span>
                                            <span class="st-radio-lbl" style="@(isCur ? $"color:{StatusColor(s)}" : "")">@s</span>
                                        </label>
                                    }
                                </div>
                            </div>

                            <div style="margin-bottom:14px">
                                <label class="form-lbl">👤 Assigned To</label>
                                <input type="text" name="AssignedTo" value="@snap.AssignedTo"
                                       class="form-fi" placeholder="Staff name or code…" />
                            </div>

                            <div style="margin-bottom:20px">
                                <label class="form-lbl">
                                    📝 Note
                                    <span style="font-weight:400;text-transform:none;letter-spacing:0;color:var(--muted);font-size:10px">
                                        (shown to customer)
                                    </span>
                                </label>
                                <textarea name="InternalNote" rows="4" class="form-fi"
                                      style="resize:vertical"
                                      placeholder="Add a note for the customer or team…">@snap.InternalNote</textarea>
                            </div>

                            <button type="submit" class="btn-save">💾 Save Changes</button>
                        </form>

                        <a asp-page="/Admin/ServiceOrders/Index" class="back-link">← Back to Service Orders</a>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(snap.InternalNote))
                {
                    <div class="note-box">
                        <div style="font-size:10px;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px">Current Note</div>
                        <p>@snap.InternalNote</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

<script>
    document.querySelectorAll('.st-radio').forEach(lbl => {
        lbl.addEventListener('click', () => {
            document.querySelectorAll('.st-radio').forEach(b => {
                b.classList.remove('selected');
                b.style.cssText = '';
            });
            lbl.classList.add('selected');
            const r = lbl.querySelector('input[type=radio]');
            if (r) r.checked = true;
        });
    });
</script>
