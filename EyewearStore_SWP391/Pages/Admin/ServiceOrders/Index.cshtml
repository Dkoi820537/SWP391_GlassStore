@page
@model EyewearStore_SWP391.Pages.Admin.ServiceOrders.IndexModel
@{
    ViewData["Title"] = "Service Orders";
    Layout = "_Layout";

    string BadgeClass(string s) => s switch
    {
        "Pending" => "st-pending",
        "Processing" => "st-processing",
        "Ready" => "st-ready",
        "Done" => "st-done",
        "Cancelled" => "st-cancelled",
        _ => "st-pending"
    };
    string BadgeIcon(string s) => s switch
    {
        "Pending" => "bi-hourglass-split",
        "Processing" => "bi-gear-wide-connected",
        "Ready" => "bi-check-circle-fill",
        "Done" => "bi-bag-check-fill",
        "Cancelled" => "bi-x-circle-fill",
        _ => "bi-hourglass-split"
    };
}

@section Styles {
    <style>
        :root {
            --navy: #0d1b2a;
            --acc: #2563eb;
            --gold: #b8862a;
            --ok: #059669;
            --warn: #d97706;
            --err: #dc2626;
            --info: #0891b2;
            --txt: #0f172a;
            --txt2: #475569;
            --muted: #94a3b8;
            --surf: #fff;
            --bg: #f1f5f9;
            --bg2: #e8edf4;
            --bdr: #e2e8f0;
            --shadow: 0 2px 12px rgba(0,0,0,.07);
            --shadow-md: 0 4px 20px rgba(0,0,0,.1);
            --r: 14px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
        }

        .so-wrap {
            max-width: 1400px;
            margin: 0 auto;
            padding: 32px 24px 80px;
        }

        /* ── HEADER ── */
        .so-hdr {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }

            .so-hdr h1 {
                font-size: 1.75rem;
                font-weight: 900;
                color: var(--navy);
                margin: 0 0 4px;
                letter-spacing: -.5px;
            }

            .so-hdr p {
                font-size: 13px;
                color: var(--muted);
                margin: 0;
            }

        .hdr-icon {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            background: linear-gradient(135deg,#2563eb,#1d4ed8);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            box-shadow: 0 4px 14px rgba(37,99,235,.28);
            flex-shrink: 0;
        }

        /* ── STATS ── */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(5,1fr);
            gap: 12px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            padding: 16px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: var(--shadow);
            transition: box-shadow .2s;
        }

            .stat-card:hover {
                box-shadow: var(--shadow-md);
            }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .si-all {
            background: rgba(37,99,235,.1);
            color: #2563eb;
        }

        .si-pend {
            background: rgba(217,119,6,.1);
            color: #d97706;
        }

        .si-proc {
            background: rgba(91,91,219,.1);
            color: #5b5bdb;
        }

        .si-ready {
            background: rgba(5,150,105,.1);
            color: #059669;
        }

        .si-done {
            background: rgba(15,30,60,.1);
            color: #0f1e3c;
        }

        .stat-lbl {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 2px;
        }

        .stat-val {
            font-size: 24px;
            font-weight: 800;
            color: var(--txt);
            letter-spacing: -.5px;
        }

        /* ── FILTER ── */
        .filter-bar {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            padding: 14px 18px;
            margin-bottom: 16px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: flex-end;
            box-shadow: var(--shadow);
        }

        .fg {
            display: flex;
            flex-direction: column;
            gap: 4px;
            flex: 1;
            min-width: 140px;
        }

            .fg label {
                font-size: 10px;
                font-weight: 700;
                color: var(--muted);
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .fi {
            background: var(--bg);
            border: 1.5px solid var(--bdr);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 13px;
            color: var(--txt);
            width: 100%;
            transition: border-color .2s;
        }

            .fi:focus {
                outline: none;
                border-color: var(--acc);
                box-shadow: 0 0 0 3px rgba(37,99,235,.1);
            }

        .btn-filter {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--acc);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 9px 16px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s;
        }

            .btn-filter:hover {
                background: #1d4ed8;
            }

        .btn-reset {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--bg);
            color: var(--muted);
            border: 1.5px solid var(--bdr);
            border-radius: 8px;
            padding: 9px 14px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all .2s;
        }

            .btn-reset:hover {
                color: var(--txt);
                border-color: #94a3b8;
            }

        /* ── TABLE WRAP ── */
        .tbl-wrap {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            overflow: hidden;
            box-shadow: var(--shadow-md);
        }

        .so-tbl {
            width: 100%;
            border-collapse: collapse;
        }

            .so-tbl thead tr {
                background: var(--bg2);
                border-bottom: 1px solid var(--bdr);
            }

            .so-tbl th {
                font-size: 10px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.4px;
                color: var(--muted);
                padding: 12px 16px;
                text-align: left;
                white-space: nowrap;
            }

            .so-tbl td {
                padding: 14px 16px;
                border-bottom: 1px solid var(--bdr);
                vertical-align: middle;
                font-size: 13px;
                color: var(--txt2);
            }

            .so-tbl tbody tr:last-child td {
                border-bottom: none;
            }

            .so-tbl tbody tr:hover {
                background: var(--bg);
            }

        /* ── ORDER ID ── */
        .oid {
            font-weight: 800;
            color: var(--navy);
            font-size: 13px;
        }

        .oid-sub {
            font-size: 10px;
            color: var(--muted);
            font-weight: 500;
            margin-top: 1px;
        }

        /* ── CUSTOMER CELL ── */
        .cust-name {
            font-weight: 700;
            color: var(--txt);
            font-size: 13px;
        }

        .cust-email {
            font-size: 11px;
            color: var(--muted);
        }

        /* ── SERVICE PILL ── */
        .svc-breakdown {
            font-size: 11.5px;
            line-height: 1.9;
        }

        .svc-row-item {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .svc-tag {
            display: inline-block;
            background: var(--bg2);
            border-radius: 5px;
            padding: 1px 7px;
            font-size: 10px;
            font-weight: 700;
            color: var(--txt2);
            white-space: nowrap;
        }

        /* ── STATUS BADGES ── */
        .st-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700;
        }

        .st-pending {
            background: rgba(217,119,6,.1);
            color: #d97706;
            border: 1px solid rgba(217,119,6,.25);
        }

        .st-processing {
            background: rgba(91,91,219,.1);
            color: #5b5bdb;
            border: 1px solid rgba(91,91,219,.25);
        }

        .st-ready {
            background: rgba(5,150,105,.1);
            color: #059669;
            border: 1px solid rgba(5,150,105,.25);
        }

        .st-done {
            background: rgba(15,30,60,.1);
            color: #0f1e3c;
            border: 1px solid rgba(15,30,60,.2);
        }

        .st-cancelled {
            background: rgba(220,38,38,.1);
            color: #dc2626;
            border: 1px solid rgba(220,38,38,.25);
        }

        .bdot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor;
        }

        /* ── ASSIGN CHIP ── */
        .assign-chip {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(37,99,235,.08);
            border-radius: 100px;
            padding: 3px 10px;
            font-size: 11px;
            font-weight: 600;
            color: #2563eb;
        }

        .no-assign {
            font-size: 11px;
            color: var(--muted);
        }

        /* ── PRICE ── */
        .price-col {
            font-weight: 700;
            color: var(--gold);
            font-size: 13px;
            white-space: nowrap;
        }

        /* ── ACTION BTN ── */
        .btn-detail {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg,var(--navy),#1a2f54);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: all .2s;
            white-space: nowrap;
        }

            .btn-detail:hover {
                color: #fff;
                transform: translateY(-1px);
                box-shadow: 0 4px 14px rgba(15,30,60,.22);
            }

        /* ── EMPTY ── */
        .so-empty {
            text-align: center;
            padding: 72px 24px;
        }

            .so-empty .ei {
                font-size: 52px;
                opacity: .2;
                display: block;
                margin-bottom: 14px;
            }

            .so-empty h3 {
                font-size: 18px;
                font-weight: 800;
                color: var(--txt);
                margin: 0 0 6px;
            }

            .so-empty p {
                font-size: 13px;
                color: var(--muted);
            }

        /* ── PAGINATION ── */
        .pagi {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 18px;
            border-top: 1px solid var(--bdr);
            background: var(--bg2);
            flex-wrap: wrap;
            gap: 10px;
        }

        .pagi-info {
            font-size: 12px;
            color: var(--muted);
        }

        .pagi-btns {
            display: flex;
            gap: 4px;
        }

        .pg {
            min-width: 34px;
            height: 34px;
            padding: 0 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--bdr);
            border-radius: 7px;
            background: var(--surf);
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s;
        }

            .pg:hover {
                border-color: var(--acc);
                color: var(--acc);
            }

            .pg.active {
                background: var(--acc);
                border-color: var(--acc);
                color: #fff;
            }

            .pg.disabled {
                opacity: .3;
                pointer-events: none;
            }

        /* ── ALERT ── */
        .alert-bar {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 11px 16px;
            border-radius: 10px;
            margin-bottom: 16px;
            font-size: 13px;
            font-weight: 600;
            animation: slideIn .3s ease;
        }

            .alert-bar.ok {
                background: rgba(5,150,105,.08);
                border: 1px solid rgba(5,150,105,.22);
                color: #059669;
            }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media(max-width:1100px) {
            .stat-grid {
                grid-template-columns: repeat(3,1fr);
            }
        }

        @@media(max-width:700px) {
            .stat-grid {
                grid-template-columns: 1fr 1fr;
            }

            .so-wrap {
                padding: 20px 12px 60px;
            }
        }
    </style>
}

<div class="so-wrap">

    <!-- HEADER -->
    <div class="so-hdr">
        <div style="display:flex;align-items:center;gap:14px">
            <div class="hdr-icon">🔧</div>
            <div>
                <h1>Service Orders</h1>
                <p>Manage all custom glasses, frame repair &amp; lens replacement orders</p>
            </div>
        </div>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="alert-bar ok"><i class="bi bi-check-circle-fill"></i> @ok</div>
    }

    <!-- STATS -->
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-icon si-all"><i class="bi bi-list-ul"></i></div>
            <div><div class="stat-lbl">Total</div><div class="stat-val">@Model.StatTotal</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon si-pend"><i class="bi bi-hourglass-split"></i></div>
            <div><div class="stat-lbl">Pending</div><div class="stat-val">@Model.StatPending</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon si-proc"><i class="bi bi-gear-wide-connected"></i></div>
            <div><div class="stat-lbl">Processing</div><div class="stat-val">@Model.StatProcessing</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon si-ready"><i class="bi bi-check-circle-fill"></i></div>
            <div><div class="stat-lbl">Ready</div><div class="stat-val">@Model.StatReady</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon si-done"><i class="bi bi-bag-check-fill"></i></div>
            <div><div class="stat-lbl">Done</div><div class="stat-val">@Model.StatDone</div></div>
        </div>
    </div>

    <!-- FILTER -->
    <form method="get" class="filter-bar">
        <div class="fg" style="flex:2">
            <label>Search</label>
            <input class="fi" type="text" name="SearchTerm" value="@Model.SearchTerm"
                   placeholder="Order #, customer name, frame, service…" />
        </div>
        <div class="fg" style="max-width:160px">
            <label>Status</label>
            <select class="fi" name="StatusFilter">
                <option value="">All Statuses</option>
                @foreach (var s in new[] { "Pending", "Processing", "Ready", "Done", "Cancelled" })
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
        </div>
        <div style="display:flex;gap:8px;align-items:flex-end">
            <button type="submit" class="btn-filter"><i class="bi bi-search"></i> Filter</button>
            <a asp-page="Index" class="btn-reset"><i class="bi bi-x-lg"></i> Reset</a>
        </div>
    </form>

    <!-- TABLE -->
    <div class="tbl-wrap">
        @if (Model.Items.Any())
        {
            <div style="overflow-x:auto">
                <table class="so-tbl">
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Customer</th>
                            <th>Service Details</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Assigned To</th>
                            <th>Date</th>
                            <th style="text-align:right">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="oid">#@row.OrderId</div>
                                    <div class="oid-sub">Item #@row.OrderItemId</div>
                                </td>
                                <td>
                                    <div class="cust-name">@row.CustomerName</div>
                                    <div class="cust-email">@row.CustomerEmail</div>
                                </td>
                                <td>
                                    <div class="svc-breakdown">
                                        <div class="svc-row-item">
                                            🕶 <span class="svc-tag">Frame</span> @row.FrameName
                                        </div>
                                        @if (!string.IsNullOrEmpty(row.LensName) && row.LensName != "—")
                                        {
                                            <div class="svc-row-item">
                                                ⭕ <span class="svc-tag">Lens</span> @row.LensName
                                            </div>
                                        }
                                        <div class="svc-row-item">
                                            ⚙️ <span class="svc-tag">Service</span> @row.ServiceName
                                        </div>
                                    </div>
                                </td>
                                <td class="price-col">@row.Total.ToString("N0") ₫</td>
                                <td>
                                    <span class="st-badge @BadgeClass(row.Status)">
                                        <span class="bdot"></span>
                                        <i class="bi @BadgeIcon(row.Status)" style="font-size:10px"></i>
                                        @row.Status
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(row.AssignedTo))
                                    {
                                        <span class="assign-chip">
                                            <i class="bi bi-person-fill" style="font-size:10px"></i>
                                            @row.AssignedTo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="no-assign">Unassigned</span>
                                    }
                                </td>
                                <td style="color:var(--muted);font-size:12px;white-space:nowrap">
                                    @row.CreatedAt.ToString("dd/MM/yyyy")<br />
                                    <span style="font-size:10px">@row.CreatedAt.ToString("HH:mm")</span>
                                </td>
                                <td style="text-align:right">
                                    <a asp-page="Detail"
                                       asp-route-orderItemId="@row.OrderItemId"
                                       class="btn-detail">
                                        <i class="bi bi-eye-fill"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                int ps = Math.Max(1, Model.CurrentPage - 2);
                int pe = Math.Min(Model.TotalPages, ps + 4);
                int from = (Model.CurrentPage - 1) * IndexModel.PageSize + 1;
                int to = Math.Min(Model.CurrentPage * IndexModel.PageSize, Model.TotalCount);

                <div class="pagi">
                    <div class="pagi-info">
                        Showing <strong>@from–@to</strong> of <strong>@Model.TotalCount</strong>
                    </div>
                    <div class="pagi-btns">
                        @if (Model.HasPrev)
                        {
                            <a class="pg" asp-page="Index"
                               asp-route-SearchTerm="@Model.SearchTerm"
                               asp-route-StatusFilter="@Model.StatusFilter"
                               asp-route-CurrentPage="@(Model.CurrentPage - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        }
                        else
                        {

                            <span class="pg disabled"><i class="bi bi-chevron-left"></i></span>
                        }

                        @for (int i = ps; i <= pe; i++)
                        {
                            if (i == Model.CurrentPage)
                            {
                                <span class="pg active">@i</span>
                            }
                            else
                            {
                                <a class="pg" asp-page="Index"
                                   asp-route-SearchTerm="@Model.SearchTerm"
                                   asp-route-StatusFilter="@Model.StatusFilter"
                                   asp-route-CurrentPage="@i">@i</a>
                            }
                        }

                        @if (Model.HasNext)
                        {
                            <a class="pg" asp-page="Index"
                               asp-route-SearchTerm="@Model.SearchTerm"
                               asp-route-StatusFilter="@Model.StatusFilter"
                               asp-route-CurrentPage="@(Model.CurrentPage + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                        else
                        {

                            <span class="pg disabled"><i class="bi bi-chevron-right"></i></span>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="so-empty">
                <span class="ei">🔧</span>
                <h3>No service orders found</h3>
                <p>
                    @(string.IsNullOrEmpty(Model.SearchTerm) && string.IsNullOrEmpty(Model.StatusFilter)
                                    ? "When customers place service orders, they'll appear here."
                                    : "No results match your filter. Try adjusting the search.")
            </p>
        </div>
                }
    </div>

</div>
