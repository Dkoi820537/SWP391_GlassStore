@page "{id:int}"
@model EyewearStore_SWP391.Pages.Admin.Users.EditModel
@{
    ViewData["Title"] = "Edit User";
}

<div class="container-fluid py-4 px-4 px-md-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Admin/Index">Admin</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index">Users</a></li>
            <li class="breadcrumb-item active">Edit User</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 style="font-family: var(--font-secondary); color: var(--primary-navy); font-size: 2.5rem; margin-bottom: 0.5rem;">
                <i class="bi bi-pencil-square me-2"></i>Edit User
            </h1>
            <p style="color: var(--secondary-warm-gray); font-size: 1.1rem; margin: 0;">
                Update user information and permissions
            </p>
        </div>
        <a asp-page="./Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Users
        </a>
    </div>

    <!-- Alerts -->
    @if (!ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <h5><i class="bi bi-exclamation-triangle me-2"></i>Validation Errors:</h5>
            <ul class="mb-0">
                @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

<style>
    .admin-edit-form-container {
        max-width: 900px;
        margin: 0 auto;
    }
    .admin-edit-form .form-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #6b7280;
        letter-spacing: 0.5px;
        margin-bottom: 0.35rem;
        font-weight: 600;
    }
    .admin-edit-form .input-group-text {
        background: #fdfdfd;
        border: 1px solid #d1d5db;
        border-right: none;
        color: #9ca3af;
        font-size: 1rem;
        padding-right: 0.5rem;
    }
    .admin-edit-form .form-control, .admin-edit-form .form-select {
        border: 1px solid #d1d5db;
        font-size: 0.95rem;
        padding: 0.45rem 0.75rem;
        box-shadow: none !important;
        color: #1f2937;
    }
    .admin-edit-form .form-control {
        border-left: none;
    }
    .admin-edit-form .form-control:focus, .admin-edit-form .form-select:focus {
        border-color: #20c997;
        box-shadow: none !important;
    }
    .admin-edit-form .input-group:focus-within .input-group-text,
    .admin-edit-form .input-group:focus-within .form-control {
        border-color: #20c997;
    }
    .admin-edit-form .section-title {
        color: var(--primary-navy, #0f2027);
        border-left: 3px solid #20c997;
        padding-left: 0.6rem;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1.25rem;
    }
    .admin-edit-form .form-switch .form-check-input {
        cursor: pointer;
        width: 2.5em;
        height: 1.25em;
    }
    .admin-edit-form .form-switch .form-check-input:checked {
        background-color: #20c997;
        border-color: #20c997;
    }
    .admin-edit-form .btn-outline-cancel {
        border: 1px solid #d1d5db;
        color: #4b5563;
        background: transparent;
        font-weight: 500;
        font-size: 0.9rem;
        border-radius: 6px;
    }
    .admin-edit-form .btn-outline-cancel:hover {
        background: #f3f4f6;
        color: #1f2937;
    }
    .admin-edit-form .btn-save {
        background-color: var(--primary-navy, #0f2027);
        border: none;
        color: white;
        font-weight: 500;
        font-size: 0.9rem;
        border-radius: 6px;
    }
    .admin-edit-form .btn-save:hover {
        background-color: #1a3644;
        color: white;
    }
    .user-info-box {
        background: #f9fafb;
        border-radius: 8px;
        border-left: 3px solid rgba(32, 201, 151, 0.5);
        padding: 1.25rem;
        font-size: 0.85rem;
        line-height: 1.6;
        color: #4b5563;
    }
</style>

<div class="admin-edit-form-container">
    <div class="card shadow-sm border" style="border-radius: 12px; border-color: #e5e7eb !important;">
        <div class="card-body p-4 p-md-5">
            <form method="post" class="admin-edit-form">
                <div class="row gx-5 gy-4">
                    <!-- User Information -->
                    <div class="col-lg-7">
                        <h6 class="section-title">User Information</h6>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                    <input asp-for="Input.Email" class="form-control" required />
                                </div>
                                <span asp-validation-for="Input.Email" class="text-danger small" style="font-size: 0.8rem;"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Full Name</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                                    <input asp-for="Input.FullName" class="form-control" required />
                                </div>
                                <span asp-validation-for="Input.FullName" class="text-danger small" style="font-size: 0.8rem;"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Phone Number</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                    <input asp-for="Input.Phone" class="form-control" />
                                </div>
                                <span asp-validation-for="Input.Phone" class="text-danger small" style="font-size: 0.8rem;"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label">New Password</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                    <input asp-for="Input.NewPassword" type="password" class="form-control" placeholder="Leave blank to keep current" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Role & Status -->
                    <div class="col-lg-5">
                        <h6 class="section-title">Role & Status</h6>
                        
                        <div class="mb-4">
                            <label class="form-label">User Role</label>
                            <select asp-for="Input.Role" class="form-select" required>
                                <option value="">-- Select Role --</option>
                                <option value="customer">Customer</option>
                                <option value="sale">Sale Staff</option>
                                <option value="operational">Operational Staff</option>
                                <option value="manager">Manager</option>
                                <option value="admin">Administrator</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom" style="border-color: #f3f4f6 !important;">
                            <label class="form-label mb-0" style="margin-bottom: 0 !important;">Account Status</label>
                            <div class="form-check form-switch mb-0">
                                <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" id="activeSwitch" />
                            </div>
                        </div>

                        <!-- User Info Box -->
                        <div class="user-info-box mt-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span>User ID:</span>
                                <strong class="text-dark">#@Model.UserId</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Created:</span>
                                <strong class="text-dark">@Model.CreatedAt.ToString("MMM dd, yyyy")</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Current Role:</span>
                                <span style="color: var(--primary-navy, #0f2027); font-weight: 600;">@Model.CurrentRole</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top" style="border-color: #f3f4f6 !important;">
                    <a asp-page="./Index" class="btn btn-outline-cancel px-4 py-2">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-save px-4 py-2">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
