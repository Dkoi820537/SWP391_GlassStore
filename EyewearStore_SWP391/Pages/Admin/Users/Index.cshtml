@page
@model EyewearStore_SWP391.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "User Management";
}

<style>
    .lenses-container { padding: 1.5rem 2rem; background: #f4f6f9; min-height: calc(100vh - 60px); font-family: 'Inter', sans-serif; }
    .controls-bar { background: white; border-radius: 12px; padding: 1rem 1.5rem; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 1.5rem; box-shadow: 0 4px 6px rgba(0,0,0,0.02); }
    .page-title { font-size: 1.5rem; font-weight: 700; color: #1a1a2e; margin: 0; display: flex; align-items: center; gap: 0.5rem; }
    .page-subtitle { font-size: 0.85rem; color: #8f9bb3; margin-top: 0.25rem; font-weight: normal; }
    .controls-right { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; width: 100%; justify-content: space-between; }
    .filter-inline-form { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; flex: 1; justify-content: flex-end; }
    .search-input-group { position: relative; min-width: 250px; flex-grow: 1; max-width: 400px; }
    .search-input-group .bi-search { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #8f9bb3; }
    .search-input-group .form-control { padding-left: 2.5rem; border-radius: 8px; border: 1px solid #e4e9f2; background: #f7f9fc; box-shadow: none; width: 100%; height: 38px; }
    .search-input-group .form-control:focus { border-color: #008080; background: white; }
    .filter-select { border-radius: 8px; border: 1px solid #e4e9f2; padding: 0.375rem 2rem 0.375rem 1rem; background-color: white; color: #1a1a2e; cursor: pointer; font-size: 0.9rem; height: 38px; }
    .btn-create { background: #008080; color: white; border: none; border-radius: 8px; padding: 0.5rem 1.25rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; transition: all 0.2s; text-decoration: none; height: 38px;}
    .btn-create:hover { background: #006666; color: white; transform: translateY(-1px); }
    .btn-filter-action { background: #1a1a2e; color: white; border-radius: 8px; border: none; padding: 0.375rem 1rem; font-weight: 500; transition: background 0.2s; height: 38px; }
    .btn-filter-action:hover { background: #2a2a4a; }
    .btn-reset { background: transparent; color: #8f9bb3; border: 1px solid #e4e9f2; border-radius: 8px; padding: 0.375rem 1rem; height: 38px; text-decoration: none; display: inline-flex; align-items: center; }
    .btn-reset:hover { background: #f7f9fc; color: #1a1a2e; }
    .table-card { background: white; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); overflow: hidden; }
    .modern-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .modern-table th { background: #1a1a2e; color: white; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; padding: 1.2rem 1.5rem; border: none; white-space: nowrap; }
    .modern-table td { padding: 1.2rem 1.5rem; vertical-align: middle; border-bottom: 1px solid #edf1f7; color: #222b45; font-size: 0.9rem; }
    .modern-table tbody tr { transition: background-color 0.2s; }
    .modern-table tbody tr:hover { background-color: #f7f9fc; }
    
    .avatar-circle { width: 36px; height: 36px; border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0; }
    .customer-cell { display: flex; align-items: center; gap: 0.75rem; }
    .customer-name { font-weight: 600; color: #1a1a2e; }

    .badge-modern { padding: 0.35rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; display: inline-block; }
    .badge-teal { background: rgba(0, 128, 128, 0.1); color: #008080; }
    .badge-navy { background: rgba(26, 26, 46, 0.1); color: #1a1a2e; }
    .badge-success { background: rgba(0, 200, 83, 0.1); color: #00c853; }
    .badge-warning { background: rgba(255, 170, 0, 0.1); color: #ffaa00; }
    .badge-danger { background: rgba(255, 61, 113, 0.1); color: #ff3d71; }
    .badge-info { background: rgba(13, 202, 240, 0.1); color: #0dcaf0; }
    .badge-primary { background: rgba(13, 110, 253, 0.1); color: #0d6efd; }
    .badge-neutral { background: #f7f9fc; color: #8f9bb3; border: 1px solid #e4e9f2; }
    
    .actions-cell { display: flex; gap: 0.5rem; justify-content: flex-end;}
    .btn-action { padding: 0.4rem 0.75rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.35rem; text-decoration: none; border: 1px solid transparent; transition: all 0.2s; cursor: pointer; }
    .btn-action-edit { background: #f7f9fc; color: #008080; border-color: #e4e9f2; }
    .btn-action-edit:hover { background: #008080; color: white; border-color: #008080; }
    .btn-action-delete { background: #f7f9fc; color: #ff3d71; border-color: #e4e9f2; }
    .btn-action-delete:hover { background: #ff3d71; color: white; border-color: #ff3d71; }

    .empty-state { text-align: center; padding: 4rem 2rem; color: #8f9bb3; }

    /* Stats Grid */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
    .stat-card { border-radius: 12px; padding: 1.25rem; color: white; display: flex; align-items: center; justify-content: space-between; overflow: hidden; position: relative; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    .stat-bg-1 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .stat-bg-2 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
    .stat-bg-3 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
    .stat-bg-4 { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
    .stat-info { z-index: 1; display: flex; flex-direction: column; }
    .stat-title { font-size: 0.85rem; opacity: 0.9; margin-bottom: 0.25rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; }
    .stat-value { font-size: 2rem; font-weight: 700; margin: 0; line-height: 1; margin-bottom: 0.25rem; }
    .stat-desc { font-size: 0.75rem; opacity: 0.8; margin: 0; }
    .stat-icon { font-size: 3rem; opacity: 0.2; z-index: 0; line-height: 1; margin-left: -1rem; }
</style>

<div class="lenses-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert" style="border-radius: 8px; background: rgba(0, 200, 83, 0.1); color: #00c853; border: none;">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert" style="border-radius: 8px; background: rgba(255, 61, 113, 0.1); color: #ff3d71; border: none;">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card stat-bg-1">
            <div class="stat-info">
                <span class="stat-title">Total Users</span>
                <span class="stat-value">@Model.Stats.TotalUsers</span>
                <span class="stat-desc">@Model.Stats.ActiveUsers active</span>
            </div>
            <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
        </div>
        <div class="stat-card stat-bg-2">
            <div class="stat-info">
                <span class="stat-title">Customers</span>
                <span class="stat-value">@Model.Stats.CustomerCount</span>
                <span class="stat-desc">Regular users</span>
            </div>
            <div class="stat-icon"><i class="bi bi-bag-fill"></i></div>
        </div>
        <div class="stat-card stat-bg-3">
            <div class="stat-info">
                <span class="stat-title">Staff Members</span>
                <span class="stat-value">@Model.Stats.StaffCount</span>
                <span class="stat-desc">All roles</span>
            </div>
            <div class="stat-icon"><i class="bi bi-person-badge-fill"></i></div>
        </div>
        <div class="stat-card stat-bg-4">
            <div class="stat-info">
                <span class="stat-title">Admins</span>
                <span class="stat-value">@Model.Stats.AdminCount</span>
                <span class="stat-desc">System admins</span>
            </div>
            <div class="stat-icon"><i class="bi bi-shield-lock-fill"></i></div>
        </div>
    </div>

    <!-- Controls Bar -->
    <div class="controls-bar">
        <div class="controls-right" style="flex-wrap: nowrap; align-items: flex-start; flex-direction: column;">
            <div class="d-flex w-100 justify-content-between align-items-center">
                <h1 class="page-title">
                    <i class="bi bi-people"></i> User Management
                </h1>
                <a asp-page="./Create" class="btn-create">
                    <i class="bi bi-person-plus"></i> Add New User
                </a>
            </div>
            
            <form method="get" class="filter-inline-form w-100 mt-2">
                <div class="search-input-group">
                    <i class="bi bi-search"></i>
                    <input type="text" class="form-control" name="Search" value="@Model.Search" placeholder="Search by name, email, or phone..." />
                </div>
                
                <select class="filter-select" name="RoleFilter">
                    <option value="">All Roles</option>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role" selected="@(Model.RoleFilter == role)">@role.ToUpper()</option>
                    }
                </select>
                
                <select class="filter-select" name="StatusFilter" style="width: 120px;">
                    <option value="">All Statuses</option>
                    <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
                    <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive</option>
                </select>

                <button type="submit" class="btn-filter-action">
                    Filter
                </button>
            </form>
        </div>
    </div>

    <div class="table-card">
        @if (!Model.Users.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox fs-1 mb-3 d-block"></i>
                <h4>No Users Found</h4>
                <p>Adjust your search/filters or add a new user.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>User</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end" style="padding-right: 2rem;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>
                                    <span class="fw-bold" style="color: #1a1a2e;">#@user.UserId</span>
                                </td>
                                <td>
                                    <div class="customer-cell">
                                        <div class="avatar-circle" style="background: @GetAvatarColor(user.Role);">
                                            @if (!string.IsNullOrEmpty(user.FullName))
                                            {
                                                @user.FullName.Substring(0, 1).ToUpper()
                                            }
                                            else
                                            {
                                                <span>?</span>
                                            }
                                        </div>
                                        <div>
                                            <div class="customer-name">@(user.FullName ?? "N/A")</div>
                                            @if (user.UserId == Model.CurrentUserId)
                                            {
                                                <small class="badge-modern badge-info" style="padding: 0.1rem 0.4rem; font-size: 0.65rem;">You</small>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <a href="mailto:@user.Email" style="color: #8f9bb3; text-decoration: none;">@user.Email</a>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(user.Phone))
                                    {
                                        <span style="color: #8f9bb3;">@user.Phone</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var roleColor = user.Role switch
                                        {
                                            "admin" => "badge-danger",
                                            "manager" => "badge-warning",
                                            "staff" => "badge-primary",
                                            "support" => "badge-info",
                                            "sale" or "sales" => "badge-success",
                                            _ => "badge-neutral"
                                        };
                                    }
                                    <span class="badge-modern @roleColor">@user.Role.ToUpper()</span>
                                </td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge-modern badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern badge-neutral">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div>@user.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    <div style="font-size: 0.75rem; color: #8f9bb3;">@user.CreatedAt.ToString("hh:mm tt")</div>
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <a asp-page="./Edit" asp-route-id="@user.UserId" class="btn-action btn-action-edit" title="Edit">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        @if (user.UserId != Model.CurrentUserId)
                                        {
                                            <button type="button" class="btn-action btn-action-delete" onclick="confirmDelete(@user.UserId, '@user.Email')" title="Delete">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div style="padding: 1rem 1.5rem; border-top: 1px solid #edf1f7; display: flex; justify-content: space-between; align-items: center;">
                <span style="color: #8f9bb3; font-size: 0.85rem;">Total @Model.Users.Count users matches your criteria.</span>
            </div>
        }
    </div>
</div>

<form id="deleteForm" method="post" asp-page-handler="Delete" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="userId" id="deleteUserId" />
</form>

@section Scripts {
    <script>
        function confirmDelete(userId, email) {
            if (confirm(`Are you sure you want to delete user: ${email}?\n\nThis action cannot be undone!`)) {
                document.getElementById('deleteUserId').value = userId;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}

@functions {
    string GetAvatarColor(string role)
    {
        return role switch
        {
            "admin" => "#ff3d71",
            "manager" => "#ffaa00",
            "staff" => "#0d6efd",
            "support" => "#0dcaf0",
            "sale" or "sales" => "#00c853",
            _ => "#8f9bb3"
        };
    }
}
