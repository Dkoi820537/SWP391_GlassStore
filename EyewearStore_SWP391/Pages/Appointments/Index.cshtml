@page
@model EyewearStore_SWP391.Pages.Admin.Appointments.IndexModel
@{
    ViewData["Title"] = "Appointments";
    Layout = "_Layout";
    int pageSize = EyewearStore_SWP391.Pages.Admin.Appointments.IndexModel.PageSize;
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f5f6fa;
            --surf: #fff;
            --surf2: #f0f2f8;
            --bdr: rgba(99,102,141,.13);
            --navy: #0d1b2a;
            --gold: #b8862a;
            --ok: #059669;
            --ok-bg: rgba(5,150,105,.08);
            --ok-bdr: rgba(5,150,105,.22);
            --warn: #d97706;
            --warn-bg: rgba(217,119,6,.09);
            --warn-bdr: rgba(217,119,6,.25);
            --info: #2563eb;
            --info-bg: rgba(37,99,235,.08);
            --info-bdr: rgba(37,99,235,.22);
            --err: #dc2626;
            --err-bg: rgba(220,38,38,.08);
            --err-bdr: rgba(220,38,38,.22);
            --muted: #8b8da8;
            --txt: #12132a;
            --txt2: #40415e;
            --sh: 0 2px 12px rgba(18,19,42,.07);
            --sh-md: 0 4px 20px rgba(18,19,42,.1)
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        body {
            background: var(--bg);
            color: var(--txt);
            font-family: 'Plus Jakarta Sans',sans-serif
        }

        .pg-wrap {
            max-width: 1340px;
            margin: 0 auto;
            padding: 32px 24px 80px
        }

        .pg-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
            flex-wrap: wrap;
            gap: 12px
        }

            .pg-hdr h1 {
                font-size: 1.75rem;
                font-weight: 800;
                margin: 0 0 4px;
                display: flex;
                align-items: center;
                gap: 10px
            }

        .h-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: linear-gradient(135deg,var(--info),#1d4ed8);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            box-shadow: 0 4px 14px rgba(37,99,235,.28)
        }

        .pg-hdr p {
            margin: 0;
            font-size: 13px;
            color: var(--muted)
        }

        .al {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 16px;
            font-size: 13px;
            font-weight: 600
        }

            .al.ok {
                background: var(--ok-bg);
                border: 1px solid var(--ok-bdr);
                color: var(--ok)
            }

        .stats {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 18px
        }

        .sc {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 16px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            box-shadow: var(--sh)
        }

        .sc-ico {
            width: 48px;
            height: 48px;
            border-radius: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0
        }

        .bl {
            background: var(--info-bg);
            color: var(--info)
        }

        .or {
            background: var(--warn-bg);
            color: var(--warn)
        }

        .gr {
            background: var(--ok-bg);
            color: var(--ok)
        }

        .re {
            background: var(--err-bg);
            color: var(--err)
        }

        .sc-lbl {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 3px
        }

        .sc-val {
            font-family: 'DM Mono',monospace;
            font-size: 26px;
            font-weight: 500;
            color: var(--txt)
        }

        .fbar {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 14px;
            padding: 14px 18px;
            margin-bottom: 16px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: flex-end;
            box-shadow: var(--sh)
        }

        .fg {
            display: flex;
            flex-direction: column;
            gap: 5px;
            flex: 1;
            min-width: 120px
        }

            .fg label {
                font-size: 10px;
                font-weight: 700;
                color: var(--muted);
                text-transform: uppercase;
                letter-spacing: 1px
            }

        .inp {
            background: var(--surf2);
            border: 1px solid var(--bdr);
            border-radius: 8px;
            padding: 9px 12px;
            color: var(--txt);
            font-family: 'Plus Jakarta Sans',sans-serif;
            font-size: 13px;
            width: 100%;
            transition: border .2s
        }

            .inp:focus {
                outline: none;
                border-color: var(--info);
                box-shadow: 0 0 0 3px rgba(37,99,235,.1)
            }

        .btn-f {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--info);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 9px 16px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Plus Jakarta Sans',sans-serif;
            transition: all .2s;
            white-space: nowrap
        }

            .btn-f:hover {
                background: #1d4ed8
            }

        .btn-r {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--surf2);
            color: var(--muted);
            border: 1px solid var(--bdr);
            border-radius: 8px;
            padding: 9px 14px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            font-family: 'Plus Jakarta Sans',sans-serif;
            white-space: nowrap;
            transition: all .2s
        }

            .btn-r:hover {
                color: var(--txt)
            }

        .tbl-wrap {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: var(--sh-md)
        }

        .tbl {
            width: 100%;
            border-collapse: collapse
        }

            .tbl thead tr {
                background: var(--surf2);
                border-bottom: 1px solid var(--bdr)
            }

            .tbl th {
                font-size: 10px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.4px;
                color: var(--muted);
                padding: 13px 14px;
                text-align: left;
                white-space: nowrap
            }

            .tbl td {
                padding: 13px 14px;
                border-bottom: 1px solid var(--bdr);
                vertical-align: middle
            }

            .tbl tbody tr:last-child td {
                border-bottom: none
            }

            .tbl tbody tr:hover {
                background: var(--surf2)
            }

        .cust {
            display: flex;
            align-items: center;
            gap: 10px
        }

        .av {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg,#e0e7ff,#c7d2fe);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            color: var(--info);
            flex-shrink: 0
        }

        .cn {
            font-size: 14px;
            font-weight: 700;
            color: var(--txt)
        }

        .cc {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px
        }

        .dt .dd {
            font-size: 14px;
            font-weight: 700;
            color: var(--txt)
        }

        .dt .tm {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            margin-top: 3px;
            font-size: 11px;
            font-weight: 600;
            color: #fff;
            background: var(--navy);
            border-radius: 5px;
            padding: 2px 8px
        }

        .dt .today {
            font-size: 10px;
            font-weight: 700;
            color: var(--ok);
            background: var(--ok-bg);
            border: 1px solid var(--ok-bdr);
            border-radius: 4px;
            padding: 1px 6px;
            margin-left: 5px
        }

        .bd {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700
        }

        .bd-Pending {
            background: var(--warn-bg);
            color: var(--warn);
            border: 1px solid var(--warn-bdr)
        }

        .bd-Confirmed {
            background: var(--ok-bg);
            color: var(--ok);
            border: 1px solid var(--ok-bdr)
        }

        .bd-Completed {
            background: rgba(15,23,42,.07);
            color: #0f172a;
            border: 1px solid rgba(15,23,42,.18)
        }

        .bd-Cancelled {
            background: var(--err-bg);
            color: var(--err);
            border: 1px solid var(--err-bdr)
        }

        .dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor
        }

        .acts {
            display: flex;
            gap: 5px;
            justify-content: flex-end
        }

        .ba {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            border-radius: 7px;
            border: 1px solid var(--bdr);
            background: var(--surf2);
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
            padding: 6px 10px;
            cursor: pointer;
            transition: all .2s;
            font-family: 'Plus Jakarta Sans',sans-serif;
            white-space: nowrap
        }

            .ba.conf:hover {
                border-color: var(--ok);
                color: var(--ok);
                background: var(--ok-bg)
            }

            .ba.done:hover {
                border-color: var(--info);
                color: var(--info);
                background: var(--info-bg)
            }

            .ba.canc:hover {
                border-color: var(--err);
                color: var(--err);
                background: var(--err-bg)
            }

        .empty {
            text-align: center;
            padding: 80px 24px
        }

            .empty .ei {
                font-size: 52px;
                opacity: .18;
                display: block;
                margin-bottom: 14px
            }

            .empty h3 {
                font-size: 18px;
                font-weight: 700;
                color: var(--txt);
                margin: 0 0 6px
            }

            .empty p {
                font-size: 13px;
                color: var(--muted);
                margin: 0
            }

        .pagi {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 18px;
            border-top: 1px solid var(--bdr);
            background: var(--surf2);
            flex-wrap: wrap;
            gap: 8px
        }

        .pi {
            font-size: 12px;
            color: var(--muted);
            font-weight: 500
        }

        .pp {
            display: flex;
            gap: 4px
        }

        .pg-btn {
            min-width: 33px;
            height: 33px;
            padding: 0 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--bdr);
            border-radius: 7px;
            background: var(--surf);
            color: var(--muted);
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s
        }

            .pg-btn:hover {
                border-color: var(--info);
                color: var(--info)
            }

            .pg-btn.active {
                background: var(--info);
                border-color: var(--info);
                color: #fff
            }

            .pg-btn.dis {
                opacity: .3;
                pointer-events: none
            }

        .mo {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 1000;
            display: none;
            align-items: center;
            justify-content: center
        }

            .mo.show {
                display: flex
            }

        .mb {
            background: #fff;
            border-radius: 16px;
            padding: 28px;
            max-width: 430px;
            width: 90%;
            box-shadow: 0 20px 60px rgba(0,0,0,.2)
        }

            .mb h3 {
                font-size: 1.1rem;
                font-weight: 800;
                color: var(--txt);
                margin: 0 0 8px
            }

            .mb p {
                font-size: 13.5px;
                color: var(--txt2);
                margin: 0 0 16px;
                line-height: 1.55
            }

        .mo-inp {
            width: 100%;
            background: #f5f6fa;
            border: 1.5px solid var(--bdr);
            border-radius: 9px;
            padding: 10px 13px;
            font-size: 13px;
            color: var(--txt);
            font-family: 'Plus Jakarta Sans',sans-serif;
            margin-bottom: 16px
        }

            .mo-inp:focus {
                outline: none;
                border-color: var(--err)
            }

        .mo-btns {
            display: flex;
            gap: 8px;
            justify-content: flex-end
        }

        .mo-keep {
            background: var(--surf2);
            color: var(--muted);
            border: 1px solid var(--bdr);
            border-radius: 8px;
            padding: 9px 18px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Plus Jakarta Sans',sans-serif
        }

        .mo-go {
            background: var(--err);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 9px 20px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Plus Jakarta Sans',sans-serif
        }

        @@media(max-width:900px) {
            .stats {
                grid-template-columns: 1fr 1fr
            }
        }

        @@media(max-width:580px) {
            .stats {
                grid-template-columns: 1fr
            }

            .pg-wrap {
                padding: 16px 12px 60px
            }
        }
    </style>
}

<div class="pg-wrap">
    <div class="pg-hdr">
        <div>
            <h1><span class="h-icon">📅</span> Eye Exam Appointments</h1>
            <p>Manage bookings — confirm, complete or cancel appointments, with automatic email notifications</p>
        </div>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="al ok"><i class="bi bi-check-circle-fill"></i> @ok</div>
    }

    <div class="stats">
        <div class="sc">
            <div class="sc-ico bl"><i class="bi bi-calendar2-week"></i></div>
            <div><div class="sc-lbl">Total</div><div class="sc-val">@Model.StatTotal</div></div>
        </div>
        <div class="sc">
            <div class="sc-ico or"><i class="bi bi-hourglass-split"></i></div>
            <div><div class="sc-lbl">Pending</div><div class="sc-val">@Model.StatPending</div></div>
        </div>
        <div class="sc">
            <div class="sc-ico gr"><i class="bi bi-check-circle-fill"></i></div>
            <div><div class="sc-lbl">Confirmed</div><div class="sc-val">@Model.StatConfirmed</div></div>
        </div>
        <div class="sc">
            <div class="sc-ico re"><i class="bi bi-calendar-day"></i></div>
            <div><div class="sc-lbl">Today</div><div class="sc-val">@Model.StatToday</div></div>
        </div>
    </div>

    <form method="get" class="fbar">
        <div class="fg" style="flex:2">
            <label>Search</label>
            <input class="inp" type="text" name="Search" value="@Model.Search" placeholder="Name, phone or email…" />
        </div>
        <div class="fg" style="max-width:155px">
            <label>Status</label>
            <select class="inp" name="StatusFilter">
                <option value="">All statuses</option>
                @foreach (var s in new[] { "Pending", "Confirmed", "Completed", "Cancelled" })
                {
                    if (Model.StatusFilter == s)
                    {
                        <option value="@s" selected="selected">@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            </select>
        </div>
        <div class="fg" style="max-width:165px">
            <label>Date</label>
            <input class="inp" type="date" name="DateFilter" value="@Model.DateFilter" />
        </div>
        <div style="display:flex;gap:7px;align-items:flex-end">
            <button type="submit" class="btn-f"><i class="bi bi-search"></i> Filter</button>
            <a asp-page="Index" class="btn-r"><i class="bi bi-x-lg"></i> Reset</a>
        </div>
    </form>

    <div class="tbl-wrap">
        @if (Model.Items.Any())
        {
            <div style="overflow-x:auto">
                <table class="tbl">
                    <thead>
                        <tr>
                            <th style="width:42px">ID</th>
                            <th>Customer</th>
                            <th>Date & Time</th>
                            <th>Status</th>
                            <th>Notes</th>
                            <th>Booked at</th>
                            <th style="text-align:right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model.Items)
                        {
                            bool isToday = a.AppointmentDate == DateOnly.FromDateTime(DateTime.Today);
                            var ini = string.Concat(a.FullName.Split(' ').Take(2)
                            .Select(w => char.ToUpper(w.FirstOrDefault())));
                            <tr>
                                <td style="color:var(--muted);font-family:'DM Mono',monospace;font-size:12px">#@a.AppointmentId</td>
                                <td>
                                    <div class="cust">
                                        <div class="av">@ini</div>
                                        <div>
                                            <div class="cn">@a.FullName</div>
                                            <div class="cc">
                                                📞 @a.Phone
                                                @if (!string.IsNullOrEmpty(a.Email))
                                                {
                                                    <span style="margin-left:5px">✉️ @a.Email</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="dt">
                                        <div class="dd">
                                            @a.AppointmentDate.ToString("dd/MM/yyyy")
                                            @if (isToday)
                                            {
                                                <span class="today">TODAY</span>
                                            }
                                        </div>
                                        <span class="tm">⏰ @a.TimeSlot</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="bd bd-@a.Status">
                                        <span class="dot"></span>@a.Status
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(a.Notes))
                                    {
                                        <span style="font-size:12px;color:var(--txt2);max-width:180px;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@a.Notes">@a.Notes</span>
                                    }
                                    else
                                    {

                                        <span style="color:var(--muted);font-size:12px">—</span>
                                    }
                                </td>
                                <td style="font-size:12px;color:var(--muted);font-family:'DM Mono',monospace;white-space:nowrap">
                                    @a.CreatedAt.ToString("dd/MM HH:mm")
                                </td>
                                <td>
                                    <div class="acts">
                                        @if (a.Status == "Pending")
                                        {
                                            <form method="post" asp-page-handler="Confirm"
                                                  asp-route-id="@a.AppointmentId" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="ba conf">
                                                    <i class="bi bi-check-lg"></i> Confirm
                                                </button>
                                            </form>
                                        }
                                        @if (a.Status == "Confirmed")
                                        {
                                            <form method="post" asp-page-handler="Complete"
                                                  asp-route-id="@a.AppointmentId" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="ba done">
                                                    <i class="bi bi-check2-all"></i> Done
                                                </button>
                                            </form>
                                        }
                                        @if (a.Status == "Pending" || a.Status == "Confirmed")
                                        {
                                            <button class="ba canc"
                                                    onclick="openCancel(@a.AppointmentId,'@Html.Raw(a.FullName.Replace("'", "\\'"))')">
                                                <i class="bi bi-x-lg"></i> Cancel
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                int from = (Model.Page - 1) * pageSize + 1;
                int to = Math.Min(Model.Page * pageSize, Model.TotalCount);
                <div class="pagi">
                    <div class="pi">Showing <strong>@from–@to</strong> of <strong>@Model.TotalCount</strong></div>
                    <div class="pp">
                        <a class="pg-btn @(!Model.HasPrev ? "dis" : "")"
                           asp-page="Index" asp-route-Page="@(Model.Page - 1)"
                           asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                        @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                        {
                            <a class="pg-btn @(i == Model.Page ? "active" : "")"
                               asp-page="Index" asp-route-Page="@i"
                               asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter">@i</a>
                        }
                        <a class="pg-btn @(!Model.HasNext ? "dis" : "")"
                           asp-page="Index" asp-route-Page="@(Model.Page + 1)"
                           asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty">
                <span class="ei">📅</span>
                <h3>No appointments found</h3>
                <p>@(string.IsNullOrWhiteSpace(Model.Search) ? "No eye exam appointments have been booked yet." : "No results match your search.")</p>
            </div>
        }
    </div>
</div>

<!-- CANCEL MODAL -->
<div class="mo" id="moCancel">
    <div class="mb">
        <h3>Cancel Appointment</h3>
        <p>
            Cancel appointment for <strong id="moName"></strong>?<br>
            A cancellation email will be sent automatically.
        </p>
        <textarea class="mo-inp" id="moReason" rows="3"
                  placeholder="Reason for cancellation (optional, shown in email)…"></textarea>
        <div class="mo-btns">
            <button class="mo-keep" onclick="closeCancel()">Keep</button>
            <form method="post" asp-page-handler="Cancel" id="cancelForm" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" id="moId" name="id" />
                <input type="hidden" id="moReasonH" name="reason" />
                <button type="button" class="mo-go" onclick="submitCancel()">Yes, Cancel</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCancel(id, name) {
            document.getElementById('moId').value = id;
            document.getElementById('moName').textContent = name;
            document.getElementById('moReason').value = '';
            document.getElementById('moCancel').classList.add('show');
        }
        function closeCancel() {
            document.getElementById('moCancel').classList.remove('show');
        }
        function submitCancel() {
            document.getElementById('moReasonH').value = document.getElementById('moReason').value;
            document.getElementById('cancelForm').submit();
        }
        document.getElementById('moCancel').addEventListener('click', function(e){
            if (e.target === this) closeCancel();
        });
    </script>
}
