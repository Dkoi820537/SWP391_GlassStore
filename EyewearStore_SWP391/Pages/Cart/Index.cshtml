@page
@model EyewearStore_SWP391.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Shopping Cart";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" />
}

<div class="container py-5">
    @Html.AntiForgeryToken()

    <!-- Page Header -->
    <div class="mb-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb" style="background: transparent; padding: 0; margin-bottom: 1rem;">
                <li class="breadcrumb-item"><a asp-page="/Index" style="color: var(--primary-gold); text-decoration: none;">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page" style="color: var(--dark-gray);">Shopping Cart</li>
            </ol>
        </nav>
        <h1 style="font-family: var(--font-secondary); color: var(--primary-navy); font-size: 2.5rem; margin-bottom: 0.5rem;">
            🛒 Your Shopping Cart
        </h1>
        <p style="color: var(--secondary-warm-gray); font-size: 1.1rem;">
            Review your items and proceed to checkout
        </p>
    </div>

    <!-- Alert Messages (Optional fallback but we do AJAX mainly) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 8px; border-left: 4px solid var(--success);">
            <strong>✓</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 8px; border-left: 4px solid var(--error);">
            <strong>⚠</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Cart == null || !Model.Cart.CartItems.Any())
    {
        <!-- Empty Cart State -->
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card" style="border: none; border-radius: 16px; box-shadow: var(--shadow-lg); text-align: center; padding: 5rem 3rem; background: linear-gradient(135deg, var(--white) 0%, var(--secondary-cream) 100%);">
                    <div style="margin-bottom: 2rem;">
                        <svg width="140" height="140" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color: var(--primary-navy); opacity: 0.15; margin: 0 auto; display: block;">
                            <circle cx="9" cy="21" r="1" />
                            <circle cx="20" cy="21" r="1" />
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                        </svg>
                    </div>

                    <h2 style="color: var(--primary-navy); margin-bottom: 1.25rem; font-family: var(--font-secondary); font-size: 2.25rem; font-weight: 700;">
                        Your Cart is Empty
                    </h2>

                    <p style="color: var(--secondary-warm-gray); margin-bottom: 3rem; font-size: 1.15rem; max-width: 550px; margin-left: auto; margin-right: auto; line-height: 1.7;">
                        Looks like you haven't added any items yet. Discover our premium collection of eyewear and find your perfect pair!
                    </p>

                    <div>
                        <a asp-page="/Index" class="btn btn-primary" style="padding: 1.25rem 3.5rem; font-size: 1.2rem; background: linear-gradient(135deg, var(--primary-navy) 0%, var(--primary-navy-light) 100%); color: white !important; border: none; border-radius: 10px; text-transform: none; font-weight: 600; box-shadow: 0 4px 16px rgba(26, 35, 50, 0.25); text-decoration: none;">
                            Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="cart-container">
            <!-- Left Column: Cart Items -->
            <div class="cart-items-column">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 style="color: var(--primary-navy); margin: 0; font-weight: 600;" id="cart-items-count">
                        @Model.Cart.CartItems.Sum(x => x.Quantity) items
                    </h5>
                    <form method="post" asp-page-handler="Clear" onsubmit="return confirm('Are you sure you want to clear your entire cart?');" style="margin: 0;">
                        <button type="submit" class="btn btn-sm" style="color: var(--error); border: 1px solid var(--error); background: transparent; padding: 0.5rem 1rem; border-radius: 6px;">
                            🗑️ Clear Cart
                        </button>
                    </form>
                </div>

                @foreach (var item in Model.Cart.CartItems)
                {
                    // ── Tính toán dữ liệu như cũ ──────────────────────────────────────
                    var lensId = EyewearStore_SWP391.Services.CartService.ExtractLensProductId(item.TempPrescriptionJson);
                    bool isServiceOrder = lensId.HasValue;

                    var baseUnit = item.Product != null ? item.Product.Price : 0m;
                    EyewearStore_SWP391.Models.Product? lensProduct = null;
                    if (isServiceOrder && lensId.HasValue && Model.LensProducts.TryGetValue(lensId.Value, out var lp))
                    {
                        lensProduct = lp;
                        baseUnit += lp.Price;
                    }
                    if (item.Service != null) { baseUnit += item.Service.Price; }

                    var lineBase = baseUnit * item.Quantity;
                    var linePrescription = item.PrescriptionFee * item.Quantity;
                    var lineTotal = lineBase + linePrescription;

                    var productName = item.Product != null ? item.Product.Name :
                                      item.Service != null ? item.Service.Name : "Product";

                    var imgUrl = item.Product?.ProductImages?.OrderByDescending(x => x.IsPrimary).FirstOrDefault()?.ImageUrl;
                    
                    <div class="cart-item-card" data-item-id="@item.CartItemId">
                        
                        <div class="cart-item-image-wrap">
                            @if (!string.IsNullOrEmpty(imgUrl))
                            {
                                <img src="@imgUrl" alt="@productName" />
                            }
                            else
                            {
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--dark-gray)">
                                    <rect x="2" y="8" width="8" height="6" rx="2" />
                                    <rect x="14" y="8" width="8" height="6" rx="2" />
                                    <path d="M10 11h4" />
                                </svg>
                            }
                        </div>

                        <div class="cart-item-details">
                            <div>
                                <h5 class="cart-item-title" style="margin-bottom: 0.25rem; font-weight: 600;">
                                    @if (!isServiceOrder && item.Product != null)
                                    {
                                        if (item.Product.ProductType?.ToLower() == "lens")
                                        {
                                            <a asp-page="/Products/LensDetails" asp-route-id="@item.ProductId" class="cart-product-link text-decoration-none">
                                                @productName
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-page="/Products/FrameDetails" asp-route-id="@item.ProductId" class="cart-product-link text-decoration-none">
                                                @productName
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <span class="cart-product-static">@productName</span>
                                    }
                                </h5>
                                
                                @if (isServiceOrder || item.Service != null || lensProduct != null)
                                {
                                    <div class="cart-item-variants">
                                        @if (item.Product != null)
                                        {
                                            <div class="variant-line"><strong>Frame:</strong> @item.Product.Name (+@item.Product.Price.ToString("N0") VND)</div>
                                        }
                                        @if (lensProduct != null)
                                        {
                                            <div class="variant-line"><strong>Lens:</strong> @lensProduct.Name (+@lensProduct.Price.ToString("N0") VND)</div>
                                        }
                                        @if (item.Service != null)
                                        {
                                            <div class="variant-line"><strong>Service:</strong> @item.Service.Name (+@item.Service.Price.ToString("N0") VND)</div>
                                        }
                                    </div>
                                }
                            </div>
                            
                            <div class="d-flex align-items-center justify-content-between mt-2">
                                <div class="quantity-stepper">
                                    <button type="button" class="qty-btn" data-action="decrement" data-item-id="@item.CartItemId">−</button>
                                    <input type="number" class="qty-input" data-item-id="@item.CartItemId" value="@item.Quantity" min="1" />
                                    <button type="button" class="qty-btn" data-action="increment" data-item-id="@item.CartItemId">+</button>
                                </div>
                                <button type="button" class="btn-remove" data-action="remove" data-item-id="@item.CartItemId">
                                    🗑️ <span style="font-size: 0.9rem">Remove</span>
                                </button>
                            </div>
                        </div>

                        <div class="d-flex flex-column justify-content-between align-items-end" style="min-width: 120px;">
                            <div style="text-align: right;">
                                <div style="font-size: 0.85rem; color: var(--secondary-warm-gray);">Price</div>
                                <div style="font-weight: 600; color: var(--primary-navy);">@baseUnit.ToString("N0") VND</div>
                                @if (item.PrescriptionFee > 0)
                                {
                                    <div style="font-size: 0.8rem; color: var(--primary-gold);">+ @item.PrescriptionFee.ToString("N0") (Rx)</div>
                                }
                            </div>
                            <div style="text-align: right; margin-top: auto;">
                                <div style="font-size: 0.85rem; color: var(--secondary-warm-gray);">Total</div>
                                <div class="item-total" data-item-id="@item.CartItemId" style="font-weight: 700; font-size: 1.1rem; color: var(--primary-navy);">
                                    @lineTotal.ToString("N0") VND
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="mt-2">
                    <a asp-page="/Index" style="color: var(--primary-gold); text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem;">
                        ← Continue Shopping
                    </a>
                </div>
            </div>

            <!-- Right Column: Order Summary -->
            <div class="cart-summary-column">
                <div class="card" style="border: none; border-radius: 12px; box-shadow: var(--shadow-lg);">
                    <div style="background: linear-gradient(135deg, var(--primary-navy) 0%, var(--primary-navy-light) 100%); padding: 1.5rem; border-radius: 12px 12px 0 0;">
                        <h4 style="color: white; margin: 0; font-family: var(--font-secondary); font-size: 1.5rem;">
                            Order Summary
                        </h4>
                    </div>

                    <div style="padding: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--medium-gray);">
                            <span style="color: var(--dark-gray); font-weight: 500;">Subtotal</span>
                            <span style="color: var(--primary-navy); font-weight: 600;" id="summary-subtotal">
                                @Model.SubtotalBase.ToString("N0") VND
                            </span>
                        </div>

                        <div id="summary-prescription-row" style="display: @(Model.PrescriptionFeesTotal > 0 ? "flex" : "none"); justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid var(--medium-gray);">
                            <span style="color: var(--dark-gray); font-weight: 500;">Prescription fees</span>
                            <span style="color: var(--primary-navy); font-weight: 600;" id="summary-prescription-val">
                                @Model.PrescriptionFeesTotal.ToString("N0") VND
                            </span>
                        </div>

                        <div style="display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 2px solid var(--medium-gray);">
                            <span style="color: var(--dark-gray); font-weight: 500;">Shipping</span>
                            <span style="color: var(--success); font-weight: 600;">FREE 🎉</span>
                        </div>

                        <div style="display: flex; justify-content: space-between; padding: 1.5rem 0;">
                            <span style="color: var(--primary-navy); font-weight: 700; font-size: 1.25rem; font-family: var(--font-secondary);">
                                Total
                            </span>
                            <span style="color: var(--primary-gold); font-weight: 700; font-size: 1.5rem; font-family: var(--font-secondary);" id="summary-total">
                                @Model.Total.ToString("N0") VND
                            </span>
                        </div>

                        <a asp-page="/Checkout/Index" class="btn btn-primary w-100" style="padding: 1rem; font-size: 1.1rem; font-weight: 600; border-radius: 8px; background: linear-gradient(135deg, var(--primary-gold) 0%, var(--primary-gold-light) 100%); border: none; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 1rem;">
                            Proceed to Checkout 🛍️
                        </a>

                        <div style="text-align: center; padding: 1rem; background: var(--light-gray); border-radius: 8px;">
                            <div style="margin-bottom: 0.5rem;">🔒</div>
                            <small style="color: var(--secondary-warm-gray); font-weight: 500; display: block;">Secure Checkout</small>
                            <small style="color: var(--secondary-warm-gray);">Your payment info is safe with us</small>
                        </div>
                    </div>
                </div>

                <div class="card mt-3" style="border: none; border-radius: 12px; background: linear-gradient(135deg, var(--secondary-cream) 0%, var(--light-gray) 100%); padding: 1.5rem;">
                    <h6 style="color: var(--primary-navy); font-weight: 600; margin-bottom: 1rem;">💡 Shopping Benefits</h6>
                    <ul style="list-style: none; padding: 0; margin: 0; color: var(--dark-gray);">
                        <li style="padding: 0.5rem 0; display: flex; align-items: start; gap: 0.5rem;"><span>✓</span><span>Free shipping on all orders</span></li>
                        <li style="padding: 0.5rem 0; display: flex; align-items: start; gap: 0.5rem;"><span>✓</span><span>30-day hassle-free returns</span></li>
                        <li style="padding: 0.5rem 0; display: flex; align-items: start; gap: 0.5rem;"><span>✓</span><span>1-year warranty included</span></li>
                        <li style="padding: 0.5rem 0; display: flex; align-items: start; gap: 0.5rem;"><span>✓</span><span>Expert customer support</span></li>
                    </ul>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/cart.js"></script>
}
