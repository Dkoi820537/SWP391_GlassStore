@page
@model EyewearStore_SWP391.Pages.Checkout.IndexModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Cart/Index">Cart</a></li>
            <li class="breadcrumb-item active" aria-current="page">Checkout</li>
        </ol>
    </nav>

    <h1 style="font-family: var(--font-secondary); color: var(--primary-navy); font-size: 2.5rem; margin-bottom: 0.5rem;">
        Checkout
    </h1>
    <p style="color: var(--secondary-warm-gray); font-size: 1.1rem; margin-bottom: 2rem;">
        Review your order and complete payment
    </p>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 8px; border-left: 4px solid var(--error);">
            <strong>Warning:</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="post" asp-page-handler="Checkout">
        <div class="row g-4">
            <div class="col-lg-8">

                <div class="card mb-4" style="border: none; border-radius: 12px; box-shadow: var(--shadow-md); overflow: hidden;">
                    <div style="background: linear-gradient(135deg, var(--primary-navy) 0%, var(--primary-navy-light) 100%); padding: 1.25rem 1.5rem;">
                        <h4 style="color: white; margin: 0; font-size: 1.25rem;">Shipping Address</h4>
                    </div>
                    <div style="padding: 1.5rem;">
                        @if (Model.Addresses.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label" style="font-weight: 600; color: var(--primary-navy);">
                                    Select a saved address
                                </label>
                                <select name="SelectedAddressId" class="form-select" id="addressSelect"
                                        style="border: 2px solid var(--medium-gray); border-radius: 8px; padding: 0.75rem;"
                                        onchange="toggleNewAddressForm()">
                                    @foreach (var addr in Model.Addresses)
                                    {
                                        if (addr.AddressId == Model.SelectedAddressId)
                                        {
                                            <option value="@addr.AddressId" selected>
                                                @addr.ReceiverName — @addr.Phone — @addr.AddressLine@(addr.IsDefault ? " (Default)" : "")
                                            </option>
                                        }
                                        else
                                        {
                                            <option value="@addr.AddressId">
                                                @addr.ReceiverName — @addr.Phone — @addr.AddressLine@(addr.IsDefault ? " (Default)" : "")
                                            </option>
                                        }
                                    }
                                    <option value="0">+ Add a new address...</option>
                                </select>
                            </div>

                            <div id="newAddressForm" style="display: none;">
                                <hr style="border-color: var(--medium-gray);" />
                                <h6 style="color: var(--primary-navy); font-weight: 600; margin-bottom: 1rem;">Add New Address</h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Receiver Name</label>
                                        <input type="text" name="NewReceiverName" class="form-control"
                                               placeholder="Full name" style="border-radius: 8px;" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Phone</label>
                                        <input type="text" name="NewPhone" class="form-control"
                                               placeholder="Phone number" style="border-radius: 8px;" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">Address</label>
                                        <textarea name="NewAddressLine" class="form-control" rows="2"
                                              placeholder="Street, district, city..." style="border-radius: 8px;"></textarea>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <input type="hidden" name="SelectedAddressId" value="0" />
                            <div class="alert alert-info" style="border-radius: 8px;">
                                You don't have any saved addresses. Please add one below.
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" style="font-weight: 600;">Receiver Name *</label>
                                    <input type="text" name="NewReceiverName" class="form-control" required
                                           placeholder="Full name" style="border-radius: 8px;" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" style="font-weight: 600;">Phone *</label>
                                    <input type="text" name="NewPhone" class="form-control" required
                                           placeholder="Phone number" style="border-radius: 8px;" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label" style="font-weight: 600;">Address *</label>
                                    <textarea name="NewAddressLine" class="form-control" rows="2" required
                                          placeholder="Street, district, city..." style="border-radius: 8px;"></textarea>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="card" style="border: none; border-radius: 12px; box-shadow: var(--shadow-md); overflow: hidden;">
                    <div style="background: var(--light-gray); padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--medium-gray);">
                        <h4 style="color: var(--primary-navy); margin: 0; font-size: 1.25rem;">
                            Order Items (@Model.Cart!.CartItems.Count)
                        </h4>
                    </div>

                    @foreach (var it in Model.Cart.CartItems)
                    {
                        var lensId = EyewearStore_SWP391.Services.CartService.ExtractLensProductId(it.TempPrescriptionJson);
                        decimal lensPrice = 0m;
                        string? lensName = null;

                        if (lensId.HasValue && Model.LensProducts.TryGetValue(lensId.Value, out var lens))
                        {
                            lensPrice = lens.Price;
                            lensName = lens.Name;
                        }

                        var framePrice = it.Product != null ? it.Product.Price : 0m;
                        var servicePrice = it.Service != null ? it.Service.Price : 0m;

                        var baseUnit = framePrice + servicePrice + lensPrice;
                        var lineBase = baseUnit * it.Quantity;
                        var linePrescription = it.PrescriptionFee * it.Quantity;
                        var lineTotal = lineBase + linePrescription;

                        var productName = it.Product?.Name ?? it.Service?.Name ?? "Product";
                        if (!string.IsNullOrEmpty(lensName))
                        {
                            productName += $" + {lensName}";
                        }

                        var productType = it.Product?.ProductType ?? "Service";

                        <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--medium-gray);">
                            <div class="row align-items-center g-3">
                                <div class="col-auto">
                                    <div style="width: 70px; height: 70px; background: linear-gradient(135deg, var(--light-gray), var(--secondary-cream)); border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 2px solid var(--medium-gray); overflow: hidden;">
                                        @{
                                            var imgUrl = it.Product?.ProductImages?.OrderByDescending(x => x.IsPrimary).FirstOrDefault()?.ImageUrl;
                                        }
                                        @if (!string.IsNullOrEmpty(imgUrl))
                                        {
                                            <img src="@imgUrl" alt="@productName" style="width: 100%; height: 100%; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            @if (productType == "frame" || productType == "bundle")
                                            {
                                                <span style="font-size: 1.5rem;">👓</span>
                                            }
                                            else if (productType == "lens")
                                            {
                                                <span style="font-size: 1.5rem;">🔍</span>
                                            }
                                            else
                                            {
                                                <span style="font-size: 1.5rem;">📦</span>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="col">
                                    <h6 style="color: var(--primary-navy); margin-bottom: 0.25rem; font-weight: 600;">@productName</h6>
                                    <span class="badge" style="background: var(--primary-gold); color: white; padding: 0.25rem 0.6rem; font-size: 0.75rem; border-radius: 4px;">@productType</span>

                                    @if (!string.IsNullOrEmpty(lensName))
                                    {
                                        <span class="badge" style="background: var(--secondary-teal); color: white; padding: 0.25rem 0.6rem; font-size: 0.75rem; border-radius: 4px;">+ @lensName</span>
                                    }

                                    @if (it.Service != null)
                                    {
                                        <span class="badge" style="background: var(--secondary-teal); color: white; padding: 0.25rem 0.6rem; font-size: 0.75rem; border-radius: 4px;">+ @it.Service.Name</span>
                                    }
                                </div>
                                <div class="col-auto text-end">
                                    <div style="font-size: 0.85rem; color: var(--secondary-warm-gray);">
                                        <div>@(baseUnit.ToString("N0")) VND <span class="text-muted">× @it.Quantity</span></div>
                                        @if (it.PrescriptionFee > 0)
                                        {
                                            <div>+ @it.PrescriptionFee.ToString("N0") VND <span class="text-muted">(prescription)</span></div>
                                        }
                                    </div>
                                    <div style="font-size: 1.15rem; font-weight: 700; color: var(--primary-navy);">@lineTotal.ToString("N0") VND</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card" style="border: none; border-radius: 12px; box-shadow: var(--shadow-lg); position: sticky; top: 100px;">
                    <div style="background: linear-gradient(135deg, var(--primary-navy), var(--primary-navy-light)); padding: 1.5rem; border-radius: 12px 12px 0 0;">
                        <h4 style="color: white; margin: 0; font-family: var(--font-secondary); font-size: 1.5rem;">
                            Order Summary
                        </h4>
                    </div>
                    <div style="padding: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--medium-gray);">
                            <span style="color: var(--dark-gray);">Items</span>
                            <span style="color: var(--primary-navy); font-weight: 600;">@Model.Cart.CartItems.Count</span>
                        </div>

                        <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--medium-gray);">
                            <span style="color: var(--dark-gray);">Subtotal</span>
                            <span style="color: var(--primary-navy); font-weight: 600;">@Model.SubtotalBase.ToString("N0") VND</span>
                        </div>

                        @if (Model.PrescriptionFeesTotal > 0)
                        {
                            <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--medium-gray);">
                                <span style="color: var(--dark-gray);">Prescription fees</span>
                                <span style="color: var(--primary-navy); font-weight: 600;">@Model.PrescriptionFeesTotal.ToString("N0") VND</span>
                            </div>
                        }

                        <div style="display: flex; justify-content: space-between; align-items: flex-start; padding: 0.75rem 0; border-bottom: 2px solid var(--medium-gray);">
                            <div>
                                <span style="color: var(--dark-gray);">Shipping</span>
                                @if (!Model.IsFreeShipping)
                                {
                                    var remaining = Model.FreeShippingThreshold - Model.SubtotalBase;
                                    <div style="font-size: 0.75rem; color: var(--secondary-warm-gray); margin-top: 2px;">
                                        Spend @remaining.ToString("N0") VND more for free shipping
                                    </div>
                                }
                            </div>

                            @if (Model.IsFreeShipping)
                            {
                                <span style="color: var(--success); font-weight: 600;">FREE</span>
                            }
                            else
                            {
                                <span style="color: var(--primary-navy); font-weight: 600;">@Model.ShippingFee.ToString("N0") VND</span>
                            }
                        </div>

                        <div style="display: flex; justify-content: space-between; padding: 1.25rem 0;" id="grandTotalRow">
                            <span style="color: var(--primary-navy); font-weight: 700; font-size: 1.25rem;">Total</span>
                            <span style="color: var(--primary-gold); font-weight: 700; font-size: 1.5rem; font-family: var(--font-secondary);">
                                @Model.Total.ToString("N0") VND
                            </span>
                        </div>

                        <div id="codDepositBreakdown" style="display: none;">
                            <div style="background: linear-gradient(135deg, rgba(245,158,11,0.06), rgba(217,119,6,0.10)); border: 1.5px solid rgba(217,119,6,0.25); border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 1rem;">
                                <div style="font-weight: 700; color: #92400e; font-size: 0.85rem; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">
                                    COD Payment Breakdown
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 0.4rem 0; border-bottom: 1px dashed rgba(217,119,6,0.2);">
                                    <span style="color: #78350f; font-size: 0.9rem;">Deposit (50%)</span>
                                    <span style="color: #92400e; font-weight: 700; font-size: 0.95rem;" id="depositAmount">
                                        @(Math.Ceiling(Model.Total * 0.5m).ToString("N0")) VND
                                    </span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 0.4rem 0;">
                                    <span style="color: #78350f; font-size: 0.9rem;">Balance on Delivery</span>
                                    <span style="color: #b45309; font-weight: 600; font-size: 0.95rem;" id="balanceAmount">
                                        @((Model.Total - Math.Ceiling(Model.Total * 0.5m)).ToString("N0")) VND
                                    </span>
                                </div>
                            </div>
                            <div style="display: flex; align-items: flex-start; gap: 0.5rem; background: rgba(37,99,235,0.05); border-radius: 8px; padding: 0.75rem; margin-bottom: 0.75rem;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" style="flex-shrink:0; margin-top:2px;">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="16" x2="12" y2="12"></line>
                                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                                </svg>
                                <small style="color: #1e40af; font-size: 0.8rem; line-height: 1.4;">
                                    You will pay <strong>50% now</strong> via secure online payment. The remaining balance will be collected in cash when your order is delivered.
                                </small>
                            </div>
                        </div>

                        <input type="hidden" name="PaymentMethod" id="paymentMethodInput" value="Stripe" />
                        <div style="margin-bottom: 1.25rem;">
                            <div style="font-weight: 700; color: var(--primary-navy); font-size: 1rem; margin-bottom: 0.75rem; text-align: center;">
                                Select Payment Method
                            </div>
                            <div style="display: flex; gap: 0.5rem;" id="paymentMethodButtons">
                                <button type="button" class="payment-method-btn selected" id="btnStripe" onclick="selectPaymentMethod('Stripe')">
                                    Card Payment
                                    <span class="payment-btn-sub">Full amount via Stripe</span>
                                </button>
                                <button type="button" class="payment-method-btn" id="btnCOD" onclick="selectPaymentMethod('COD')">
                                    Cash on Delivery
                                    <span class="payment-btn-sub">50% deposit + pay on delivery</span>
                                </button>
                            </div>
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-100"
                                id="checkoutBtn"
                                style="padding: 1rem;
                                       font-size: 1.1rem;
                                       font-weight: 600;
                                       border-radius: 8px;
                                       background: linear-gradient(135deg, #635bff 0%, #7c3aed 100%);
                                       border: none;
                                       letter-spacing: 0.5px;
                                       margin-bottom: 1rem;
                                       transition: all 0.3s ease;">
                            PAY WITH STRIPE
                        </button>

                        <div id="paymentInfoMessage" style="text-align: center; padding: 1rem; background: var(--light-gray); border-radius: 8px;">
                            <small style="color: var(--secondary-warm-gray); font-weight: 500;">
                                Secure payment powered by Stripe
                            </small><br />
                            <small style="color: var(--secondary-warm-gray);">
                                Your payment information is encrypted and secure
                            </small>
                        </div>
                    </div>
                </div>

                <div class="mt-3 text-center">
                    <a asp-page="/Cart/Index" style="color: var(--primary-gold); text-decoration: none; font-weight: 600;">
                        ← Back to Cart
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .breadcrumb {
        background: transparent;
        padding: 0;
        margin-bottom: 1rem;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
        color: var(--secondary-warm-gray);
    }

    .breadcrumb-item a {
        color: var(--primary-gold);
        text-decoration: none;
    }

    .breadcrumb-item.active {
        color: var(--dark-gray);
    }

    #checkoutBtn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(99, 91, 255, 0.35);
    }

    .payment-method-btn {
        flex: 1;
        padding: 0.85rem 0.75rem;
        border: 2px solid var(--medium-gray);
        border-radius: 8px;
        background: white;
        color: var(--dark-gray);
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.25s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.2rem;
    }

        .payment-method-btn:hover {
            border-color: var(--primary-navy);
            background: var(--light-gray);
        }

        .payment-method-btn.selected {
            border-color: #635bff;
            background: rgba(99, 91, 255, 0.08);
            color: #635bff;
            box-shadow: 0 0 0 1px #635bff;
        }

        .payment-method-btn.selected-cod {
            border-color: #d97706;
            background: rgba(245, 158, 11, 0.08);
            color: #d97706;
            box-shadow: 0 0 0 1px #d97706;
        }

    .payment-btn-sub {
        font-size: 0.78rem;
        font-weight: 400;
        opacity: 0.7;
    }

    @@media (max-width: 576px) {
        #paymentMethodButtons {
            flex-direction: column !important;
        }
    }
</style>

<script>
    function toggleNewAddressForm() {
        var select = document.getElementById('addressSelect');
        var form = document.getElementById('newAddressForm');
        if (select && form)
            form.style.display = select.value === '0' ? 'block' : 'none';
    }

    function selectPaymentMethod(method) {
        document.getElementById('paymentMethodInput').value = method;

        var btnStripe = document.getElementById('btnStripe');
        var btnCOD = document.getElementById('btnCOD');
        var checkoutBtn = document.getElementById('checkoutBtn');
        var infoMsg = document.getElementById('paymentInfoMessage');
        var codBreakdown = document.getElementById('codDepositBreakdown');

        btnStripe.classList.remove('selected', 'selected-cod');
        btnCOD.classList.remove('selected', 'selected-cod');

        if (method === 'Stripe') {
            btnStripe.classList.add('selected');
            checkoutBtn.textContent = 'PAY WITH STRIPE';
            checkoutBtn.style.background = 'linear-gradient(135deg, #635bff 0%, #7c3aed 100%)';
            codBreakdown.style.display = 'none';
            infoMsg.innerHTML =
                '<small style="color: var(--secondary-warm-gray); font-weight: 500;">Secure payment powered by Stripe</small><br />' +
                '<small style="color: var(--secondary-warm-gray);">Your payment information is encrypted and secure</small>';
        } else {
            btnCOD.classList.add('selected-cod');
            var depositAmt = document.getElementById('depositAmount').textContent.trim();
            checkoutBtn.textContent = 'PAY ' + depositAmt + ' DEPOSIT';
            checkoutBtn.style.background = 'linear-gradient(135deg, #f59e0b 0%, #d97706 100%)';
            codBreakdown.style.display = 'block';
            infoMsg.innerHTML =
                '<small style="color: var(--secondary-warm-gray); font-weight: 500;">50% Deposit via Stripe + Cash on Delivery</small><br />' +
                '<small style="color: var(--secondary-warm-gray);">Pay the deposit now, the rest when your order arrives</small>';
        }
    }

    window.addEventListener('DOMContentLoaded', function () {
        toggleNewAddressForm();
    });
</script>