@page
@model EyewearStore_SWP391.Pages.Checkout.SuccessModel
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <!-- Success Header -->
            @if (Model.IsCodOrder)
            {
                <div class="success-header" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                    <div class="success-icon-wrap">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    </div>
                    <h1 class="success-title">Deposit Payment Successful!</h1>
                    <p class="success-subtitle">Your 50% deposit has been received. The remaining balance will be collected upon delivery.</p>
                </div>
            }
            else
            {
                <div class="success-header" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                    <div class="success-icon-wrap">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    </div>
                    <h1 class="success-title">Payment Successful!</h1>
                    <p class="success-subtitle">Thank you for your order</p>
                </div>
            }

            @if (Model.Orders.Any())
            {
                <!-- Split-Order Notice -->
                @if (Model.IsSplitOrder)
                {
                    <div class="split-notice">
                        <div class="split-notice-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
                        </div>
                        <div>
                            <strong>Your order has been split into @Model.Orders.Count separate orders</strong>
                            <div class="split-notice-desc">Standard products and custom orders are fulfilled separately for faster delivery.</div>
                        </div>
                    </div>
                }

                <!-- COD Deposit Breakdown Banner -->
                @if (Model.IsCodOrder)
                {
                    <div style="background: linear-gradient(135deg, rgba(245,158,11,0.06), rgba(217,119,6,0.10)); border: 1.5px solid rgba(217,119,6,0.25); border-radius: 12px; padding: 1.25rem 1.5rem; margin: 1.5rem 0;">
                        <div style="font-weight: 800; color: #92400e; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 1rem;">
                            Payment Summary — Cash on Delivery
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px dashed rgba(217,119,6,0.2);">
                            <span style="color: #78350f;">Grand Total</span>
                            <span style="color: #92400e; font-weight: 700; font-size: 1.1rem;">@Model.GrandTotal.ToString("N0") VND</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px dashed rgba(217,119,6,0.2);">
                            <span style="color: #059669; font-weight: 600;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5" style="vertical-align: -2px; margin-right: 4px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                Deposit Paid (50%)
                            </span>
                            <span style="color: #059669; font-weight: 700; font-size: 1.1rem;">@Model.TotalDepositPaid.ToString("N0") VND</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0;">
                            <span style="color: #b45309; font-weight: 600;">Balance Due on Delivery</span>
                            <span style="color: #b45309; font-weight: 700; font-size: 1.1rem;">@Model.TotalPendingBalance.ToString("N0") VND</span>
                        </div>
                    </div>
                }

                <!-- Grand Total Banner (non-COD or split) -->
                @if (Model.IsSplitOrder && !Model.IsCodOrder)
                {
                    <div class="grand-total-banner">
                        <span>Total Charged</span>
                        <span class="grand-total-amount">@Model.GrandTotal.ToString("N0") VND</span>
                    </div>
                }

                <!-- Order Cards -->
                @foreach (var order in Model.Orders)
                {
                    var isCustom = order.OrderType == "Custom";
                    var accentColor = isCustom ? "#7c3aed" : "#10b981";
                    var gradientBg = isCustom
                        ? "linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%)"
                        : "linear-gradient(135deg, #10b981 0%, #059669 100%)";
                    var lightBg = isCustom ? "rgba(124, 58, 237, 0.06)" : "rgba(16, 185, 129, 0.06)";
                    var badgeText = isCustom ? "Custom Order" : "Standard Order";
                    var statusMessage = isCustom
                        ? "Your custom lenses are in production! Estimated 5–7 business days."
                        : "Your standard items will ship within 1–2 business days!";
                    var statusIcon = isCustom ? "⚙" : "📦";

                    <div class="order-card" style="border-left: 4px solid @accentColor;">
                        <!-- Order Card Header -->
                        <div class="order-card-header" style="background: @lightBg;">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <span class="order-type-badge" style="background: @accentColor;">@badgeText</span>
                                <span class="order-number">Order #@order.OrderId</span>
                            </div>
                            <div class="order-card-total" style="color: @accentColor;">
                                @order.TotalAmount.ToString("N0") VND
                            </div>
                        </div>

                        <!-- Status Message -->
                        <div class="order-status-msg" style="background: @lightBg; border-left: 3px solid @accentColor;">
                            <span class="status-icon">@statusIcon</span>
                            <span>@statusMessage</span>
                        </div>

                        <!-- Order Info Row -->
                        <div class="order-info-row">
                            <div>
                                <div class="info-label">Status</div>
                                <span class="badge" style="background: @accentColor; color: white; padding: 0.35rem 0.75rem; font-size: 0.8rem; border-radius: 6px;">
                                    @order.Status
                                </span>
                            </div>
                            <div>
                                <div class="info-label">Payment</div>
                                <div class="info-value">@(order.PaymentMethod == "COD" ? "COD (50% Deposit)" : order.PaymentMethod ?? "—")</div>
                            </div>
                            <div>
                                <div class="info-label">Items</div>
                                <div class="info-value">@order.OrderItems.Count</div>
                            </div>
                            @if (order.PaymentMethod == "COD")
                            {
                                <div>
                                    <div class="info-label">Deposit Paid</div>
                                    <div class="info-value" style="color: #059669;">@order.DepositAmount.ToString("N0") VND</div>
                                </div>
                                <div>
                                    <div class="info-label">Balance Due</div>
                                    <div class="info-value" style="color: #b45309;">@order.PendingBalance.ToString("N0") VND</div>
                                </div>
                            }
                        </div>

                        <!-- Order Items -->
                        @if (order.OrderItems.Any())
                        {
                            <div class="order-items-section">
                                @foreach (var oi in order.OrderItems)
                                {
                                    <div class="order-item-row">
                                        <div class="order-item-thumb">
                                            @{
                                                var imgUrl = oi.Product?.ProductImages?
                                                    .OrderByDescending(x => x.IsPrimary)
                                                    .FirstOrDefault()?.ImageUrl;
                                            }
                                            @if (!string.IsNullOrEmpty(imgUrl))
                                            {
                                                <img src="@imgUrl" alt="@(oi.Product?.Name ?? "Product")" />
                                            }
                                            else
                                            {
                                                <span style="font-size: 1.3rem;">@(isCustom ? "⚙" : "👓")</span>
                                            }
                                        </div>
                                        <div class="order-item-info">
                                            <div class="order-item-name">@(oi.Product?.Name ?? "Product")</div>
                                            <small class="order-item-qty">Qty: @oi.Quantity × @oi.UnitPrice.ToString("N0") VND</small>
                                        </div>
                                        <div class="order-item-price">
                                            @((oi.UnitPrice * oi.Quantity).ToString("N0")) VND
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Action Buttons -->
                <div class="mt-4 d-flex gap-3 justify-content-center flex-wrap">
                    <a asp-page="/Orders/Index"
                       class="btn action-btn-primary">
                        View Order History
                    </a>
                    <a asp-page="/Index"
                       class="btn action-btn-outline">
                        Continue Shopping
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .success-header {
        text-align: center;
        padding: 3rem 2rem;
        border-radius: 16px 16px 0 0;
        margin-bottom: 0;
    }
    .success-icon-wrap {
        width: 80px; height: 80px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.5rem;
        animation: scaleIn 0.5s ease;
    }
    .success-title {
        color: white;
        font-family: var(--font-secondary);
        font-size: 2.25rem;
        margin-bottom: 0.5rem;
    }
    .success-subtitle {
        color: rgba(255,255,255,0.85);
        font-size: 1.1rem;
        margin: 0;
    }

    /* Split Notice */
    .split-notice {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 10px;
        padding: 1.25rem 1.5rem;
        margin: 1.5rem 0 1rem;
        color: #1e40af;
    }
    .split-notice-icon {
        flex-shrink: 0;
        margin-top: 2px;
    }
    .split-notice-desc {
        font-size: 0.9rem;
        opacity: 0.8;
        margin-top: 0.25rem;
    }

    /* Grand Total */
    .grand-total-banner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--light-gray, #f8f9fa);
        border-radius: 10px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
        color: var(--primary-navy, #1e293b);
        font-size: 1.1rem;
    }
    .grand-total-amount {
        font-size: 1.5rem;
        font-family: var(--font-secondary);
        color: var(--primary-gold, #d97706);
    }

    /* Order Card */
    .order-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        overflow: hidden;
        margin-bottom: 1.5rem;
        animation: fadeUp 0.5s ease;
    }
    .order-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 1.5rem;
        flex-wrap: wrap;
        gap: 0.75rem;
    }
    .order-type-badge {
        color: white;
        padding: 0.3rem 0.8rem;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.3px;
    }
    .order-number {
        font-weight: 700;
        color: var(--primary-navy, #1e293b);
        font-size: 1.15rem;
    }
    .order-card-total {
        font-weight: 700;
        font-size: 1.35rem;
        font-family: var(--font-secondary);
    }

    /* Status Message */
    .order-status-msg {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.5rem;
        margin: 0 1.5rem 1rem;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--dark-gray, #374151);
    }
    .status-icon { font-size: 1.25rem; }

    /* Order Info Row */
    .order-info-row {
        display: flex;
        gap: 2rem;
        padding: 0 1.5rem 1rem;
        flex-wrap: wrap;
    }
    .info-label {
        font-size: 0.8rem;
        color: var(--secondary-warm-gray, #9ca3af);
        margin-bottom: 0.25rem;
    }
    .info-value {
        font-weight: 600;
        color: var(--primary-navy, #1e293b);
    }

    /* Order Items */
    .order-items-section {
        border-top: 1px solid var(--medium-gray, #e5e7eb);
        padding: 0.5rem 0;
    }
    .order-item-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.85rem 1.5rem;
        border-bottom: 1px solid var(--medium-gray, #f3f4f6);
    }
    .order-item-row:last-child { border-bottom: none; }

    .order-item-thumb {
        width: 50px; height: 50px;
        border-radius: 8px;
        background: var(--light-gray, #f3f4f6);
        display: flex; align-items: center; justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        border: 1px solid var(--medium-gray, #e5e7eb);
    }
    .order-item-thumb img {
        width: 100%; height: 100%; object-fit: cover;
    }
    .order-item-info { flex: 1; }
    .order-item-name {
        font-weight: 600;
        color: var(--primary-navy, #1e293b);
        font-size: 0.95rem;
    }
    .order-item-qty {
        color: var(--secondary-warm-gray, #9ca3af);
    }
    .order-item-price {
        font-weight: 700;
        color: var(--primary-navy, #1e293b);
        white-space: nowrap;
    }

    /* Action Buttons */
    .action-btn-primary {
        padding: 0.75rem 2rem;
        background: linear-gradient(135deg, var(--primary-navy, #1e3a5f), var(--primary-navy-light, #2563eb));
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }
    .action-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(30, 58, 95, 0.3);
        color: white;
    }
    .action-btn-outline {
        padding: 0.75rem 2rem;
        background: white;
        color: var(--primary-navy, #1e3a5f);
        border: 2px solid var(--primary-navy, #1e3a5f);
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }
    .action-btn-outline:hover {
        background: var(--primary-navy, #1e3a5f);
        color: white;
    }

    /* Animations */
    @@keyframes scaleIn {
        from { transform: scale(0); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
    @@keyframes fadeUp {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    @@media (max-width: 576px) {
        .order-card-header { flex-direction: column; align-items: flex-start; }
        .order-info-row { gap: 1rem; }
        .grand-total-banner { flex-direction: column; gap: 0.5rem; text-align: center; }
    }
</style>
