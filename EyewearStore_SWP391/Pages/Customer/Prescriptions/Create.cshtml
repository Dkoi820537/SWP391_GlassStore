@page
@model EyewearStore_SWP391.Pages.Customer.Prescriptions.CreateModel
@{
    ViewData["Title"] = "Add Prescription";
}

<style>
    .prescription-form .form-control {
        border-color: #e2e8f0;
        font-size: 0.9rem;
        padding: 0.4rem 0.75rem;
    }
    .prescription-form .form-control:focus {
        border-color: var(--accent-teal, #20c997);
        box-shadow: 0 0 0 0.2rem rgba(32, 201, 151, 0.25);
    }
    .prescription-form .form-label {
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        font-weight: 600;
        color: #64748b;
        margin-bottom: 0.25rem;
    }
    .section-header {
        color: var(--primary-navy, #1e293b);
        border-left: 3px solid var(--accent-teal, #20c997);
        padding-left: 0.75rem;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 1rem;
    }
    .main-section-header {
        color: var(--primary-navy, #1e293b);
        border-left: 3px solid var(--accent-teal, #20c997);
        padding-left: 0.75rem;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 1.5rem;
    }
</style>

<div class="container-fluid py-3 prescription-form">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb" style="font-size: 0.85rem;">
            <li class="breadcrumb-item"><a asp-page="/Index" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="./Index" class="text-decoration-none">My Prescriptions</a></li>
            <li class="breadcrumb-item active">Add New</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h4 mb-1" style="color: var(--primary-navy, #1e293b); font-weight: 600;">
                Add New Prescription
            </h1>
            <p class="text-muted mb-0" style="font-size: 0.85rem;">
                Enter your eyeglass prescription details
            </p>
        </div>
        <a asp-page="./Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>

    <!-- Validation Summary -->
    @if (!ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show py-2 px-3 mb-3" style="font-size: 0.9rem;">
            <div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle me-2"></i>Please fix the following errors:</div>
            <ul class="mb-0 ps-3">
                @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert" style="padding: 0.75rem 1rem;"></button>
        </div>
    }

    <form method="post">
        <div class="row g-3">
            <!-- Form -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="card-body" style="padding: 1.5rem;">
                        <h5 class="main-section-header">Prescription Details</h5>

                        <!-- Profile Name -->
                        <div class="mb-3">
                            <label class="form-label">
                                Profile Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Input.ProfileName" class="form-control" placeholder="e.g., Reading Glasses, Distance Vision" required />
                            <span asp-validation-for="Input.ProfileName" class="text-danger small"></span>
                            <div class="text-muted mt-1" style="font-size: 0.75rem;">Give this prescription a memorable name</div>
                        </div>

                        <!-- Right Eye (OD) -->
                        <div class="mb-4 pt-2 border-top">
                            <h6 class="section-header">Right Eye (OD)</h6>
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="form-label">SPH (Sphere)</label>
                                    <input asp-for="Input.RightSph" type="number" step="0.25" class="form-control" placeholder="-20.00 to +20.00" />
                                    <span asp-validation-for="Input.RightSph" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">CYL (Cylinder)</label>
                                    <input asp-for="Input.RightCyl" type="number" step="0.25" class="form-control" placeholder="-6.00 to +6.00" />
                                    <span asp-validation-for="Input.RightCyl" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">AXIS</label>
                                    <input asp-for="Input.RightAxis" type="number" class="form-control" placeholder="0 to 180" />
                                    <span asp-validation-for="Input.RightAxis" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Left Eye (OS) -->
                        <div class="mb-4 pt-3 border-top" style="border-top-style: dashed !important; border-top-color: #e2e8f0 !important;">
                            <h6 class="section-header">Left Eye (OS)</h6>
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="form-label">SPH (Sphere)</label>
                                    <input asp-for="Input.LeftSph" type="number" step="0.25" class="form-control" placeholder="-20.00 to +20.00" />
                                    <span asp-validation-for="Input.LeftSph" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">CYL (Cylinder)</label>
                                    <input asp-for="Input.LeftCyl" type="number" step="0.25" class="form-control" placeholder="-6.00 to +6.00" />
                                    <span asp-validation-for="Input.LeftCyl" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">AXIS</label>
                                    <input asp-for="Input.LeftAxis" type="number" class="form-control" placeholder="0 to 180" />
                                    <span asp-validation-for="Input.LeftAxis" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Active Status -->
                        <div class="mb-0 pt-3 border-top">
                            <div class="form-check form-switch mb-1">
                                <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" id="activeSwitch" checked />
                                <label class="form-check-label fw-semibold" for="activeSwitch" style="font-size: 0.85rem; color: var(--primary-navy);">
                                    Set as Active Prescription
                                </label>
                            </div>
                            <div class="text-muted" style="font-size: 0.75rem;">Active prescriptions can be used when ordering eyewear</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Info Panel -->
            <div class="col-lg-4">
                <div class="card shadow-sm mb-3 border-0" style="border-left: 3px solid var(--accent-teal, #20c997) !important;">
                    <div class="card-body" style="padding: 1.25rem;">
                        <h6 style="color: var(--primary-navy, #1e293b); font-size: 0.9rem; margin-bottom: 0.75rem; font-weight: 600;">
                            Prescription Guide
                        </h6>
                        <div style="font-size: 0.8rem; color: var(--secondary-warm-gray, #64748b);">
                            <p class="mb-1"><strong>SPH:</strong> Nearsightedness (-) or farsightedness (+)</p>
                            <p class="mb-1"><strong>CYL:</strong> Astigmatism</p>
                            <p class="mb-2"><strong>AXIS:</strong> Astigmatism direction</p>
                            <div class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-lightbulb me-1"></i>Values are found on your eye doctor's prescription. Valid ranges: SPH (±20.00), CYL (±6.00), AXIS (0-180). All are optional.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
            <a asp-page="./Index" class="btn btn-sm btn-light px-4" style="font-weight: 500;">
                Cancel
            </a>
            <button type="submit" class="btn btn-sm btn-primary px-4 shadow-sm" style="font-weight: 500; background-color: var(--primary-navy, #1e293b); border-color: var(--primary-navy, #1e293b);">
                Save Prescription
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
