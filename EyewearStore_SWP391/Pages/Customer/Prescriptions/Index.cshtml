
@page
@model EyewearStore_SWP391.Pages.Customer.Prescriptions.IndexModel
@{
    ViewData["Title"] = "My Prescriptions";
}

<div class="container py-4 py-lg-5 px-3 px-md-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item active">My Prescriptions</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
        <div>
            <h2 class="mb-1" style="color: var(--primary-navy); font-weight: 600;">My Prescriptions</h2>
            <p class="text-muted mb-0 small">Manage your eyeglass prescription profiles.</p>
        </div>

        <div class="d-flex gap-3 align-items-center">
            <form method="get" class="d-flex align-items-center" style="gap:0.5rem;">
                <label class="small text-muted mb-0">Show</label>
                <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()" style="width:90px; border-radius: 4px;">
                    @* Avoid C# inside option attributes — use if/else to output selected option *@
                    @foreach (var opt in Model.PageSizeOptions)
                    {
                        if (Model.PageSize == opt)
                        {
                            <option value="@opt" selected="selected">@opt</option>
                        }
                        else
                        {
                            <option value="@opt">@opt</option>
                        }
                    }
                </select>

                <input type="hidden" name="pageNumber" value="1" />
            </form>

            <a asp-page="./Create" class="btn btn-sm px-3" style="background-color: var(--primary-navy, #0D1B34); border-color: var(--primary-navy, #0D1B34); color: white; border-radius: 6px;">
                <i class="bi bi-plus-lg me-1"></i> ADD NEW
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- If no prescriptions -->
    @if (!Model.Prescriptions.Any())
    {
        <div class="d-flex justify-content-center align-items-center py-5">
            <div class="bg-white text-center w-100" style="max-width: 42rem; padding: 3rem; border: 1px solid rgba(0,0,0,0.05); box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08); border-radius: 1rem !important;">
                
                <!-- Illustration Placeholder (Modern Teal Glasses) -->
                <div class="mb-4 d-flex justify-content-center">
                    <div class="position-relative d-flex align-items-center justify-content-center" style="width: 16rem; height: 10rem;">
                        <!-- Stylized SVG Illustration of Glasses -->
                        <svg viewBox="0 0 200 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-100 h-100" style="opacity: 0.8;">
                            <path d="M40 50C40 38.9543 48.9543 30 60 30H75C86.0457 30 95 38.9543 95 50V60C95 71.0457 86.0457 80 75 80H60C48.9543 80 40 71.0457 40 60V50Z" stroke="var(--primary-teal, #008080)" stroke-width="4"/>
                            <path d="M105 50C105 38.9543 113.954 30 125 30H140C151.046 30 160 38.9543 160 50V60C160 71.0457 151.046 80 140 80H125C113.954 80 105 71.0457 105 60V50Z" stroke="var(--primary-teal, #008080)" stroke-width="4"/>
                            <path d="M95 45C95 45 97.5 40 100 40C102.5 40 105 45 105 45" stroke="var(--primary-teal, #008080)" stroke-width="4" stroke-linecap="round"/>
                            <path d="M40 50L15 45C10 44 10 35 15 35" stroke="var(--primary-teal, #008080)" stroke-width="3" stroke-dasharray="4 4" opacity="0.4"/>
                            <path d="M160 50L185 45C190 44 190 35 185 35" stroke="var(--primary-teal, #008080)" stroke-width="3" stroke-dasharray="4 4" opacity="0.4"/>
                            <!-- Decorative Blobs -->
                            <circle cx="35" cy="75" r="8" fill="var(--primary-teal, #008080)" fill-opacity="0.1"/>
                            <rect x="155" y="15" width="12" height="12" transform="rotate(15 155 15)" fill="var(--primary-teal, #008080)" fill-opacity="0.1"/>
                        </svg>
                    </div>
                </div>
                
                <h2 class="fw-bold mb-3" style="color: var(--primary-navy, #0D1B34); font-size: 1.75rem; font-family: 'Playfair Display', serif;">No Prescription Profiles Yet</h2>
                
                <p class="text-muted mb-4 mx-auto" style="font-size: 1.125rem; max-width: 24rem; line-height: 1.6;">
                    Add your first prescription to get started with personalized eyewear.
                </p>

                <div class="mb-3">
                    <a asp-page="./Create" class="btn text-white fw-semibold px-4 py-3 rounded-pill" style="background-color: var(--primary-navy, #0D1B34); font-size: 0.875rem; letter-spacing: 0.05em; text-transform: uppercase;">
                        <span class="fs-5 me-1 lh-1" style="vertical-align: middle;">+</span> ADD YOUR FIRST PRESCRIPTION
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Grid of prescriptions -->
        <div class="row g-3">
            @foreach (var prescription in Model.Prescriptions)
            {
                <div class="col-sm-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm" style="border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; border-top: 4px solid @(prescription.IsActive ? "var(--primary-teal, #008080)" : "var(--secondary-warm-gray, #9e9e9e)"); @(!prescription.IsActive ? "opacity: 0.75;" : "")">
                        
                        <!-- Card Header -->
                        <div class="px-3 pt-3 pb-2 d-flex justify-content-between align-items-center border-bottom border-light">
                            <h6 class="mb-0" style="color: var(--primary-navy); font-weight: 600; font-size: 1rem;">
                                @(prescription.ProfileName ?? "Prescription")
                            </h6>
                            @if (prescription.IsActive)
                            {
                                <span class="badge rounded-pill d-flex align-items-center" style="background-color: rgba(0, 128, 128, 0.1); color: var(--primary-teal, #008080); font-weight: 500; font-size: 0.75rem; padding: 0.4em 0.8em;">
                                    <i class="bi bi-check-circle-fill me-1"></i> Active
                                </span>
                            }
                        </div>

                        <div class="card-body p-0">
                            <!-- Right Eye -->
                            <div class="d-flex justify-content-between px-3 py-2 bg-light border-bottom" style="font-size: 0.65rem; color: #6c757d; font-weight: 500;">
                                <div style="flex: 2;">RIGHT EYE (OD)</div>
                                <div style="flex: 1; text-align: center;">SPH</div>
                                <div style="flex: 1; text-align: center;">CYL</div>
                                <div style="flex: 1; text-align: center;">AXIS</div>
                            </div>
                            <div class="d-flex justify-content-between px-3 py-2 border-bottom" style="font-size: 0.85rem;">
                                <div style="flex: 2; color: #6c757d;">OD</div>
                                <div style="flex: 1; text-align: center;">@(prescription.RightSph?.ToString("+0.00;-0.00;0.00") ?? "—")</div>
                                <div style="flex: 1; text-align: center;">@(prescription.RightCyl?.ToString("+0.00;-0.00;0.00") ?? "—")</div>
                                <div style="flex: 1; text-align: center;">@(prescription.RightAxis?.ToString() ?? "—")</div>
                            </div>

                            <!-- Left Eye -->
                            <div class="d-flex justify-content-between px-3 py-2 bg-light border-bottom" style="font-size: 0.65rem; color: #6c757d; font-weight: 500;">
                                <div style="flex: 2;">LEFT EYE (OS)</div>
                                <div style="flex: 1; text-align: center;">SPH</div>
                                <div style="flex: 1; text-align: center;">CYL</div>
                                <div style="flex: 1; text-align: center;">AXIS</div>
                            </div>
                            <div class="d-flex justify-content-between px-3 py-2 border-bottom" style="font-size: 0.85rem;">
                                <div style="flex: 2; color: #6c757d;">OS</div>
                                <div style="flex: 1; text-align: center;">@(prescription.LeftSph?.ToString("+0.00;-0.00;0.00") ?? "—")</div>
                                <div style="flex: 1; text-align: center;">@(prescription.LeftCyl?.ToString("+0.00;-0.00;0.00") ?? "—")</div>
                                <div style="flex: 1; text-align: center;">@(prescription.LeftAxis?.ToString() ?? "—")</div>
                            </div>
                        </div>

                        <!-- Actions and Date -->
                        <div class="px-3 pb-3 pt-3 d-flex justify-content-between align-items-center">
                            <div class="text-muted" style="font-size: 0.85rem;">
                                @prescription.CreatedAt.ToString("MMM dd, yyyy")
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <a asp-page="./Edit" asp-route-id="@prescription.PrescriptionId" class="btn btn-sm d-flex justify-content-center align-items-center" style="background-color: var(--primary-navy, #0D1B34); color: white; border-radius: 6px; width: 32px; height: 32px; font-size: 0.9rem;">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <a href="javascript:void(0)" onclick="confirmDelete(@prescription.PrescriptionId)" class="btn btn-sm d-flex justify-content-center align-items-center" style="background-color: #ffe4e6; color: #f43f5e; border-radius: 6px; width: 32px; height: 32px; font-size: 0.9rem;">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination / Footer -->
        <div class="d-flex justify-content-between align-items-center mt-4">
            <div class="text-muted small">
                Showing
                <strong>@(((Model.PageNumber - 1) * Model.PageSize) + 1)</strong>
                -
                <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalItems))</strong>
                of <strong>@Model.TotalItems</strong> prescriptions
            </div>

            <nav aria-label="Page navigation">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize">Previous</a>
                    </li>

                    @{
                        // show a compact window of pages (max 7 buttons)
                        var maxButtons = 7;
                        var start = Math.Max(1, Model.PageNumber - 3);
                        var end = Math.Min(Model.TotalPages, start + maxButtons - 1);
                        if (end - start + 1 < maxButtons)
                        {
                            start = Math.Max(1, end - maxButtons + 1);
                        }
                    }

                    @if (start > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-route-pageNumber="1" asp-route-pageSize="@Model.PageSize">1</a>
                        </li>
                        @if (start > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }

                    @for (int i = start; i <= end; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-route-pageNumber="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                        </li>
                    }

                    @if (end < Model.TotalPages)
                    {
                        if (end < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="@Model.PageSize">@Model.TotalPages</a>
                        </li>
                    }

                    <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Delete Form -->
<form id="deleteForm" method="post" asp-page-handler="Delete" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="prescriptionId" id="deletePrescriptionId" />
    <input type="hidden" name="pageNumber" value="@Model.PageNumber" />
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Are you sure you want to delete this prescription profile?\n\nThis action cannot be undone!')) {
                document.getElementById('deletePrescriptionId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}