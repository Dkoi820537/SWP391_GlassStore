
@page
@model EyewearStore_SWP391.Pages.Customer.Prescriptions.IndexModel
@{
    ViewData["Title"] = "My Prescriptions";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item active">My Prescriptions</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
        <div>
            <h2 class="mb-1" style="color: var(--primary-navy); font-weight: 600;">My Prescriptions</h2>
            <p class="text-muted mb-0 small">Manage your eyeglass prescription profiles.</p>
        </div>

        <div class="d-flex gap-3 align-items-center">
            <form method="get" class="d-flex align-items-center" style="gap:0.5rem;">
                <label class="small text-muted mb-0">Show</label>
                <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()" style="width:90px; border-radius: 4px;">
                    @* Avoid C# inside option attributes — use if/else to output selected option *@
                    @foreach (var opt in Model.PageSizeOptions)
                    {
                        if (Model.PageSize == opt)
                        {
                            <option value="@opt" selected="selected">@opt</option>
                        }
                        else
                        {
                            <option value="@opt">@opt</option>
                        }
                    }
                </select>

                <input type="hidden" name="pageNumber" value="1" />
            </form>

            <a asp-page="./Create" class="btn btn-sm btn-primary px-3" style="background-color: var(--primary-teal, #008080); border-color: var(--primary-teal, #008080);">
                <i class="bi bi-plus-lg me-1"></i> Add New
            </a>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- If no prescriptions -->
    @if (!Model.Prescriptions.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <div style="font-size: 4rem; opacity: 0.2; margin-bottom: 1rem;">👓</div>
                <h4 style="color: var(--primary-navy);">No Prescription Profiles Yet</h4>
                <p style="color: var(--secondary-warm-gray);">
                    Add your first prescription to get started with personalized eyewear.
                </p>
                <a asp-page="./Create" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-circle me-2"></i>Add Your First Prescription
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Grid of prescriptions -->
        <div class="row g-3">
            @foreach (var prescription in Model.Prescriptions)
            {
                <div class="col-sm-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm" style="border: 1px solid rgba(0,0,0,0.08); border-radius: 8px; border-left: 4px solid @(prescription.IsActive ? "var(--primary-teal, #008080)" : "var(--secondary-warm-gray, #9e9e9e)"); @(!prescription.IsActive ? "opacity: 0.75;" : "")">
                        
                        <!-- Card Header -->
                        <div class="px-3 pt-3 pb-2 d-flex justify-content-between align-items-center border-bottom border-light">
                            <h6 class="mb-0" style="color: var(--primary-navy); font-weight: 600; font-size: 0.95rem;">
                                @(prescription.ProfileName ?? "Prescription")
                            </h6>
                            @if (prescription.IsActive)
                            {
                                <span class="badge rounded-pill" style="background-color: rgba(0, 128, 128, 0.1); color: var(--primary-teal, #008080); font-weight: 500; font-size: 0.7rem;">Active</span>
                            }
                        </div>

                        <div class="card-body p-3">
                            <!-- Right Eye -->
                            <div>
                                <div class="text-muted mb-1" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">Right Eye (OD)</div>
                                <div class="d-flex gap-2 my-1">
                                    <div class="flex-fill bg-light rounded text-center py-1 px-0">
                                        <div class="text-muted" style="font-size: 0.6rem;">SPH</div>
                                        <div style="font-size: 0.85rem; font-weight: 500;">@(prescription.RightSph?.ToString("0.00") ?? "—")</div>
                                    </div>
                                    <div class="flex-fill bg-light rounded text-center py-1 px-0">
                                        <div class="text-muted" style="font-size: 0.6rem;">CYL</div>
                                        <div style="font-size: 0.85rem; font-weight: 500;">@(prescription.RightCyl?.ToString("0.00") ?? "—")</div>
                                    </div>
                                    <div class="flex-fill bg-light rounded text-center py-1 px-0">
                                        <div class="text-muted" style="font-size: 0.6rem;">AXIS</div>
                                        <div style="font-size: 0.85rem; font-weight: 500;">@(prescription.RightAxis?.ToString() ?? "—")</div>
                                    </div>
                                </div>
                            </div>

                            <hr class="text-secondary my-2" style="opacity: 0.15;">

                            <!-- Left Eye -->
                            <div>
                                <div class="text-muted mb-1" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">Left Eye (OS)</div>
                                <div class="d-flex gap-2 my-1">
                                    <div class="flex-fill bg-light rounded text-center py-1 px-0">
                                        <div class="text-muted" style="font-size: 0.6rem;">SPH</div>
                                        <div style="font-size: 0.85rem; font-weight: 500;">@(prescription.LeftSph?.ToString("0.00") ?? "—")</div>
                                    </div>
                                    <div class="flex-fill bg-light rounded text-center py-1 px-0">
                                        <div class="text-muted" style="font-size: 0.6rem;">CYL</div>
                                        <div style="font-size: 0.85rem; font-weight: 500;">@(prescription.LeftCyl?.ToString("0.00") ?? "—")</div>
                                    </div>
                                    <div class="flex-fill bg-light rounded text-center py-1 px-0">
                                        <div class="text-muted" style="font-size: 0.6rem;">AXIS</div>
                                        <div style="font-size: 0.85rem; font-weight: 500;">@(prescription.LeftAxis?.ToString() ?? "—")</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions and Date -->
                        <div class="px-3 pb-3 pt-0 d-flex justify-content-between align-items-center">
                            <div class="text-muted" style="font-size: 0.75rem;">
                                @prescription.CreatedAt.ToString("MMM dd, yyyy")
                            </div>
                            <div class="d-flex align-items-center gap-2" style="font-size: 0.8rem; font-weight: 500;">
                                <a asp-page="./Edit" asp-route-id="@prescription.PrescriptionId" class="text-decoration-none" style="color: var(--primary-teal, #008080);">Edit</a>
                                <span class="text-muted" style="opacity:0.5;">|</span>
                                <a href="javascript:void(0)" onclick="confirmDelete(@prescription.PrescriptionId)" class="text-decoration-none text-danger" style="display: inline;">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination / Footer -->
        <div class="d-flex justify-content-between align-items-center mt-4">
            <div class="text-muted small">
                Showing
                <strong>@(((Model.PageNumber - 1) * Model.PageSize) + 1)</strong>
                -
                <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalItems))</strong>
                of <strong>@Model.TotalItems</strong> prescriptions
            </div>

            <nav aria-label="Page navigation">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize">Previous</a>
                    </li>

                    @{
                        // show a compact window of pages (max 7 buttons)
                        var maxButtons = 7;
                        var start = Math.Max(1, Model.PageNumber - 3);
                        var end = Math.Min(Model.TotalPages, start + maxButtons - 1);
                        if (end - start + 1 < maxButtons)
                        {
                            start = Math.Max(1, end - maxButtons + 1);
                        }
                    }

                    @if (start > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-route-pageNumber="1" asp-route-pageSize="@Model.PageSize">1</a>
                        </li>
                        @if (start > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }

                    @for (int i = start; i <= end; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-route-pageNumber="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                        </li>
                    }

                    @if (end < Model.TotalPages)
                    {
                        if (end < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="@Model.PageSize">@Model.TotalPages</a>
                        </li>
                    }

                    <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Delete Form -->
<form id="deleteForm" method="post" asp-page-handler="Delete" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="prescriptionId" id="deletePrescriptionId" />
    <input type="hidden" name="pageNumber" value="@Model.PageNumber" />
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Are you sure you want to delete this prescription profile?\n\nThis action cannot be undone!')) {
                document.getElementById('deletePrescriptionId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}