@page "{orderId:int}"
@model EyewearStore_SWP391.Pages.Customer.RequestReturnModel
@{
    ViewData["Title"] = "Request Refund";
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Orders/Index">My Orders</a></li>
            <li class="breadcrumb-item active">Request Refund</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="mb-5">
        <h1 style="font-family: var(--font-secondary);
                   color: var(--primary-navy);
                   font-size: 2.5rem;
                   margin-bottom: 0.5rem;">
            💳 Request Refund
        </h1>
        <p style="color: var(--secondary-warm-gray); font-size: 1.1rem;">
            Order #@Model.Order?.OrderId — Select an item to request a refund
        </p>
    </div>

    <!-- Alerts -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>⚠️</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>✅</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.CanRefund && Model.Order != null)
    {
        <div class="alert alert-warning" style="border-radius: 12px; border-left: 4px solid #ff9800;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @if (Model.Order.Status != "Completed")
            {
                <span>Refunds can only be requested for <strong>completed</strong> orders. This order is currently <strong>@Model.Order.Status</strong>.</span>
            }
            else
            {
                <span>The <strong>7-day refund window</strong> has expired for this order.</span>
            }
        </div>
    }

    <div class="row g-4">
        <!-- Left Column: Items -->
        <div class="col-lg-8">
            <div class="card" style="border: none; border-radius: 16px; box-shadow: var(--shadow-md); overflow: hidden;">
                <div style="background: linear-gradient(135deg, var(--primary-navy) 0%, var(--primary-navy-light) 100%);
                            padding: 1.5rem 2rem;">
                    <h4 style="color: white; margin: 0; font-weight: 600;">
                        <i class="bi bi-bag-check me-2"></i>Order Items
                        @if (Model.CanRefund && Model.DaysLeft > 0)
                        {
                            <span class="badge bg-warning text-dark ms-2" style="font-size: 0.75rem;">
                                <i class="bi bi-clock me-1"></i>@Model.DaysLeft days left
                            </span>
                        }
                    </h4>
                </div>
                <div class="card-body" style="padding: 2rem;">
                    @if (Model.Items.Any())
                    {
                        @foreach (var item in Model.Items)
                        {
                            <div class="refund-item-card mb-3"
                                 style="border: 2px solid var(--medium-gray);
                                        border-radius: 12px;
                                        padding: 1.5rem;
                                        transition: all 0.3s ease;">
                                <div class="row align-items-center">
                                    <!-- Product Info -->
                                    <div class="col-md-5">
                                        <div class="d-flex align-items-center gap-3">
                                            <div style="width: 60px; height: 60px;
                                                        background: var(--light-gray);
                                                        border-radius: 10px;
                                                        display: flex; align-items: center; justify-content: center;
                                                        flex-shrink: 0;">
                                                <i class="bi bi-eyeglasses" style="font-size: 1.5rem; color: var(--primary-gold);"></i>
                                            </div>
                                            <div>
                                                <h6 style="color: var(--primary-navy); font-weight: 600; margin-bottom: 0.25rem;">
                                                    @item.ProductName
                                                </h6>
                                                <div style="color: var(--secondary-warm-gray); font-size: 0.85rem;">
                                                    <span class="badge" style="background: var(--light-gray); color: var(--dark-gray);">
                                                        SKU: @item.Sku
                                                    </span>
                                                    <span class="ms-2">Qty: <strong>×@item.Quantity</strong></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Price -->
                                    <div class="col-md-3 text-center">
                                        <div style="color: var(--secondary-warm-gray); font-size: 0.85rem;">Refund Amount</div>
                                        <div style="color: var(--primary-gold); font-weight: 700; font-size: 1.15rem;">
                                            @((item.UnitPrice * item.Quantity).ToString("N0")) VND
                                        </div>
                                    </div>

                                    <!-- Status / Action -->
                                    <div class="col-md-4 text-end">
                                        @if (item.RefundStatus == "Pending")
                                        {
                                            <span class="badge" style="background: linear-gradient(135deg, #ff9800, #ffb74d);
                                                                       color: white; font-size: 0.9rem;
                                                                       padding: 0.5rem 1rem; border-radius: 20px;">
                                                <i class="bi bi-hourglass-split me-1"></i>Refund Pending
                                            </span>
                                        }
                                        else if (item.RefundStatus == "Approved")
                                        {
                                            <span class="badge" style="background: linear-gradient(135deg, #4caf50, #66bb6a);
                                                                       color: white; font-size: 0.9rem;
                                                                       padding: 0.5rem 1rem; border-radius: 20px;">
                                                <i class="bi bi-check-circle me-1"></i>Refund Approved
                                            </span>
                                        }
                                        else if (item.RefundStatus == "Rejected")
                                        {
                                            <span class="badge" style="background: linear-gradient(135deg, #f44336, #ef5350);
                                                                       color: white; font-size: 0.9rem;
                                                                       padding: 0.5rem 1rem; border-radius: 20px;">
                                                <i class="bi bi-x-circle me-1"></i>Refund Rejected
                                            </span>
                                        }

                                        @if (item.CanRequestRefund)
                                        {
                                            <button type="button"
                                                    class="btn btn-refund mt-2"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#refundModal"
                                                    onclick="setRefundItem(@item.OrderItemId, '@item.ProductName.Replace("'", "\\'")' , '@((item.UnitPrice * item.Quantity).ToString("N0"))')">
                                                <i class="bi bi-arrow-return-left me-1"></i>Request Refund
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5" style="color: var(--secondary-warm-gray);">
                            <i class="bi bi-inbox" style="font-size: 3rem; opacity: 0.3;"></i>
                            <p class="mt-3">No items in this order</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Back Button -->
            <div class="mt-4">
                <a asp-page="/Orders/Index"
                   class="btn btn-outline-secondary btn-lg"
                   style="padding: 0.875rem 2rem; border-radius: 10px;">
                    <i class="bi bi-arrow-left me-2"></i>Back to My Orders
                </a>
            </div>
        </div>

        <!-- Right Column: Policy & Info -->
        <div class="col-lg-4">
            <!-- Refund Policy Card -->
            <div class="card mb-4" style="border: none; border-radius: 16px; box-shadow: var(--shadow-md);
                                          position: sticky; top: 100px;">
                <div style="background: linear-gradient(135deg, var(--secondary-teal) 0%, #4a7c7e 100%);
                            padding: 1.5rem;">
                    <h5 style="color: white; margin: 0; font-weight: 600;">
                        <i class="bi bi-shield-check me-2"></i>Refund Policy
                    </h5>
                </div>
                <div class="card-body" style="padding: 1.5rem;">
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="padding: 0.75rem 0; border-bottom: 1px solid var(--light-gray);">
                            <i class="bi bi-check-circle-fill me-2" style="color: var(--success);"></i>
                            <strong>7-day</strong> refund window
                        </li>
                        <li style="padding: 0.75rem 0; border-bottom: 1px solid var(--light-gray);">
                            <i class="bi bi-check-circle-fill me-2" style="color: var(--success);"></i>
                            <strong>Full refund</strong> on approval
                        </li>
                        <li style="padding: 0.75rem 0; border-bottom: 1px solid var(--light-gray);">
                            <i class="bi bi-check-circle-fill me-2" style="color: var(--success);"></i>
                            <strong>24–48 hours</strong> review time
                        </li>
                        <li style="padding: 0.75rem 0;">
                            <i class="bi bi-check-circle-fill me-2" style="color: var(--success);"></i>
                            <strong>5–10 business days</strong> refund processing
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Help Card -->
            <div class="card" style="border: none; border-radius: 16px;
                                     background: linear-gradient(135deg, var(--secondary-cream) 0%, var(--light-gray) 100%);
                                     padding: 1.5rem;">
                <h6 style="color: var(--primary-navy); font-weight: 600; margin-bottom: 1rem;">
                    <i class="bi bi-question-circle me-2"></i>Need Help?
                </h6>
                <p style="color: var(--dark-gray); font-size: 0.9rem; margin-bottom: 1rem;">
                    If your refund request is rejected and you have questions, please contact our support team.
                </p>
                <a href="#footer"
                   class="btn btn-primary w-100"
                   style="background: var(--primary-navy); border: none;
                          padding: 0.75rem; border-radius: 8px;">
                    <i class="bi bi-headset me-2"></i>Contact Support
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Refund Request Modal -->
<div class="modal fade" id="refundModal" tabindex="-1" aria-labelledby="refundModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: 16px; overflow: hidden;">
            <div style="background: linear-gradient(135deg, var(--primary-navy) 0%, var(--primary-navy-light) 100%);
                        padding: 1.5rem 2rem;">
                <h5 class="modal-title" id="refundModalLabel" style="color: white; margin: 0; font-weight: 600;">
                    <i class="bi bi-arrow-return-left me-2"></i>Request Refund
                </h5>
            </div>
            <form method="post">
                <div class="modal-body" style="padding: 2rem;">
                    <input type="hidden" name="RefundOrderItemId" id="refundOrderItemId" />

                    <!-- Product Info Summary -->
                    <div class="alert" style="background: var(--light-gray); border: none; border-radius: 10px;
                                              border-left: 4px solid var(--primary-gold);">
                        <div style="font-weight: 600; color: var(--primary-navy);" id="refundProductName"></div>
                        <div style="color: var(--primary-gold); font-weight: 700; font-size: 1.1rem; margin-top: 0.25rem;">
                            Refund: <span id="refundAmount"></span> VND
                        </div>
                    </div>

                    <!-- Reason Textarea -->
                    <div class="mb-3">
                        <label class="form-label" style="font-weight: 600; color: var(--primary-navy); font-size: 1rem;">
                            <i class="bi bi-chat-left-text me-2"></i>Reason for refund <span class="text-danger">*</span>
                        </label>
                        <textarea name="RefundReason"
                                  class="form-control"
                                  rows="4"
                                  required
                                  placeholder="Please describe why you'd like a refund for this item..."
                                  style="border: 2px solid var(--medium-gray);
                                         border-radius: 10px;
                                         padding: 1rem;
                                         font-size: 0.95rem;
                                         resize: vertical;"></textarea>
                        <small style="color: var(--secondary-warm-gray);">
                            Your reason helps our team process the request faster.
                        </small>
                    </div>

                    <!-- Info Note -->
                    <div class="alert alert-info" style="border-radius: 10px; font-size: 0.9rem; border: none;
                                                         background: rgba(33, 150, 243, 0.08); color: #1565c0;">
                        <i class="bi bi-info-circle me-2"></i>
                        Refunds are typically reviewed within <strong>24–48 hours</strong>. Once approved, the refund will
                        appear in your account within <strong>5–10 business days</strong>.
                    </div>
                </div>
                <div class="modal-footer" style="padding: 1rem 2rem; border-top: 1px solid var(--light-gray);">
                    <button type="button" class="btn btn-outline-secondary"
                            data-bs-dismiss="modal"
                            style="border-radius: 8px; padding: 0.625rem 1.5rem;">
                        Cancel
                    </button>
                    <button type="submit"
                            class="btn btn-primary"
                            style="background: linear-gradient(135deg, var(--primary-gold) 0%, var(--primary-gold-light) 100%);
                                   border: none; border-radius: 8px; padding: 0.625rem 2rem; font-weight: 600;">
                        <i class="bi bi-send me-1"></i>Submit Refund Request
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .breadcrumb {
        background: transparent;
        padding: 0;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "›";
        color: var(--secondary-warm-gray);
    }

    .breadcrumb-item a {
        color: var(--primary-gold);
        text-decoration: none;
    }

    .refund-item-card:hover {
        border-color: var(--primary-gold) !important;
        box-shadow: 0 4px 12px rgba(212, 165, 116, 0.15);
    }

    .btn-refund {
        background: linear-gradient(135deg, #ff9800 0%, #ffb74d 100%);
        border: none;
        color: white;
        padding: 0.5rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(255,152,0,0.25);
    }

    .btn-refund:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255,152,0,0.4);
        color: white;
    }
</style>

<script>
    function setRefundItem(itemId, productName, amount) {
        document.getElementById('refundOrderItemId').value = itemId;
        document.getElementById('refundProductName').textContent = productName;
        document.getElementById('refundAmount').textContent = amount;
    }
</script>
