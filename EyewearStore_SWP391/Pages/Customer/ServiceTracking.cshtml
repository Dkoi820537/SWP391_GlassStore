@page
@model EyewearStore_SWP391.Pages.Customer.ServiceTrackingModel
@{
    ViewData["Title"] = "My Service Orders";
    Layout = "_Layout";

    string[] steps = { "Pending", "Processing", "Ready", "Done" };

    int StepIndex(string status) => status switch
    {
        "Processing" => 1,
        "Ready" => 2,
        "Done" => 3,
        "Cancelled" => -1,
        _ => 0
    };
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f5f6fa;
            --surf: #fff;
            --surf2: #f0f2f8;
            --bdr: rgba(99,102,141,.13);
            --navy: #0d1b2a;
            --gold: #b8862a;
            --ok: #059669;
            --ok-bg: rgba(5,150,105,.08);
            --ok-bdr: rgba(5,150,105,.22);
            --warn: #d97706;
            --warn-bg: rgba(217,119,6,.09);
            --warn-bdr: rgba(217,119,6,.25);
            --info: #2563eb;
            --info-bg: rgba(37,99,235,.08);
            --info-bdr: rgba(37,99,235,.22);
            --err: #dc2626;
            --err-bg: rgba(220,38,38,.08);
            --err-bdr: rgba(220,38,38,.22);
            --muted: #8b8da8;
            --txt: #12132a;
            --txt2: #40415e;
            --sh: 0 2px 12px rgba(18,19,42,.07);
            --sh-md: 0 4px 24px rgba(18,19,42,.1)
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        body {
            background: var(--bg);
            color: var(--txt);
            font-family: 'Plus Jakarta Sans',sans-serif
        }

        .st-wrap {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px 80px
        }

        /* HERO */
        .hero {
            background: linear-gradient(135deg,#0a0a1a 0%,#1a2332 60%,#0f2744 100%);
            border-radius: 20px;
            padding: 40px 36px;
            margin-bottom: 32px;
            position: relative;
            overflow: hidden
        }

            .hero::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 240px;
                height: 240px;
                border-radius: 50%;
                background: rgba(184,134,42,.07);
                pointer-events: none
            }

        .hero-tag {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2.5px;
            color: rgba(255,255,255,.35);
            text-transform: uppercase;
            margin-bottom: 12px
        }

        .hero h1 {
            font-size: 2rem;
            font-weight: 800;
            color: #fff;
            margin: 0 0 8px;
            letter-spacing: -.5px
        }

        .hero p {
            font-size: 14px;
            color: rgba(255,255,255,.5);
            margin: 0
        }

        /* CARD */
        .order-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--sh-md);
            margin-bottom: 20px
        }

        /* CARD TOP ROW */
        .card-top {
            padding: 22px 24px 18px;
            display: flex;
            align-items: flex-start;
            gap: 16px
        }

        .prod-img {
            width: 80px;
            height: 80px;
            border-radius: 14px;
            object-fit: cover;
            background: var(--surf2);
            flex-shrink: 0;
            border: 1px solid var(--bdr)
        }

        .prod-img-ph {
            width: 80px;
            height: 80px;
            border-radius: 14px;
            background: var(--surf2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            border: 1px solid var(--bdr);
            flex-shrink: 0
        }

        .card-info {
            flex: 1;
            min-width: 0
        }

        .card-oid {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 4px
        }

        .card-title {
            font-size: 17px;
            font-weight: 800;
            color: var(--txt);
            margin-bottom: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        .card-sub {
            font-size: 12px;
            color: var(--muted)
        }

        .card-price {
            font-family: 'DM Mono',monospace;
            font-size: 16px;
            font-weight: 500;
            color: var(--gold);
            white-space: nowrap
        }

        .card-date {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px;
            text-align: right
        }

        /* STATUS BADGE */
        .st-bd {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 11px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700;
            margin-top: 6px
        }

        .st-Pending {
            background: var(--warn-bg);
            color: var(--warn);
            border: 1px solid var(--warn-bdr)
        }

        .st-Processing {
            background: var(--info-bg);
            color: var(--info);
            border: 1px solid var(--info-bdr)
        }

        .st-Ready {
            background: var(--ok-bg);
            color: var(--ok);
            border: 1px solid var(--ok-bdr)
        }

        .st-Done {
            background: rgba(15,23,42,.07);
            color: #0f172a;
            border: 1px solid rgba(15,23,42,.18)
        }

        .st-Cancelled {
            background: var(--err-bg);
            color: var(--err);
            border: 1px solid var(--err-bdr)
        }

        .dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor
        }

        /* PROGRESS TIMELINE */
        .timeline {
            padding: 18px 24px 22px;
            border-top: 1px solid var(--bdr);
            background: var(--surf2)
        }

        .tl-steps {
            display: flex;
            align-items: center;
            gap: 0;
            position: relative
        }

        .tl-step {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 1
        }

            .tl-step:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 16px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: #e0e2f0;
                z-index: 0
            }

            .tl-step.done:not(:last-child)::after {
                background: var(--ok)
            }

            .tl-step.active:not(:last-child)::after {
                background: linear-gradient(90deg,var(--ok),#e0e2f0)
            }

        .tl-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            border: 2px solid #dde1f0;
            background: #fff;
            position: relative;
            z-index: 2;
            transition: all .3s
        }

        .tl-step.done .tl-circle {
            background: var(--ok);
            border-color: var(--ok);
            color: #fff
        }

        .tl-step.active .tl-circle {
            background: var(--info);
            border-color: var(--info);
            color: #fff;
            box-shadow: 0 0 0 4px rgba(37,99,235,.15)
        }

        .tl-step.cancelled .tl-circle {
            background: var(--err);
            border-color: var(--err);
            color: #fff
        }

        .tl-label {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            margin-top: 7px;
            text-align: center;
            letter-spacing: .5px;
            text-transform: uppercase
        }

        .tl-step.done .tl-label {
            color: var(--ok)
        }

        .tl-step.active .tl-label {
            color: var(--info)
        }

        /* DETAIL ROW */
        .detail-row {
            padding: 16px 24px;
            border-top: 1px solid var(--bdr);
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 12px
        }

        .detail-item .dl {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px
        }

        .detail-item .dv {
            font-size: 13px;
            font-weight: 600;
            color: var(--txt)
        }

        /* NOTE BOX */
        .note-box {
            margin: 0 24px 20px;
            background: #fffbeb;
            border: 1px solid #fde68a;
            border-radius: 12px;
            padding: 13px 16px
        }

            .note-box p {
                margin: 0;
                font-size: 13px;
                color: #92400e;
                line-height: 1.55
            }

        /* ASSIGNED */
        .assigned-box {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--info-bg);
            border: 1px solid var(--info-bdr);
            border-radius: 8px;
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 600;
            color: var(--info);
            margin: 0 24px 20px;
            display: flex;
            width: fit-content
        }

        /* EMPTY */
        .empty {
            text-align: center;
            padding: 80px 20px
        }

            .empty .ei {
                font-size: 56px;
                opacity: .15;
                display: block;
                margin-bottom: 16px
            }

            .empty h3 {
                font-size: 20px;
                font-weight: 700;
                color: var(--txt);
                margin: 0 0 8px
            }

            .empty p {
                font-size: 14px;
                color: var(--muted);
                margin: 0 0 24px
            }

        .btn-go {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: linear-gradient(135deg,#0a0a1a,#1a2332);
            color: #fff;
            text-decoration: none;
            border-radius: 10px;
            padding: 13px 28px;
            font-size: 14px;
            font-weight: 700;
            transition: all .2s
        }

            .btn-go:hover {
                opacity: .88;
                transform: translateY(-1px)
            }

        @@media(max-width:600px) {
            .detail-row {
                grid-template-columns: 1fr 1fr
            }

            .card-top {
                flex-wrap: wrap
            }

            .hero {
                padding: 28px 22px
            }

                .hero h1 {
                    font-size: 1.5rem
                }
        }
    </style>
}

<div class="st-wrap">

    <!-- HERO -->
    <div class="hero">
        <div class="hero-tag">✦ OptiPlus</div>
        <h1>My Service Orders</h1>
        <p>Track the progress of your eyewear service and repair orders in real time</p>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="order-card">
            <div class="empty">
                <span class="ei">🕶️</span>
                <h3>No service orders yet</h3>
                <p>You haven't placed any eyewear service orders. Explore our services below.</p>
                <a href="/Customer/Services/FrameRepair" class="btn-go">
                    <i class="bi bi-tools"></i> View Services
                </a>
            </div>
        </div>
    }
    else
    {
        @foreach (var o in Model.Orders)
        {
            int stepIdx = StepIndex(o.ServiceStatus);
            bool isCancelled = o.ServiceStatus == "Cancelled";

            <div class="order-card">
                <!-- TOP -->
                <div class="card-top">
                    @if (!string.IsNullOrEmpty(o.ImageUrl))
                    {
                        <img class="prod-img" src="@o.ImageUrl" alt="@o.FrameName" />
                    }
                    else
                    {

                        <div class="prod-img-ph">🕶️</div>
                    }

                    <div class="card-info">
                        <div class="card-oid">Order #@o.OrderId</div>
                        <div class="card-title">@o.FrameName</div>
                        <div class="card-sub">@o.ServiceName • Lens: @o.LensName</div>
                        <span class="st-bd st-@o.ServiceStatus">
                            <span class="dot"></span> @o.ServiceStatus
                        </span>
                    </div>
                    <div style="text-align:right;flex-shrink:0">
                        <div class="card-price">@o.Total.ToString("N0") ₫</div>
                        <div class="card-date">@o.CreatedAt.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>

                <!-- TIMELINE (not shown for cancelled) -->
                @if (!isCancelled)
                {
                    <div class="timeline">
                        <div class="tl-steps">
                            @for (int i = 0; i < steps.Length; i++)
                            {
                                string cls = i < stepIdx ? "done" : i == stepIdx ? "active" : "";
                                string icon = i < stepIdx ? "✓" : i == stepIdx ? "●" : (i + 1).ToString();
                                <div class="tl-step @cls">
                                    <div class="tl-circle">@icon</div>
                                    <div class="tl-label">@steps[i]</div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="timeline">
                        <div style="display:flex;align-items:center;gap:10px;color:var(--err)">
                            <span style="font-size:20px">❌</span>
                            <span style="font-size:13px;font-weight:700">This service order has been cancelled.</span>
                        </div>
                    </div>
                }

                <!-- DETAIL ROW -->
                <div class="detail-row">
                    <div class="detail-item">
                        <div class="dl">Frame</div>
                        <div class="dv">@o.FrameName</div>
                    </div>
                    <div class="detail-item">
                        <div class="dl">Service</div>
                        <div class="dv">@o.ServiceName</div>
                    </div>
                    <div class="detail-item">
                        <div class="dl">Lens</div>
                        <div class="dv">@o.LensName</div>
                    </div>
                    <div class="detail-item">
                        <div class="dl">Frame price</div>
                        <div class="dv">@o.FramePrice.ToString("N0") ₫</div>
                    </div>
                    <div class="detail-item">
                        <div class="dl">Service fee</div>
                        <div class="dv">@o.ServicePrice.ToString("N0") ₫</div>
                    </div>
                    <div class="detail-item">
                        <div class="dl">Lens price</div>
                        <div class="dv">@o.LensPrice.ToString("N0") ₫</div>
                    </div>
                </div>

                <!-- ASSIGNED -->
                @if (!string.IsNullOrEmpty(o.AssignedTo))
                {
                    <div class="assigned-box" style="margin:0 24px 12px">
                        <i class="bi bi-person-check-fill"></i>
                        Assigned to: <strong>@o.AssignedTo</strong>
                    </div>
                }

                <!-- NOTE -->
                @if (!string.IsNullOrEmpty(o.InternalNote))
                {
                    <div class="note-box">
                        <p>💬 <strong>Note from our team:</strong> @o.InternalNote</p>
                    </div>
                }
            </div>
        }
    }
</div>
