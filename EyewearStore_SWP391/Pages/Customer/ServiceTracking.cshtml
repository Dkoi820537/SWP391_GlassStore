@page
@model EyewearStore_SWP391.Pages.Customer.ServiceTrackingModel
@{
    ViewData["Title"] = "My Service Orders";
    Layout = "_Layout";

    string[] steps = { "Pending", "Processing", "Ready", "Done" };

    int StepIndex(string status) => status switch
    {
        "Processing" => 1,
        "Ready" => 2,
        "Done" => 3,
        "Cancelled" => -1,
        _ => 0
    };
    string StepIcon(string status) => status switch
    {
        "Pending" => "bi-hourglass-split",
        "Processing" => "bi-gear-fill",
        "Ready" => "bi-check-circle-fill",
        "Done" => "bi-bag-check-fill",
        "Cancelled" => "bi-x-circle-fill",
        _ => "bi-wrench"
    };
    string StatusMsg(string status) => status switch
    {
        "Pending" => "Your order has been received and is awaiting workshop.",
        "Processing" => "Our technicians are currently working on your eyewear.",
        "Ready" => "Your glasses are ready! Please come in to collect them.",
        "Done" => "Order completed. Thank you for choosing OptiPlus!",
        "Cancelled" => "This service order has been cancelled.",
        _ => ""
    };
    string StatusEmoji(string status) => status switch
    {
        "Pending" => "⏳",
        "Processing" => "⚙️",
        "Ready" => "✅",
        "Done" => "🎉",
        "Cancelled" => "❌",
        _ => "🔭"
    };

    // count by status for summary bar
    int total = Model.TotalCount;
    int pending = Model.PendingCount;
    int processing = Model.ProcessingCount;
    int ready = Model.ReadyCount;
    int done = Model.DoneCount;
    int cancelled = Model.CancelledCount;
}

@section Styles {
    <style>
        :root {
            --bg: #f4f5fb;
            --surf: #ffffff;
            --surf2: #f0f2f8;
            --bdr: rgba(99,102,141,.12);
            --navy: #0d1b2a;
            --navy2: #1a2f54;
            --gold: #b8862a;
            --gold2: #d4a74a;
            --ok: #059669;
            --ok-bg: rgba(5,150,105,.08);
            --ok-bdr: rgba(5,150,105,.2);
            --warn: #d97706;
            --warn-bg: rgba(217,119,6,.09);
            --warn-bdr: rgba(217,119,6,.24);
            --info: #2563eb;
            --info-bg: rgba(37,99,235,.08);
            --info-bdr: rgba(37,99,235,.2);
            --err: #dc2626;
            --err-bg: rgba(220,38,38,.08);
            --err-bdr: rgba(220,38,38,.2);
            --purple: #7c3aed;
            --pur-bg: rgba(124,58,237,.08);
            --pur-bdr: rgba(124,58,237,.2);
            --muted: #8b8da8;
            --txt: #12132a;
            --sh: 0 1px 6px rgba(18,19,42,.06);
            --sh-md: 0 4px 24px rgba(18,19,42,.09);
            --sh-lg: 0 8px 40px rgba(18,19,42,.13);
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            color: var(--txt);
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        /* ── WRAP ── */
        .st-wrap {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px 90px;
        }

        /* ── HERO ── */
        .hero {
            background: linear-gradient(135deg, #07101e 0%, #13243d 55%, #0c2240 100%);
            border-radius: 22px;
            padding: 40px 38px 32px;
            margin-bottom: 28px;
            position: relative;
            overflow: hidden;
        }

            .hero::before {
                content: '';
                position: absolute;
                top: -60px;
                right: -60px;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(184,134,42,.12) 0%, transparent 70%);
                pointer-events: none;
            }

            .hero::after {
                content: '';
                position: absolute;
                bottom: -40px;
                left: 40px;
                width: 180px;
                height: 180px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(124,58,237,.08) 0%, transparent 70%);
                pointer-events: none;
            }

        .hero-eyebrow {
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 3px;
            color: rgba(255,255,255,.3);
            text-transform: uppercase;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .hero-eyebrow::before {
                content: '✦';
                color: var(--gold2);
            }

        .hero h1 {
            font-size: 2.2rem;
            font-weight: 900;
            color: #fff;
            margin: 0 0 6px;
            letter-spacing: -.6px;
        }

        .hero p {
            font-size: 14px;
            color: rgba(255,255,255,.45);
            margin: 0 0 28px;
        }

        /* stat pills */
        .hero-stats {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .stat-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(255,255,255,.1);
            border-radius: 100px;
            padding: 6px 14px;
            font-size: 12px;
            font-weight: 700;
            color: rgba(255,255,255,.75);
            backdrop-filter: blur(4px);
        }

            .stat-pill .sp-dot {
                width: 7px;
                height: 7px;
                border-radius: 50%;
            }

            .stat-pill .sp-num {
                font-size: 15px;
                font-weight: 900;
                color: #fff;
            }

        /* ── FILTER TABS ── */
        .filter-bar {
            display: flex;
            gap: 8px;
            margin-bottom: 22px;
            flex-wrap: wrap;
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 14px;
            padding: 8px;
            box-shadow: var(--sh);
        }

        .f-tab {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            border-radius: 9px;
            border: none;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            background: transparent;
            color: var(--muted);
            transition: all .18s;
            white-space: nowrap;
        }

            .f-tab:hover {
                background: var(--surf2);
                color: var(--txt);
            }

            .f-tab.active {
                background: var(--navy);
                color: #fff;
                box-shadow: 0 2px 8px rgba(13,27,42,.25);
            }

            .f-tab .ft-count {
                background: rgba(255,255,255,.18);
                border-radius: 100px;
                padding: 1px 7px;
                font-size: 10px;
            }

            .f-tab:not(.active) .ft-count {
                background: var(--surf2);
                color: var(--muted);
            }

        /* ── ORDER CARD ── */
        .order-card {
            display: block;
            text-decoration: none;
            color: inherit;
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--sh-md);
            margin-bottom: 16px;
            transition: transform .2s, box-shadow .2s, border-color .2s;
            position: relative;
        }

            .order-card:hover {
                transform: translateY(-3px);
                box-shadow: var(--sh-lg);
                border-color: rgba(124,58,237,.2);
                color: inherit;
            }

                .order-card:hover .card-arrow {
                    opacity: 1;
                    transform: translateX(0);
                }

            /* status accent bar on left */
            .order-card::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                width: 4px;
                border-radius: 20px 0 0 20px;
            }

            .order-card.st-Pending::before {
                background: var(--warn);
            }

            .order-card.st-Processing::before {
                background: var(--info);
            }

            .order-card.st-Ready::before {
                background: var(--ok);
            }

            .order-card.st-Done::before {
                background: var(--muted);
            }

            .order-card.st-Cancelled::before {
                background: var(--err);
            }

        /* ── CARD TOP ── */
        .card-top {
            padding: 20px 24px 16px 28px;
            display: flex;
            align-items: flex-start;
            gap: 16px;
        }

        .prod-img {
            width: 76px;
            height: 76px;
            border-radius: 14px;
            object-fit: cover;
            background: var(--surf2);
            flex-shrink: 0;
            border: 1px solid var(--bdr);
        }

        .prod-img-ph {
            width: 76px;
            height: 76px;
            border-radius: 14px;
            background: linear-gradient(135deg, var(--surf2), #e8eaf5);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            border: 1px solid var(--bdr);
            flex-shrink: 0;
        }

        .card-info {
            flex: 1;
            min-width: 0;
        }

        .card-oid {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            letter-spacing: 1.2px;
            text-transform: uppercase;
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .card-title {
            font-size: 16px;
            font-weight: 800;
            color: var(--txt);
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .card-sub {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 8px;
        }

        /* status badge */
        .st-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700;
        }

            .st-badge i {
                font-size: 11px;
            }

        .sb-Pending {
            background: var(--warn-bg);
            color: var(--warn);
            border: 1px solid var(--warn-bdr);
        }

        .sb-Processing {
            background: var(--info-bg);
            color: var(--info);
            border: 1px solid var(--info-bdr);
        }

        .sb-Ready {
            background: var(--ok-bg);
            color: var(--ok);
            border: 1px solid var(--ok-bdr);
        }

        .sb-Done {
            background: rgba(15,23,42,.06);
            color: #334155;
            border: 1px solid rgba(15,23,42,.14);
        }

        .sb-Cancelled {
            background: var(--err-bg);
            color: var(--err);
            border: 1px solid var(--err-bdr);
        }

        .card-right {
            text-align: right;
            flex-shrink: 0;
        }

        .card-price {
            font-size: 17px;
            font-weight: 900;
            color: var(--gold);
        }

        .card-date {
            font-size: 11px;
            color: var(--muted);
            margin-top: 3px;
        }

        .card-arrow {
            margin-top: 8px;
            font-size: 18px;
            color: var(--purple);
            opacity: 0;
            transform: translateX(-4px);
            transition: all .2s;
        }

        /* ── STATUS MSG BAR ── */
        .status-bar {
            margin: 0 28px 14px;
            padding: 9px 14px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .smb-Pending {
            background: var(--warn-bg);
            color: var(--warn);
            border: 1px solid var(--warn-bdr);
        }

        .smb-Processing {
            background: var(--info-bg);
            color: var(--info);
            border: 1px solid var(--info-bdr);
        }

        .smb-Ready {
            background: var(--ok-bg);
            color: var(--ok);
            border: 1px solid var(--ok-bdr);
        }

        .smb-Done {
            background: rgba(15,23,42,.05);
            color: #334155;
            border: 1px solid rgba(15,23,42,.1);
        }

        .smb-Cancelled {
            background: var(--err-bg);
            color: var(--err);
            border: 1px solid var(--err-bdr);
        }

        /* ── TIMELINE STRIP ── */
        .tl-strip {
            padding: 14px 28px 18px;
            border-top: 1px solid var(--bdr);
            background: linear-gradient(to bottom, var(--surf2), #eef0f8);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .tl-steps {
            display: flex;
            align-items: center;
            flex: 1;
        }

        .tl-step {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 1;
        }

            .tl-step:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 15px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: #dde0f0;
                z-index: 0;
            }

            .tl-step.done:not(:last-child)::after {
                background: var(--ok);
            }

            .tl-step.active:not(:last-child)::after {
                background: linear-gradient(90deg, var(--ok), #dde0f0);
            }

        .tl-circle {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            border: 2px solid #dde0f0;
            background: #fff;
            position: relative;
            z-index: 2;
            transition: all .3s;
        }

        .tl-step.done .tl-circle {
            background: var(--ok);
            border-color: var(--ok);
            color: #fff;
        }

        .tl-step.active .tl-circle {
            background: var(--purple);
            border-color: var(--purple);
            color: #fff;
            box-shadow: 0 0 0 4px var(--pur-bg);
        }

        .tl-label {
            font-size: 9.5px;
            font-weight: 700;
            color: var(--muted);
            margin-top: 6px;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: .4px;
        }

        .tl-step.done .tl-label {
            color: var(--ok);
        }

        .tl-step.active .tl-label {
            color: var(--purple);
            font-weight: 900;
        }

        /* view detail hint */
        .view-hint {
            flex-shrink: 0;
            margin-left: 16px;
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 11px;
            font-weight: 700;
            color: var(--purple);
            background: var(--pur-bg);
            border: 1px solid var(--pur-bdr);
            border-radius: 8px;
            padding: 6px 12px;
            white-space: nowrap;
            align-self: center;
        }

        /* ── EMPTY STATE ── */
        .empty-state {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 22px;
            text-align: center;
            padding: 80px 30px;
            box-shadow: var(--sh-md);
        }

        .empty-icon {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--surf2), #e8eaf5);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 44px;
            margin: 0 auto 24px;
            border: 2px solid var(--bdr);
        }

        .empty-state h3 {
            font-size: 20px;
            font-weight: 800;
            margin: 0 0 8px;
        }

        .empty-state p {
            font-size: 14px;
            color: var(--muted);
            margin: 0 0 28px;
        }

        .btn-go {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, var(--navy), var(--navy2));
            color: #fff;
            text-decoration: none;
            border-radius: 12px;
            padding: 13px 30px;
            font-size: 14px;
            font-weight: 800;
            box-shadow: 0 4px 16px rgba(13,27,42,.25);
            transition: all .2s;
        }

            .btn-go:hover {
                color: #fff;
                opacity: .88;
                transform: translateY(-2px);
            }

        /* ── SECTION LABEL ── */
        .section-label {
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--muted);
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .section-label::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--bdr);
            }

        /* ── SEARCH BAR ── */
        .search-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 16px;
            padding: 6px;
            margin-bottom: 22px;
            box-shadow: var(--sh);
            transition: box-shadow .2s, border-color .2s;
        }

            .search-card:focus-within {
                box-shadow: var(--sh-md);
                border-color: rgba(124,58,237,.25);
            }

        .search-inner {
            display: flex;
            align-items: center;
            gap: 0;
        }

        .search-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            flex-shrink: 0;
            color: var(--muted);
            font-size: 16px;
            transition: color .2s;
        }

        .search-card:focus-within .search-icon {
            color: var(--purple);
        }

        .search-input {
            flex: 1;
            border: none;
            outline: none;
            background: transparent;
            font-size: 14px;
            font-weight: 500;
            color: var(--txt);
            padding: 12px 0;
            font-family: inherit;
        }

            .search-input::placeholder {
                color: var(--muted);
                font-weight: 400;
            }

        .search-btn {
            flex-shrink: 0;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 22px;
            background: linear-gradient(135deg, var(--navy), var(--navy2));
            color: #fff;
            border: none;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s;
            font-family: inherit;
        }

            .search-btn:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 16px rgba(13,27,42,.3);
            }

        .search-clear {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: none;
            background: transparent;
            color: var(--muted);
            font-size: 14px;
            cursor: pointer;
            flex-shrink: 0;
            transition: all .15s;
            margin-right: 4px;
            text-decoration: none;
        }

            .search-clear:hover {
                background: var(--err-bg);
                color: var(--err);
            }

        .search-result-info {
            padding: 0 6px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: var(--muted);
            font-weight: 600;
        }

            .search-result-info .sri-term {
                color: var(--txt);
                font-weight: 800;
                background: var(--pur-bg);
                padding: 2px 10px;
                border-radius: 6px;
                font-size: 12px;
            }

            .search-result-info a {
                color: var(--purple);
                text-decoration: none;
                font-weight: 700;
                font-size: 12px;
            }

                .search-result-info a:hover {
                    text-decoration: underline;
                }

        @@media(max - width:600px) {
            .hero

        {
            padding: 28px 22px 24px;
        }

        .hero h1 {
            font-size: 1.6rem;
        }

        .card-top {
            padding: 16px 18px 12px 22px;
            flex-wrap: wrap;
        }

        .tl-strip {
            padding: 14px 18px 16px;
            flex-direction: column;
            gap: 12px;
        }

        .view-hint {
            align-self: flex-start;
        }

        .filter-bar {
            gap: 6px;
        }

        .f-tab {
            padding: 7px 12px;
        }

        .search-btn span { display: none; }

        }
    </style>
}

<div class="st-wrap">

    <!-- ── HERO ── -->
    <div class="hero">
        <div class="hero-eyebrow">OptiPlus Workshop</div>
        <h1>My Service Orders</h1>
        <p>Track every step of your custom eyewear — from workshop to your hands.</p>

        @if (total > 0)
        {
            <div class="hero-stats">
                <div class="stat-pill">
                    <span class="sp-num">@total</span>
                    <span>Total</span>
                </div>
                @if (processing > 0)
                {
                    <div class="stat-pill">
                        <span class="sp-dot" style="background:#60a5fa;"></span>
                        <span class="sp-num">@processing</span>
                        <span>In Workshop</span>
                    </div>
                }
                @if (ready > 0)
                {
                    <div class="stat-pill">
                        <span class="sp-dot" style="background:#34d399;"></span>
                        <span class="sp-num">@ready</span>
                        <span>Ready</span>
                    </div>
                }
                @if (pending > 0)
                {
                    <div class="stat-pill">
                        <span class="sp-dot" style="background:#fbbf24;"></span>
                        <span class="sp-num">@pending</span>
                        <span>Pending</span>
                    </div>
                }
                @if (done > 0)
                {
                    <div class="stat-pill">
                        <span class="sp-dot" style="background:#94a3b8;"></span>
                        <span class="sp-num">@done</span>
                        <span>Done</span>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ── SEARCH BAR ── -->
    <form method="get" class="search-card" id="searchForm">
        <div class="search-inner">
            <div class="search-icon">
                <i class="bi bi-search"></i>
            </div>
            <input type="text"
                   class="search-input"
                   name="SearchQuery"
                   value="@Model.SearchQuery"
                   placeholder="Search by order ID, frame, lens, or service name..."
                   autocomplete="off"
                   id="searchInput" />
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <a href="/Customer/ServiceTracking" class="search-clear" title="Clear search">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
            <button type="submit" class="search-btn">
                <i class="bi bi-search"></i>
                <span>Search</span>
            </button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
    {
        <div class="search-result-info">
            <i class="bi bi-funnel-fill" style="font-size:12px;"></i>
            Showing results for <span class="sri-term">@Model.SearchQuery</span>
            <span style="opacity:.4;">·</span>
            <a href="/Customer/ServiceTracking">Clear filter</a>
        </div>
    }

    @if (!Model.Orders.Any())
    {
        <!-- empty -->
        <div class="empty-state">
            <div class="empty-icon">🔭</div>
            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <h3>No service orders found</h3>
                <p>No orders match "<strong>@Model.SearchQuery</strong>". Try a different search term.</p>
                <a href="/Customer/ServiceTracking" class="btn-go">
                    <i class="bi bi-arrow-left"></i> View All Service Orders
                </a>
            }
            else
            {
                <h3>No service orders yet</h3>
                <p>You haven't placed any eyewear service or custom assembly orders.</p>
                <a href="/Customer/Services/FrameRepair" class="btn-go">
                    <i class="bi bi-tools"></i> Explore Services
                </a>
            }
        </div>
    }
    else
    {
        <!-- ── FILTER TABS ── -->
        <div class="filter-bar" id="filterBar">
            <button class="f-tab active" data-filter="all">
                All <span class="ft-count">@total</span>
            </button>
            @if (pending > 0)
            {
                <button class="f-tab" data-filter="Pending" style="color:#d97706;">
                    ⏳ Pending <span class="ft-count">@pending</span>
                </button>
            }
            @if (processing > 0)
            {
                <button class="f-tab" data-filter="Processing" style="color:#2563eb;">
                    ⚙️ In Workshop <span class="ft-count">@processing</span>
                </button>
            }
            @if (ready > 0)
            {
                <button class="f-tab" data-filter="Ready" style="color:#059669;">
                    ✅ Ready <span class="ft-count">@ready</span>
                </button>
            }
            @if (done > 0)
            {
                <button class="f-tab" data-filter="Done">
                    🎉 Done <span class="ft-count">@done</span>
                </button>
            }
            @if (cancelled > 0)
            {
                <button class="f-tab" data-filter="Cancelled" style="color:#dc2626;">
                    ❌ Cancelled <span class="ft-count">@cancelled</span>
                </button>
            }
        </div>

        <!-- ── CARDS ── -->
        <div id="cardList">
            @foreach (var o in Model.Orders)
            {
                int stepIdx = StepIndex(o.ServiceStatus);
                bool isCancelled = o.ServiceStatus == "Cancelled";

                <a href="/Customer/ServiceTrackingDetail?orderId=@o.OrderId&itemId=@o.OrderItemId"
                   class="order-card st-@o.ServiceStatus"
                   data-status="@o.ServiceStatus">

                    <!-- TOP -->
                    <div class="card-top">
                        @if (!string.IsNullOrEmpty(o.ImageUrl))
                        {
                            <img class="prod-img" src="@o.ImageUrl" alt="@o.FrameName" />
                        }
                        else
                        {
                            <div class="prod-img-ph">🔭</div>
                        }

                        <div class="card-info">
                            <div class="card-oid">
                                <i class="bi bi-hash"></i> Order @o.OrderId
                                <span style="opacity:.35;">·</span>
                                Item @o.OrderItemId
                            </div>
                            <div class="card-title">@o.FrameName</div>
                            <div class="card-sub">
                                @o.ServiceName
                                @if (!string.IsNullOrEmpty(o.LensName) && o.LensName != "N/A")
                                {
                                    <text> · Lens: @o.LensName</text>
                                }
                            </div>
                            <span class="st-badge sb-@o.ServiceStatus">
                                <i class="bi @StepIcon(o.ServiceStatus)"></i>
                                @o.ServiceStatus
                            </span>
                        </div>

                        <div class="card-right">
                            <div class="card-price">@o.Total.ToString("N0") ₫</div>
                            <div class="card-date">
                                <i class="bi bi-calendar3" style="font-size:10px;"></i>
                                @o.CreatedAt.ToString("dd/MM/yyyy")
                            </div>
                            <div class="card-arrow"><i class="bi bi-arrow-right-circle-fill"></i></div>
                        </div>
                    </div>

                    <!-- STATUS MSG -->
                    <div class="status-bar smb-@o.ServiceStatus">
                        <span>@StatusEmoji(o.ServiceStatus)</span>
                        <span>@StatusMsg(o.ServiceStatus)</span>
                    </div>

                    <!-- TIMELINE STRIP -->
                    <div class="tl-strip">
                        @if (!isCancelled)
                        {
                            <div class="tl-steps">
                                @for (int i = 0; i < steps.Length; i++)
                                {
                                    string cls = i < stepIdx ? "done" : i == stepIdx ? "active" : "";
                                    string icon = i < stepIdx ? "✓" : i == stepIdx ? "●" : (i + 1).ToString();
                                    <div class="tl-step @cls">
                                        <div class="tl-circle">@icon</div>
                                        <div class="tl-label">@steps[i]</div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div style="display:flex;align-items:center;gap:10px;color:var(--err);flex:1;">
                                <i class="bi bi-x-circle-fill" style="font-size:20px;"></i>
                                <span style="font-size:13px;font-weight:700;">This service order has been cancelled.</span>
                            </div>
                        }

                        <div class="view-hint">
                            <i class="bi bi-eye"></i> View Detail
                        </div>
                    </div>

                </a>
            }
        </div>

        <!-- no results after filter -->
        <div id="noResults" style="display:none;text-align:center;padding:48px 20px;color:var(--muted);">
            <i class="bi bi-funnel" style="font-size:32px;display:block;margin-bottom:12px;opacity:.3;"></i>
            No orders match this filter.
        </div>

        <!-- Pagination Controls -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center" style="gap: 5px;">
                    <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="./ServiceTracking" asp-route-pageIndex="@(Model.PageIndex - 1)" asp-route-searchQuery="@Model.SearchQuery" style="border-radius: 8px; border: 1px solid var(--bdr); color: var(--txt);">Previous</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.PageIndex == i ? "active" : "")">
                            <a class="page-link" asp-page="./ServiceTracking" asp-route-pageIndex="@i" asp-route-searchQuery="@Model.SearchQuery" style="border-radius: 8px; @(Model.PageIndex == i ? "background: var(--navy); border-color: var(--navy); color: #fff;" : "border: 1px solid var(--bdr); color: var(--txt);")">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="./ServiceTracking" asp-route-pageIndex="@(Model.PageIndex + 1)" asp-route-searchQuery="@Model.SearchQuery" style="border-radius: 8px; border: 1px solid var(--bdr); color: var(--txt);">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

<script>
    (function () {
        const bar   = document.getElementById('filterBar');
        const list  = document.getElementById('cardList');
        const empty = document.getElementById('noResults');
        if (!bar || !list) return;

        bar.addEventListener('click', function (e) {
            const btn = e.target.closest('.f-tab');
            if (!btn) return;

            bar.querySelectorAll('.f-tab').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const filter = btn.dataset.filter;
            let visible  = 0;

            list.querySelectorAll('.order-card').forEach(card => {
                const show = filter === 'all' || card.dataset.status === filter;
                card.style.display = show ? 'block' : 'none';
                if (show) visible++;
            });

            if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
        });
    })();
</script>
