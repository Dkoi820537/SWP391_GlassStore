@page
@model EyewearStore_SWP391.Pages.Customer.Services.CustomGlassesModel
@{
    ViewData["Title"] = "Custom Glasses";
    Layout = "_Layout";
}

@section Styles {
    <style>
        :root {
            --navy: #0f1e3c;
            --gold: #b8862a;
            --acc: #2563eb;
            --ok: #059669;
            --txt: #0f172a;
            --txt2: #475569;
            --muted: #94a3b8;
            --surf: #ffffff;
            --bg: #f8fafc;
            --bg2: #f0f4ff;
            --bdr: #e2e8f0;
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        .clf-wrap {
            max-width: 1060px;
            margin: 0 auto;
            padding: 40px 24px 100px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 600;
            color: var(--muted);
            text-decoration: none;
            margin-bottom: 32px;
            transition: color .2s;
        }

            .back-link:hover {
                color: var(--txt);
            }

        .clf-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }

        .clf-header-left h1 {
            font-size: clamp(1.6rem,4vw,2.4rem);
            font-weight: 900;
            color: var(--navy);
            letter-spacing: -.8px;
            margin: 0 0 8px;
        }

        .clf-header-left p {
            font-size: 14px;
            color: var(--txt2);
            margin: 0;
            line-height: 1.5;
        }

        .clf-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(184,134,42,.1);
            border: 1px solid rgba(184,134,42,.25);
            color: var(--gold);
            border-radius: 100px;
            padding: 6px 14px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .8px;
            white-space: nowrap;
            flex-shrink: 0;
            margin-top: 4px;
        }

        .stepper {
            display: flex;
            align-items: center;
            margin-bottom: 44px;
            overflow-x: auto;
            padding: 4px 2px 8px;
        }

        .stepper-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            flex: 1;
            min-width: 80px;
            cursor: default;
            position: relative;
        }

            .stepper-item.clickable {
                cursor: pointer;
            }

        .stepper-circle {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--bdr);
            border: 2.5px solid #cbd5e1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 800;
            color: var(--muted);
            transition: all .25s;
            position: relative;
            z-index: 1;
        }

        .stepper-item.active .stepper-circle {
            background: var(--navy);
            border-color: var(--navy);
            color: white;
            box-shadow: 0 4px 18px rgba(15,30,60,.25);
            transform: scale(1.05);
        }

        .stepper-item.done .stepper-circle {
            background: var(--ok);
            border-color: var(--ok);
            color: white;
            font-size: 16px;
        }

        .stepper-label {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-align: center;
            text-transform: uppercase;
            letter-spacing: .8px;
            white-space: nowrap;
        }

        .stepper-item.active .stepper-label {
            color: var(--navy);
        }

        .stepper-item.done .stepper-label {
            color: var(--ok);
        }

        .stepper-line {
            flex: 1;
            height: 2px;
            background: var(--bdr);
            min-width: 20px;
            margin-bottom: 28px;
            transition: background .3s;
        }

            .stepper-line.done {
                background: var(--ok);
            }

        .step-count {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 600;
            color: var(--muted);
            background: var(--bg);
            border: 1px solid var(--bdr);
            border-radius: 100px;
            padding: 4px 12px;
            margin-bottom: 12px;
        }

        .clf-panel {
            display: none;
        }

            .clf-panel.active {
                display: block;
            }

        .panel-heading {
            margin-bottom: 24px;
        }

            .panel-heading h2 {
                font-size: 1.5rem;
                font-weight: 800;
                color: var(--txt);
                margin: 0 0 4px;
                letter-spacing: -.4px;
            }

            .panel-heading p {
                font-size: 13.5px;
                color: var(--txt2);
                margin: 0;
            }

        .prod-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(170px,1fr));
            gap: 14px;
            margin-bottom: 28px;
        }

        .prod-card {
            border: 2px solid var(--bdr);
            border-radius: 14px;
            padding: 18px 14px;
            cursor: pointer;
            transition: all .2s;
            background: var(--surf);
            text-align: center;
            position: relative;
        }

            .prod-card:hover {
                border-color: var(--navy);
                box-shadow: 0 6px 20px rgba(15,30,60,.1);
                transform: translateY(-2px);
            }

            .prod-card.selected {
                border-color: var(--navy);
                background: rgba(15,30,60,.03);
                box-shadow: 0 0 0 4px rgba(15,30,60,.08);
            }

                .prod-card.selected::after {
                    content: 'checkmark';
                    position: absolute;
                    top: 8px;
                    right: 10px;
                    width: 22px;
                    height: 22px;
                    background: var(--ok);
                    color: white;
                    border-radius: 50%;
                    font-size: 11px;
                    font-weight: 800;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    line-height: 22px;
                }

        .prod-img {
            width: 76px;
            height: 76px;
            object-fit: cover;
            border-radius: 10px;
            margin: 0 auto 10px;
            display: block;
        }

        .prod-img-ph {
            width: 76px;
            height: 76px;
            border-radius: 10px;
            margin: 0 auto 10px;
            background: var(--bg2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
        }

        .prod-name {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt);
            margin-bottom: 4px;
            line-height: 1.3;
        }

        .prod-price {
            font-size: 13px;
            font-weight: 700;
            color: var(--gold);
        }

        .svc-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(210px,1fr));
            gap: 14px;
            margin-bottom: 28px;
        }

        .svc-card {
            border: 2px solid var(--bdr);
            border-radius: 14px;
            padding: 20px 18px;
            cursor: pointer;
            transition: all .2s;
            background: var(--surf);
            position: relative;
        }

            .svc-card:hover {
                border-color: var(--navy);
                box-shadow: 0 6px 20px rgba(15,30,60,.1);
                transform: translateY(-2px);
            }

            .svc-card.selected {
                border-color: var(--navy);
                background: rgba(15,30,60,.03);
                box-shadow: 0 0 0 4px rgba(15,30,60,.08);
            }

                .svc-card.selected::after {
                    content: 'checkmark';
                    position: absolute;
                    top: 10px;
                    right: 12px;
                    width: 22px;
                    height: 22px;
                    background: var(--ok);
                    color: white;
                    border-radius: 50%;
                    font-size: 11px;
                    font-weight: 800;
                    line-height: 22px;
                    text-align: center;
                }

        .svc-icon {
            font-size: 24px;
            margin-bottom: 10px;
            display: block;
        }

        .svc-name {
            font-size: 14px;
            font-weight: 700;
            color: var(--txt);
            margin-bottom: 4px;
        }

        .svc-desc {
            font-size: 12px;
            color: var(--txt2);
            margin-bottom: 10px;
            line-height: 1.45;
        }

        .svc-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 4px;
        }

        .svc-price {
            font-size: 14px;
            font-weight: 800;
            color: var(--gold);
        }

        .svc-dur {
            font-size: 11px;
            color: var(--muted);
            font-weight: 500;
        }

        .summary-card {
            background: var(--surf);
            border: 2px solid var(--bdr);
            border-radius: 18px;
            overflow: hidden;
            margin-bottom: 24px;
            box-shadow: 0 4px 20px rgba(15,30,60,.06);
        }

        .summary-header {
            background: linear-gradient(135deg,var(--navy),#1a2f54);
            padding: 18px 24px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .summary-header h3 {
                color: white;
                font-size: 15px;
                font-weight: 700;
                margin: 0;
            }

        .summary-body {
            padding: 0 24px;
        }

        .sum-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid var(--bdr);
            gap: 12px;
        }

            .sum-row:last-child {
                border-bottom: none;
            }

            .sum-row.total-row {
                background: rgba(184,134,42,.05);
                margin: 0 -24px;
                padding: 18px 24px;
                border-bottom: none;
            }

        .sum-item-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sum-thumb {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            object-fit: cover;
            border: 1.5px solid var(--bdr);
            flex-shrink: 0;
        }

        .sum-thumb-ph {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: var(--bg2);
            border: 1.5px solid var(--bdr);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .sum-item-info .lbl {
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--muted);
            margin-bottom: 2px;
        }

        .sum-item-info .val {
            font-size: 14px;
            font-weight: 700;
            color: var(--txt);
        }

        .sum-price {
            font-size: 15px;
            font-weight: 800;
            color: var(--gold);
            white-space: nowrap;
        }

        .total-label {
            font-size: 16px;
            font-weight: 800;
            color: var(--txt);
        }

        .total-price {
            font-size: 22px;
            font-weight: 900;
            color: var(--gold);
        }

        .nav-btns {
            display: flex;
            gap: 12px;
            align-items: center;
            margin-top: 12px;
            flex-wrap: wrap;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--bg);
            color: var(--txt2);
            border: 1.5px solid var(--bdr);
            border-radius: 10px;
            padding: 12px 20px;
            font-size: 13.5px;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
        }

            .btn-back:hover {
                background: #e2e8f0;
                color: var(--txt);
            }

        .btn-next {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg,var(--navy),#1a2f54);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 12px 28px;
            font-size: 13.5px;
            font-weight: 700;
            cursor: pointer;
            transition: all .2s;
            box-shadow: 0 4px 14px rgba(15,30,60,.2);
        }

            .btn-next:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(15,30,60,.25);
            }

            .btn-next:disabled {
                opacity: .35;
                cursor: not-allowed;
                transform: none;
                box-shadow: none;
            }

        .btn-add-cart {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(135deg,#059669,#047857);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 14px 36px;
            font-size: 15px;
            font-weight: 800;
            cursor: pointer;
            transition: all .2s;
            box-shadow: 0 4px 16px rgba(5,150,105,.3);
        }

            .btn-add-cart:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(5,150,105,.35);
            }

        .empty-state {
            text-align: center;
            padding: 48px 24px;
            background: var(--bg);
            border-radius: 14px;
            border: 2px dashed var(--bdr);
            color: var(--muted);
        }

            .empty-state .ei {
                font-size: 44px;
                opacity: .3;
                display: block;
                margin-bottom: 12px;
            }

        .mini-sel {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .mini-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--bg2);
            border: 1px solid rgba(37,99,235,.2);
            border-radius: 100px;
            padding: 5px 12px;
            font-size: 12px;
            font-weight: 600;
            color: var(--acc);
        }
    </style>
}

<div class="clf-wrap">

    <a href="javascript:history.back()" class="back-link">
        <i class="bi bi-arrow-left"></i> Back
    </a>

    <div class="clf-header">
        <div class="clf-header-left">
            <h1>🔭 Custom Glasses</h1>
            <p>Pick a frame, choose your lens, select a fitting service.<br>We'll assemble your perfect pair in-store.</p>
        </div>
        <div class="clf-badge">&#10022; Most Popular</div>
    </div>

    <div class="stepper" id="stepperBar">
        <div class="stepper-item active clickable" id="si1" onclick="tryGoStep(1)">
            <div class="stepper-circle">🕶</div>
            <div class="stepper-label">Frame</div>
        </div>
        <div class="stepper-line" id="ln12"></div>
        <div class="stepper-item clickable" id="si2" onclick="tryGoStep(2)">
            <div class="stepper-circle">&#9711;</div>
            <div class="stepper-label">Lens</div>
        </div>
        <div class="stepper-line" id="ln23"></div>
        <div class="stepper-item clickable" id="si3" onclick="tryGoStep(3)">
            <div class="stepper-circle">&#9881;</div>
            <div class="stepper-label">Service</div>
        </div>
        <div class="stepper-line" id="ln34"></div>
        <div class="stepper-item" id="si4">
            <div class="stepper-circle">&#10003;</div>
            <div class="stepper-label">Review</div>
        </div>
    </div>

    <!-- STEP 1: FRAME -->
    <div class="clf-panel active" id="panel1">
        <div class="panel-heading">
            <div class="step-count"><i class="bi bi-1-circle"></i> Step 1 of 4</div>
            <h2>Choose Your Frame</h2>
            <p>Select the frame you'd like your lenses fitted into</p>
        </div>
        @if (Model.Frames.Any())
        {
            <div class="prod-grid" id="frameGrid">
                @foreach (var f in Model.Frames)
                {
                    var img = f.ProductImages?.OrderByDescending(x => x.IsPrimary).FirstOrDefault()?.ImageUrl;
                    <div class="prod-card"
                         data-id="@f.ProductId"
                         data-name="@f.Name"
                         data-price="@f.Price"
                         data-img="@(img ?? "")"
                         onclick="selectFrame(this)">
                        @if (!string.IsNullOrEmpty(img))
                        {
                            <img src="@img" class="prod-img" alt="@f.Name" />
                        }
                        else
                        {
                            <div class="prod-img-ph">🕶</div>
                        }
                        <div class="prod-name">@f.Name</div>
                        <div class="prod-price">@f.Price.ToString("N0") &#x20AB;</div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <span class="ei">🕶</span>
                <p>No frames in stock right now. Check back soon!</p>
            </div>
        }
        <div class="nav-btns">
            <button class="btn-next" id="btnN1" onclick="goStep(2)" disabled>
                Next: Choose Lens <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <!-- STEP 2: LENS -->
    <div class="clf-panel" id="panel2">
        <div class="panel-heading">
            <div class="step-count"><i class="bi bi-2-circle"></i> Step 2 of 4</div>
            <h2>Choose Your Lens</h2>
            <p>Select the lens type to be fitted into your chosen frame</p>
        </div>
        <div class="mini-sel" id="miniSel2"></div>
        @if (Model.Lenses.Any())
        {
            <div class="prod-grid" id="lensGrid">
                @foreach (var l in Model.Lenses)
                {
                    var img = l.ProductImages?.OrderByDescending(x => x.IsPrimary).FirstOrDefault()?.ImageUrl;
                    <div class="prod-card"
                         data-id="@l.ProductId"
                         data-name="@l.Name"
                         data-price="@l.Price"
                         data-img="@(img ?? "")"
                         data-lens-type="@(l.LensType ?? "")"
                         onclick="selectLens(this)">
                        @if (!string.IsNullOrEmpty(img))
                        {
                            <img src="@img" class="prod-img" alt="@l.Name" />
                        }
                        else
                        {
                            <div class="prod-img-ph">&#9711;</div>
                        }
                        <div class="prod-name">@l.Name</div>
                        <div class="prod-price">@l.Price.ToString("N0") &#x20AB;</div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <span class="ei">&#9711;</span>
                <p>No lenses available. Please check back later.</p>
            </div>
        }
        <div class="nav-btns">
            <button class="btn-back" onclick="goStep(1)"><i class="bi bi-arrow-left"></i> Back</button>
            <button class="btn-next" id="btnN2" onclick="goStep(3)" disabled>
                Next: Choose Service <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <!-- STEP 3: SERVICE -->
    <div class="clf-panel" id="panel3">
        <div class="panel-heading">
            <div class="step-count"><i class="bi bi-3-circle"></i> Step 3 of 4</div>
            <h2>Choose a Fitting Service</h2>
            <p>Select the workmanship tier for your order</p>
        </div>
        <div class="mini-sel" id="miniSel3"></div>
        @if (Model.Services.Any())
        {
            <div class="svc-grid" id="serviceGrid">
                @foreach (var s in Model.Services)
                {
                    <div class="svc-card"
                         data-id="@s.ServiceId"
                         data-name="@s.Name"
                         data-price="@s.Price"
                         data-dur="@(s.DurationMin.HasValue? s.DurationMin + " min" : "")"
                         onclick="selectService(this)">
                        <span class="svc-icon">&#9881;</span>
                        <div class="svc-name">@s.Name</div>
                        @if (!string.IsNullOrEmpty(s.Description))
                        {
                            <div class="svc-desc">@s.Description</div>
                        }
                        <div class="svc-meta">
                            <div class="svc-price">@s.Price.ToString("N0") &#x20AB;</div>
                            @if (s.DurationMin.HasValue)
                            {
                                <div class="svc-dur"><i class="bi bi-clock"></i> @s.DurationMin min</div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <span class="ei">&#9881;</span>
                <p>No fitting services available right now.</p>
            </div>
        }
        <div class="nav-btns">
            <button class="btn-back" onclick="goStep(2)"><i class="bi bi-arrow-left"></i> Back</button>
            <button class="btn-next" id="btnN3" onclick="goStep(4)" disabled>
                Review Order <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <!-- STEP 4: REVIEW -->
    <div class="clf-panel" id="panel4">
        <div class="panel-heading">
            <div class="step-count"><i class="bi bi-4-circle"></i> Step 4 of 4</div>
            <h2>Review Your Order</h2>
            <p>Confirm your selections before adding to cart</p>
        </div>
        <div class="summary-card">
            <div class="summary-header">
                <i class="bi bi-receipt" style="color:rgba(255,255,255,.7);font-size:16px"></i>
                <h3>Order Summary — Custom Glasses</h3>
            </div>
            <div class="summary-body" id="summaryBody"></div>
        </div>
        <form method="post" asp-page="/Cart/Add" id="addForm">
            <input type="hidden" name="ProductId" id="fFrameId" />
            <input type="hidden" name="LensProductId" id="fLensId" />
            <input type="hidden" name="ServiceId" id="fServiceId" />
            <input type="hidden" name="Quantity" value="1" />
            <div class="nav-btns">
                <button type="button" class="btn-back" onclick="goStep(3)">
                    <i class="bi bi-arrow-left"></i> Back
                </button>
                <button type="submit" class="btn-add-cart">
                    <i class="bi bi-cart-plus"></i> Add to Cart
                </button>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    <script>
        let sel = { frame: null, lens: null, service: null };
        const steps = 4;

        function tryGoStep(n) {
            if (n >= 2 && !sel.frame)   { shake('panel1'); return; }
            if (n >= 3 && !sel.lens)    { shake('panel2'); return; }
            if (n >= 4 && !sel.service) { shake('panel3'); return; }
            goStep(n);
        }
        function goStep(n) {
            for (let i = 1; i <= steps; i++)
                document.getElementById('panel' + i)?.classList.toggle('active', i === n);
            updateStepper(n);
            if (n === 2) renderMini('miniSel2', ['frame']);
            if (n === 3) renderMini('miniSel3', ['frame', 'lens']);
            if (n === 4) buildSummary();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        function updateStepper(cur) {
            for (let i = 1; i <= steps; i++) {
                const el = document.getElementById('si' + i); if (!el) continue;
                el.classList.remove('active', 'done');
                if (i < cur)        el.classList.add('done');
                else if (i === cur) el.classList.add('active');
            }
            [['ln12',2],['ln23',3],['ln34',4]].forEach(([id, t]) =>
                document.getElementById(id)?.classList.toggle('done', cur >= t));
        }
        function shake(panelId) {
            const el = document.getElementById(panelId);
            let t = 0; const s = [4,-4,3,-3,2,-2,0];
            const next = () => {
                if (t >= s.length) { el.style.transform = ''; return; }
                el.style.transform = 'translateX(' + s[t] + 'px)'; t++;
                setTimeout(next, 60);
            };
            next();
        }
        function renderMini(containerId, keys) {
            const icons = { frame: '🕶', lens: 'O', service: 'S' };
            const el = document.getElementById(containerId); if (!el) return;
            el.innerHTML = keys.filter(k => sel[k]).map(k =>
                '<div class="mini-pill">' + icons[k] + ' ' + sel[k].name +
                '<strong style="margin-left:4px;color:#b8862a">' +
                sel[k].price.toLocaleString('vi-VN') + ' &#x20AB;</strong></div>'
            ).join('');
        }
        // Frame → compatible lens types map (from server)
        const compatMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CompatibilityMap));

        function selectFrame(card) {
            document.querySelectorAll('#frameGrid .prod-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            sel.frame = { id: card.dataset.id, name: card.dataset.name,
                          price: parseFloat(card.dataset.price), img: card.dataset.img };
            document.getElementById('btnN1').disabled = false;

            // Filter lenses by compatible types (empty = show all)
            const frameId = parseInt(card.dataset.id);
            const allowed = compatMap[frameId] || null;
            document.querySelectorAll('#lensGrid .prod-card').forEach(c => {
                const lt = c.dataset.lensType || '';
                c.style.display = (!allowed || allowed.includes(lt)) ? '' : 'none';
            });
            // Reset lens selection if current lens is now hidden
            if (sel.lens && allowed && !allowed.includes(
                document.querySelector('#lensGrid .prod-card.selected')?.dataset.lensType || '')) {
                sel.lens = null;
                document.querySelectorAll('#lensGrid .prod-card').forEach(c => c.classList.remove('selected'));
                document.getElementById('btnN2').disabled = true;
            }
        }
        function selectLens(card) {
            document.querySelectorAll('#lensGrid .prod-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            sel.lens = { id: card.dataset.id, name: card.dataset.name,
                         price: parseFloat(card.dataset.price), img: card.dataset.img };
            document.getElementById('btnN2').disabled = false;
        }
        function selectService(card) {
            document.querySelectorAll('#serviceGrid .svc-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            sel.service = { id: card.dataset.id, name: card.dataset.name,
                            price: parseFloat(card.dataset.price), dur: card.dataset.dur };
            document.getElementById('btnN3').disabled = false;
        }
        function buildSummary() {
            const f = sel.frame, l = sel.lens, s = sel.service;
            const total = f.price + l.price + s.price;
            const thumb = (img, em) => img
                ? '<img src="' + img + '" class="sum-thumb" />'
                : '<div class="sum-thumb-ph">' + em + '</div>';
            const rows = [
                { label: 'Frame',           emoji: '🕶', item: f },
                { label: 'Lens',            emoji: 'O',  item: l },
                { label: 'Fitting Service', emoji: 'S',  item: s }
            ].map(function(r) {
                return '<div class="sum-row">' +
                    '<div class="sum-item-left">' +
                    thumb(r.item.img || '', r.emoji) +
                    '<div class="sum-item-info">' +
                    '<div class="lbl">' + r.label + '</div>' +
                    '<div class="val">' + r.item.name +
                    (r.item.dur ? '<span style="font-size:11px;color:#94a3b8;margin-left:6px">· ' + r.item.dur + '</span>' : '') +
                    '</div></div></div>' +
                    '<div class="sum-price">' + r.item.price.toLocaleString('vi-VN') + ' &#x20AB;</div>' +
                    '</div>';
            }).join('');

            document.getElementById('summaryBody').innerHTML = rows +
                '<div class="sum-row total-row">' +
                '<div class="total-label">Total</div>' +
                '<div class="total-price">' + total.toLocaleString('vi-VN') + ' &#x20AB;</div>' +
                '</div>';

            document.getElementById('fFrameId').value   = f.id;
            document.getElementById('fLensId').value    = l.id;
            document.getElementById('fServiceId').value = s.id;
        }

        updateStepper(1);
    </script>
}
