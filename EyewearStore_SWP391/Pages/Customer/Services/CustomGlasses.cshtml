@page
@model EyewearStore_SWP391.Pages.Customer.Services.CustomGlassesModel
@{
    ViewData["Title"] = "Custom Glasses";
    Layout = "_Layout";
}

@section Styles {
    <style>
        :root {
            --navy: #0f1e3c;
            --gold: #b8862a;
            --acc: #2563eb;
            --ok: #059669;
            --txt: #0f172a;
            --txt2: #475569;
            --muted: #94a3b8;
            --surf: #ffffff;
            --bg: #f8fafc;
            --bg2: #f0f4ff;
            --bdr: #e2e8f0;
        }

        *, *::before, *::after { box-sizing: border-box; }

        .clf-wrap { max-width: 1060px; margin: 0 auto; padding: 40px 24px 100px; }

        .back-link { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; color: var(--muted); text-decoration: none; margin-bottom: 32px; transition: color .2s; }
        .back-link:hover { color: var(--txt); }

        .clf-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; margin-bottom: 40px; flex-wrap: wrap; }
        .clf-header-left h1 { font-size: clamp(1.6rem,4vw,2.4rem); font-weight: 900; color: var(--navy); letter-spacing: -.8px; margin: 0 0 8px; }
        .clf-header-left p { font-size: 14px; color: var(--txt2); margin: 0; line-height: 1.5; }
        .clf-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(184,134,42,.1); border: 1px solid rgba(184,134,42,.25); color: var(--gold); border-radius: 100px; padding: 6px 14px; font-size: 12px; font-weight: 700; letter-spacing: .8px; white-space: nowrap; flex-shrink: 0; margin-top: 4px; }

        .stepper { display: flex; align-items: center; margin-bottom: 44px; overflow-x: auto; padding: 4px 2px 8px; }
        .stepper-item { display: flex; flex-direction: column; align-items: center; gap: 8px; flex: 1; min-width: 80px; cursor: default; position: relative; }
        .stepper-item.clickable { cursor: pointer; }
        .stepper-item.hidden-step { display: none !important; }
        .stepper-circle { width: 48px; height: 48px; border-radius: 50%; background: var(--bdr); border: 2.5px solid #cbd5e1; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 800; color: var(--muted); transition: all .25s; position: relative; z-index: 1; }
        .stepper-item.active .stepper-circle { background: var(--navy); border-color: var(--navy); color: white; box-shadow: 0 4px 18px rgba(15,30,60,.25); transform: scale(1.05); }
        .stepper-item.done .stepper-circle { background: var(--ok); border-color: var(--ok); color: white; font-size: 16px; }
        .stepper-label { font-size: 11px; font-weight: 700; color: var(--muted); text-align: center; text-transform: uppercase; letter-spacing: .8px; white-space: nowrap; }
        .stepper-item.active .stepper-label { color: var(--navy); }
        .stepper-item.done .stepper-label { color: var(--ok); }
        .stepper-line { flex: 1; height: 2px; background: var(--bdr); min-width: 20px; margin-bottom: 28px; transition: background .3s; }
        .stepper-line.done { background: var(--ok); }
        .stepper-line.hidden-step { display: none !important; }

        .step-count { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; color: var(--muted); background: var(--bg); border: 1px solid var(--bdr); border-radius: 100px; padding: 4px 12px; margin-bottom: 12px; }
        .clf-panel { display: none; }
        .clf-panel.active { display: block; }

        .panel-heading { margin-bottom: 24px; }
        .panel-heading h2 { font-size: 1.5rem; font-weight: 800; color: var(--txt); margin: 0 0 4px; letter-spacing: -.4px; }
        .panel-heading p { font-size: 13.5px; color: var(--txt2); margin: 0; }

        .prod-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(170px,1fr)); gap: 14px; margin-bottom: 8px; }
        .prod-card { border: 2px solid var(--bdr); border-radius: 14px; padding: 18px 14px; cursor: pointer; transition: all .2s; background: var(--surf); text-align: center; position: relative; }
        .prod-card:hover { border-color: var(--navy); box-shadow: 0 6px 20px rgba(15,30,60,.1); transform: translateY(-2px); }
        .prod-card.selected { border-color: var(--navy); background: rgba(15,30,60,.03); box-shadow: 0 0 0 4px rgba(15,30,60,.08); }
        .prod-card.selected::after { content: '✓'; position: absolute; top: 8px; right: 10px; width: 22px; height: 22px; background: var(--ok); color: white; border-radius: 50%; font-size: 11px; font-weight: 800; display: flex; align-items: center; justify-content: center; line-height: 22px; }
        .prod-img { width: 76px; height: 76px; object-fit: cover; border-radius: 10px; margin: 0 auto 10px; display: block; }
        .prod-img-ph { width: 76px; height: 76px; border-radius: 10px; margin: 0 auto 10px; background: var(--bg2); display: flex; align-items: center; justify-content: center; font-size: 28px; }
        .prod-name { font-size: 13px; font-weight: 700; color: var(--txt); margin-bottom: 4px; line-height: 1.3; }
        .prod-price { font-size: 13px; font-weight: 700; color: var(--gold); }

        .svc-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(210px,1fr)); gap: 14px; margin-bottom: 8px; }
        .svc-card { border: 2px solid var(--bdr); border-radius: 14px; padding: 20px 18px; cursor: pointer; transition: all .2s; background: var(--surf); position: relative; }
        .svc-card:hover { border-color: var(--navy); box-shadow: 0 6px 20px rgba(15,30,60,.1); transform: translateY(-2px); }
        .svc-card.selected { border-color: var(--navy); background: rgba(15,30,60,.03); box-shadow: 0 0 0 4px rgba(15,30,60,.08); }
        .svc-card.selected::after { content: '✓'; position: absolute; top: 10px; right: 12px; width: 22px; height: 22px; background: var(--ok); color: white; border-radius: 50%; font-size: 11px; font-weight: 800; line-height: 22px; text-align: center; }
        .svc-icon { font-size: 24px; margin-bottom: 10px; display: block; }
        .svc-name { font-size: 14px; font-weight: 700; color: var(--txt); margin-bottom: 4px; }
        .svc-desc { font-size: 12px; color: var(--txt2); margin-bottom: 10px; line-height: 1.45; }
        .svc-meta { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 4px; }
        .svc-price { font-size: 14px; font-weight: 800; color: var(--gold); }
        .svc-dur { font-size: 11px; color: var(--muted); font-weight: 500; }

        /* ── Prescription cards ── */
        .rx-grid { display: grid; grid-template-columns: repeat(auto-fill,minmax(240px,1fr)); gap: 14px; margin-bottom: 16px; }
        .rx-card { border: 2px solid var(--bdr); border-radius: 14px; padding: 18px; cursor: pointer; transition: all .2s; background: var(--surf); position: relative; }
        .rx-card:hover { border-color: var(--navy); box-shadow: 0 6px 20px rgba(15,30,60,.1); transform: translateY(-2px); }
        .rx-card.selected { border-color: var(--navy); background: rgba(15,30,60,.03); box-shadow: 0 0 0 4px rgba(15,30,60,.08); }
        .rx-card.selected::after { content: '✓'; position: absolute; top: 10px; right: 12px; width: 22px; height: 22px; background: var(--ok); color: white; border-radius: 50%; font-size: 11px; font-weight: 800; line-height: 22px; text-align: center; }
        .rx-card.skip-card { border-style: dashed; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 120px; }
        .rx-card.skip-card .skip-icon { font-size: 28px; margin-bottom: 8px; opacity: .5; }
        .rx-card.skip-card .skip-text { font-size: 13px; font-weight: 600; color: var(--txt2); }
        .rx-name { font-size: 14px; font-weight: 700; color: var(--txt); margin-bottom: 10px; }
        .rx-eye-row { display: flex; justify-content: space-between; font-size: 12px; padding: 4px 0; border-bottom: 1px solid var(--bdr); }
        .rx-eye-row:last-child { border-bottom: none; }
        .rx-eye-label { font-weight: 700; color: var(--muted); text-transform: uppercase; font-size: 10px; letter-spacing: .5px; }
        .rx-eye-vals { display: flex; gap: 12px; }
        .rx-eye-vals span { font-weight: 600; color: var(--txt); }

        /* ── Inline create form ── */
        .rx-create-toggle { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: var(--acc); cursor: pointer; padding: 8px 0; border: none; background: none; transition: color .2s; }
        .rx-create-toggle:hover { color: var(--navy); }
        .rx-create-form { display: none; background: var(--bg); border: 1.5px solid var(--bdr); border-radius: 14px; padding: 24px; margin-top: 8px; margin-bottom: 16px; }
        .rx-create-form.open { display: block; }
        .rx-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 16px; }
        .rx-form-group { }
        .rx-form-group h4 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--muted); margin: 0 0 10px; }
        .rx-field-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .rx-field label { font-size: 11px; font-weight: 600; color: var(--txt2); display: block; margin-bottom: 3px; }
        .rx-field input { width: 100%; padding: 8px 10px; border: 1.5px solid var(--bdr); border-radius: 8px; font-size: 13px; transition: border-color .2s; }
        .rx-field input:focus { outline: none; border-color: var(--navy); }
        .rx-name-field { margin-bottom: 16px; }
        .rx-name-field label { font-size: 12px; font-weight: 600; color: var(--txt2); display: block; margin-bottom: 4px; }
        .rx-name-field input { width: 100%; max-width: 300px; padding: 8px 12px; border: 1.5px solid var(--bdr); border-radius: 8px; font-size: 13px; }
        .btn-save-rx { display: inline-flex; align-items: center; gap: 8px; background: var(--navy); color: white; border: none; border-radius: 10px; padding: 10px 22px; font-size: 13px; font-weight: 700; cursor: pointer; transition: all .2s; }
        .btn-save-rx:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(15,30,60,.2); }
        .btn-save-rx:disabled { opacity: .4; cursor: not-allowed; transform: none; }
        .rx-msg { font-size: 12px; margin-top: 8px; font-weight: 600; }
        .rx-msg.success { color: var(--ok); }
        .rx-msg.error { color: #ef4444; }

        .summary-card { background: var(--surf); border: 2px solid var(--bdr); border-radius: 18px; overflow: hidden; margin-bottom: 24px; box-shadow: 0 4px 20px rgba(15,30,60,.06); }
        .summary-header { background: linear-gradient(135deg,var(--navy),#1a2f54); padding: 18px 24px; display: flex; align-items: center; gap: 10px; }
        .summary-header h3 { color: white; font-size: 15px; font-weight: 700; margin: 0; }
        .summary-body { padding: 0 24px; }
        .sum-row { display: flex; justify-content: space-between; align-items: center; padding: 16px 0; border-bottom: 1px solid var(--bdr); gap: 12px; }
        .sum-row:last-child { border-bottom: none; }
        .sum-row.total-row { background: rgba(184,134,42,.05); margin: 0 -24px; padding: 18px 24px; border-bottom: none; }
        .sum-item-left { display: flex; align-items: center; gap: 12px; }
        .sum-thumb { width: 42px; height: 42px; border-radius: 10px; object-fit: cover; border: 1.5px solid var(--bdr); flex-shrink: 0; }
        .sum-thumb-ph { width: 42px; height: 42px; border-radius: 10px; background: var(--bg2); border: 1.5px solid var(--bdr); display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
        .sum-item-info .lbl { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 2px; }
        .sum-item-info .val { font-size: 14px; font-weight: 700; color: var(--txt); }
        .sum-price { font-size: 15px; font-weight: 800; color: var(--gold); white-space: nowrap; }
        .total-label { font-size: 16px; font-weight: 800; color: var(--txt); }
        .total-price { font-size: 22px; font-weight: 900; color: var(--gold); }

        .nav-btns { display: flex; gap: 12px; align-items: center; margin-top: 12px; flex-wrap: wrap; }
        .btn-back { display: inline-flex; align-items: center; gap: 7px; background: var(--bg); color: var(--txt2); border: 1.5px solid var(--bdr); border-radius: 10px; padding: 12px 20px; font-size: 13.5px; font-weight: 600; cursor: pointer; transition: all .2s; text-decoration: none; }
        .btn-back:hover { background: #e2e8f0; color: var(--txt); }
        .btn-next { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg,var(--navy),#1a2f54); color: white; border: none; border-radius: 10px; padding: 12px 28px; font-size: 13.5px; font-weight: 700; cursor: pointer; transition: all .2s; box-shadow: 0 4px 14px rgba(15,30,60,.2); }
        .btn-next:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(15,30,60,.25); }
        .btn-next:disabled { opacity: .35; cursor: not-allowed; transform: none; box-shadow: none; }
        .btn-add-cart { display: inline-flex; align-items: center; gap: 10px; background: linear-gradient(135deg,#059669,#047857); color: white; border: none; border-radius: 10px; padding: 14px 36px; font-size: 15px; font-weight: 800; cursor: pointer; transition: all .2s; box-shadow: 0 4px 16px rgba(5,150,105,.3); }
        .btn-add-cart:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(5,150,105,.35); }

        .empty-state { text-align: center; padding: 48px 24px; background: var(--bg); border-radius: 14px; border: 2px dashed var(--bdr); color: var(--muted); }
        .empty-state .ei { font-size: 44px; opacity: .3; display: block; margin-bottom: 12px; }

        .mini-sel { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
        .mini-pill { display: inline-flex; align-items: center; gap: 6px; background: var(--bg2); border: 1px solid rgba(37,99,235,.2); border-radius: 100px; padding: 5px 12px; font-size: 12px; font-weight: 600; color: var(--acc); }

        .pager { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; margin-top: 20px; margin-bottom: 8px; }
        .pg-btn { height: 36px; min-width: 36px; padding: 0 10px; border: 1.5px solid var(--bdr); border-radius: 8px; background: var(--surf); color: var(--txt2); font-size: 13px; font-weight: 600; cursor: pointer; transition: all .18s; display: inline-flex; align-items: center; justify-content: center; line-height: 1; }
        .pg-btn:hover:not(:disabled) { border-color: var(--navy); color: var(--navy); background: var(--bg2); }
        .pg-btn.active { background: var(--navy); border-color: var(--navy); color: #fff; }
        .pg-btn:disabled { opacity: .35; cursor: not-allowed; }
        .pg-ellipsis { font-size: 13px; color: var(--muted); padding: 0 4px; line-height: 36px; }
        .pg-info { font-size: 12px; color: var(--muted); font-weight: 500; margin-left: 6px; }
    </style>
}

<div class="clf-wrap">

    <a href="javascript:history.back()" class="back-link">
        <i class="bi bi-arrow-left"></i> Back
    </a>

    <div class="clf-header">
        <div class="clf-header-left">
            <h1>🔭 Custom Glasses</h1>
            <p>Pick a frame, choose your lens, add your prescription, select a fitting service.<br>We'll assemble your perfect pair in-store.</p>
        </div>
        <div class="clf-badge">&#10022; Most Popular</div>
    </div>

    <div class="stepper" id="stepperBar">
        <div class="stepper-item active clickable" id="si1" onclick="tryGoStep(1)">
            <div class="stepper-circle">🕶</div>
            <div class="stepper-label">Frame</div>
        </div>
        <div class="stepper-line" id="ln12"></div>
        <div class="stepper-item clickable" id="si2" onclick="tryGoStep(2)">
            <div class="stepper-circle">&#9711;</div>
            <div class="stepper-label">Lens</div>
        </div>
        <div class="stepper-line" id="ln23"></div>
        <div class="stepper-item clickable" id="si3" onclick="tryGoStep(3)">
            <div class="stepper-circle">📋</div>
            <div class="stepper-label">Prescription</div>
        </div>
        <div class="stepper-line" id="ln34"></div>
        <div class="stepper-item clickable" id="si4" onclick="tryGoStep(4)">
            <div class="stepper-circle">&#9881;</div>
            <div class="stepper-label">Service</div>
        </div>
        <div class="stepper-line" id="ln45"></div>
        <div class="stepper-item" id="si5">
            <div class="stepper-circle">&#10003;</div>
            <div class="stepper-label">Review</div>
        </div>
    </div>

    <!-- STEP 1: FRAME -->
    <div class="clf-panel active" id="panel1">
        <div class="panel-heading">
            <div class="step-count"><i class="bi bi-1-circle"></i> <span class="step-label-1">Step 1 of 5</span></div>
            <h2>Choose Your Frame</h2>
            <p>Select the frame you'd like your lenses fitted into</p>
        </div>
        @if (Model.Frames.Any())
        {
            <div class="prod-grid" id="frameGrid">
                @foreach (var f in Model.Frames)
                {
                    var img = f.ProductImages?.OrderByDescending(x => x.IsPrimary).FirstOrDefault()?.ImageUrl;
                    <div class="prod-card"
                         data-id="@f.ProductId"
                         data-name="@f.Name"
                         data-price="@f.Price"
                         data-img="@(img ?? "")"
                         onclick="selectFrame(this)">
                        @if (!string.IsNullOrEmpty(img))
                        {
                            <img src="@img" class="prod-img" alt="@f.Name" />
                        }
                        else
                        {
                            <div class="prod-img-ph">🕶</div>
                        }
                        <div class="prod-name">@f.Name</div>
                        <div class="prod-price">@f.Price.ToString("N0") &#x20AB;</div>
                    </div>
                }
            </div>
            <div class="pager" id="frameGridPager"></div>
        }
        else
        {
            <div class="empty-state">
                <span class="ei">🕶</span>
                <p>No frames in stock right now. Check back soon!</p>
            </div>
        }
        <div class="nav-btns">
            <button class="btn-next" id="btnN1" onclick="goNextStep(1)" disabled>
                Next: Choose Lens <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <!-- STEP 2: LENS -->
    <div class="clf-panel" id="panel2">
        <div class="panel-heading">
            <div class="step-count"><i class="bi bi-2-circle"></i> <span class="step-label-2">Step 2 of 5</span></div>
            <h2>Choose Your Lens</h2>
            <p>Select the lens type to be fitted into your chosen frame</p>
        </div>
        <div class="mini-sel" id="miniSel2"></div>
        @if (Model.Lenses.Any())
        {
            <div class="prod-grid" id="lensGrid">
                @foreach (var l in Model.Lenses)
                {
                    var img = l.ProductImages?.OrderByDescending(x => x.IsPrimary).FirstOrDefault()?.ImageUrl;
                    <div class="prod-card"
                         data-id="@l.ProductId"
                         data-name="@l.Name"
                         data-price="@l.Price"
                         data-img="@(img ?? "")"
                         data-lens-type="@(l.LensType ?? "")"
                         onclick="selectLens(this)">
                        @if (!string.IsNullOrEmpty(img))
                        {
                            <img src="@img" class="prod-img" alt="@l.Name" />
                        }
                        else
                        {
                            <div class="prod-img-ph">&#9711;</div>
                        }
                        <div class="prod-name">@l.Name</div>
                        <div class="prod-price">@l.Price.ToString("N0") &#x20AB;</div>
                    </div>
                }
            </div>
            <div class="pager" id="lensGridPager"></div>
        }
        else
        {
            <div class="empty-state">
                <span class="ei">&#9711;</span>
                <p>No lenses available. Please check back later.</p>
            </div>
        }
        <div class="nav-btns">
            <button class="btn-back" onclick="goPrevStep(2)"><i class="bi bi-arrow-left"></i> Back</button>
            <button class="btn-next" id="btnN2" onclick="goNextStep(2)" disabled>
                Next <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <!-- STEP 3: PRESCRIPTION (conditional) -->
    <div class="clf-panel" id="panel3">
        <div class="panel-heading">
            <div class="step-count"><i class="bi bi-3-circle"></i> <span class="step-label-3">Step 3 of 5</span></div>
            <h2>Add Your Prescription</h2>
            <p>Select a saved prescription profile or create a new one. You can also skip this step.</p>
        </div>
        <div class="mini-sel" id="miniSel3"></div>

        <div class="rx-grid" id="rxGrid">
            <!-- Skip card -->
            <div class="rx-card skip-card selected" onclick="selectPrescription(this, null)" data-rx-id="">
                <div class="skip-icon">🚫</div>
                <div class="skip-text">No Prescription<br><small style="color:var(--muted);font-weight:400">Skip this step</small></div>
            </div>

            @foreach (var rx in Model.PrescriptionProfiles)
            {
                <div class="rx-card" onclick="selectPrescription(this, @rx.PrescriptionId)" data-rx-id="@rx.PrescriptionId"
                     data-rx-name="@rx.ProfileName"
                     data-rx-lsph="@(rx.LeftSph?.ToString("0.00") ?? "")"
                     data-rx-lcyl="@(rx.LeftCyl?.ToString("0.00") ?? "")"
                     data-rx-lax="@(rx.LeftAxis?.ToString() ?? "")"
                     data-rx-rsph="@(rx.RightSph?.ToString("0.00") ?? "")"
                     data-rx-rcyl="@(rx.RightCyl?.ToString("0.00") ?? "")"
                     data-rx-rax="@(rx.RightAxis?.ToString() ?? "")">
                    <div class="rx-name">@(rx.ProfileName ?? "Prescription")</div>
                    <div class="rx-eye-row">
                        <span class="rx-eye-label">OD (Right)</span>
                        <div class="rx-eye-vals">
                            <span>SPH @(rx.RightSph?.ToString("+0.00;-0.00;0.00") ?? "—")</span>
                            <span>CYL @(rx.RightCyl?.ToString("+0.00;-0.00;0.00") ?? "—")</span>
                            <span>AXIS @(rx.RightAxis?.ToString() ?? "—")</span>
                        </div>
                    </div>
                    <div class="rx-eye-row">
                        <span class="rx-eye-label">OS (Left)</span>
                        <div class="rx-eye-vals">
                            <span>SPH @(rx.LeftSph?.ToString("+0.00;-0.00;0.00") ?? "—")</span>
                            <span>CYL @(rx.LeftCyl?.ToString("+0.00;-0.00;0.00") ?? "—")</span>
                            <span>AXIS @(rx.LeftAxis?.ToString() ?? "—")</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Inline create new -->
        <button class="rx-create-toggle" onclick="toggleRxForm()">
            <i class="bi bi-plus-circle"></i> Create a new prescription profile
        </button>
        <div class="rx-create-form" id="rxCreateForm">
            <div class="rx-name-field">
                <label for="rxNewName">Profile Name</label>
                <input type="text" id="rxNewName" placeholder="e.g. My Daily Glasses" />
            </div>
            <div class="rx-form-grid">
                <div class="rx-form-group">
                    <h4>👁 Right Eye (OD)</h4>
                    <div class="rx-field-row">
                        <div class="rx-field"><label>SPH</label><input type="number" id="rxRSph" step="0.25" placeholder="0.00" /></div>
                        <div class="rx-field"><label>CYL</label><input type="number" id="rxRCyl" step="0.25" placeholder="0.00" /></div>
                        <div class="rx-field"><label>AXIS</label><input type="number" id="rxRAxis" step="1" min="0" max="180" placeholder="0" /></div>
                    </div>
                </div>
                <div class="rx-form-group">
                    <h4>👁 Left Eye (OS)</h4>
                    <div class="rx-field-row">
                        <div class="rx-field"><label>SPH</label><input type="number" id="rxLSph" step="0.25" placeholder="0.00" /></div>
                        <div class="rx-field"><label>CYL</label><input type="number" id="rxLCyl" step="0.25" placeholder="0.00" /></div>
                        <div class="rx-field"><label>AXIS</label><input type="number" id="rxLAxis" step="1" min="0" max="180" placeholder="0" /></div>
                    </div>
                </div>
            </div>
            <button class="btn-save-rx" id="btnSaveRx" onclick="saveNewPrescription()">
                <i class="bi bi-check-lg"></i> Save & Use This Prescription
            </button>
            <div class="rx-msg" id="rxMsg"></div>
        </div>

        <div class="nav-btns" style="margin-top:20px">
            <button class="btn-back" onclick="goPrevStep(3)"><i class="bi bi-arrow-left"></i> Back</button>
            <button class="btn-next" id="btnN3" onclick="goNextStep(3)">
                Next: Choose Service <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <!-- STEP 4: SERVICE -->
    <div class="clf-panel" id="panel4">
        <div class="panel-heading">
            <div class="step-count"><i class="bi bi-4-circle"></i> <span class="step-label-4">Step 4 of 5</span></div>
            <h2>Choose a Fitting Service</h2>
            <p>Select the workmanship tier for your order</p>
        </div>
        <div class="mini-sel" id="miniSel4"></div>
        @if (Model.Services.Any())
        {
            <div class="svc-grid" id="serviceGrid">
                @foreach (var s in Model.Services)
                {
                    <div class="svc-card"
                         data-id="@s.ServiceId"
                         data-name="@s.Name"
                         data-price="@s.Price"
                         data-dur="@(s.DurationMin.HasValue? s.DurationMin + " min" : "")"
                         onclick="selectService(this)">
                        <span class="svc-icon">&#9881;</span>
                        <div class="svc-name">@s.Name</div>
                        @if (!string.IsNullOrEmpty(s.Description))
                        {
                            <div class="svc-desc">@s.Description</div>
                        }
                        <div class="svc-meta">
                            <div class="svc-price">@s.Price.ToString("N0") &#x20AB;</div>
                            @if (s.DurationMin.HasValue)
                            {
                                <div class="svc-dur"><i class="bi bi-clock"></i> @s.DurationMin min</div>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="pager" id="serviceGridPager"></div>
        }
        else
        {
            <div class="empty-state">
                <span class="ei">&#9881;</span>
                <p>No fitting services available right now.</p>
            </div>
        }
        <div class="nav-btns">
            <button class="btn-back" onclick="goPrevStep(4)"><i class="bi bi-arrow-left"></i> Back</button>
            <button class="btn-next" id="btnN4" onclick="goNextStep(4)" disabled>
                Review Order <i class="bi bi-arrow-right"></i>
            </button>
        </div>
    </div>

    <!-- STEP 5: REVIEW -->
    <div class="clf-panel" id="panel5">
        <div class="panel-heading">
            <div class="step-count"><i class="bi bi-5-circle"></i> <span class="step-label-5">Step 5 of 5</span></div>
            <h2>Review Your Order</h2>
            <p>Confirm your selections before adding to cart</p>
        </div>
        <div class="summary-card">
            <div class="summary-header">
                <i class="bi bi-receipt" style="color:rgba(255,255,255,.7);font-size:16px"></i>
                <h3>Order Summary — Custom Glasses</h3>
            </div>
            <div class="summary-body" id="summaryBody"></div>
        </div>
        <form method="post" asp-page="/Cart/Add" id="addForm">
            <input type="hidden" name="ProductId" id="fFrameId" />
            <input type="hidden" name="LensProductId" id="fLensId" />
            <input type="hidden" name="ServiceId" id="fServiceId" />
            <input type="hidden" name="PrescriptionId" id="fPrescriptionId" />
            <input type="hidden" name="Quantity" value="1" />
            <div class="nav-btns">
                <button type="button" class="btn-back" onclick="goPrevStep(5)">
                    <i class="bi bi-arrow-left"></i> Back
                </button>
                <button type="submit" class="btn-add-cart">
                    <i class="bi bi-cart-plus"></i> Add to Cart
                </button>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    <script>
        /* ── State ── */
        let sel = { frame: null, lens: null, prescription: null, service: null };
        const TOTAL_STEPS = 5;
        const RX_STEP = 3; // prescription step number
        const PAGE_SIZE = 8;

        /* ── Data from server ── */
        const compatMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CompatibilityMap));
        const lensRxMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LensPrescriptionMap, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

        /* ── Prescription step visibility ── */
        function isRxStepNeeded() {
            return sel.lens && lensRxMap[parseInt(sel.lens.id)]?.isPrescription === true;
        }

        function getVisibleSteps() {
            if (isRxStepNeeded()) return [1, 2, 3, 4, 5];
            return [1, 2, 4, 5]; // skip step 3
        }

        function getStepPosition(step) {
            const vs = getVisibleSteps();
            return vs.indexOf(step) + 1;
        }

        function getTotalVisibleSteps() {
            return getVisibleSteps().length;
        }

        function goNextStep(current) {
            const vs = getVisibleSteps();
            const idx = vs.indexOf(current);
            if (idx >= 0 && idx < vs.length - 1) goStep(vs[idx + 1]);
        }

        function goPrevStep(current) {
            const vs = getVisibleSteps();
            const idx = vs.indexOf(current);
            if (idx > 0) goStep(vs[idx - 1]);
        }

        function updateStepperVisibility() {
            const show = isRxStepNeeded();
            document.getElementById('si3')?.classList.toggle('hidden-step', !show);
            document.getElementById('ln23')?.classList.toggle('hidden-step', !show);
            // Update step count labels
            const vs = getVisibleSteps();
            const total = vs.length;
            vs.forEach((step, i) => {
                const label = document.querySelector('.step-label-' + step);
                if (label) label.textContent = 'Step ' + (i + 1) + ' of ' + total;
            });
        }

        /* ── Pagination ── */
        const pagers = {};

        function initPager(gridId, pagerId) {
            const allCards = Array.from(document.querySelectorAll(
                '#' + gridId + ' .prod-card, #' + gridId + ' .svc-card'
            ));
            pagers[gridId] = { allCards, visibleCards: allCards, currentPage: 1, pagerId };
            renderPage(gridId);
        }

        function getVisibleCardsForPager(gridId) {
            return pagers[gridId].allCards.filter(c => !c._compatHidden);
        }

        function renderPage(gridId) {
            const state = pagers[gridId];
            if (!state) return;
            state.visibleCards = getVisibleCardsForPager(gridId);
            const tp = Math.ceil(state.visibleCards.length / PAGE_SIZE) || 1;
            if (state.currentPage > tp) state.currentPage = 1;
            state.allCards.forEach(c => c.style.display = 'none');
            const start = (state.currentPage - 1) * PAGE_SIZE;
            state.visibleCards.slice(start, start + PAGE_SIZE).forEach(c => c.style.display = '');
            buildPagerUI(gridId, tp, state.visibleCards.length);
        }

        function buildPagerUI(gridId, tp, total) {
            const state = pagers[gridId];
            const page = state.currentPage;
            const el = document.getElementById(state.pagerId);
            if (!el) return;
            if (tp <= 1) { el.innerHTML = ''; return; }
            let html = `<button class="pg-btn" onclick="changePage('${gridId}',${page - 1})" ${page === 1 ? 'disabled' : ''}>&#8249; Prev</button>`;
            for (let i = 1; i <= tp; i++) {
                if (tp > 7 && i > 2 && i < tp - 1 && Math.abs(i - page) > 1) {
                    if (i === 3 || i === tp - 2) html += `<span class="pg-ellipsis">…</span>`;
                    continue;
                }
                html += `<button class="pg-btn ${i === page ? 'active' : ''}" onclick="changePage('${gridId}',${i})">${i}</button>`;
            }
            html += `<button class="pg-btn" onclick="changePage('${gridId}',${page + 1})" ${page === tp ? 'disabled' : ''}>Next &#8250;</button>`;
            const from = (page - 1) * PAGE_SIZE + 1;
            const to = Math.min(page * PAGE_SIZE, total);
            html += `<span class="pg-info">${from}–${to} / ${total}</span>`;
            el.innerHTML = html;
        }

        function changePage(gridId, n) {
            const state = pagers[gridId];
            if (!state) return;
            const tp = Math.ceil(state.visibleCards.length / PAGE_SIZE) || 1;
            state.currentPage = Math.max(1, Math.min(n, tp));
            renderPage(gridId);
        }

        /* ── Stepper ── */
        function tryGoStep(n) {
            if (n >= 2 && !sel.frame) { shake('panel1'); return; }
            if (n >= 3 && !sel.lens) { shake('panel2'); return; }
            if (n >= 4 && !isRxStepNeeded() && n === 3) return; // can't click hidden step
            if (n >= 4 && !sel.lens) { shake('panel2'); return; }
            if (n >= 5 && !sel.service) { shake('panel4'); return; }
            goStep(n);
        }

        function goStep(n) {
            for (let i = 1; i <= TOTAL_STEPS; i++)
                document.getElementById('panel' + i)?.classList.toggle('active', i === n);
            updateStepper(n);
            if (n === 2) { renderMini('miniSel2', ['frame']); initPager('lensGrid', 'lensGridPager'); }
            if (n === 3) { renderMini('miniSel3', ['frame', 'lens']); }
            if (n === 4) { renderMini('miniSel4', ['frame', 'lens']); initPager('serviceGrid', 'serviceGridPager'); }
            if (n === 5) buildSummary();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function updateStepper(cur) {
            const vs = getVisibleSteps();
            for (let i = 1; i <= TOTAL_STEPS; i++) {
                const el = document.getElementById('si' + i); if (!el) continue;
                el.classList.remove('active', 'done');
                if (vs.includes(i)) {
                    if (vs.indexOf(i) < vs.indexOf(cur)) el.classList.add('done');
                    else if (i === cur) el.classList.add('active');
                }
            }
            [['ln12', 2], ['ln23', 3], ['ln34', 4], ['ln45', 5]].forEach(([id, t]) => {
                const line = document.getElementById(id);
                if (line && !line.classList.contains('hidden-step'))
                    line.classList.toggle('done', vs.indexOf(cur) >= vs.indexOf(t));
            });
        }

        function shake(panelId) {
            const el = document.getElementById(panelId);
            let t = 0; const s = [4, -4, 3, -3, 2, -2, 0];
            const next = () => {
                if (t >= s.length) { el.style.transform = ''; return; }
                el.style.transform = 'translateX(' + s[t] + 'px)'; t++;
                setTimeout(next, 60);
            };
            next();
        }

        function renderMini(containerId, keys) {
            const icons = { frame: '🕶', lens: 'O', service: 'S', prescription: '📋' };
            const el = document.getElementById(containerId); if (!el) return;
            el.innerHTML = keys.filter(k => sel[k]).map(k =>
                '<div class="mini-pill">' + icons[k] + ' ' + sel[k].name +
                '<strong style="margin-left:4px;color:#b8862a">' +
                (sel[k].price !== undefined ? sel[k].price.toLocaleString('vi-VN') + ' &#x20AB;' : '') +
                '</strong></div>'
            ).join('');
        }

        /* ── Selection: Frame ── */
        function selectFrame(card) {
            document.querySelectorAll('#frameGrid .prod-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            sel.frame = { id: card.dataset.id, name: card.dataset.name, price: parseFloat(card.dataset.price), img: card.dataset.img };
            document.getElementById('btnN1').disabled = false;

            const frameId = parseInt(card.dataset.id);
            const allowed = compatMap[frameId] || null;
            
            // Set _compatHidden directly on the lens cards in the DOM
            // so it works even if the lens pager hasn't been initialized yet.
            document.querySelectorAll('#lensGrid .prod-card').forEach(c => {
                const lt = c.dataset.lensType || '';
                c._compatHidden = !(!allowed || allowed.includes(lt));
            });

            const selCard = document.querySelector('#lensGrid .prod-card.selected');
            if (sel.lens && selCard && selCard._compatHidden) {
                sel.lens = null;
                selCard.classList.remove('selected');
                document.getElementById('btnN2').disabled = true;
            }

            const lensState = pagers['lensGrid'];
            if (lensState) {
                lensState.currentPage = 1;
                renderPage('lensGrid');
            }
        }

        /* ── Selection: Lens ── */
        function selectLens(card) {
            document.querySelectorAll('#lensGrid .prod-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            const lensId = parseInt(card.dataset.id);
            const rxInfo = lensRxMap[lensId] || { isPrescription: false, prescriptionFee: 0 };
            sel.lens = {
                id: card.dataset.id, name: card.dataset.name,
                price: parseFloat(card.dataset.price), img: card.dataset.img,
                isPrescription: rxInfo.isPrescription, prescriptionFee: rxInfo.prescriptionFee
            };
            document.getElementById('btnN2').disabled = false;

            // Reset prescription if lens changed and doesn't need one
            if (!rxInfo.isPrescription) {
                sel.prescription = null;
                resetRxSelection();
            }
            updateStepperVisibility();
        }

        function resetRxSelection() {
            document.querySelectorAll('#rxGrid .rx-card').forEach(c => c.classList.remove('selected'));
            const skipCard = document.querySelector('#rxGrid .rx-card.skip-card');
            if (skipCard) skipCard.classList.add('selected');
        }

        /* ── Selection: Prescription ── */
        function selectPrescription(card, rxId) {
            document.querySelectorAll('#rxGrid .rx-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            if (rxId) {
                sel.prescription = {
                    id: rxId,
                    name: card.dataset.rxName || 'Prescription',
                    fee: sel.lens ? sel.lens.prescriptionFee : 0
                };
            } else {
                sel.prescription = null; // skip
            }
        }

        /* ── Selection: Service ── */
        function selectService(card) {
            document.querySelectorAll('#serviceGrid .svc-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            sel.service = { id: card.dataset.id, name: card.dataset.name, price: parseFloat(card.dataset.price), dur: card.dataset.dur };
            document.getElementById('btnN4').disabled = false;
        }

        /* ── Inline Prescription Creation ── */
        function toggleRxForm() {
            document.getElementById('rxCreateForm').classList.toggle('open');
        }

        async function saveNewPrescription() {
            const btn = document.getElementById('btnSaveRx');
            const msgEl = document.getElementById('rxMsg');
            btn.disabled = true;
            msgEl.textContent = 'Saving...';
            msgEl.className = 'rx-msg';

            const body = new URLSearchParams({
                profileName: document.getElementById('rxNewName').value,
                rightSph: document.getElementById('rxRSph').value,
                rightCyl: document.getElementById('rxRCyl').value,
                rightAxis: document.getElementById('rxRAxis').value,
                leftSph: document.getElementById('rxLSph').value,
                leftCyl: document.getElementById('rxLCyl').value,
                leftAxis: document.getElementById('rxLAxis').value
            });

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                           || document.querySelector('meta[name="RequestVerificationToken"]')?.content || '';
                const res = await fetch('?handler=CreatePrescription', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: body.toString()
                });
                const data = await res.json();
                if (data.success) {
                    msgEl.textContent = '✓ Prescription saved!';
                    msgEl.className = 'rx-msg success';
                    // Add new card to grid
                    const grid = document.getElementById('rxGrid');
                    const newCard = document.createElement('div');
                    newCard.className = 'rx-card';
                    newCard.setAttribute('data-rx-id', data.prescriptionId);
                    newCard.setAttribute('data-rx-name', data.profileName);
                    newCard.setAttribute('onclick', `selectPrescription(this, ${data.prescriptionId})`);
                    const fmtVal = (v) => v != null ? (v >= 0 ? '+' : '') + parseFloat(v).toFixed(2) : '—';
                    newCard.innerHTML =
                        `<div class="rx-name">${data.profileName}</div>
                         <div class="rx-eye-row"><span class="rx-eye-label">OD (Right)</span>
                           <div class="rx-eye-vals"><span>SPH ${fmtVal(data.rightSph)}</span><span>CYL ${fmtVal(data.rightCyl)}</span><span>AXIS ${data.rightAxis ?? '—'}</span></div></div>
                         <div class="rx-eye-row"><span class="rx-eye-label">OS (Left)</span>
                           <div class="rx-eye-vals"><span>SPH ${fmtVal(data.leftSph)}</span><span>CYL ${fmtVal(data.leftCyl)}</span><span>AXIS ${data.leftAxis ?? '—'}</span></div></div>`;
                    grid.appendChild(newCard);
                    // Auto-select the new card
                    selectPrescription(newCard, data.prescriptionId);
                    // Clear form
                    document.getElementById('rxCreateForm').classList.remove('open');
                    ['rxNewName','rxRSph','rxRCyl','rxRAxis','rxLSph','rxLCyl','rxLAxis'].forEach(id =>
                        document.getElementById(id).value = '');
                } else {
                    msgEl.textContent = '✗ ' + (data.error || 'Failed to save.');
                    msgEl.className = 'rx-msg error';
                }
            } catch (err) {
                msgEl.textContent = '✗ Network error. Please try again.';
                msgEl.className = 'rx-msg error';
            }
            btn.disabled = false;
        }

        /* ── Summary ── */
        function buildSummary() {
            const f = sel.frame, l = sel.lens, s = sel.service, rx = sel.prescription;
            let total = f.price + l.price + s.price;
            const rxFee = rx ? (l.prescriptionFee || 0) : 0;
            total += rxFee;

            const thumb = (img, em) => img
                ? '<img src="' + img + '" class="sum-thumb" />'
                : '<div class="sum-thumb-ph">' + em + '</div>';

            const rows = [
                { label: 'Frame', emoji: '🕶', item: f },
                { label: 'Lens', emoji: 'O', item: l },
                { label: 'Fitting Service', emoji: 'S', item: s }
            ].map(r =>
                '<div class="sum-row">' +
                '<div class="sum-item-left">' +
                thumb(r.item.img || '', r.emoji) +
                '<div class="sum-item-info">' +
                '<div class="lbl">' + r.label + '</div>' +
                '<div class="val">' + r.item.name +
                (r.item.dur ? '<span style="font-size:11px;color:#94a3b8;margin-left:6px">· ' + r.item.dur + '</span>' : '') +
                '</div></div></div>' +
                '<div class="sum-price">' + r.item.price.toLocaleString('vi-VN') + ' &#x20AB;</div>' +
                '</div>'
            ).join('');

            let rxRow = '';
            if (rx) {
                rxRow = '<div class="sum-row">' +
                    '<div class="sum-item-left">' +
                    '<div class="sum-thumb-ph">📋</div>' +
                    '<div class="sum-item-info">' +
                    '<div class="lbl">Prescription</div>' +
                    '<div class="val">' + rx.name + '</div>' +
                    '</div></div>' +
                    '<div class="sum-price">' + rxFee.toLocaleString('vi-VN') + ' &#x20AB;</div>' +
                    '</div>';
            }

            document.getElementById('summaryBody').innerHTML = rows + rxRow +
                '<div class="sum-row total-row">' +
                '<div class="total-label">Total</div>' +
                '<div class="total-price">' + total.toLocaleString('vi-VN') + ' &#x20AB;</div>' +
                '</div>';

            document.getElementById('fFrameId').value = f.id;
            document.getElementById('fLensId').value = l.id;
            document.getElementById('fServiceId').value = s.id;
            document.getElementById('fPrescriptionId').value = rx ? rx.id : '';
        }

        /* ── Init ── */
        updateStepper(1);
        updateStepperVisibility();
        initPager('frameGrid', 'frameGridPager');
    </script>
}
