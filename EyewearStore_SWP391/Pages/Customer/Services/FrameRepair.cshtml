@page
@model EyewearStore_SWP391.Pages.Customer.Services.FrameRepairModel
@{
    ViewData["Title"] = "Frame Repair";
    Layout = "_Layout";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #0a0a0f;
            --bone: #f4f0eb;
            --cream: #faf8f5;
            --amber: #c17f3a;
            --amber-pale: #f7edd8;
            --amber-mid: #e8a84e;
            --steel: #6b7280;
            --mist: #e5e2dd;
            --ok: #2d7a5f;
            --bdr: #e0dbd3;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        .rp-page {
            min-height: 100vh;
            background: var(--cream);
            font-family: 'DM Sans', sans-serif;
            color: var(--ink);
        }

        .rp-hero {
            background: var(--ink);
            padding: 56px 32px 48px;
            position: relative;
            overflow: hidden;
        }

            .rp-hero::before {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(193,127,58,.18) 0%, transparent 70%);
                pointer-events: none;
            }

        .rp-hero-inner {
            max-width: 1000px;
            margin: 0 auto;
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 24px;
            flex-wrap: wrap;
        }

        .rp-back {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: rgba(255,255,255,.45);
            text-decoration: none;
            font-size: 12px;
            font-weight: 500;
            letter-spacing: .8px;
            text-transform: uppercase;
            transition: color .2s;
            position: absolute;
            top: 22px;
            left: 32px;
        }

            .rp-back:hover {
                color: rgba(255,255,255,.9)
            }

        .rp-hero-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.4rem, 6vw, 4rem);
            font-weight: 700;
            color: #fff;
            line-height: 1.05;
            letter-spacing: -.5px;
        }

            .rp-hero-title span {
                color: var(--amber-mid);
                font-style: italic;
            }

        .rp-hero-sub {
            font-size: 14px;
            color: rgba(255,255,255,.5);
            margin-top: 10px;
            max-width: 480px;
            line-height: 1.6;
        }

        .rp-price-badge {
            background: linear-gradient(135deg, var(--amber), #9e6228);
            border-radius: 12px;
            padding: 16px 24px;
            text-align: right;
            flex-shrink: 0;
        }

            .rp-price-badge .pb-label {
                font-size: 10px;
                letter-spacing: 1.5px;
                text-transform: uppercase;
                color: rgba(255,255,255,.65);
            }

            .rp-price-badge .pb-val {
                font-family: 'Cormorant Garamond', serif;
                font-size: 2rem;
                font-weight: 700;
                color: #fff;
                margin-top: 2px;
            }

        .rp-stepper-wrap {
            background: #fff;
            border-bottom: 1px solid var(--bdr);
            padding: 0 32px;
        }

        .rp-stepper {
            max-width: 1000px;
            margin: 0 auto;
            display: flex;
            align-items: stretch;
        }

        .rp-step {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 20px 0;
            border-bottom: 3px solid transparent;
            transition: border-color .3s;
            cursor: default;
        }

            .rp-step.active {
                border-color: var(--amber);
            }

            .rp-step.done {
                border-color: var(--ok);
            }

        .rp-step-num {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: 2px solid var(--mist);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
            color: var(--steel);
            transition: all .3s;
            flex-shrink: 0;
        }

        .rp-step.active .rp-step-num {
            background: var(--amber);
            border-color: var(--amber);
            color: #fff;
        }

        .rp-step.done .rp-step-num {
            background: var(--ok);
            border-color: var(--ok);
            color: #fff;
        }

        .rp-step-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: var(--steel);
        }

        .rp-step.active .rp-step-label {
            color: var(--amber);
        }

        .rp-step.done .rp-step-label {
            color: var(--ok);
        }

        .rp-step-desc {
            font-size: 12px;
            color: var(--steel);
            margin-top: 1px;
        }

        .rp-sep {
            width: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--mist);
            flex-shrink: 0;
        }

        .rp-main {
            max-width: 1000px;
            margin: 0 auto;
            padding: 40px 32px 80px;
        }

        .rp-panel {
            display: none;
        }

            .rp-panel.active {
                display: block;
            }

        .panel-head {
            margin-bottom: 28px;
        }

            .panel-head h2 {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.9rem;
                font-weight: 600;
                color: var(--ink);
                letter-spacing: -.3px;
            }

            .panel-head p {
                font-size: 13.5px;
                color: var(--steel);
                margin-top: 6px;
                line-height: 1.55;
            }

        /* Search bar */
        .search-wrap {
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .search-inner {
            position: relative;
            flex: 1;
            max-width: 420px;
        }

            .search-inner i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--steel);
                font-size: 14px;
                pointer-events: none;
            }

        .search-input {
            width: 100%;
            padding: 10px 12px 10px 36px;
            border: 1.5px solid var(--bdr);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            color: var(--ink);
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }

            .search-input:focus {
                border-color: var(--amber);
            }

        .search-count {
            font-size: 12px;
            color: var(--steel);
            white-space: nowrap;
        }

        .frame-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
            gap: 16px;
            margin-bottom: 8px;
        }

        .frame-card {
            background: #fff;
            border: 2px solid var(--bdr);
            border-radius: 14px;
            overflow: hidden;
            cursor: pointer;
            transition: all .25s;
            position: relative;
        }

            .frame-card:hover {
                border-color: var(--amber);
                transform: translateY(-3px);
                box-shadow: 0 8px 28px rgba(193,127,58,.15);
            }

            .frame-card.sel {
                border-color: var(--amber);
                box-shadow: 0 0 0 4px rgba(193,127,58,.12);
            }

                .frame-card.sel::after {
                    content: '✓';
                    position: absolute;
                    top: 10px;
                    right: 10px;
                    width: 24px;
                    height: 24px;
                    background: var(--ok);
                    color: #fff;
                    border-radius: 50%;
                    font-size: 12px;
                    font-weight: 700;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    line-height: 24px;
                    text-align: center;
                }

        .frame-img-wrap {
            height: 120px;
            background: var(--bone);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

            .frame-img-wrap img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .frame-img-ph {
            font-size: 36px;
            opacity: .3;
        }

        .frame-card-body {
            padding: 12px 14px 14px;
        }

        .frame-card-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--ink);
            line-height: 1.3;
        }

        .frame-card-tag {
            display: inline-block;
            margin-top: 5px;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: .6px;
            text-transform: uppercase;
            color: var(--amber);
            background: var(--amber-pale);
            border-radius: 4px;
            padding: 2px 7px;
        }

        .repair-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 8px;
        }

        .repair-row {
            background: #fff;
            border: 2px solid var(--bdr);
            border-radius: 14px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 16px;
            cursor: pointer;
            transition: all .22s;
        }

            .repair-row:hover {
                border-color: var(--amber);
                box-shadow: 0 4px 18px rgba(193,127,58,.1);
            }

            .repair-row.sel {
                border-color: var(--amber);
                background: rgba(193,127,58,.03);
            }

        .repair-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            background: var(--amber-pale);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
        }

        .repair-row.sel .repair-icon {
            background: rgba(193,127,58,.2);
        }

        .repair-info {
            flex: 1;
        }

        .repair-name {
            font-size: 15px;
            font-weight: 600;
            color: var(--ink);
        }

        .repair-desc {
            font-size: 12px;
            color: var(--steel);
            margin-top: 3px;
            line-height: 1.45;
        }

        .repair-meta {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 5px;
            flex-wrap: wrap;
        }

        .repair-dur {
            font-size: 11px;
            color: var(--steel);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .repair-price-col {
            text-align: right;
            flex-shrink: 0;
        }

        .repair-price {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--amber);
        }

        .repair-price-lbl {
            font-size: 10px;
            color: var(--steel);
            letter-spacing: .5px;
        }

        .summary-box {
            background: #fff;
            border: 1px solid var(--bdr);
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 28px;
            box-shadow: 0 2px 16px rgba(0,0,0,.05);
        }

        .sum-hdr {
            background: var(--ink);
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sum-hdr-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: #fff;
        }

        .sum-hdr-badge {
            margin-left: auto;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--amber-mid);
            border: 1px solid rgba(193,127,58,.4);
            border-radius: 4px;
            padding: 3px 9px;
        }

        .sum-row {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 24px;
            border-bottom: 1px solid var(--bdr);
        }

            .sum-row:last-child {
                border-bottom: none
            }

            .sum-row.total {
                background: linear-gradient(135deg, rgba(193,127,58,.06), rgba(193,127,58,.02));
            }

        .sum-thumb {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            object-fit: cover;
            border: 1px solid var(--bdr);
            flex-shrink: 0;
        }

        .sum-ph {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            background: var(--bone);
            border: 1px solid var(--bdr);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .sum-info-lbl {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--steel);
        }

        .sum-info-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--ink);
            margin-top: 2px;
        }

        .sum-price {
            margin-left: auto;
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--amber);
            white-space: nowrap;
        }

        .sum-total-lbl {
            font-size: 15px;
            font-weight: 600;
            color: var(--ink);
        }

        .sum-total-val {
            margin-left: auto;
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 700;
            color: var(--amber);
        }

        .mini-sel {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .mini-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #fff;
            border: 1px solid var(--amber);
            border-radius: 100px;
            padding: 5px 12px 5px 8px;
            font-size: 12px;
            font-weight: 500;
            color: var(--ink);
        }

            .mini-pill .mp-dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--amber);
            }

            .mini-pill strong {
                color: var(--amber);
                font-weight: 600;
            }

        .nav-btns {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: transparent;
            color: var(--steel);
            border: 1.5px solid var(--bdr);
            border-radius: 10px;
            padding: 12px 20px;
            font-size: 13px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
        }

            .btn-back:hover {
                border-color: var(--steel);
                color: var(--ink);
                background: var(--bone);
            }

        .btn-next {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, var(--amber), #9e6228);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 13px 28px;
            font-size: 13.5px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all .22s;
            box-shadow: 0 4px 18px rgba(193,127,58,.3);
        }

            .btn-next:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 26px rgba(193,127,58,.38);
            }

            .btn-next:disabled {
                opacity: .35;
                cursor: not-allowed;
                transform: none;
                box-shadow: none;
            }

        .btn-add {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            background: linear-gradient(135deg, #1a3a2a, var(--ok));
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 14px 34px;
            font-size: 14px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all .22s;
            box-shadow: 0 4px 18px rgba(45,122,95,.3);
        }

            .btn-add:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 26px rgba(45,122,95,.38);
            }

        .empty-state {
            text-align: center;
            padding: 60px 24px;
            background: #fff;
            border-radius: 14px;
            border: 2px dashed var(--bdr);
        }

            .empty-state .ei {
                font-size: 52px;
                opacity: .2;
                display: block;
                margin-bottom: 14px;
            }

            .empty-state p {
                color: var(--steel);
                font-size: 14px;
            }

        .trust-row {
            display: flex;
            gap: 12px;
            margin-top: 32px;
            flex-wrap: wrap;
        }

        .trust-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #fff;
            border: 1px solid var(--bdr);
            border-radius: 100px;
            padding: 8px 16px;
            font-size: 12px;
            font-weight: 500;
            color: var(--steel);
        }

            .trust-chip i {
                color: var(--amber);
            }

        .pager {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
            margin-top: 16px;
            margin-bottom: 20px;
        }

        .pg-btn {
            height: 34px;
            min-width: 34px;
            padding: 0 10px;
            border: 1.5px solid var(--bdr);
            border-radius: 8px;
            background: #fff;
            color: var(--steel);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all .18s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Sans', sans-serif;
        }

            .pg-btn:hover:not(:disabled) {
                border-color: var(--amber);
                color: var(--amber);
                background: var(--amber-pale);
            }

            .pg-btn.active {
                background: var(--amber);
                border-color: var(--amber);
                color: #fff;
            }

            .pg-btn:disabled {
                opacity: .35;
                cursor: not-allowed;
            }

        .pg-ellipsis {
            font-size: 13px;
            color: var(--steel);
            padding: 0 4px;
        }

        .pg-info {
            font-size: 12px;
            color: var(--steel);
            margin-left: 6px;
        }

        @@media (max-width: 600px) {
            .rp-hero {
                padding: 48px 18px 36px
            }

            .rp-main {
                padding: 28px 18px 60px
            }

            .frame-grid {
                grid-template-columns: repeat(auto-fill, minmax(140px, 1fr))
            }

            .rp-stepper-wrap {
                padding: 0 18px
            }
        }
    </style>
}

<div class="rp-page">

    <!-- HERO -->
    <div class="rp-hero">
        <a href="javascript:history.back()" class="rp-back"><i class="bi bi-arrow-left"></i> Back</a>
        <div class="rp-hero-inner">
            <div>
                <h1 class="rp-hero-title">Frame <span>Repair</span><br>Service</h1>
                <p class="rp-hero-sub">Professional frame restoration — bent temples, broken hinges, loose nose pads and more. Handled by our certified opticians.</p>
            </div>
            <div class="rp-price-badge">
                <div class="pb-label">Starting from</div>
                <div class="pb-val">@(Model.Services.Any() ? Model.Services.Min(s => s.Price).ToString("N0") + " ₫" : "—")</div>
            </div>
        </div>
    </div>

    <!-- STEPPER -->
    <div class="rp-stepper-wrap">
        <div class="rp-stepper">
            <div class="rp-step active" id="rs1">
                <div class="rp-step-num" id="rn1">1</div>
                <div class="rp-step-info">
                    <div class="rp-step-label">Select Frame</div>
                    <div class="rp-step-desc">Choose the frame model</div>
                </div>
            </div>
            <div class="rp-sep"><i class="bi bi-chevron-right" style="font-size:11px"></i></div>
            <div class="rp-step" id="rs2">
                <div class="rp-step-num" id="rn2">2</div>
                <div class="rp-step-info">
                    <div class="rp-step-label">Repair Type</div>
                    <div class="rp-step-desc">What needs fixing?</div>
                </div>
            </div>
            <div class="rp-sep"><i class="bi bi-chevron-right" style="font-size:11px"></i></div>
            <div class="rp-step" id="rs3">
                <div class="rp-step-num" id="rn3">3</div>
                <div class="rp-step-info">
                    <div class="rp-step-label">Review & Add</div>
                    <div class="rp-step-desc">Confirm your order</div>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="rp-main">

        <!-- STEP 1: FRAME -->
        <div class="rp-panel active" id="rp1">
            <div class="panel-head">
                <h2>Which frame needs repair?</h2>
                <p>Select the frame model from our catalogue — this helps our technicians source the right parts.</p>
            </div>

            @if (Model.Frames.Any())
            {
                <!-- SEARCH BAR -->
                <div class="search-wrap">
                    <div class="search-inner">
                        <i class="bi bi-search"></i>
                        <input type="text" id="frameSearch" class="search-input"
                               placeholder="Search frames…"
                               oninput="rFilterFrames(this.value)" />
                    </div>
                    <span id="frameCount" class="search-count"></span>
                </div>

                <div class="frame-grid" id="frameGrid">
                    @foreach (var f in Model.Frames)
                    {
                        var img = f.ProductImages?.OrderByDescending(x => x.IsPrimary).FirstOrDefault()?.ImageUrl;
                        <div class="frame-card" data-id="@f.ProductId" data-name="@f.Name"
                             data-img="@(img ?? "")" onclick="rSelectFrame(this)">
                            <div class="frame-img-wrap">
                                @if (!string.IsNullOrEmpty(img))
                                {
                                    <img src="@img" alt="@f.Name" />
                                }
                                else
                                {
                                    <div class="frame-img-ph">🕶</div>
                                }
                            </div>
                            <div class="frame-card-body">
                                <div class="frame-card-name">@f.Name</div>
                                <div class="frame-card-tag">Frame</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="pager" id="frameGridPager"></div>
            }
            else
            {
                <div class="empty-state"><span class="ei">🕶</span><p>No frames in catalogue right now.</p></div>
            }

            <div class="trust-row">
                <div class="trust-chip"><i class="bi bi-shield-check"></i> 90-day repair warranty</div>
                <div class="trust-chip"><i class="bi bi-clock"></i> Same-day service available</div>
                <div class="trust-chip"><i class="bi bi-tools"></i> Certified opticians</div>
            </div>

            <div class="nav-btns" style="margin-top:28px">
                <button class="btn-next" id="rBtn1" onclick="rGoStep(2)" disabled>
                    Continue — Choose Repair <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- STEP 2: REPAIR TYPE -->
        <div class="rp-panel" id="rp2">
            <div class="panel-head">
                <h2>Select repair type</h2>
                <p>Choose the specific repair service your frame needs.</p>
            </div>

            <div class="mini-sel" id="miniSel2"></div>

            @if (Model.Services.Any())
            {
                <!-- SEARCH BAR -->
                <div class="search-wrap">
                    <div class="search-inner">
                        <i class="bi bi-search"></i>
                        <input type="text" id="serviceSearch" class="search-input"
                               placeholder="Search repair services…"
                               oninput="rFilterServices(this.value)" />
                    </div>
                    <span id="serviceCount" class="search-count"></span>
                </div>

                <div class="repair-list" id="repairGrid">
                    @foreach (var s in Model.Services)
                    {
                        <div class="repair-row" data-id="@s.ServiceId" data-name="@s.Name"
                             data-price="@s.Price" onclick="rSelectService(this)">
                            <div class="repair-icon">🛠</div>
                            <div class="repair-info">
                                <div class="repair-name">@s.Name</div>
                                @if (!string.IsNullOrEmpty(s.Description))
                                {
                                    <div class="repair-desc">@s.Description</div>
                                }
                                <div class="repair-meta">
                                    @if (s.DurationMin.HasValue)
                                    {
                                        <div class="repair-dur"><i class="bi bi-clock" style="font-size:10px"></i> ~@s.DurationMin min</div>
                                    }
                                </div>
                            </div>
                            <div class="repair-price-col">
                                <div class="repair-price">@s.Price.ToString("N0")</div>
                                <div class="repair-price-lbl">₫</div>
                            </div>
                        </div>
                    }
                </div>
                <div class="pager" id="repairGridPager"></div>
            }
            else
            {
                <div class="empty-state"><span class="ei">🛠</span><p>No repair services available.</p></div>
            }

            <div class="nav-btns">
                <button class="btn-back" onclick="rGoStep(1)"><i class="bi bi-arrow-left"></i> Back</button>
                <button class="btn-next" id="rBtn2" onclick="rGoStep(3)" disabled>
                    Review Order <i class="bi bi-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- STEP 3: REVIEW -->
        <div class="rp-panel" id="rp3">
            <div class="panel-head">
                <h2>Review your repair order</h2>
                <p>Confirm the details before adding to your cart.</p>
            </div>

            <div class="summary-box" id="rSummary"></div>

            <form method="post" asp-page="/Cart/Add" id="rForm">
                <input type="hidden" name="ProductId" id="rFrameId" />
                <input type="hidden" name="ServiceId" id="rServiceId" />
                <input type="hidden" name="Quantity" value="1" />
                <div class="nav-btns">
                    <button type="button" class="btn-back" onclick="rGoStep(2)"><i class="bi bi-arrow-left"></i> Back</button>
                    <button type="submit" class="btn-add"><i class="bi bi-cart-plus"></i> Add to Cart</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let rSel = { frame: null, svc: null };
        const R_PAGE_SIZE = 8;
        const rPagers = {};

        /* ── Pagination engine ── */
        function rInitPager(gridId, pagerId) {
            const allCards = Array.from(document.querySelectorAll(
                '#' + gridId + ' .frame-card, #' + gridId + ' .repair-row'
            )).filter(c => c.getAttribute('data-hidden') !== '1');
            rPagers[gridId] = { allCards, currentPage: 1, pagerId };
            rRenderPage(gridId);
        }

        function rRenderPage(gridId) {
            const state = rPagers[gridId];
            if (!state) return;
            const total = state.allCards.length;
            const tp = Math.ceil(total / R_PAGE_SIZE) || 1;
            if (state.currentPage > tp) state.currentPage = 1;

            // Hide all cards in grid first
            document.querySelectorAll('#' + gridId + ' .frame-card, #' + gridId + ' .repair-row')
                .forEach(c => c.style.display = 'none');

            // Show only current page from filtered set
            const start = (state.currentPage - 1) * R_PAGE_SIZE;
            state.allCards.slice(start, start + R_PAGE_SIZE).forEach(c => c.style.display = '');

            rBuildPagerUI(gridId, tp, total);
        }

        function rBuildPagerUI(gridId, tp, total) {
            const state = rPagers[gridId];
            const page = state.currentPage;
            const el = document.getElementById(state.pagerId);
            if (!el) return;
            if (tp <= 1) { el.innerHTML = ''; return; }

            let html = `<button class="pg-btn" onclick="rChangePage('${gridId}',${page - 1})" ${page === 1 ? 'disabled' : ''}>&#8249; Prev</button>`;
            for (let i = 1; i <= tp; i++) {
                if (tp > 7 && i > 2 && i < tp - 1 && Math.abs(i - page) > 1) {
                    if (i === 3 || i === tp - 2) html += `<span class="pg-ellipsis">…</span>`;
                    continue;
                }
                html += `<button class="pg-btn ${i === page ? 'active' : ''}" onclick="rChangePage('${gridId}',${i})">${i}</button>`;
            }
            html += `<button class="pg-btn" onclick="rChangePage('${gridId}',${page + 1})" ${page === tp ? 'disabled' : ''}>Next &#8250;</button>`;
            const from = (page - 1) * R_PAGE_SIZE + 1;
            const to   = Math.min(page * R_PAGE_SIZE, total);
            html += `<span class="pg-info">${from}–${to} / ${total}</span>`;
            el.innerHTML = html;
        }

        function rChangePage(gridId, n) {
            const state = rPagers[gridId];
            if (!state) return;
            const tp = Math.ceil(state.allCards.length / R_PAGE_SIZE) || 1;
            state.currentPage = Math.max(1, Math.min(n, tp));
            rRenderPage(gridId);
        }

        /* ── Search filters ── */
        function rFilterFrames(q) {
            const kw = q.trim().toLowerCase();
            const all = Array.from(document.querySelectorAll('#frameGrid .frame-card'));
            all.forEach(c => {
                const name = (c.dataset.name || '').toLowerCase();
                c.setAttribute('data-hidden', (!kw || name.includes(kw)) ? '' : '1');
            });
            const visible = all.filter(c => c.getAttribute('data-hidden') !== '1');
            rPagers['frameGrid'] = { allCards: visible, currentPage: 1, pagerId: 'frameGridPager' };
            rRenderPage('frameGrid');
            document.getElementById('frameCount').textContent = q ? `${visible.length} result${visible.length !== 1 ? 's' : ''}` : '';
        }

        function rFilterServices(q) {
            const kw = q.trim().toLowerCase();
            const all = Array.from(document.querySelectorAll('#repairGrid .repair-row'));
            all.forEach(c => {
                const name = (c.dataset.name || '').toLowerCase();
                const desc = (c.querySelector('.repair-desc')?.textContent || '').toLowerCase();
                c.setAttribute('data-hidden', (!kw || name.includes(kw) || desc.includes(kw)) ? '' : '1');
            });
            const visible = all.filter(c => c.getAttribute('data-hidden') !== '1');
            rPagers['repairGrid'] = { allCards: visible, currentPage: 1, pagerId: 'repairGridPager' };
            rRenderPage('repairGrid');
            document.getElementById('serviceCount').textContent = q ? `${visible.length} result${visible.length !== 1 ? 's' : ''}` : '';
        }

        /* ── Step navigation ── */
        function rGoStep(n) {
            if (n > 1 && !rSel.frame) { rShake('rp1'); return; }
            if (n > 2 && !rSel.svc)   { rShake('rp2'); return; }
            [1,2,3].forEach(i => {
                document.getElementById('rp'+i)?.classList.toggle('active', i===n);
            });
            updateRStepper(n);
            if (n === 2) {
                renderMini('miniSel2');
                // Reset service search when entering step 2
                const si = document.getElementById('serviceSearch');
                if (si) { si.value = ''; rFilterServices(''); }
                rInitPager('repairGrid', 'repairGridPager');
            }
            if (n === 3) rBuildSummary();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function updateRStepper(cur) {
            [1,2,3].forEach(i => {
                const step = document.getElementById('rs'+i);
                const num  = document.getElementById('rn'+i);
                if (!step) return;
                step.classList.remove('active', 'done');
                if (i < cur) {
                    step.classList.add('done');
                    num.innerHTML = '<i class="bi bi-check-lg" style="font-size:12px"></i>';
                } else if (i === cur) {
                    step.classList.add('active');
                    num.textContent = i;
                } else {
                    num.textContent = i;
                }
            });
        }

        function rShake(id) {
            const el = document.getElementById(id);
            let t = 0;
            const s = [6,-6,4,-4,2,-2,0];
            const next = () => { if(t>=s.length){el.style.transform='';return;} el.style.transform=`translateX(${s[t]}px)`; t++; setTimeout(next,60); };
            next();
        }

        function rSelectFrame(card) {
            document.querySelectorAll('#frameGrid .frame-card').forEach(c => c.classList.remove('sel'));
            card.classList.add('sel');
            rSel.frame = { id: card.dataset.id, name: card.dataset.name, img: card.dataset.img };
            document.getElementById('rBtn1').disabled = false;
        }

        function rSelectService(card) {
            document.querySelectorAll('#repairGrid .repair-row').forEach(c => c.classList.remove('sel'));
            card.classList.add('sel');
            rSel.svc = { id: card.dataset.id, name: card.dataset.name, price: +card.dataset.price };
            document.getElementById('rBtn2').disabled = false;
        }

        function renderMini(containerId) {
            const el = document.getElementById(containerId);
            if (!el) return;
            el.innerHTML = `<div class="mini-pill"><span class="mp-dot"></span> Frame: <strong>${rSel.frame.name}</strong></div>`;
        }

        function rBuildSummary() {
            const f = rSel.frame, s = rSel.svc;
            const img = f.img ? `<img src="${f.img}" class="sum-thumb"/>` : `<div class="sum-ph">🕶</div>`;
            document.getElementById('rSummary').innerHTML = `
                <div class="sum-hdr">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.6)" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <span class="sum-hdr-title">Repair Order Summary</span>
                    <span class="sum-hdr-badge">Frame Repair</span>
                </div>
                <div class="sum-row">
                    ${img}
                    <div><div class="sum-info-lbl">Frame Model</div><div class="sum-info-name">${f.name}</div></div>
                    <div class="sum-price" style="color:var(--steel);font-size:1rem">Reference only</div>
                </div>
                <div class="sum-row">
                    <div class="sum-ph">🛠</div>
                    <div><div class="sum-info-lbl">Repair Service</div><div class="sum-info-name">${s.name}</div></div>
                    <div class="sum-price">${s.price.toLocaleString('vi-VN')} ₫</div>
                </div>
                <div class="sum-row total">
                    <div style="flex:1"><div class="sum-total-lbl">Total Amount</div></div>
                    <div class="sum-total-val">${s.price.toLocaleString('vi-VN')} ₫</div>
                </div>`;
            document.getElementById('rFrameId').value  = f.id;
            document.getElementById('rServiceId').value = s.id;
        }

        /* ── Init ── */
        rInitPager('frameGrid', 'frameGridPager');
    </script>
}