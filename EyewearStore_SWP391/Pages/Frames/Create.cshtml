@page
@model EyewearStore_SWP391.Pages.Frames.CreateModel
@{
    ViewData["Title"] = "Create Frame";
    Layout = "_Layout";
}

<style>
    .fc-wrap { max-width: 900px; margin: 0 auto; padding: 2rem; }
    .fc-header { margin-bottom: 2rem; }
    .fc-header h1 { font-size: 2rem; font-weight: 700; color: #1a1a2e; margin: 0 0 .5rem; }
    .fc-header p  { color: #6c757d; margin: 0; }
    .breadcrumb   { display:flex; gap:.5rem; margin-bottom:1rem; font-size:.9rem; }
    .breadcrumb a { color:#667eea; text-decoration:none; }
    .breadcrumb a:hover { text-decoration:underline; }
    .breadcrumb .sep { color:#adb5bd; }
    .breadcrumb .cur { color:#6c757d; }
    .form-card { background:#fff; border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,.08); overflow:hidden; }
    .form-section { padding:2rem; border-bottom:1px solid #f0f0f5; }
    .form-section:last-of-type { border-bottom:none; }
    .section-title { font-size:1.1rem; font-weight:600; color:#1a1a2e; margin:0 0 1.5rem; padding-bottom:.75rem; border-bottom:2px solid #667eea; display:inline-block; }
    .form-row { display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; margin-bottom:1.5rem; }
    .form-row.single { grid-template-columns:1fr; }
    .form-row.tri    { grid-template-columns:repeat(3,1fr); }
    .form-group { display:flex; flex-direction:column; }
    .form-group label { font-weight:600; font-size:.875rem; color:#4a4a68; margin-bottom:.5rem; }
    .form-group label .req { color:#dc3545; }
    .form-control { padding:.75rem 1rem; border:1px solid #e0e0e8; border-radius:8px; font-size:.95rem; transition:border-color .2s, box-shadow .2s; width:100%; box-sizing:border-box; }
    .form-control:focus { outline:none; border-color:#667eea; box-shadow:0 0 0 3px rgba(102,126,234,.2); }
    .form-control.input-validation-error { border-color:#dc3545; }
    textarea.form-control { resize:vertical; min-height:100px; }
    .field-validation-error { color:#dc3545; font-size:.85rem; margin-top:.35rem; }
    .validation-summary-errors { background:#f8d7da; border:1px solid #f5c6cb; border-radius:8px; padding:1rem 1.5rem; margin-bottom:1.5rem; color:#721c24; }
    .helper-text { font-size:.8rem; color:#6c757d; margin-top:.35rem; }
    .color-preview { display:flex; gap:8px; flex-wrap:wrap; margin-top:8px; }
    .color-dot { width:26px; height:26px; border-radius:50%; border:2px solid rgba(0,0,0,.15); cursor:pointer; transition:transform .15s; }
    .color-dot:hover { transform:scale(1.15); }
    .toggle-group { display:flex; gap:1rem; }
    .toggle-opt { display:flex; align-items:center; gap:.5rem; padding:.6rem 1.2rem; border:2px solid #e0e0e8; border-radius:8px; cursor:pointer; font-size:.9rem; font-weight:600; color:#4a4a68; transition:all .18s; }
    .toggle-opt input[type=radio] { accent-color:#667eea; width:16px; height:16px; }
    .toggle-opt:has(input:checked) { border-color:#667eea; background:#f0f0ff; color:#667eea; }
    .face-tags-wrap { display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:.5rem; }
    .face-tag { display:inline-flex; align-items:center; gap:.4rem; padding:.4rem .9rem; border:2px solid #e0e0e8; border-radius:20px; font-size:.82rem; font-weight:600; color:#4a4a68; cursor:pointer; transition:all .15s; }
    .face-tag input[type=checkbox] { accent-color:#667eea; width:14px; height:14px; }
    .face-tag:has(input:checked) { border-color:#667eea; background:#f0f0ff; color:#667eea; }
    .image-drop-zone { border:2px dashed #e0e0e8; border-radius:12px; padding:2.5rem 2rem; text-align:center; background:#fafafa; cursor:pointer; transition:border-color .25s, background .25s; user-select:none; }
    .image-drop-zone:hover, .image-drop-zone.drag-over { border-color:#667eea; background:rgba(102,126,234,.04); }
    .image-drop-zone .dz-icon { font-size:2.8rem; color:#adb5bd; margin-bottom:.75rem; }
    .image-drop-zone h4 { margin:0 0 .35rem; font-size:1rem; color:#4a4a68; }
    .image-drop-zone p { margin:0; font-size:.85rem; color:#6c757d; }
    .thumb-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(120px,1fr)); gap:1rem; margin-top:1.25rem; }
    .thumb-card { position:relative; border-radius:10px; overflow:hidden; border:2px solid #e0e0e8; background:#f8f9fc; aspect-ratio:1; transition:border-color .2s, box-shadow .2s; }
    .thumb-card.is-primary { border-color:#667eea; box-shadow:0 0 0 3px rgba(102,126,234,.25); }
    .thumb-card img { width:100%; height:100%; object-fit:cover; display:block; }
    .thumb-card .tc-actions { position:absolute; bottom:0; left:0; right:0; background:linear-gradient(to top,rgba(0,0,0,.65),transparent); padding:.5rem .4rem .4rem; display:flex; gap:.3rem; justify-content:center; opacity:0; transition:opacity .18s; }
    .thumb-card:hover .tc-actions { opacity:1; }
    .tc-btn { padding:.25rem .55rem; border-radius:5px; border:none; font-size:.72rem; font-weight:700; cursor:pointer; color:#fff; }
    .tc-btn-primary { background:#667eea; }
    .tc-btn-primary:hover { background:#5a6fd6; }
    .tc-btn-remove  { background:#dc3545; }
    .tc-btn-remove:hover  { background:#c82333; }
    .tc-primary-badge { position:absolute; top:6px; left:6px; background:#667eea; color:#fff; font-size:.65rem; font-weight:700; padding:.2rem .45rem; border-radius:4px; }
    .upload-count-info { font-size:.85rem; color:#6c757d; margin-top:.75rem; text-align:right; }
    .upload-count-info span { font-weight:600; color:#4a4a68; }
    .form-actions { display:flex; justify-content:flex-end; gap:1rem; padding:1.5rem 2rem; background:#f8f9fc; border-top:1px solid #f0f0f5; }
    .btn { display:inline-flex; align-items:center; gap:.5rem; padding:.75rem 1.5rem; border-radius:8px; font-weight:600; text-decoration:none; transition:all .2s; border:none; cursor:pointer; font-size:.95rem; }
    .btn-primary { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); color:#fff; }
    .btn-primary:hover { transform:translateY(-2px); box-shadow:0 4px 12px rgba(102,126,234,.4); }
    .btn-secondary { background:#f0f0f5; color:#4a4a68; }
    .btn-secondary:hover { background:#e0e0e8; }
    @@media(max-width:768px) {
        .fc-wrap { padding:1rem; }
        .form-section { padding:1.5rem; }
        .form-row, .form-row.tri { grid-template-columns:1fr; }
        .form-actions { flex-direction:column-reverse; }
        .btn { width:100%; justify-content:center; }
        .thumb-grid { grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); }
    }
</style>

<div class="fc-wrap">
    <nav class="breadcrumb">
        <a href="/">Home</a><span class="sep">›</span>
        <a asp-page="/Frames/Index">Frames</a><span class="sep">›</span>
        <span class="cur">Create</span>
    </nav>

    <div class="fc-header">
        <h1><i class="bi bi-plus-circle"></i> Create Frame</h1>
        <p>Add a new frame product to your inventory</p>
    </div>

    <div class="form-card">
        <form method="post" enctype="multipart/form-data" id="createForm">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <!-- ── Basic Information ──────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Basic Information</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.Sku">SKU <span class="req">*</span></label>
                        <input asp-for="Input.Sku" class="form-control" placeholder="e.g., FRAME-TI-001" />
                        <span asp-validation-for="Input.Sku" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Name">Product Name <span class="req">*</span></label>
                        <input asp-for="Input.Name" class="form-control" placeholder="e.g., Classic Titanium Frame" />
                        <span asp-validation-for="Input.Name" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-row single">
                    <div class="form-group">
                        <label asp-for="Input.Description">Description</label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>

            <!-- ── Brand & Identity ───────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Brand &amp; Identity</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.Brand">Brand</label>
                        <input asp-for="Input.Brand" class="form-control" placeholder="e.g., Ray-Ban, Bolon, Oakley" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Gender">Gender</label>
                        <select asp-for="Input.Gender" class="form-control">
                            <option value="">-- Select --</option>
                            <option value="Unisex">Unisex</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.Origin">Country of Origin</label>
                        <input asp-for="Input.Origin" class="form-control" placeholder="e.g., P.R.C, Japan, Italy" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.StyleTags">Style Tags (comma-separated)</label>
                        <input asp-for="Input.StyleTags" class="form-control" placeholder="e.g., Vintage, Sporty, Elegant" />
                        <span class="helper-text">Displayed on the product page.</span>
                    </div>
                </div>
            </div>

            <!-- ── Frame Details ──────────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Frame Details</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.FrameMaterial">Frame Material</label>
                        <input asp-for="Input.FrameMaterial" class="form-control" placeholder="e.g., Titanium, Acetate, Mixed" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.FrameType">Frame Type</label>
                        <select asp-for="Input.FrameType" class="form-control">
                            <option value="">-- Select --</option>
                            <option value="Full-Rim">Full-Rim</option>
                            <option value="Half-Rim">Half-Rim</option>
                            <option value="Rimless">Rimless</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.FrameShape">Frame Shape</label>
                        <input asp-for="Input.FrameShape" class="form-control"
                               list="shapeList" placeholder="Select or enter a shape..." autocomplete="off" />
                        <datalist id="shapeList">
                            <option value="Round"></option>
                            <option value="Square"></option>
                            <option value="Rectangle"></option>
                            <option value="Aviator"></option>
                            <option value="Cat-eye"></option>
                            <option value="Oval"></option>
                            <option value="Wayfarer"></option>
                            <option value="Pillow"></option>
                            <option value="Butterfly"></option>
                        </datalist>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.FrameColor">Frame Color</label>
                        <input asp-for="Input.FrameColor" class="form-control" placeholder="e.g., Gold, Matte Black, Silver" />
                        <span class="helper-text">Specific color of the frame.</span>
                    </div>
                </div>
                <div class="form-row tri">
                    <div class="form-group">
                        <label asp-for="Input.LensWidth">Lens Width (mm)</label>
                        <input asp-for="Input.LensWidth" type="number" step="0.01" min="0" class="form-control" placeholder="53" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.BridgeWidth">Bridge Width (mm)</label>
                        <input asp-for="Input.BridgeWidth" type="number" step="0.01" min="0" class="form-control" placeholder="18" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.TempleLength">Temple Length (mm)</label>
                        <input asp-for="Input.TempleLength" type="number" step="0.01" min="0" class="form-control" placeholder="140" />
                    </div>
                </div>
            </div>

            <!-- ── Lens Details ──────────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Lens Details</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.LensMaterial">Lens Material</label>
                        <input asp-for="Input.LensMaterial" class="form-control"
                               list="lensMaterialList" placeholder="e.g., Nylon, Polycarbonate, CR-39" autocomplete="off" />
                        <datalist id="lensMaterialList">
                            <option value="Nylon"></option>
                            <option value="Polycarbonate"></option>
                            <option value="Glass"></option>
                            <option value="CR-39"></option>
                            <option value="Trivex"></option>
                            <option value="Polarized Nylon"></option>
                        </datalist>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.LensColor">Lens Color</label>
                        <input asp-for="Input.LensColor" class="form-control"
                               list="lensColorList" placeholder="e.g., Dark Grey, Brown, Clear" autocomplete="off" />
                        <datalist id="lensColorList">
                            <option value="Dark Grey"></option>
                            <option value="Light Grey"></option>
                            <option value="Brown"></option>
                            <option value="Green"></option>
                            <option value="Blue"></option>
                            <option value="Yellow"></option>
                            <option value="Pink"></option>
                            <option value="Black"></option>
                            <option value="Clear"></option>
                            <option value="Mirror Silver"></option>
                            <option value="Mirror Gold"></option>
                        </datalist>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.IsPolarized">Polarized</label>
                        <div class="toggle-group">
                            <label class="toggle-opt">
                                <input type="radio" asp-for="Input.IsPolarized" value="true" /> Yes
                            </label>
                            <label class="toggle-opt">
                                <input type="radio" asp-for="Input.IsPolarized" value="false" checked /> No
                            </label>
                        </div>
                        <span class="helper-text">Polarized lenses reduce glare and eye strain.</span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.HasUvProtection">UV Protection</label>
                        <div class="toggle-group">
                            <label class="toggle-opt">
                                <input type="radio" asp-for="Input.HasUvProtection" value="true" checked /> Yes
                            </label>
                            <label class="toggle-opt">
                                <input type="radio" asp-for="Input.HasUvProtection" value="false" /> No
                            </label>
                        </div>
                        <span class="helper-text">Lenses block harmful UV rays to protect your eyes.</span>
                    </div>
                </div>
            </div>

            <!-- ── Suitable Face Shapes ───────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Suitable Face Shapes</h2>
                <div class="form-row single">
                    <div class="form-group">
                        <label>Face Shape Compatibility</label>
                        <div class="face-tags-wrap">
                            @foreach (var face in new[] { "Oval", "Round", "Square", "Heart", "Oblong", "Triangle", "Diamond", "Rectangle" })
                            {
                                <label class="face-tag">
                                    <input type="checkbox" class="face-cb" value="@face" onchange="syncFaceShapes()" />
                                    @face
                                </label>
                            }
                        </div>
                        <input type="hidden" asp-for="Input.SuitableFaceShapes" id="suitableFaceShapesInput" />
                        <span class="helper-text">Displayed in the "Suitable For" section on the product page.</span>
                    </div>
                </div>
            </div>

            <!-- ── Compatible Lens Types ───────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Compatible Lens Types</h2>
                <p class="helper-text" style="margin-bottom:1rem;">
                    Select which lens types are physically compatible with this frame.
                    If none are selected, <strong>all lens types</strong> will be shown to customers.
                </p>
                <div style="margin-bottom:.75rem;">
                    <button type="button" class="btn-sm" id="toggleAllBtn" onclick="toggleAllLensTypes()"
                            style="padding:.35rem .75rem; font-size:.8rem; border-radius:6px; border:none; cursor:pointer; background:#667eea; color:#fff;">
                        Select All
                    </button>
                </div>
                <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:.75rem;">
                    @foreach (var lt in Model.AllLensTypes)
                    {
                        <label style="display:flex; align-items:center; gap:.5rem; cursor:pointer; padding:.5rem .75rem; border:1px solid #e0e0e8; border-radius:8px; transition:all .2s;">
                            <input type="checkbox"
                                   name="SelectedLensTypes"
                                   value="@lt"
                                   class="lens-type-cb"
                                   style="width:18px; height:18px; cursor:pointer;" />
                            <span style="font-size:.9rem; color:#4a4a68;">@lt</span>
                        </label>
                    }
                </div>
            </div>

            <!-- ── Color Options ──────────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Color Options</h2>
                <div class="form-row single">
                    <div class="form-group">
                        <label asp-for="Input.Color">Color Swatches (comma-separated)</label>
                        <input asp-for="Input.Color" class="form-control" id="colorInput"
                               placeholder="e.g., Black, Gold, Red" oninput="updateColorPreview()" />
                        <span class="helper-text">Each color will appear as a swatch on the product page.</span>
                        <div class="color-preview" id="colorPreview"></div>
                    </div>
                </div>
                <div class="form-row single">
                    <div class="form-group">
                        <p class="helper-text">Quick add:</p>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                            @foreach (var c in new[] {
                                "Black","Gold","Red","Silver","Tortoise",
                                "Blue","Pink","Green","Transparent",
                                "Brown","Nude","Purple","Orange","White","Rose Gold"
                            })
                            {
                                <button type="button" class="color-dot" onclick="addColor('@c')" title="@c"
                                        style="background:@(c switch {
                                            "Black"     => "#1a1a1a",
                                            "Gold"      => "#c9a96e",
                                            "Red"       => "#cc2200",
                                            "Silver"    => "linear-gradient(135deg,#d0d0d0,#f5f5f5,#b0b0b0)",
                                            "Tortoise"  => "#7b4f1e",
                                            "Blue"      => "#1a4fa0",
                                            "Pink"      => "#e879a0",
                                            "Green"     => "#2d7a3a",
                                            "Brown"     => "#5c3a1e",
                                            "Nude"      => "#c9a882",
                                            "Purple"    => "#6b3fa0",
                                            "Orange"    => "#e8621a",
                                            "White"     => "#f0f0f0",
                                            "Rose Gold" => "linear-gradient(135deg,#c47b6f,#e8b4a8,#b5736a)",
                                            _           => "rgba(180,220,255,.6)"
                                        });@(c == "White" ? "outline:1px solid #ccc;" : "")"></button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Pricing & Inventory ────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Pricing &amp; Inventory</h2>
                <div class="form-row tri">
                    <div class="form-group">
                        <label asp-for="Input.Price">Price <span class="req">*</span></label>
                        <input asp-for="Input.Price" type="number" step="0.01" min="0.01" class="form-control" />
                        <span asp-validation-for="Input.Price" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Currency">Currency</label>
                        <input asp-for="Input.Currency" class="form-control" maxlength="3" placeholder="VND" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.QuantityOnHand">Inventory Qty</label>
                        <input asp-for="Input.QuantityOnHand" type="number" min="0" class="form-control" />
                    </div>
                </div>
            </div>

            <!-- ── Product Images ─────────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Product Images</h2>

                <input type="file" id="fileSubmit" name="Input.ImageFiles"
                       accept=".jpg,.jpeg,.png,.webp" multiple style="display:none" />
                <input type="file" id="filePicker"
                       accept=".jpg,.jpeg,.png,.webp" multiple style="display:none" />

                <div class="image-drop-zone" id="dropZone">
                    <div class="dz-icon"><i class="bi bi-images"></i></div>
                    <h4>Upload Product Images</h4>
                    <p>Drag &amp; drop or click to select · Max 10 images</p>
                    <p class="helper-text" style="margin-top:.4rem;">JPG, PNG, WEBP · Max 5 MB · First image will be the primary (cover) image</p>
                </div>

                <div class="thumb-grid" id="thumbGrid"></div>
                <div class="upload-count-info" id="countInfo" style="display:none;">
                    <span id="countText">0</span> image(s) selected — the first image will be the primary (cover) image
                </div>

                <div class="form-row single" style="margin-top:1.2rem;">
                    <div class="form-group">
                        <label asp-for="Input.ImageAltText">Image Alt Text</label>
                        <input asp-for="Input.ImageAltText" class="form-control" placeholder="Describe the image (applied to all uploaded images)" />
                        <span class="helper-text">Optional. Helps with SEO &amp; accessibility.</span>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a asp-page="/Frames/Index" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    // ── Image upload ──────────────────────────────────────────────────────────
    var fileSubmit = document.getElementById('fileSubmit');
    var filePicker = document.getElementById('filePicker');
    var dropZone   = document.getElementById('dropZone');
    var thumbGrid  = document.getElementById('thumbGrid');
    var countInfo  = document.getElementById('countInfo');
    var countText  = document.getElementById('countText');
    var MAX_FILES  = 10;
    var MAX_BYTES  = 5 * 1024 * 1024;
    var ALLOWED    = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
    var fileList   = [];

    dropZone.addEventListener('click', function() { filePicker.click(); });
    dropZone.addEventListener('dragover', function(e) { e.preventDefault(); dropZone.classList.add('drag-over'); });
    dropZone.addEventListener('dragleave', function() { dropZone.classList.remove('drag-over'); });
    dropZone.addEventListener('drop', function(e) {
        e.preventDefault(); dropZone.classList.remove('drag-over');
        handleFiles(Array.from(e.dataTransfer.files));
    });
    filePicker.addEventListener('change', function(e) {
        handleFiles(Array.from(e.target.files));
        e.target.value = '';
    });

    function handleFiles(incoming) {
        for (var i = 0; i < incoming.length; i++) {
            var file = incoming[i];
            if (fileList.length >= MAX_FILES) { alert('Maximum ' + MAX_FILES + ' images allowed.'); break; }
            if (ALLOWED.indexOf(file.type) === -1) { alert('"' + file.name + '" is not a valid file type.'); continue; }
            if (file.size > MAX_BYTES) { alert('"' + file.name + '" exceeds 5 MB.'); continue; }
            addFile(file);
        }
        syncToSubmitInput();
        updateCount();
    }
    function addFile(file) {
        var idx = fileList.length;
        fileList.push({ file: file, dataUrl: null });
        var reader = new FileReader();
        reader.onload = (function(i) {
            return function(ev) { fileList[i].dataUrl = ev.target.result; renderThumbs(); };
        })(idx);
        reader.readAsDataURL(file);
    }
    function renderThumbs() {
        thumbGrid.innerHTML = '';
        fileList.forEach(function(item, idx) {
            if (!item.dataUrl) return;
            var card = document.createElement('div');
            card.className = 'thumb-card' + (idx === 0 ? ' is-primary' : '');
            var badge = idx === 0 ? '<span class="tc-primary-badge">\u2605 Primary</span>' : '';
            var setPrimaryBtn = idx !== 0
                ? '<button type="button" class="tc-btn tc-btn-primary" onclick="setPrimary(' + idx + ')">Set Primary</button>'
                : '';
            card.innerHTML = badge
                + '<img src="' + item.dataUrl + '" alt="Preview ' + (idx+1) + '">'
                + '<div class="tc-actions">' + setPrimaryBtn
                + '<button type="button" class="tc-btn tc-btn-remove" onclick="removeImg(' + idx + ')">Remove</button></div>';
            thumbGrid.appendChild(card);
        });
    }
    function setPrimary(idx) {
        var item = fileList.splice(idx, 1)[0];
        fileList.unshift(item);
        renderThumbs(); syncToSubmitInput();
    }
    function removeImg(idx) {
        fileList.splice(idx, 1);
        renderThumbs(); syncToSubmitInput(); updateCount();
    }
    function syncToSubmitInput() {
        try {
            var dt = new DataTransfer();
            fileList.forEach(function(item) { dt.items.add(item.file); });
            fileSubmit.files = dt.files;
        } catch(e) { console.warn('DataTransfer not supported:', e); }
    }
    function updateCount() {
        countInfo.style.display = fileList.length > 0 ? 'block' : 'none';
        countText.textContent = fileList.length;
    }

    // ── Color preview ─────────────────────────────────────────────────────────
    var COLOR_MAP = {
        Black:'#1a1a1a', Red:'#cc2200', Gold:'#c9a96e', Silver:'#c0c0c0',
        Tortoise:'#7b4f1e', Blue:'#1a4fa0', Pink:'#e879a0', Green:'#2d7a3a',
        Transparent:'rgba(180,220,255,.5)', Brown:'#5c3a1e', Nude:'#c9a882',
        Purple:'#6b3fa0', Orange:'#e8621a', White:'#f0f0f0', 'Rose Gold':'#c47b6f'
    };
    function updateColorPreview() {
        var val = document.getElementById('colorInput').value;
        var container = document.getElementById('colorPreview');
        container.innerHTML = '';
        val.split(',').forEach(function(c) {
            c = c.trim(); if (!c) return;
            var dot = document.createElement('div');
            dot.className = 'color-dot'; dot.title = c;
            dot.style.background = COLOR_MAP[c] || '#ccc';
            if (c === 'White') dot.style.outline = '1px solid #ccc';
            container.appendChild(dot);
        });
    }
    function addColor(color) {
        var inp = document.getElementById('colorInput');
        var existing = inp.value.split(',').map(function(s){ return s.trim(); }).filter(Boolean);
        if (existing.indexOf(color) === -1) {
            inp.value = existing.length ? existing.join(', ') + ', ' + color : color;
            updateColorPreview();
        }
    }

    // ── Compatible lens types toggle ──────────────────────────────────────────
    function toggleAllLensTypes() {
        var cbs = document.querySelectorAll('.lens-type-cb');
        var allChecked = Array.from(cbs).every(function(cb) { return cb.checked; });
        cbs.forEach(function(cb) { cb.checked = !allChecked; });
        document.getElementById('toggleAllBtn').textContent = allChecked ? 'Select All' : 'Deselect All';
    }

    // ── Face shapes → hidden input ────────────────────────────────────────────
    function syncFaceShapes() {
        var checked = Array.from(document.querySelectorAll('.face-cb:checked')).map(function(cb){ return cb.value; });
        document.getElementById('suitableFaceShapesInput').value = checked.join(', ');
    }

    document.addEventListener('DOMContentLoaded', function() {
        updateColorPreview();
        syncFaceShapes();
    });
    </script>
}
