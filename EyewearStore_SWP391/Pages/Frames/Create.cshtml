@page
@model EyewearStore_SWP391.Pages.Frames.CreateModel
@{
    ViewData["Title"] = "Create Frame";
    Layout = "_Layout";
}

<style>
    .fc-wrap { max-width: 900px; margin: 0 auto; padding: 2rem; }
    .fc-header { margin-bottom: 2rem; }
    .fc-header h1 { font-size: 2rem; font-weight: 700; color: #1a1a2e; margin: 0 0 .5rem; }
    .fc-header p  { color: #6c757d; margin: 0; }
    .breadcrumb   { display:flex; gap:.5rem; margin-bottom:1rem; font-size:.9rem; }
    .breadcrumb a { color:#667eea; text-decoration:none; }
    .breadcrumb a:hover { text-decoration:underline; }
    .breadcrumb .sep { color:#adb5bd; }
    .breadcrumb .cur { color:#6c757d; }
    .form-card { background:#fff; border-radius:12px; box-shadow:0 2px 12px rgba(0,0,0,.08); overflow:hidden; }
    .form-section { padding:2rem; border-bottom:1px solid #f0f0f5; }
    .form-section:last-of-type { border-bottom:none; }
    .section-title { font-size:1.1rem; font-weight:600; color:#1a1a2e; margin:0 0 1.5rem; padding-bottom:.75rem; border-bottom:2px solid #667eea; display:inline-block; }
    .form-row { display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; margin-bottom:1.5rem; }
    .form-row.single { grid-template-columns:1fr; }
    .form-row.tri    { grid-template-columns:repeat(3,1fr); }
    .form-group { display:flex; flex-direction:column; }
    .form-group label { font-weight:600; font-size:.875rem; color:#4a4a68; margin-bottom:.5rem; }
    .form-group label .req { color:#dc3545; }
    .form-control { padding:.75rem 1rem; border:1px solid #e0e0e8; border-radius:8px; font-size:.95rem; transition:border-color .2s, box-shadow .2s; width:100%; box-sizing:border-box; }
    .form-control:focus { outline:none; border-color:#667eea; box-shadow:0 0 0 3px rgba(102,126,234,.2); }
    .form-control.input-validation-error { border-color:#dc3545; }
    textarea.form-control { resize:vertical; min-height:100px; }
    .field-validation-error { color:#dc3545; font-size:.85rem; margin-top:.35rem; }
    .validation-summary-errors { background:#f8d7da; border:1px solid #f5c6cb; border-radius:8px; padding:1rem 1.5rem; margin-bottom:1.5rem; color:#721c24; }
    .helper-text { font-size:.8rem; color:#6c757d; margin-top:.35rem; }
    .color-preview { display:flex; gap:8px; flex-wrap:wrap; margin-top:8px; }
    .color-dot { width:26px; height:26px; border-radius:50%; border:2px solid rgba(0,0,0,.15); cursor:pointer; transition:transform .15s; }
    .color-dot:hover { transform:scale(1.15); }
    .image-upload-area { border:2px dashed #e0e0e8; border-radius:12px; padding:2rem; text-align:center; transition:all .3s; background:#fafafa; cursor:pointer; }
    .image-upload-area:hover, .image-upload-area.drag-over { border-color:#667eea; background:rgba(102,126,234,.05); }
    .image-upload-area .upload-icon { font-size:3rem; margin-bottom:1rem; }
    .image-upload-area input[type="file"] { display:none; }
    .image-preview-container { display:none; margin-top:1.5rem; text-align:center; }
    .image-preview-container.has-image { display:block; }
    .image-preview { max-width:300px; max-height:200px; border-radius:8px; box-shadow:0 2px 8px rgba(0,0,0,.1); object-fit:cover; }
    .image-preview-info { margin-top:.75rem; padding:.75rem; background:#f0f0f5; border-radius:8px; display:inline-block; }
    .btn-remove-image { margin-top:.75rem; background:#dc3545; color:#fff; padding:.5rem 1rem; border:none; border-radius:6px; cursor:pointer; font-size:.85rem; }
    .btn-remove-image:hover { background:#c82333; }
    .form-actions { display:flex; justify-content:flex-end; gap:1rem; padding:1.5rem 2rem; background:#f8f9fc; border-top:1px solid #f0f0f5; }
    .btn { display:inline-flex; align-items:center; gap:.5rem; padding:.75rem 1.5rem; border-radius:8px; font-weight:600; text-decoration:none; transition:all .2s; border:none; cursor:pointer; font-size:.95rem; }
    .btn-primary { background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); color:#fff; }
    .btn-primary:hover { transform:translateY(-2px); box-shadow:0 4px 12px rgba(102,126,234,.4); }
    .btn-secondary { background:#f0f0f5; color:#4a4a68; }
    .btn-secondary:hover { background:#e0e0e8; }
    @@media(max-width:768px) {
        .fc-wrap { padding:1rem; }
        .form-section { padding:1.5rem; }
        .form-row, .form-row.tri { grid-template-columns:1fr; }
        .form-actions { flex-direction:column-reverse; }
        .btn { width:100%; justify-content:center; }
    }
</style>

<div class="fc-wrap">
    <nav class="breadcrumb">
        <a href="/">Home</a><span class="sep">›</span>
        <a asp-page="/Frames/Index">Frames</a><span class="sep">›</span>
        <span class="cur">Create</span>
    </nav>

    <div class="fc-header">
        <h1><i class="bi bi-plus-circle"></i> Create Frame</h1>
        <p>Add a new frame product to your inventory</p>
    </div>

    <div class="form-card">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <!-- ── Basic Info ──────────────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Basic Information</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.Sku">SKU <span class="req">*</span></label>
                        <input asp-for="Input.Sku" class="form-control" placeholder="e.g., FRAME-TI-001" />
                        <span asp-validation-for="Input.Sku" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Name">Product Name <span class="req">*</span></label>
                        <input asp-for="Input.Name" class="form-control" placeholder="e.g., Classic Titanium Frame" />
                        <span asp-validation-for="Input.Name" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-row single">
                    <div class="form-group">
                        <label asp-for="Input.Description">Description</label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Enter frame description..."></textarea>
                    </div>
                </div>
            </div>

            <!-- ── Brand & Identity ────────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Brand &amp; Identity</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.Brand">Brand</label>
                        <input asp-for="Input.Brand" class="form-control" placeholder="e.g., Ray-Ban, Bolon, Oakley" />
                        <span class="helper-text">Displays as a clickable link on the product page</span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Gender">Gender</label>
                        <select asp-for="Input.Gender" class="form-control">
                            <option value="">-- Select --</option>
                            <option value="Unisex">Unisex</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.Origin">Country of Origin</label>
                        <input asp-for="Input.Origin" class="form-control" placeholder="e.g., P.R.C, Japan, Italy" />
                        <span class="helper-text">Shown in product status row</span>
                    </div>
                    <div class="form-group">
                        <!-- spacer -->
                    </div>
                </div>
            </div>

            <!-- ── Frame Details ───────────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Frame Details</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.FrameMaterial">Frame Material</label>
                        <input asp-for="Input.FrameMaterial" class="form-control" placeholder="e.g., Titanium, Acetate, Metal" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.FrameType">Frame Type</label>
                        <select asp-for="Input.FrameType" class="form-control">
                            <option value="">-- Select --</option>
                            <option value="Full-Rim">Full-Rim</option>
                            <option value="Half-Rim">Half-Rim</option>
                            <option value="Rimless">Rimless</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.FrameShape">Frame Shape</label>
                        <select asp-for="Input.FrameShape" class="form-control">
                            <option value="">-- Select --</option>
                            <option value="Round">Round</option>
                            <option value="Square">Square</option>
                            <option value="Rectangle">Rectangle</option>
                            <option value="Aviator">Aviator</option>
                            <option value="Cat-eye">Cat-eye</option>
                            <option value="Oval">Oval</option>
                            <option value="Wayfarer">Wayfarer</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <!-- spacer -->
                    </div>
                </div>
                <!-- ── Size measurements (4 fields in a row) ── -->
                <div class="form-row tri">
                    <div class="form-group">
                        <label asp-for="Input.LensWidth">Lens Width (mm)</label>
                        <input asp-for="Input.LensWidth" type="number" step="0.01" min="0" class="form-control" placeholder="e.g., 53.00" />
                        <span class="helper-text">Horizontal lens diameter</span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.BridgeWidth">Bridge Width (mm)</label>
                        <input asp-for="Input.BridgeWidth" type="number" step="0.01" min="0" class="form-control" placeholder="e.g., 18.00" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.TempleLength">Temple Length (mm)</label>
                        <input asp-for="Input.TempleLength" type="number" step="0.01" min="0" class="form-control" placeholder="e.g., 140.00" />
                    </div>
                </div>
            </div>

            <!-- ── Color ──────────────────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Color Options</h2>
                <div class="form-row single">
                    <div class="form-group">
                        <label asp-for="Input.Color">Colors (comma-separated)</label>
                        <input asp-for="Input.Color" class="form-control" id="colorInput"
                               placeholder="e.g., Black, Gold, Red"
                               oninput="updateColorPreview()" />
                        <span class="helper-text">Enter color names separated by commas. Each becomes a swatch on the product page.</span>
                        <div class="color-preview" id="colorPreview"></div>
                    </div>
                </div>
                <div class="form-row single">
                    <div class="form-group">
                        <p class="helper-text">Quick add:</p>
                        <div style="display:flex; gap:8px; flex-wrap:wrap;">
                            @foreach (var c in new[] { "Black", "Gold", "Red", "Silver", "Tortoise", "Blue", "Pink", "Green", "Transparent" })
                            {
                                <button type="button" class="color-dot" data-color="@c"
                                        style="background:@(c switch {
                                            "Black" => "#1a1a1a",
                                            "Gold"  => "#c9a96e",
                                            "Red"   => "#cc2200",
                                            "Silver"=> "linear-gradient(135deg,#d0d0d0,#f5f5f5,#b0b0b0)",
                                            "Tortoise" => "#7b4f1e",
                                            "Blue"  => "#1a4fa0",
                                            "Pink"  => "#e879a0",
                                            "Green" => "#2d7a3a",
                                            _ => "rgba(180,220,255,.6)"
                                        })"
                                        onclick="addColor('@c')" title="@c"></button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Pricing & Inventory ─────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Pricing &amp; Inventory</h2>
                <div class="form-row tri">
                    <div class="form-group">
                        <label asp-for="Input.Price">Price <span class="req">*</span></label>
                        <input asp-for="Input.Price" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="Input.Price" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Currency">Currency</label>
                        <input asp-for="Input.Currency" class="form-control" maxlength="3" placeholder="VND" />
                        <span class="helper-text">3-char code (USD, VND…)</span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.InventoryQty">Inventory Qty</label>
                        <input asp-for="Input.InventoryQty" type="number" min="0" class="form-control" placeholder="0" />
                    </div>
                </div>
            </div>

            <!-- ── Product Image ──────────────────────────────────────── -->
            <div class="form-section">
                <h2 class="section-title">Product Image</h2>
                <div class="form-row single">
                    <div class="form-group">
                        <label id="imageUploadArea" class="image-upload-area" for="imageFileInput">
                            <div class="upload-icon"><i class="bi bi-camera"></i></div>
                            <h4>Upload Product Image</h4>
                            <p>Drag and drop or click to select</p>
                            <p class="helper-text">JPG, PNG, WEBP · Max 5 MB</p>
                            <input type="file" id="imageFileInput" name="Input.ImageFile" accept=".jpg,.jpeg,.png,.webp" />
                        </label>
                        <div id="imagePreviewContainer" class="image-preview-container">
                            <img id="imagePreview" class="image-preview" src="" alt="Preview" />
                            <div class="image-preview-info">
                                <span id="fileName"></span>
                                <span id="fileSize" style="color:#6c757d;font-size:.85rem;margin-left:.5rem;"></span>
                            </div><br/>
                            <button type="button" id="removeImageBtn" class="btn-remove-image">Remove</button>
                        </div>
                    </div>
                </div>
                <div class="form-row single">
                    <div class="form-group">
                        <label asp-for="Input.ImageAltText">Image Alt Text</label>
                        <input asp-for="Input.ImageAltText" class="form-control" placeholder="Describe the image" />
                        <span class="helper-text">Optional. Helps accessibility &amp; SEO.</span>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a asp-page="/Frames/Index" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Create</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    const imageInput = document.getElementById('imageFileInput');
    const uploadArea = document.getElementById('imageUploadArea');
    const previewContainer = document.getElementById('imagePreviewContainer');
    const imagePreview = document.getElementById('imagePreview');
    const fileNameEl = document.getElementById('fileName');
    const fileSizeEl = document.getElementById('fileSize');

    imageInput.addEventListener('change', e => handleFile(e.target.files[0]));
    document.getElementById('removeImageBtn').addEventListener('click', () => {
        imageInput.value = ''; previewContainer.classList.remove('has-image');
        imagePreview.src = ''; fileNameEl.textContent = ''; fileSizeEl.textContent = '';
    });
    uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('drag-over'); });
    uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('drag-over'));
    uploadArea.addEventListener('drop', e => {
        e.preventDefault(); uploadArea.classList.remove('drag-over');
        const f = e.dataTransfer.files[0];
        if (f) { imageInput.files = e.dataTransfer.files; handleFile(f); }
    });
    function handleFile(f) {
        if (!f) return;
        if (!['image/jpeg','image/jpg','image/png','image/webp'].includes(f.type)) { alert('Invalid file type.'); return; }
        if (f.size > 5*1024*1024) { alert('File too large (max 5MB).'); return; }
        const reader = new FileReader();
        reader.onload = e => {
            imagePreview.src = e.target.result;
            previewContainer.classList.add('has-image');
            fileNameEl.textContent = f.name;
            fileSizeEl.textContent = f.size < 1048576 ? (f.size/1024).toFixed(1)+' KB' : (f.size/1048576).toFixed(1)+' MB';
        };
        reader.readAsDataURL(f);
    }

    const COLOR_MAP = {
        Black:'#1a1a1a', Red:'#cc2200', Gold:'#c9a96e', Silver:'#c0c0c0',
        Tortoise:'#7b4f1e', Blue:'#1a4fa0', Pink:'#e879a0', Green:'#2d7a3a', Transparent:'rgba(180,220,255,.5)'
    };
    function updateColorPreview() {
        const val = document.getElementById('colorInput').value;
        const container = document.getElementById('colorPreview');
        container.innerHTML = '';
        val.split(',').forEach(c => {
            c = c.trim();
            if (!c) return;
            const dot = document.createElement('div');
            dot.className = 'color-dot';
            dot.title = c;
            dot.style.background = COLOR_MAP[c] || '#ccc';
            container.appendChild(dot);
        });
    }
    function addColor(color) {
        const inp = document.getElementById('colorInput');
        const existing = inp.value.split(',').map(s => s.trim()).filter(Boolean);
        if (!existing.includes(color)) {
            inp.value = existing.length ? existing.join(', ') + ', ' + color : color;
            updateColorPreview();
        }
    }
    </script>
}
