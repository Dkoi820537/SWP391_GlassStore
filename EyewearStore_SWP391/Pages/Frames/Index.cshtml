@page
@model EyewearStore_SWP391.Pages.Frames.IndexModel
@{
    ViewData["Title"] = "Manage Frames";
    Layout = "_Layout";
}

<style>
    .frames-container {
        padding: 1.5rem 2rem;
        background: #f4f6f9;
        min-height: calc(100vh - 60px);
        font-family: 'Inter',sans-serif;
    }

    .controls-bar {
        background: white;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 6px rgba(0,0,0,.02);
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .controls-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        width: 100%;
        justify-content: space-between;
    }

    .filter-inline-form {
        display: flex;
        align-items: center;
        gap: .75rem;
        flex-wrap: wrap;
        flex: 1;
        justify-content: flex-end;
    }

    .search-input-group {
        position: relative;
        min-width: 250px;
        flex-grow: 1;
        max-width: 400px;
    }

        .search-input-group .bi-search {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #8f9bb3;
        }

        .search-input-group .form-control {
            padding-left: 2.5rem;
            border-radius: 8px;
            border: 1px solid #e4e9f2;
            background: #f7f9fc;
            box-shadow: none;
            width: 100%;
            height: 38px;
        }

            .search-input-group .form-control:focus {
                border-color: #008080;
                background: white;
            }

    .filter-select {
        border-radius: 8px;
        border: 1px solid #e4e9f2;
        padding: .375rem 2rem .375rem 1rem;
        background-color: white;
        color: #1a1a2e;
        cursor: pointer;
        font-size: .9rem;
        height: 38px;
    }

    .btn-create {
        background: #008080;
        color: white;
        border: none;
        border-radius: 8px;
        padding: .5rem 1.25rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: .5rem;
        transition: all .2s;
        text-decoration: none;
        height: 38px;
    }

        .btn-create:hover {
            background: #006666;
            color: white;
            transform: translateY(-1px);
        }

    .btn-filter-action {
        background: #1a1a2e;
        color: white;
        border-radius: 8px;
        border: none;
        padding: .375rem 1rem;
        font-weight: 500;
        transition: background .2s;
        height: 38px;
    }

        .btn-filter-action:hover {
            background: #2a2a4a;
        }

    .btn-reset {
        background: transparent;
        color: #8f9bb3;
        border: 1px solid #e4e9f2;
        border-radius: 8px;
        padding: .375rem 1rem;
        height: 38px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

        .btn-reset:hover {
            background: #f7f9fc;
            color: #1a1a2e;
        }

    .table-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,.02);
        overflow: hidden;
    }

    .modern-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .modern-table th {
            background: #1a1a2e;
            color: white;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .5px;
            padding: 1.2rem 1.5rem;
            border: none;
            white-space: nowrap;
        }

        .modern-table td {
            padding: .9rem 1.5rem;
            vertical-align: middle;
            border-bottom: 1px solid #edf1f7;
            color: #222b45;
            font-size: .9rem;
        }

        .modern-table tbody tr {
            transition: background-color .2s;
        }

            .modern-table tbody tr:hover {
                background-color: #f7f9fc;
            }

    /* ── Product cell with thumbnail ── */
    .product-cell {
        display: flex;
        align-items: center;
        gap: .9rem;
    }

    .product-thumb {
        width: 52px;
        height: 52px;
        border-radius: 8px;
        overflow: hidden;
        background: #f0f2f8;
        flex-shrink: 0;
        border: 1px solid #e4e9f2;
    }

        .product-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform .3s;
        }

    .modern-table tbody tr:hover .product-thumb img {
        transform: scale(1.08);
    }

    .product-thumb-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #b0b8d0;
    }

    .product-info {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .product-name {
        font-weight: 600;
        color: #1a1a2e;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 200px;
    }

    .product-sku {
        font-size: .75rem;
        color: #8f9bb3;
        font-family: monospace;
        margin-top: 2px;
    }

    .badge-modern {
        padding: .35rem .75rem;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-teal {
        background: rgba(0,128,128,.1);
        color: #008080;
    }

    .badge-navy {
        background: rgba(26,26,46,.1);
        color: #1a1a2e;
    }

    .badge-success {
        background: rgba(0,200,83,.1);
        color: #00c853;
    }

    .badge-warning {
        background: rgba(255,170,0,.1);
        color: #ffaa00;
    }

    .badge-danger {
        background: rgba(255,61,113,.1);
        color: #ff3d71;
    }

    .badge-neutral {
        background: #f7f9fc;
        color: #8f9bb3;
        border: 1px solid #e4e9f2;
    }

    .actions-cell {
        display: flex;
        gap: .5rem;
    }

    .btn-action {
        padding: .4rem .75rem;
        border-radius: 6px;
        font-size: .8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        text-decoration: none;
        border: 1px solid transparent;
        transition: all .2s;
    }

    .btn-action-edit {
        background: #f7f9fc;
        color: #008080;
        border-color: #e4e9f2;
    }

        .btn-action-edit:hover {
            background: #008080;
            color: white;
            border-color: #008080;
        }

    .btn-action-details {
        background: #f7f9fc;
        color: #1a1a2e;
        border-color: #e4e9f2;
    }

        .btn-action-details:hover {
            background: #1a1a2e;
            color: white;
            border-color: #1a1a2e;
        }

    .btn-action-delete {
        background: #f7f9fc;
        color: #ff3d71;
        border-color: #e4e9f2;
    }

        .btn-action-delete:hover {
            background: #ff3d71;
            color: white;
            border-color: #ff3d71;
        }

    .pagination-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        border-top: 1px solid #edf1f7;
    }

    .pagination-info {
        color: #8f9bb3;
        font-size: .85rem;
    }

    .modern-pagination {
        display: flex;
        gap: .35rem;
        margin: 0;
        padding: 0;
        list-style: none;
    }

        .modern-pagination .page-link {
            min-width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            border: 1px solid #e4e9f2;
            background: white;
            color: #1a1a2e;
            font-size: .85rem;
            font-weight: 500;
            text-decoration: none;
            transition: all .2s;
            padding: 0 .5rem;
        }

            .modern-pagination .page-link:hover:not(.disabled) {
                border-color: #008080;
                color: #008080;
            }

            .modern-pagination .page-link.active {
                background: #008080;
                border-color: #008080;
                color: white;
            }

            .modern-pagination .page-link.disabled {
                opacity: .5;
                cursor: not-allowed;
                background: #f7f9fc;
                color: #8f9bb3;
            }

    .price-group {
        display: flex;
        align-items: center;
        gap: .25rem;
        background: #f7f9fc;
        border: 1px solid #e4e9f2;
        border-radius: 8px;
        padding: 0 .5rem;
        height: 38px;
    }

        .price-group input {
            border: none;
            width: 60px;
            outline: none;
            font-size: .9rem;
            text-align: center;
            background: transparent;
        }

        .price-group span {
            color: #8f9bb3;
            font-size: .9rem;
        }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #8f9bb3;
    }
</style>

<div class="frames-container">
    <div class="controls-bar">
        <div class="controls-right" style="flex-wrap:nowrap; align-items:flex-start; flex-direction:column;">
            <div class="d-flex w-100 justify-content-between align-items-center">
                <h1 class="page-title"><i class="bi bi-eyeglasses"></i> Frame Products</h1>
                <a asp-page="/Frames/Create" class="btn-create"><i class="bi bi-plus-lg"></i> Create New</a>
            </div>

            <form method="get" class="filter-inline-form w-100 mt-2">
                <div class="search-input-group">
                    <i class="bi bi-search"></i>
                    <input type="text" class="form-control" name="SearchTerm" value="@Model.SearchTerm" placeholder="Search by name or SKU..." />
                </div>
                <select class="filter-select" name="FilterMaterial">
                    <option value="">All Materials</option>
                    @foreach (var m in Model.FrameList.AvailableMaterials)
                    {
                        <option value="@m" selected="@(Model.FilterMaterial == m)">@m</option>
                    }
                </select>
                <select class="filter-select" name="FilterType">
                    <option value="">All Types</option>
                    @foreach (var t in Model.FrameList.AvailableTypes)
                    {
                        <option value="@t" selected="@(Model.FilterType == t)">@t</option>
                    }
                </select>
                <div class="price-group">
                    <input type="number" name="MinPrice" value="@Model.MinPrice" min="0" step="0.01" placeholder="Min" />
                    <span>-</span>
                    <input type="number" name="MaxPrice" value="@Model.MaxPrice" min="0" step="0.01" placeholder="Max" />
                </div>
                <button type="submit" class="btn-filter-action">Filter</button>
                <a asp-page="/Frames/Index" class="btn-reset">Reset</a>
            </form>
        </div>
    </div>

    <div class="table-card">
        @if (Model.FrameList.Items.Any())
        {
            <div class="table-responsive">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Material</th>
                            <th>Type</th>
                            <th>Stock</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var frame in Model.FrameList.Items)
                        {
                            <tr>
                                <td>
                                    <div class="product-cell">
                                        <!-- Thumbnail image -->
                                        <div class="product-thumb">
                                            @if (!string.IsNullOrEmpty(frame.PrimaryImageUrl))
                                            {
                                                <img src="@frame.PrimaryImageUrl" alt="@frame.Name" loading="lazy" />
                                            }
                                            else
                                            {
                                                <div class="product-thumb-placeholder">
                                                    <i class="bi bi-eyeglasses"></i>
                                                </div>
                                            }
                                        </div>
                                        <div class="product-info">
                                            <span class="product-name">@frame.Name</span>
                                            <span class="product-sku">@frame.Sku</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(frame.FrameMaterial))
                                    {
                                        <span class="badge-modern badge-navy">@frame.FrameMaterial</span>
                                    }
                                    else
                                    {

                                        <span class="badge-modern badge-neutral">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(frame.FrameType))
                                    {
                                        <span class="badge-modern badge-teal">@frame.FrameType</span>
                                    }
                                    else
                                    {

                                        <span class="badge-modern badge-neutral">N/A</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var stockVal = frame.QuantityOnHand ?? 0;
                                        var stockCls = stockVal == 0 ? "badge-danger" : stockVal < 10 ? "badge-warning" : "badge-success";
                                    }
                                    <span class="badge-modern @stockCls">@stockVal in stock</span>
                                </td>
                                <td style="font-weight:600;">@frame.Price.ToString("N0") @frame.Currency</td>
                                <td>
                                    @if (frame.IsActive)
                                    {
                                        <span class="badge-modern badge-success">Active</span>
                                    }
                                    else
                                    {

                                        <span class="badge-modern badge-neutral">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <a asp-page="/Frames/Details" asp-route-id="@frame.ProductId" class="btn-action btn-action-details">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                        <a asp-page="/Frames/Edit" asp-route-id="@frame.ProductId" class="btn-action btn-action-edit">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <a asp-page="/Frames/Delete" asp-route-id="@frame.ProductId" class="btn-action btn-action-delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pagination-footer">
                <div class="pagination-info">
                    Showing <strong>@(((Model.CurrentPage - 1) * Model.FrameList.PageSize) + 1)</strong> to
                    <strong>@Math.Min(Model.CurrentPage * Model.FrameList.PageSize, Model.FrameList.TotalCount)</strong> of
                    <strong>@Model.FrameList.TotalCount</strong> products
                </div>
                <ul class="modern-pagination">
                    @if (Model.FrameList.HasPreviousPage)
                    {
                        <li><a asp-page="/Frames/Index" asp-route-SearchTerm="@Model.SearchTerm" asp-route-FilterMaterial="@Model.FilterMaterial" asp-route-FilterType="@Model.FilterType" asp-route-MinPrice="@Model.MinPrice" asp-route-MaxPrice="@Model.MaxPrice" asp-route-CurrentPage="@(Model.CurrentPage - 1)" class="page-link"><i class="bi bi-chevron-left"></i> Prev</a></li>
                    }
                    else
                    {
                        <li><span class="page-link disabled"><i class="bi bi-chevron-left"></i> Prev</span></li>
                    }

                    @{
                        var sp = Math.Max(1, Model.CurrentPage - 2);
                        var ep = Math.Min(Model.FrameList.TotalPages, Model.CurrentPage + 2);
                        if (sp > 1)
                        {
                            <li><a asp-page="/Frames/Index" asp-route-CurrentPage="1" class="page-link">1</a></li>
                            if (sp > 2)
                            {
                                <li><span class="page-link disabled">...</span></li>
                            }
                        }
                        for (var i = sp; i <= ep; i++)
                        {
                            if (i == Model.CurrentPage)
                            {
                                <li><span class="page-link active">@i</span></li>
                            }
                            else
                            {
                                <li><a asp-page="/Frames/Index" asp-route-SearchTerm="@Model.SearchTerm" asp-route-FilterMaterial="@Model.FilterMaterial" asp-route-FilterType="@Model.FilterType" asp-route-MinPrice="@Model.MinPrice" asp-route-MaxPrice="@Model.MaxPrice" asp-route-CurrentPage="@i" class="page-link">@i</a></li>
                            }
                        }
                        if (ep < Model.FrameList.TotalPages)
                        {
                            if (ep < Model.FrameList.TotalPages - 1)
                            {
                                <li><span class="page-link disabled">...</span></li>
                            }
                            <li><a asp-page="/Frames/Index" asp-route-CurrentPage="@Model.FrameList.TotalPages" class="page-link">@Model.FrameList.TotalPages</a></li>
                        }
                    }

                    @if (Model.FrameList.HasNextPage)
                    {
                        <li><a asp-page="/Frames/Index" asp-route-SearchTerm="@Model.SearchTerm" asp-route-FilterMaterial="@Model.FilterMaterial" asp-route-FilterType="@Model.FilterType" asp-route-MinPrice="@Model.MinPrice" asp-route-MaxPrice="@Model.MaxPrice" asp-route-CurrentPage="@(Model.CurrentPage + 1)" class="page-link">Next <i class="bi bi-chevron-right"></i></a></li>
                    }
                    else
                    {
                        <li><span class="page-link disabled">Next <i class="bi bi-chevron-right"></i></span></li>
                    }
                </ul>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox fs-1 mb-3 d-block"></i>
                <h4>No frames found</h4>
                <p>Adjust your search/filters or create a new frame.</p>
            </div>
        }
    </div>
</div>
