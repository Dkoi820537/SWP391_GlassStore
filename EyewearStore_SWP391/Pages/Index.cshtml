@section Scripts {
    <script>
        function smoothScroll(e, id) {
            e.preventDefault();
            var el = document.getElementById(id);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // ============================================
        // BRAND SELECTOR LOGIC
        // ============================================
        document.addEventListener("DOMContentLoaded", function() {
            const frameBrands = ['Ray-Ban', 'Oakley', 'Gucci', 'Prada', 'Tom Ford', 'Versace', 'Burberry', 'Persol', 'Maui Jim'];
            const lensBrands = ['ZEISS', 'Essilor', 'Hoya', 'Nikon', 'Shamir', 'Kodak'];

            const createBrandChip = (brandName, type) => {
                const url = `/Products/Index?BrandFilter=${encodeURIComponent(brandName)}&ProductTypeFilter=${type}`;
                return `<a href="${url}" class="brand-chip">${brandName}</a>`;
            };

            const listFrames = document.getElementById('list-frames');
            const listLenses = document.getElementById('list-lenses');

            if (listFrames && listLenses) {
                listFrames.innerHTML = frameBrands.map(b => createBrandChip(b, 'Frame')).join('');
                listLenses.innerHTML = lensBrands.map(b => createBrandChip(b, 'Lens')).join('');
            }
        });

        function switchBrandTab(tabId) {
            const btnFrames = document.getElementById('btn-frames');
            const btnLenses = document.getElementById('btn-lenses');
            const listFrames = document.getElementById('list-frames');
            const listLenses = document.getElementById('list-lenses');
            
            if (!btnFrames || !btnLenses || !listFrames || !listLenses) return;

            const setTabStyle = (btn, isActive) => {
                if (isActive) {
                    btn.classList.add('active');
                    btn.classList.remove('inactive');
                } else {
                    btn.classList.add('inactive');
                    btn.classList.remove('active');
                }
            };

            const showList = (hideEl, showEl) => {
                hideEl.classList.add('hidden');
                hideEl.classList.remove('fade-in');
                showEl.classList.remove('hidden');
                
                // Trigger browser reflow to instantly restart animation
                void showEl.offsetWidth; 
                showEl.classList.add('fade-in');
            };

            if (tabId === 'frames') {
                setTabStyle(btnFrames, true);
                setTabStyle(btnLenses, false);
                showList(listLenses, listFrames);
            } else {
                setTabStyle(btnFrames, false);
                setTabStyle(btnLenses, true);
                showList(listFrames, listLenses);
            }
        }
    </script>
}
