                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        <polyline points="9 12 11 14 15 10" />
                    </svg>
                </div>
                <div class="trust-text">
                    <h4>Premium Quality</h4>
                    <p>Certified authentic products</p>
                </div>
            </div>
            <div class="trust-item">
