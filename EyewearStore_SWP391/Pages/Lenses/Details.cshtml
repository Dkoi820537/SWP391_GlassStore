@page "{id:int}"
@model EyewearStore_SWP391.Pages.Lenses.DetailsModel
@{
    ViewData["Title"] = $"Lens Details - {Model.Lens.Name}";
    Layout = "_Layout";
}
<style>
    .details-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem
    }

        .page-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0
        }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all .2s;
        border: none;
        cursor: pointer;
        font-size: .95rem
    }

    .btn-warning {
        background: #ffc107;
        color: #212529
    }

        .btn-warning:hover {
            background: #e0a800
        }

    .btn-secondary {
        background: #f0f0f5;
        color: #4a4a68
    }

        .btn-secondary:hover {
            background: #e0e0e8
        }

    .content-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 2rem
    }

    .image-section {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.08)
    }

    .main-image {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        background: #f8f9fc;
        display: flex;
        align-items: center;
        justify-content: center
    }

        .main-image img {
            width: 100%;
            height: 100%;
            object-fit: cover
        }

    .no-image {
        color: #6c757d;
        font-size: 4rem
    }

    .thumbnail-gallery {
        display: flex;
        gap: .5rem;
        margin-top: 1rem;
        flex-wrap: wrap
    }

    .thumbnail {
        width: 60px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: border-color .2s
    }

        .thumbnail:hover, .thumbnail.active {
            border-color: #667eea
        }

        .thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover
        }

    .details-section {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.08)
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 1.25rem;
        padding-bottom: .6rem;
        border-bottom: 2px solid #f0f0f5
    }

    .details-list {
        margin-bottom: 1.5rem
    }

        .details-list dl {
            display: grid;
            grid-template-columns: 160px 1fr;
            gap: .75rem 2rem;
            margin: 0
        }

        .details-list dt {
            font-weight: 600;
            color: #4a4a68;
            font-size: .875rem
        }

        .details-list dd {
            margin: 0;
            color: #1a1a2e;
            font-size: .9rem
        }

    .sku-badge {
        font-family: 'Courier New',monospace;
        background: #e8eaff;
        color: #667eea;
        padding: .25rem .75rem;
        border-radius: 4px;
        font-size: .9rem;
        font-weight: 600;
        display: inline-block
    }

    .price-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #28a745
    }

    .status-badge {
        display: inline-block;
        padding: .35rem 1rem;
        border-radius: 20px;
        font-size: .85rem;
        font-weight: 600
    }

    .status-active {
        background: #d4edda;
        color: #155724
    }

    .status-inactive {
        background: #f8d7da;
        color: #721c24
    }

    .tag-pill {
        display: inline-flex;
        align-items: center;
        padding: .3rem .8rem;
        border-radius: 20px;
        font-size: .8rem;
        font-weight: 600;
        margin: .15rem
    }

    .tag-teal {
        background: rgba(0,128,128,.1);
        color: #008080
    }

    .tag-navy {
        background: rgba(26,26,46,.1);
        color: #1a1a2e
    }

    .tag-purple {
        background: #e8eaff;
        color: #667eea
    }

    .tag-green {
        background: #d4edda;
        color: #155724
    }

    .tag-gray {
        background: #f0f0f5;
        color: #6c757d
    }

    .stock-value {
        font-weight: 600
    }

    .stock-in {
        color: #28a745
    }

    .stock-low {
        color: #ffc107
    }

    .stock-out {
        color: #dc3545
    }

    .na-text {
        color: #6c757d;
        font-style: italic
    }

    .timestamp {
        color: #6c757d;
        font-size: .85rem
    }

    .actions-section {
        margin-top: 2rem;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap
    }

    @@media(max-width:992px) {
        .content-grid {
            grid-template-columns: 1fr
        }
    }

    @@media(max-width:768px) {
        .details-container {
            padding: 1rem
        }

        .details-list dl {
            grid-template-columns: 1fr;
            gap: .4rem
        }
    }
</style>

<div class="details-container">
    <div class="page-header">
        <h1><i class="bi bi-circle-half"></i> @Model.Lens.Name</h1>
        <div style="display:flex;gap:.5rem;">
            <a asp-page="/Lenses/Edit" asp-route-id="@Model.Lens.ProductId" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-page="/Lenses/Index" class="btn btn-secondary">← Back to List</a>
        </div>
    </div>

    <div class="content-grid">
        <!-- Images -->
        <div class="image-section">
            <div class="main-image" id="mainImage">
                @if (!string.IsNullOrEmpty(Model.Lens.PrimaryImageUrl))
                {
                    <img src="@Model.Lens.PrimaryImageUrl" alt="@Model.Lens.Name" id="mainImageElement" />
                }
                else
                {
                    <span class="no-image"><i class="bi bi-circle-half"></i></span>
                }
            </div>
            @if (Model.Lens.ImageUrls.Count > 1)
            {
                <div class="thumbnail-gallery">
                    @foreach (var url in Model.Lens.ImageUrls)
                    {
                        <div class="thumbnail @(url == Model.Lens.PrimaryImageUrl ? "active" : "")"
                             onclick="changeMainImage(this,'@url')">
                            <img src="@url" alt="Lens thumbnail" />
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Details -->
        <div class="details-section">

            <!-- Product Info -->
            <h3 class="section-title"><i class="bi bi-box-seam me-2"></i>Product Information</h3>
            <div class="details-list">
                <dl>
                    <dt>SKU</dt>
                    <dd><span class="sku-badge">@Model.Lens.Sku</span></dd>
                    <dt>Name</dt>
                    <dd><strong>@Model.Lens.Name</strong></dd>
                    <dt>Brand</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(Model.Lens.Brand))
                        {
                            <span class="tag-pill tag-teal">@Model.Lens.Brand</span>
                        }
                        else
                        {

                            <span class="na-text">N/A</span>
                        }
                    </dd>
                    <dt>Origin</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(Model.Lens.Origin))
                        {
                            <span>@Model.Lens.Origin</span>
                        }
                        else
                        {

                            <span class="na-text">N/A</span>
                        }
                    </dd>
                    <dt>Price</dt>
                    <dd>
                        <span class="price-value">@Model.Lens.Price.ToString("N0")</span>
                        <span style="font-size:.9rem;color:#6c757d;margin-left:4px;">@Model.Lens.Currency</span>
                    </dd>
                    <dt>Inventory</dt>
                    <dd>
                        @{
                            var sv = Model.Lens.QuantityOnHand ?? 0;
                            var sc = sv == 0 ? "stock-out" : sv < 10 ? "stock-low" : "stock-in";
                        }
                        <span class="stock-value @sc">@sv units</span>
                    </dd>
                    <dt>Description</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(Model.Lens.Description))
                        {
                            <span style="line-height:1.6;">@Model.Lens.Description</span>
                        }
                        else
                        {

                            <span class="na-text">N/A</span>
                        }
                    </dd>
                </dl>
            </div>

            <!-- Lens Specs -->
            <h3 class="section-title"><i class="bi bi-sliders me-2"></i>Lens Specifications</h3>
            <div class="details-list">
                <dl>
                    <dt>Lens Type</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(Model.Lens.LensType))
                        {
                            <span class="tag-pill tag-navy">@Model.Lens.LensType</span>
                        }
                        else
                        {

                            <span class="na-text">N/A</span>
                        }
                    </dd>
                    <dt>Lens Index</dt>
                    <dd>
                        @if (Model.Lens.LensIndex.HasValue)
                        {
                            <span class="tag-pill tag-teal">@Model.Lens.LensIndex.Value.ToString("F2")</span>
                        }
                        else
                        {

                            <span class="na-text">N/A</span>
                        }
                    </dd>
                    <dt>Material</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(Model.Lens.LensMaterial))
                        {
                            <span class="tag-pill tag-gray">@Model.Lens.LensMaterial</span>
                        }
                        else
                        {

                            <span class="na-text">N/A</span>
                        }
                    </dd>
                    <dt>Thickness</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(Model.Lens.LensThickness))
                        {
                            <span class="tag-pill tag-gray">@Model.Lens.LensThickness</span>
                        }
                        else
                        {

                            <span class="na-text">N/A</span>
                        }
                    </dd>
                    <dt>Prescription</dt>
                    <dd>
                        @if (Model.Lens.IsPrescription)
                        {
                            <span class="tag-pill tag-purple"><i class="bi bi-file-earmark-medical me-1"></i>Required</span>
                        }
                        else
                        {

                            <span class="tag-pill tag-gray">Not Required</span>
                        }
                    </dd>
                </dl>
            </div>

            <!-- Coatings & Protection -->
            <h3 class="section-title"><i class="bi bi-shield-check me-2"></i>Coatings &amp; Protection</h3>
            <div class="details-list">
                <dl>
                    <dt>Coatings</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(Model.Lens.LensCoating))
                        {
                            var coatings = Model.Lens.LensCoating.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                            foreach (var c in coatings)
                            {
                                <span class="tag-pill tag-teal">@c</span>
                            }
                        }
                        else
                        {

                            <span class="na-text">None</span>
                        }
                    </dd>
                    <dt>UV Protection</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(Model.Lens.UVProtection))
                        {
                            <span class="tag-pill tag-green">@Model.Lens.UVProtection</span>
                        }
                        else
                        {

                            <span class="na-text">N/A</span>
                        }
                    </dd>
                </dl>
            </div>

            <!-- Status & Metadata -->
            <h3 class="section-title"><i class="bi bi-card-checklist me-2"></i>Status &amp; Metadata</h3>
            <div class="details-list">
                <dl>
                    <dt>Status</dt>
                    <dd>
                        @if (Model.Lens.IsActive)
                        {
                            <span class="status-badge status-active">Active</span>
                        }
                        else
                        {

                            <span class="status-badge status-inactive">Inactive</span>
                        }
                    </dd>
                    <dt>Created</dt>
                    <dd><span class="timestamp">@Model.Lens.CreatedAt.ToString("MMMM dd, yyyy 'at' hh:mm tt")</span></dd>
                    <dt>Last Updated</dt>
                    <dd><span class="timestamp">@Model.Lens.UpdatedAt.ToString("MMMM dd, yyyy 'at' hh:mm tt")</span></dd>
                </dl>
            </div>

            <div class="actions-section">
                <a asp-page="/Lenses/Edit" asp-route-id="@Model.Lens.ProductId" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Edit Lens
                </a>
                <a asp-page="/Lenses/Delete" asp-route-id="@Model.Lens.ProductId" class="btn btn-secondary"
                   onclick="return confirm('Are you sure you want to deactivate this lens?');">
                    <i class="bi bi-trash"></i> Delete
                </a>
                <a asp-page="/Lenses/Index" class="btn btn-secondary">← Back to List</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeMainImage(thumbnail, imageUrl) {
            var img = document.getElementById('mainImageElement');
            if (img) { img.src = imageUrl; }
            else {
                document.getElementById('mainImage').innerHTML = '<img src="' + imageUrl + '" alt="Lens" id="mainImageElement" />';
            }
            document.querySelectorAll('.thumbnail').forEach(function(t){ t.classList.remove('active'); });
            thumbnail.classList.add('active');
        }
    </script>
}
