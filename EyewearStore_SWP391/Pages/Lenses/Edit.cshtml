@page "{id:int}"
@model EyewearStore_SWP391.Pages.Lenses.EditModel
@{
    ViewData["Title"] = "Edit Lens";
    Layout = "_Layout";
}
<style>
    .le-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem
    }

    .le-header {
        margin-bottom: 2rem
    }

        .le-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0 0 .5rem
        }

        .le-header p {
            color: #6c757d;
            margin: 0
        }

    .breadcrumb {
        display: flex;
        gap: .5rem;
        margin-bottom: 1rem;
        font-size: .9rem
    }

        .breadcrumb a {
            color: #667eea;
            text-decoration: none
        }

            .breadcrumb a:hover {
                text-decoration: underline
            }

        .breadcrumb .sep {
            color: #adb5bd
        }

        .breadcrumb .cur {
            color: #6c757d
        }

    .form-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.08);
        overflow: hidden
    }

    .form-section {
        padding: 2rem;
        border-bottom: 1px solid #f0f0f5
    }

        .form-section:last-of-type {
            border-bottom: none
        }

    .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #1a1a2e;
        margin: 0 0 1.5rem;
        padding-bottom: .75rem;
        border-bottom: 2px solid #667eea;
        display: inline-block
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 1.5rem;
        margin-bottom: 1.5rem
    }

        .form-row.single {
            grid-template-columns: 1fr
        }

        .form-row.tri {
            grid-template-columns: repeat(3,1fr)
        }

    .form-group {
        display: flex;
        flex-direction: column
    }

        .form-group label {
            font-weight: 600;
            font-size: .875rem;
            color: #4a4a68;
            margin-bottom: .5rem
        }

    .req {
        color: #dc3545
    }

    .form-control {
        padding: .75rem 1rem;
        border: 1px solid #e0e0e8;
        border-radius: 8px;
        font-size: .95rem;
        transition: border-color .2s,box-shadow .2s;
        width: 100%;
        box-sizing: border-box
    }

        .form-control:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,.2)
        }

        .form-control.input-validation-error {
            border-color: #dc3545
        }

    textarea.form-control {
        resize: vertical;
        min-height: 100px
    }

    .field-validation-error {
        color: #dc3545;
        font-size: .85rem;
        margin-top: .35rem
    }

    .validation-summary-errors {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        border-radius: 8px;
        padding: 1rem 1.5rem;
        margin-bottom: 1.5rem;
        color: #721c24
    }

    .helper-text {
        font-size: .8rem;
        color: #6c757d;
        margin-top: .35rem
    }

    .product-id-badge {
        display: inline-block;
        background: #e8eaff;
        color: #667eea;
        padding: .25rem .75rem;
        border-radius: 4px;
        font-size: .85rem;
        font-weight: 600;
        margin-left: .5rem
    }

    .check-wrap {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-top: .5rem
    }

        .check-wrap input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: #667eea
        }

        .check-wrap label {
            margin-bottom: 0;
            cursor: pointer;
            font-weight: 500
        }

    .coating-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 8px
    }

    .coating-tag {
        padding: .25rem .7rem;
        border-radius: 20px;
        font-size: .78rem;
        font-weight: 600;
        background: #e8eaff;
        color: #667eea;
        border: 1.5px solid #667eea;
        cursor: pointer;
        transition: all .15s
    }

        .coating-tag:hover {
            background: #667eea;
            color: #fff
        }

    .existing-images-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(180px,1fr));
        gap: 1.25rem;
        margin-bottom: 1.5rem
    }

    .existing-image-card {
        background: #fff;
        border: 2px solid #e0e0e8;
        border-radius: 12px;
        overflow: hidden;
        position: relative;
        transition: all .2s
    }

        .existing-image-card:hover {
            box-shadow: 0 4px 12px rgba(0,0,0,.1)
        }

        .existing-image-card.is-primary {
            border-color: #667eea;
            box-shadow: 0 0 0 2px rgba(102,126,234,.3)
        }

        .existing-image-card img {
            width: 100%;
            height: 140px;
            object-fit: cover
        }

        .existing-image-card .image-actions {
            padding: .65rem;
            display: flex;
            gap: .4rem;
            justify-content: center
        }

        .existing-image-card .btn-sm {
            padding: .3rem .65rem;
            font-size: .75rem;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            transition: all .2s;
            font-weight: 600
        }

    .btn-set-primary {
        background: #667eea;
        color: #fff
    }

        .btn-set-primary:hover {
            background: #5a6fd6
        }

    .btn-delete-image {
        background: #dc3545;
        color: #fff
    }

        .btn-delete-image:hover {
            background: #c82333
        }

    .primary-badge {
        position: absolute;
        top: 8px;
        left: 8px;
        background: #667eea;
        color: #fff;
        padding: .2rem .5rem;
        border-radius: 4px;
        font-size: .72rem;
        font-weight: 700
    }

    .no-images-message {
        text-align: center;
        padding: 2rem;
        color: #6c757d;
        background: #f8f9fc;
        border-radius: 8px;
        border: 1px dashed #e0e0e8
    }

    .image-drop-zone {
        border: 2px dashed #e0e0e8;
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        background: #fafafa;
        cursor: pointer;
        transition: border-color .25s,background .25s
    }

        .image-drop-zone:hover, .image-drop-zone.drag-over {
            border-color: #667eea;
            background: rgba(102,126,234,.04)
        }

        .image-drop-zone .dz-icon {
            font-size: 2.5rem;
            color: #adb5bd;
            margin-bottom: .6rem
        }

        .image-drop-zone h4 {
            margin: 0 0 .3rem;
            font-size: .95rem;
            color: #4a4a68
        }

        .image-drop-zone p {
            margin: 0;
            font-size: .82rem;
            color: #6c757d
        }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;
        padding: 1.5rem 2rem;
        background: #f8f9fc;
        border-top: 1px solid #f0f0f5
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        transition: all .2s;
        border: none;
        cursor: pointer;
        font-size: .95rem
    }

    .btn-primary {
        background: linear-gradient(135deg,#667eea 0%,#764ba2 100%);
        color: #fff
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102,126,234,.4)
        }

    .btn-secondary {
        background: #f0f0f5;
        color: #4a4a68
    }

        .btn-secondary:hover {
            background: #e0e0e8
        }

    @@media(max-width:768px) {
        .le-wrap {
            padding: 1rem
        }

        .form-section {
            padding: 1.5rem
        }

        .form-row, .form-row.tri {
            grid-template-columns: 1fr
        }

        .form-actions {
            flex-direction: column-reverse
        }

        .btn {
            width: 100%;
            justify-content: center
        }
    }
</style>

<div class="le-wrap">
    <nav class="breadcrumb">
        <a href="/">Home</a><span class="sep">›</span>
        <a asp-page="/Lenses/Index">Lenses</a><span class="sep">›</span>
        <span class="cur">Edit</span>
    </nav>
    <div class="le-header">
        <h1>
            <i class="bi bi-pencil-square"></i> Edit Lens
            <span class="product-id-badge">ID: @Model.Input.ProductId</span>
        </h1>
        <p>Update the lens product details</p>
    </div>

    <div class="form-card">
        <form method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Input.ProductId" />
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <!-- Basic Information -->
            <div class="form-section">
                <h2 class="section-title">Basic Information</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.Sku">SKU <span class="req">*</span></label>
                        <input asp-for="Input.Sku" class="form-control" />
                        <span asp-validation-for="Input.Sku" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Name">Product Name <span class="req">*</span></label>
                        <input asp-for="Input.Name" class="form-control" />
                        <span asp-validation-for="Input.Name" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-row single">
                    <div class="form-group">
                        <label asp-for="Input.Description">Description</label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>

            <!-- Brand & Identity -->
            <div class="form-section">
                <h2 class="section-title">Brand &amp; Identity</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.Brand">Brand</label>
                        <select asp-for="Input.Brand" class="form-control">
                            <option value="">-- Select Brand --</option>
                            @foreach (var b in new[] { "Essilor", "Hoya", "Zeiss", "Nikon", "Rodenstock", "Shamir", "Seiko", "Kodak", "Other" })
                            {
                                <option value="@b">@b</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Origin">Country of Origin</label>
                        <input asp-for="Input.Origin" class="form-control" placeholder="e.g., France, Germany, Japan" />
                    </div>
                </div>
            </div>

            <!-- Lens Specifications -->
            <div class="form-section">
                <h2 class="section-title">Lens Specifications</h2>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.LensType">Lens Type</label>
                        <select asp-for="Input.LensType" class="form-control">
                            <option value="">-- Select Type --</option>
                            @foreach (var lt in EyewearStore_SWP391.Models.LensTypes.All)
                            {
                                <option value="@lt">@lt</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.LensIndex">Lens Index</label>
                        <select asp-for="Input.LensIndex" class="form-control">
                            <option value="">-- Select Index --</option>
                            <option value="1.50">1.50 — Standard</option>
                            <option value="1.56">1.56 — Mid-Index</option>
                            <option value="1.60">1.60 — Mid-High</option>
                            <option value="1.67">1.67 — High-Index</option>
                            <option value="1.74">1.74 — Ultra High-Index</option>
                            <option value="1.76">1.76 — Super Ultra</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.LensMaterial">Lens Material</label>
                        <select asp-for="Input.LensMaterial" class="form-control">
                            <option value="">-- Select Material --</option>
                            <option value="CR-39">CR-39 (Plastic)</option>
                            <option value="Polycarbonate">Polycarbonate</option>
                            <option value="Trivex">Trivex</option>
                            <option value="MR-8">MR-8</option>
                            <option value="Glass">Glass</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.LensThickness">Thickness Category</label>
                        <select asp-for="Input.LensThickness" class="form-control">
                            <option value="">-- Select Thickness --</option>
                            <option value="Standard">Standard</option>
                            <option value="Thin">Thin</option>
                            <option value="Ultra-Thin">Ultra-Thin</option>
                            <option value="Aspheric">Aspheric</option>
                        </select>
                    </div>
                </div>
                <div class="form-row single">
                    <div class="form-group">
                        <label>Prescription Requirement</label>
                        <div class="check-wrap">
                            <input asp-for="Input.IsPrescription" type="checkbox" id="isPrescription" />
                            <label for="isPrescription">This lens requires a prescription (Rx)</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Coatings & Protection -->
            <div class="form-section">
                <h2 class="section-title">Coatings &amp; Protection</h2>
                <div class="form-row single">
                    <div class="form-group">
                        <label asp-for="Input.LensCoating">Coatings (comma-separated)</label>
                        <input asp-for="Input.LensCoating" class="form-control" id="coatingInput"
                               placeholder="e.g., Anti-Reflective, Anti-Scratch, Blue Light Filter"
                               oninput="updateCoatingTags()" />
                        <div class="coating-tags" id="coatingTagsPreview"></div>
                    </div>
                </div>
                <div class="form-row single">
                    <div class="form-group">
                        <p class="helper-text" style="margin:0 0 6px;">Quick add:</p>
                        <div style="display:flex;gap:6px;flex-wrap:wrap;">
                            @foreach (var c in new[] { "Anti-Reflective", "Anti-Scratch", "Blue Light Filter", "Photochromic", "Polarized", "Oleophobic", "Hydrophobic", "UV Coating" })
                            {
                                <button type="button" class="coating-tag" onclick="addCoating('@c')">+ @c</button>
                            }
                        </div>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.UVProtection">UV Protection</label>
                        <select asp-for="Input.UVProtection" class="form-control">
                            <option value="">-- Select --</option>
                            <option value="UV400">UV400 (Full protection)</option>
                            <option value="UV380">UV380</option>
                            <option value="None">None</option>
                        </select>
                    </div>
                    <div class="form-group"></div>
                </div>
            </div>

            <!-- Pricing, Inventory & Status -->
            <div class="form-section">
                <h2 class="section-title">Pricing &amp; Inventory</h2>
                <div class="form-row tri">
                    <div class="form-group">
                        <label asp-for="Input.Price">Price <span class="req">*</span></label>
                        <input asp-for="Input.Price" type="number" step="1000" min="0" class="form-control" />
                        <span asp-validation-for="Input.Price" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Currency">Currency</label>
                        <input asp-for="Input.Currency" class="form-control" maxlength="3" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.InventoryQty">Inventory Qty</label>
                        <input asp-for="Input.InventoryQty" type="number" min="0" class="form-control" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.IsActive">Status</label>
                        <select asp-for="Input.IsActive" class="form-control">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                    <div class="form-group"></div>
                </div>
            </div>

            <!-- Product Images -->
            <div class="form-section">
                <h2 class="section-title">Product Images</h2>
                @if (Model.ExistingImages.Any())
                {
                    <h4 style="margin-bottom:1rem;color:#4a4a68;font-size:.95rem;">Current Images</h4>
                    <div class="existing-images-grid">
                        @foreach (var image in Model.ExistingImages)
                        {
                            <div class="existing-image-card @(image.IsPrimary ? "is-primary" : "")">
                                @if (image.IsPrimary)
                                {
                                    <span class="primary-badge">★ Primary</span>
                                }
                                <img src="@image.ImageUrl" alt="@(image.AltText ?? "Product Image")" />
                                <div class="image-actions">
                                    @if (!image.IsPrimary)
                                    {
                                        <a asp-page-handler="SetPrimaryImage" asp-route-imageId="@image.ImageId" asp-route-productId="@Model.Input.ProductId"
                                           class="btn-sm btn-set-primary" style="text-decoration:none;">Set Primary</a>
                                    }
                                    <a asp-page-handler="DeleteImage" asp-route-imageId="@image.ImageId" asp-route-productId="@Model.Input.ProductId"
                                       class="btn-sm btn-delete-image" style="text-decoration:none;"
                                       onclick="return confirm('Delete this image?');">Delete</a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="no-images-message"><p><i class="bi bi-image text-muted"></i> No images uploaded yet.</p></div>
                }

                <h4 style="margin:1.5rem 0 1rem;color:#4a4a68;font-size:.95rem;">Add New Image</h4>
                <input type="file" id="imageFileInput" name="Input.ImageFile" accept=".jpg,.jpeg,.png,.webp" style="display:none" />
                <label class="image-drop-zone" for="imageFileInput" id="editDropZone">
                    <div class="dz-icon"><i class="bi bi-camera"></i></div>
                    <h4>Upload Image</h4>
                    <p>Click to select · JPG, PNG, WEBP · Max 5 MB</p>
                </label>
                <div id="imagePreviewContainer" style="display:none;margin-top:1rem;text-align:center;">
                    <img id="imagePreview" style="max-width:200px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.1);" src="" alt="Preview" />
                    <div style="margin-top:.5rem;">
                        <span id="fileName" style="font-weight:600;font-size:.85rem;"></span>
                        <button type="button" onclick="removeImage()"
                                style="margin-left:.75rem;background:#dc3545;color:#fff;border:none;border-radius:5px;padding:.3rem .8rem;font-size:.8rem;cursor:pointer;">
                            Remove
                        </button>
                    </div>
                </div>
                <div class="form-row single" style="margin-top:1.2rem;">
                    <div class="form-group">
                        <label asp-for="Input.ImageAltText">Image Alt Text</label>
                        <input asp-for="Input.ImageAltText" class="form-control" placeholder="Describe the image for accessibility" />
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a asp-page="/Lenses/Index" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var imageInput=document.getElementById('imageFileInput');
        imageInput.addEventListener('change',function(e){
            var file=e.target.files[0];if(!file)return;
            var reader=new FileReader();
            reader.onload=function(ev){document.getElementById('imagePreview').src=ev.target.result;document.getElementById('fileName').textContent=file.name;document.getElementById('imagePreviewContainer').style.display='block';};
            reader.readAsDataURL(file);
        });
        function removeImage(){imageInput.value='';document.getElementById('imagePreviewContainer').style.display='none';document.getElementById('imagePreview').src='';}
        function updateCoatingTags(){var val=document.getElementById('coatingInput').value,container=document.getElementById('coatingTagsPreview');container.innerHTML='';val.split(',').forEach(function(c){c=c.trim();if(!c)return;var tag=document.createElement('span');tag.className='coating-tag';tag.style.cursor='default';tag.textContent=c;container.appendChild(tag);});}
        function addCoating(coating){var inp=document.getElementById('coatingInput'),existing=inp.value.split(',').map(function(s){return s.trim();}).filter(Boolean);if(existing.indexOf(coating)===-1){inp.value=existing.length?existing.join(', ')+', '+coating:coating;updateCoatingTags();}}
        document.addEventListener('DOMContentLoaded',function(){updateCoatingTags();});
    </script>
}
