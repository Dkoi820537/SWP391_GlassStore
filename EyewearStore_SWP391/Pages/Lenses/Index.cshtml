@page
@model EyewearStore_SWP391.Pages.Lenses.IndexModel
@{
    ViewData["Title"] = "Manage Lenses";
    Layout = "_Layout";
}

<style>
    .lenses-container {
        padding: 1.5rem 2rem;
        background: #f4f6f9;
        min-height: calc(100vh - 60px);
        font-family: 'Inter',sans-serif;
    }

    .controls-bar {
        background: white;
        border-radius: 12px;
        padding: 1rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 6px rgba(0,0,0,.02);
    }

    .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a1a2e;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .controls-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        width: 100%;
        justify-content: space-between;
    }

    .filter-inline-form {
        display: flex;
        align-items: center;
        gap: .75rem;
        flex-wrap: wrap;
        flex: 1;
        justify-content: flex-end;
    }

    .search-input-group {
        position: relative;
        min-width: 220px;
        flex-grow: 1;
        max-width: 360px;
    }

        .search-input-group .bi-search {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #8f9bb3;
        }

        .search-input-group .form-control {
            padding-left: 2.5rem;
            border-radius: 8px;
            border: 1px solid #e4e9f2;
            background: #f7f9fc;
            box-shadow: none;
            width: 100%;
            height: 38px;
        }

            .search-input-group .form-control:focus {
                border-color: #008080;
                background: white;
            }

    .filter-select {
        border-radius: 8px;
        border: 1px solid #e4e9f2;
        padding: .375rem 2rem .375rem 1rem;
        background-color: white;
        color: #1a1a2e;
        cursor: pointer;
        font-size: .9rem;
        height: 38px;
    }

    .btn-create {
        background: #008080;
        color: white;
        border: none;
        border-radius: 8px;
        padding: .5rem 1.25rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: .5rem;
        transition: all .2s;
        text-decoration: none;
        height: 38px;
    }

        .btn-create:hover {
            background: #006666;
            color: white;
            transform: translateY(-1px);
        }

    .btn-filter-action {
        background: #1a1a2e;
        color: white;
        border-radius: 8px;
        border: none;
        padding: .375rem 1rem;
        font-weight: 500;
        transition: background .2s;
        height: 38px;
    }

        .btn-filter-action:hover {
            background: #2a2a4a;
        }

    .btn-reset {
        background: transparent;
        color: #8f9bb3;
        border: 1px solid #e4e9f2;
        border-radius: 8px;
        padding: .375rem 1rem;
        height: 38px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

        .btn-reset:hover {
            background: #f7f9fc;
            color: #1a1a2e;
        }

    .table-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,.02);
        overflow: hidden;
    }

    .modern-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .modern-table th {
            background: #1a1a2e;
            color: white;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .5px;
            padding: 1.2rem 1.5rem;
            border: none;
            white-space: nowrap;
        }

        .modern-table td {
            padding: 1rem 1.5rem;
            vertical-align: middle;
            border-bottom: 1px solid #edf1f7;
            color: #222b45;
            font-size: .9rem;
        }

        .modern-table tbody tr {
            transition: background-color .2s;
        }

            .modern-table tbody tr:hover {
                background-color: #f7f9fc;
            }

    .product-cell {
        display: flex;
        align-items: center;
        gap: .9rem;
    }

    .product-thumb {
        width: 52px;
        height: 52px;
        border-radius: 8px;
        overflow: hidden;
        background: #f0f2f8;
        flex-shrink: 0;
        border: 1px solid #e4e9f2;
    }

        .product-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform .3s;
        }

    .modern-table tbody tr:hover .product-thumb img {
        transform: scale(1.08);
    }

    .product-thumb-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #b0b8d0;
    }

    .product-info {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .product-name {
        font-weight: 600;
        color: #1a1a2e;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 180px;
    }

    .product-sku {
        font-size: .75rem;
        color: #8f9bb3;
        font-family: monospace;
        margin-top: 2px;
    }

    .product-brand {
        font-size: .75rem;
        color: #008080;
        font-weight: 600;
        margin-top: 1px;
    }

    .badge-modern {
        padding: .3rem .7rem;
        border-radius: 20px;
        font-size: .73rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-teal {
        background: rgba(0,128,128,.1);
        color: #008080;
    }

    .badge-navy {
        background: rgba(26,26,46,.1);
        color: #1a1a2e;
    }

    .badge-success {
        background: rgba(0,200,83,.1);
        color: #00c853;
    }

    .badge-warning {
        background: rgba(255,170,0,.1);
        color: #ffaa00;
    }

    .badge-danger {
        background: rgba(255,61,113,.1);
        color: #ff3d71;
    }

    .badge-neutral {
        background: #f7f9fc;
        color: #8f9bb3;
        border: 1px solid #e4e9f2;
    }

    .badge-purple {
        background: rgba(102,126,234,.1);
        color: #667eea;
    }

    .coating-pills {
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
    }

    .coating-pill {
        padding: .15rem .5rem;
        border-radius: 12px;
        font-size: .68rem;
        font-weight: 600;
        background: #e8f5f4;
        color: #008080;
        white-space: nowrap;
    }

    .actions-cell {
        display: flex;
        gap: .5rem;
    }

    .btn-action {
        padding: .4rem .75rem;
        border-radius: 6px;
        font-size: .8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        text-decoration: none;
        border: 1px solid transparent;
        transition: all .2s;
    }

    .btn-action-edit {
        background: #f7f9fc;
        color: #008080;
        border-color: #e4e9f2;
    }

        .btn-action-edit:hover {
            background: #008080;
            color: white;
            border-color: #008080;
        }

    .btn-action-details {
        background: #f7f9fc;
        color: #1a1a2e;
        border-color: #e4e9f2;
    }

        .btn-action-details:hover {
            background: #1a1a2e;
            color: white;
            border-color: #1a1a2e;
        }

    .btn-action-delete {
        background: #f7f9fc;
        color: #ff3d71;
        border-color: #e4e9f2;
    }

        .btn-action-delete:hover {
            background: #ff3d71;
            color: white;
            border-color: #ff3d71;
        }

    .pagination-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        border-top: 1px solid #edf1f7;
    }

    .pagination-info {
        color: #8f9bb3;
        font-size: .85rem;
    }

    .modern-pagination {
        display: flex;
        gap: .35rem;
        margin: 0;
        padding: 0;
        list-style: none;
    }

        .modern-pagination .page-link {
            min-width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            border: 1px solid #e4e9f2;
            background: white;
            color: #1a1a2e;
            font-size: .85rem;
            font-weight: 500;
            text-decoration: none;
            transition: all .2s;
            padding: 0 .5rem;
        }

            .modern-pagination .page-link:hover:not(.disabled) {
                border-color: #008080;
                color: #008080;
            }

            .modern-pagination .page-link.active {
                background: #008080;
                border-color: #008080;
                color: white;
            }

            .modern-pagination .page-link.disabled {
                opacity: .5;
                cursor: not-allowed;
                background: #f7f9fc;
                color: #8f9bb3;
            }

    .price-group {
        display: flex;
        align-items: center;
        gap: .25rem;
        background: #f7f9fc;
        border: 1px solid #e4e9f2;
        border-radius: 8px;
        padding: 0 .5rem;
        height: 38px;
    }

        .price-group input {
            border: none;
            width: 60px;
            outline: none;
            font-size: .9rem;
            text-align: center;
            background: transparent;
        }

        .price-group span {
            color: #8f9bb3;
            font-size: .9rem;
        }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #8f9bb3;
    }
</style>

<div class="lenses-container">
    <div class="controls-bar">
        <div class="controls-right" style="flex-wrap:nowrap;align-items:flex-start;flex-direction:column;">
            <div class="d-flex w-100 justify-content-between align-items-center">
                <h1 class="page-title"><i class="bi bi-circle-half"></i> Lens Products</h1>
                <a asp-page="/Lenses/Create" class="btn-create"><i class="bi bi-plus-lg"></i> Create New</a>
            </div>
            <form method="get" class="filter-inline-form w-100 mt-2">
                <div class="search-input-group">
                    <i class="bi bi-search"></i>
                    <input type="text" class="form-control" name="SearchTerm" value="@Model.SearchTerm" placeholder="Search name, SKU, brand..." />
                </div>
                <select class="filter-select" name="FilterLensType">
                    <option value="">All Types</option>
                    @foreach (var type in Model.LensList.AvailableLensTypes)
                    {
                        <option value="@type" selected="@(Model.FilterLensType == type)">@type</option>
                    }
                </select>
                <select class="filter-select" name="FilterBrand">
                    <option value="">All Brands</option>
                    @foreach (var b in new[] { "Essilor", "Hoya", "Zeiss", "Nikon", "Rodenstock", "Shamir", "Seiko", "Kodak" })
                    {
                        <option value="@b" selected="@(Model.FilterBrand == b)">@b</option>
                    }
                </select>
                <select class="filter-select" name="FilterIsPrescription">
                    <option value="">Rx: All</option>
                    <option value="true" selected="@(Model.FilterIsPrescription == true)">Rx Required</option>
                    <option value="false" selected="@(Model.FilterIsPrescription == false)">No Rx</option>
                </select>
                <div class="price-group">
                    <input type="number" name="MinPrice" value="@Model.MinPrice" min="0" placeholder="Min" />
                    <span>-</span>
                    <input type="number" name="MaxPrice" value="@Model.MaxPrice" min="0" placeholder="Max" />
                </div>
                <button type="submit" class="btn-filter-action">Filter</button>
                <a asp-page="/Lenses/Index" class="btn-reset">Reset</a>
            </form>
        </div>
    </div>

    <div class="table-card">
        @if (Model.LensList.Items.Any())
        {
            <div class="table-responsive">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Type / Index</th>
                            <th>Material / Thickness</th>
                            <th>Coatings</th>
                            <th>Rx</th>
                            <th>Stock</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lens in Model.LensList.Items)
                        {
                            <tr>
                                <td>
                                    <div class="product-cell">
                                        <div class="product-thumb">
                                            @if (!string.IsNullOrEmpty(lens.PrimaryImageUrl))
                                            {
                                                <img src="@lens.PrimaryImageUrl" alt="@lens.Name" loading="lazy" />
                                            }
                                            else
                                            {
                                                <div class="product-thumb-placeholder"><i class="bi bi-circle-half"></i></div>
                                            }
                                        </div>
                                        <div class="product-info">
                                            <span class="product-name">@lens.Name</span>
                                            <span class="product-sku">@lens.Sku</span>
                                            @if (!string.IsNullOrEmpty(lens.Brand))
                                            {
                                                <span class="product-brand">@lens.Brand</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(lens.LensType))
                                    {
                                        <span class="badge-modern badge-navy d-block mb-1">@lens.LensType</span>
                                    }
                                    @if (lens.LensIndex.HasValue)
                                    {
                                        <span class="badge-modern badge-teal">@lens.LensIndex.Value.ToString("F2")</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(lens.LensMaterial))
                                    {
                                        <span class="badge-modern badge-neutral d-block mb-1">@lens.LensMaterial</span>
                                    }
                                    @if (!string.IsNullOrEmpty(lens.LensThickness))
                                    {
                                        <span style="font-size:.75rem;color:#8f9bb3;">@lens.LensThickness</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(lens.LensCoating))
                                    {
                                        var coatings = lens.LensCoating.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(2).ToList();
                                        <div class="coating-pills">
                                            @foreach (var coat in coatings)
                                            {
                                                <span class="coating-pill">@coat</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {

                                        <span style="color:#c0c8d8;">—</span>
                                    }
                                </td>
                                <td>
                                    @if (lens.IsPrescription)
                                    {
                                        <span class="badge-modern badge-purple">Rx</span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern badge-neutral">No Rx</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var sv = lens.QuantityOnHand ?? 0;
                                        var sc = sv == 0 ? "badge-danger" : sv < 10 ? "badge-warning" : "badge-success";
                                    }
                                    <span class="badge-modern @sc">@sv in stock</span>
                                </td>
                                <td style="font-weight:600;">@lens.Price.ToString("N0") @lens.Currency</td>
                                <td>
                                    @if (lens.IsActive)
                                    {
                                        <span class="badge-modern badge-success">Active</span>
                                    }
                                    else
                                    {

                                        <span class="badge-modern badge-neutral">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <a asp-page="/Lenses/Details" asp-route-id="@lens.ProductId" class="btn-action btn-action-details"><i class="bi bi-eye"></i> Details</a>
                                        <a asp-page="/Lenses/Edit" asp-route-id="@lens.ProductId" class="btn-action btn-action-edit"><i class="bi bi-pencil"></i> Edit</a>
                                        <a asp-page="/Lenses/Delete" asp-route-id="@lens.ProductId" class="btn-action btn-action-delete"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="pagination-footer">
                <div class="pagination-info">
                    Showing <strong>@(((Model.CurrentPage - 1) * Model.LensList.PageSize) + 1)</strong> to
                    <strong>@Math.Min(Model.CurrentPage * Model.LensList.PageSize, Model.LensList.TotalCount)</strong> of
                    <strong>@Model.LensList.TotalCount</strong> products
                </div>
                <ul class="modern-pagination">
                    @if (Model.LensList.HasPreviousPage)
                    {
                        <li><a asp-page="/Lenses/Index" asp-route-SearchTerm="@Model.SearchTerm" asp-route-FilterLensType="@Model.FilterLensType" asp-route-FilterBrand="@Model.FilterBrand" asp-route-FilterIsPrescription="@Model.FilterIsPrescription" asp-route-MinPrice="@Model.MinPrice" asp-route-MaxPrice="@Model.MaxPrice" asp-route-CurrentPage="@(Model.CurrentPage - 1)" class="page-link"><i class="bi bi-chevron-left"></i> Prev</a></li>
                    }
                    else
                    {
                        <li><span class="page-link disabled"><i class="bi bi-chevron-left"></i> Prev</span></li>
                    }
                    @{
                        var sp = Math.Max(1, Model.CurrentPage - 2); var ep = Math.Min(Model.LensList.TotalPages, Model.CurrentPage + 2);
                        if (sp > 1)
                        {
                            <li><a asp-page="/Lenses/Index" asp-route-CurrentPage="1" class="page-link">1</a></li>
                            if (sp > 2)
                            {
                                <li><span class="page-link disabled">...</span></li>
                            }
                        }
                        for (var i = sp; i <= ep; i++)
                        {
                            if (i == Model.CurrentPage)
                            {
                                <li><span class="page-link active">@i</span></li>
                            }
                            else
                            {
                                <li><a asp-page="/Lenses/Index" asp-route-SearchTerm="@Model.SearchTerm" asp-route-FilterLensType="@Model.FilterLensType" asp-route-FilterBrand="@Model.FilterBrand" asp-route-FilterIsPrescription="@Model.FilterIsPrescription" asp-route-MinPrice="@Model.MinPrice" asp-route-MaxPrice="@Model.MaxPrice" asp-route-CurrentPage="@i" class="page-link">@i</a></li>
                            }
                        }
                        if (ep < Model.LensList.TotalPages)
                        {
                            if (ep < Model.LensList.TotalPages - 1)
                            {
                                <li><span class="page-link disabled">...</span></li>
                            }
                            <li><a asp-page="/Lenses/Index" asp-route-CurrentPage="@Model.LensList.TotalPages" class="page-link">@Model.LensList.TotalPages</a></li>
                        }
                
    }
                    @if (Model.LensList.HasNextPage)
                    {
                        <li><a asp-page="/Lenses/Index" asp-route-SearchTerm="@Model.SearchTerm" asp-route-FilterLensType="@Model.FilterLensType" asp-route-FilterBrand="@Model.FilterBrand" asp-route-FilterIsPrescription="@Model.FilterIsPrescription" asp-route-MinPrice="@Model.MinPrice" asp-route-MaxPrice="@Model.MaxPrice" asp-route-CurrentPage="@(Model.CurrentPage + 1)" class="page-link">Next <i class="bi bi-chevron-right"></i></a></li>
                    }
                    else
                    {
                        <li><span class="page-link disabled">Next <i class="bi bi-chevron-right"></i></span></li>
                    }
                </ul>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox fs-1 mb-3 d-block"></i>
                <h4>No lenses found</h4>
                <p>Adjust your filters or create a new lens product.</p>
            </div>
        }
    </div>
</div>
