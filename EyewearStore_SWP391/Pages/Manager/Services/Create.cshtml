@page
@model EyewearStore_SWP391.Pages.Manager.Services.CreateModel
@{
    ViewData["Title"] = "New Service";
    Layout = "_Layout";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f5f6fa;
            --surf: #ffffff;
            --surf2: #f0f2f8;
            --surf3: #e8eaf2;
            --bdr: rgba(99,102,141,0.14);
            --bdr2: rgba(99,102,141,0.28);
            --acc: #5b5bdb;
            --acc-h: #4747c2;
            --acc-gl: rgba(91,91,219,0.18);
            --gold: #b06c00;
            --txt: #12132a;
            --txt2: #40415e;
            --muted: #8b8da8;
            --ok: #0e9f6e;
            --ok-bg: rgba(14,159,110,0.08);
            --ok-bdr: rgba(14,159,110,0.25);
            --err: #d94040;
            --err-bg: rgba(217,64,64,0.08);
            --err-bd: rgba(217,64,64,0.28);
            --sh-sm: 0 1px 3px rgba(18,19,42,0.07),0 1px 2px rgba(18,19,42,0.04);
            --sh-md: 0 4px 16px rgba(18,19,42,0.09);
            --r-sm: 8px;
            --r-md: 12px;
            --r-lg: 16px;
            --r-xl: 20px;
            --tr: .2s cubic-bezier(.4,0,.2,1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            color: var(--txt);
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
        }

        .fw {
            max-width: 860px;
            margin: 0 auto;
            padding: 36px 28px 80px;
        }

        .bc {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 24px;
        }

            .bc a {
                color: var(--muted);
                text-decoration: none;
                transition: color var(--tr);
            }

                .bc a:hover {
                    color: var(--acc);
                }

            .bc .sep {
                color: var(--bdr2);
            }

        .ph {
            margin-bottom: 28px;
        }

            .ph h1 {
                font-size: 1.7rem;
                font-weight: 800;
                margin: 0 0 4px;
                color: var(--txt);
                display: flex;
                align-items: center;
                gap: 10px;
            }

        .ph-icon {
            width: 40px;
            height: 40px;
            border-radius: 11px;
            background: linear-gradient(135deg,var(--acc),var(--acc-h));
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            box-shadow: 0 4px 12px var(--acc-gl);
            flex-shrink: 0;
        }

        .ph p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

        .fc {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r-xl);
            box-shadow: var(--sh-md);
            overflow: hidden;
        }

        .fs {
            padding: 26px 30px;
            border-bottom: 1px solid var(--bdr);
        }

            .fs:last-of-type {
                border-bottom: none;
            }

        .sl {
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--acc);
            margin: 0 0 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .sl::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--bdr);
            }

        .fr {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 18px;
            margin-bottom: 18px;
        }

            .fr.one {
                grid-template-columns: 1fr;
            }

            .fr.three {
                grid-template-columns: 1fr 1fr 1fr;
            }

            .fr:last-child {
                margin-bottom: 0;
            }

        .fg {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

            .fg label {
                font-size: 11px;
                font-weight: 700;
                color: var(--txt2);
                text-transform: uppercase;
                letter-spacing: .8px;
            }

        .req {
            color: var(--err);
            margin-left: 2px;
        }

        .si {
            background: var(--surf2);
            border: 1.5px solid var(--bdr);
            border-radius: var(--r-sm);
            padding: 10px 13px;
            color: var(--txt);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            width: 100%;
            transition: border-color var(--tr), box-shadow var(--tr), background var(--tr);
        }

            .si:focus {
                outline: none;
                border-color: var(--acc);
                box-shadow: 0 0 0 3px var(--acc-gl);
                background: var(--surf);
            }

            .si::placeholder {
                color: var(--muted);
            }

        textarea.si {
            resize: vertical;
            min-height: 90px;
        }

        select.si {
            cursor: pointer;
        }

        .si.input-validation-error {
            border-color: var(--err);
        }

        .field-validation-error {
            font-size: 11px;
            color: var(--err);
        }

        .hint {
            font-size: 11px;
            color: var(--muted);
        }

        /* Category pill selector */
        .cat-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

        .cat-option {
            display: none;
        }

        .cat-label {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 14px 10px;
            border: 2px solid var(--bdr);
            border-radius: var(--r-md);
            cursor: pointer;
            transition: all var(--tr);
            background: var(--surf2);
            text-align: center;
            font-size: 12px;
            font-weight: 600;
            color: var(--txt2);
        }

            .cat-label .ci {
                font-size: 26px;
            }

            .cat-label:hover {
                border-color: var(--acc);
                background: rgba(91,91,219,.05);
                color: var(--acc);
            }

        .cat-option:checked + .cat-label {
            border-color: var(--acc);
            background: rgba(91,91,219,.08);
            color: var(--acc);
            box-shadow: 0 0 0 3px var(--acc-gl);
        }

            .cat-option:checked + .cat-label .ci {
                transform: scale(1.15);
            }

        .pw {
            position: relative;
        }

            .pw .si {
                padding-right: 58px;
            }

        .psuf {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 11px;
            font-weight: 700;
            color: var(--gold);
            background: var(--surf3);
            padding: 2px 7px;
            border-radius: 5px;
        }

        .tgl-wrap {
            display: flex;
            align-items: center;
            gap: 14px;
            background: var(--surf2);
            border: 1.5px solid var(--bdr);
            border-radius: var(--r-sm);
            padding: 13px 16px;
        }

        .tgl {
            position: relative;
            width: 44px;
            height: 24px;
            flex-shrink: 0;
        }

            .tgl input {
                opacity: 0;
                width: 0;
                height: 0;
            }

        .tslider {
            position: absolute;
            inset: 0;
            background: var(--surf3);
            border: 1.5px solid var(--bdr2);
            border-radius: 100px;
            cursor: pointer;
            transition: background var(--tr), border-color var(--tr);
        }

            .tslider::before {
                content: '';
                position: absolute;
                width: 16px;
                height: 16px;
                left: 2px;
                top: 2px;
                background: var(--muted);
                border-radius: 50%;
                transition: transform var(--tr), background var(--tr);
            }

        .tgl input:checked + .tslider {
            background: var(--ok-bg);
            border-color: var(--ok-bdr);
        }

            .tgl input:checked + .tslider::before {
                transform: translateX(20px);
                background: var(--ok);
            }

        .tgl-txt {
            font-size: 13px;
            color: var(--muted);
        }

            .tgl-txt strong {
                color: var(--txt);
                display: block;
                font-size: 14px;
                font-weight: 700;
            }

        .upzone {
            border: 2px dashed var(--bdr2);
            border-radius: var(--r-md);
            padding: 28px 20px;
            text-align: center;
            cursor: pointer;
            background: var(--surf2);
            transition: all var(--tr);
        }

            .upzone:hover, .upzone.drag {
                border-color: var(--acc);
                background: rgba(91,91,219,.04);
            }

            .upzone input {
                display: none;
            }

            .upzone .ui {
                font-size: 32px;
                margin-bottom: 8px;
                opacity: .45;
            }

            .upzone h4 {
                font-size: 14px;
                font-weight: 700;
                color: var(--txt);
                margin: 0 0 3px;
            }

            .upzone p {
                font-size: 11px;
                color: var(--muted);
                margin: 0;
            }

        .prev {
            display: none;
            margin-top: 14px;
            text-align: center;
        }

            .prev.show {
                display: block;
            }

            .prev img {
                max-width: 160px;
                max-height: 130px;
                border-radius: var(--r-sm);
                object-fit: cover;
                border: 1.5px solid var(--bdr);
                box-shadow: var(--sh-sm);
            }

        .btn-rprev {
            margin-top: 8px;
            background: var(--err-bg);
            color: var(--err);
            border: 1px solid var(--err-bd);
            border-radius: var(--r-sm);
            padding: 5px 12px;
            font-size: 11px;
            font-weight: 600;
            font-family: 'Plus Jakarta Sans', sans-serif;
            cursor: pointer;
            transition: all var(--tr);
        }

            .btn-rprev:hover {
                background: var(--err);
                color: #fff;
            }

        .validation-summary-errors {
            background: var(--err-bg);
            border: 1px solid var(--err-bd);
            border-radius: var(--r-sm);
            padding: 12px 16px;
            margin: 20px 30px 0;
            font-size: 13px;
            color: var(--err);
        }

        .fa {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding: 20px 30px;
            background: var(--surf2);
            border-top: 1px solid var(--bdr);
        }

        .btn-submit {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: linear-gradient(135deg,var(--acc),var(--acc-h));
            color: #fff;
            border: none;
            border-radius: var(--r-sm);
            padding: 11px 28px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: all var(--tr);
            box-shadow: 0 4px 12px var(--acc-gl);
        }

            .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 20px var(--acc-gl);
            }

        .btn-cancel {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--surf);
            color: var(--txt2);
            border: 1.5px solid var(--bdr2);
            border-radius: var(--r-sm);
            padding: 11px 20px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all var(--tr);
        }

            .btn-cancel:hover {
                border-color: var(--acc);
                color: var(--acc);
            }

        @@media(max-width:640px) {
            .fr, .fr.three {
                grid-template-columns: 1fr;
            }

            .fw {
                padding: 20px 14px 60px;
            }

            .fs {
                padding: 20px 18px;
            }

            .fa {
                padding: 16px 18px;
            }

            .cat-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
}

<div class="fw">
    <div class="bc">
        <a asp-page="/Manager/Index"><i class="bi bi-speedometer2"></i> Dashboard</a>
        <span class="sep">/</span>
        <a asp-page="/Manager/Services/Index">Services</a>
        <span class="sep">/</span>
        <span>New Service</span>
    </div>

    <div class="ph">
        <h1><span class="ph-icon">✨</span> New Service</h1>
        <p>Add a lens fitting, customization or repair service to the catalogue</p>
    </div>

    <div class="fc">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            @* ── BASIC INFO ── *@
            <div class="fs">
                <div class="sl"><i class="bi bi-info-circle-fill"></i> Basic Information</div>

                <div class="fr one" style="margin-bottom:18px">
                    <div class="fg">
                        <label asp-for="Input.Name">Service Name <span class="req">*</span></label>
                        <input asp-for="Input.Name" class="si" placeholder="e.g., Progressive Lens Fitting" />
                        <span asp-validation-for="Input.Name" class="field-validation-error"></span>
                    </div>
                </div>

                <div class="fr one" style="margin-bottom:18px">
                    <div class="fg">
                        <label asp-for="Input.Description">Description</label>
                        <textarea asp-for="Input.Description" class="si" rows="3"
                                  placeholder="Describe what this service includes, how long it takes, and what customers can expect…"></textarea>
                    </div>
                </div>

                @* ── SERVICE CATEGORY ── *@
                <div class="fg">
                    <label>Applies To <span class="req">*</span></label>
                    <div class="cat-grid">
                        <div>
                            <input type="radio" asp-for="Input.ServiceCategory"
                                   value="" id="catAll" class="cat-option" />
                            <label for="catAll" class="cat-label">
                                <span class="ci">🌐</span>
                                All Pages
                            </label>
                        </div>
                        <div>
                            <input type="radio" asp-for="Input.ServiceCategory"
                                   value="CustomGlasses" id="catCG" class="cat-option" />
                            <label for="catCG" class="cat-label">
                                <span class="ci">🔭</span>
                                Custom Glasses
                            </label>
                        </div>
                        <div>
                            <input type="radio" asp-for="Input.ServiceCategory"
                                   value="FrameRepair" id="catFR" class="cat-option" />
                            <label for="catFR" class="cat-label">
                                <span class="ci">🛠</span>
                                Frame Repair
                            </label>
                        </div>
                        <div>
                            <input type="radio" asp-for="Input.ServiceCategory"
                                   value="LensReplacement" id="catLR" class="cat-option" />
                            <label for="catLR" class="cat-label">
                                <span class="ci">⭕</span>
                                Lens Replacement
                            </label>
                        </div>
                    </div>
                    <span class="hint" style="margin-top:6px">
                        Controls which customer page this service appears on.
                        <strong>All Pages</strong> = hiện ở mọi trang.
                    </span>
                </div>
            </div>

            @* ── PRICING ── *@
            <div class="fs">
                <div class="sl"><i class="bi bi-tag-fill"></i> Pricing &amp; Duration</div>
                <div class="fr">
                    <div class="fg">
                        <label asp-for="Input.Price">Price <span class="req">*</span></label>
                        <div class="pw">
                            <input asp-for="Input.Price" class="si" type="number" min="0" step="1000" placeholder="0" />
                            <span class="psuf">VND</span>
                        </div>
                        <span asp-validation-for="Input.Price" class="field-validation-error"></span>
                    </div>
                    <div class="fg">
                        <label asp-for="Input.DurationMin">Duration (minutes)</label>
                        <input asp-for="Input.DurationMin" class="si" type="number" min="1" placeholder="e.g., 30" />
                        <span class="hint">Leave blank if duration varies</span>
                    </div>
                </div>
            </div>

            @* ── IMAGE ── *@
            <div class="fs">
                <div class="sl"><i class="bi bi-image-fill"></i> Service Image</div>
                <label class="upzone" id="upzone" for="imgIn">
                    <div class="ui">🖼️</div>
                    <h4>Drop image here or click to upload</h4>
                    <p>JPG, PNG, WEBP — max 5 MB · Recommended 600 × 400 px</p>
                    <input type="file" id="imgIn" name="Input.ImageFile" accept=".jpg,.jpeg,.png,.webp" />
                </label>
                <div class="prev" id="prev">
                    <img id="prevImg" src="" alt="Preview" /><br>
                    <button type="button" class="btn-rprev" id="removeBtn">
                        <i class="bi bi-trash3"></i> Remove
                    </button>
                </div>
            </div>

            @* ── STATUS ── *@
            <div class="fs">
                <div class="sl"><i class="bi bi-toggles"></i> Visibility</div>
                <div class="tgl-wrap">
                    <label class="tgl">
                        <input asp-for="Input.IsActive" type="checkbox" checked />
                        <span class="tslider"></span>
                    </label>
                    <div class="tgl-txt">
                        <strong>Active &amp; Visible</strong>
                        Customers can see and add this service to their order
                    </div>
                </div>
            </div>

            <div class="fa">
                <a asp-page="/Manager/Services/Index" class="btn-cancel">
                    <i class="bi bi-x-lg"></i> Cancel
                </a>
                <button type="submit" class="btn-submit">
                    <i class="bi bi-check-lg"></i> Create Service
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Image upload preview
        const zone = document.getElementById('upzone');
        const inp  = document.getElementById('imgIn');
        const prev = document.getElementById('prev');
        const img  = document.getElementById('prevImg');
        const rem  = document.getElementById('removeBtn');

        inp.addEventListener('change', e => showPreview(e.target.files[0]));
        zone.addEventListener('dragover',  e => { e.preventDefault(); zone.classList.add('drag'); });
        zone.addEventListener('dragleave', ()  => zone.classList.remove('drag'));
        zone.addEventListener('drop', e => {
            e.preventDefault(); zone.classList.remove('drag');
            const f = e.dataTransfer.files[0];
            if (f) { inp.files = e.dataTransfer.files; showPreview(f); }
        });
        rem.addEventListener('click', () => { inp.value = ''; img.src = ''; prev.classList.remove('show'); });

        function showPreview(f) {
            if (!f) return;
            const r = new FileReader();
            r.onload = e => { img.src = e.target.result; prev.classList.add('show'); };
            r.readAsDataURL(f);
        }

        // Default select "All Pages" if nothing checked on load
        window.addEventListener('DOMContentLoaded', () => {
            const anyChecked = document.querySelector('input[name="Input.ServiceCategory"]:checked');
            if (!anyChecked) {
                document.getElementById('catAll').checked = true;
            }
        });
    </script>
}
