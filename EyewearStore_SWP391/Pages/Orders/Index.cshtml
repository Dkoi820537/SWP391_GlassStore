@page
@model EyewearStore_SWP391.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "My Orders";

    string[] steps = { "Pending", "Confirmed", "Processing", "Shipped", "Delivered" };

    int StepIndex(string status) => status switch
    {
        "Confirmed" => 1,
        "Processing" => 2,
        "Processing - Lens Ordered" => 2,
        "Processing - Lens Received" => 2,
        "Processing - Fitting" => 2,
        "Processing - QC" => 2,
        "Processing - Packed" => 2,
        "Shipped" => 3,
        "Delivered" => 4,
        "Completed" => 4,
        "Cancelled" => -1,
        _ => 0
    };

    string StepIcon(string status) => status switch
    {
        "Pending" => "⏳",
        "Pending Confirmation" => "⏳",
        "Confirmed" => "✅",
        "Processing" => "⚙️",
        "Processing - Lens Ordered" => "⚙️",
        "Processing - Lens Received" => "⚙️",
        "Processing - Fitting" => "⚙️",
        "Processing - QC" => "⚙️",
        "Processing - Packed" => "⚙️",
        "Shipped" => "🚚",
        "Delivered" => "🎉",
        "Completed" => "🎉",
        "Cancelled" => "❌",
        _ => "📋"
    };

    string StatusMsg(string status) => status switch
    {
        "Pending" => "Your order has been received and is awaiting payment/confirmation.",
        "Pending Confirmation" => "Your payment has been received and we are confirming your order.",
        "Confirmed" => "Your order is confirmed and will be processed soon.",
        "Processing" => "We are preparing your items.",
        "Processing - Lens Ordered" => "We are ordering the lenses for your frame.",
        "Processing - Lens Received" => "Lenses received, preparing to fit.",
        "Processing - Fitting" => "Technicians are currently fitting your lenses.",
        "Processing - QC" => "Your eyewear is undergoing quality control.",
        "Processing - Packed" => "Your items are packed and ready to ship.",
        "Shipped" => "Your order has been shipped and is on the way!",
        "Delivered" => "Your order has been successfully delivered.",
        "Completed" => "Order completed. Thank you for choosing OptiPlus!",
        "Cancelled" => "This order has been cancelled.",
        _ => ""
    };
    
    // Convert status to class name suffix (e.g. st-Pending)
    string StatusClass(string status)
    {
        if (status.StartsWith("Processing")) return "Processing";
        if (status.StartsWith("Pending")) return "Pending";
        if (status == "Completed" || status == "Delivered") return "Done";
        if (status == "Cancelled" || status == "Cancellation_Pending") return "Cancelled";
        if (status == "Confirmed") return "Ready"; // Match the green color for confirmed
        if (status == "Shipped") return "Ready";   // green
        return "Pending";
    }

    string GetImageUrl(EyewearStore_SWP391.Models.Order order)
    {
        var firstItem = order.OrderItems.FirstOrDefault();
        var primaryImage = firstItem?.Product?.ProductImages?.FirstOrDefault(img => img.IsPrimary && img.IsActive)?.ImageUrl;
        return primaryImage ?? firstItem?.Product?.ProductImages?.FirstOrDefault(img => img.IsActive)?.ImageUrl ?? "";
    }
}

@section Styles {
    <style>
        :root {
            --bg: #f5f6fa;
            --surf: #fff;
            --surf2: #f0f2f8;
            --bdr: rgba(99,102,141,.13);
            --navy: #0d1b2a;
            --gold: #b8862a;
            --ok: #059669;
            --ok-bg: rgba(5,150,105,.08);
            --ok-bdr: rgba(5,150,105,.22);
            --warn: #d97706;
            --warn-bg: rgba(217,119,6,.09);
            --warn-bdr: rgba(217,119,6,.25);
            --info: #2563eb;
            --info-bg: rgba(37,99,235,.08);
            --info-bdr: rgba(37,99,235,.22);
            --err: #dc2626;
            --err-bg: rgba(220,38,38,.08);
            --err-bdr: rgba(220,38,38,.22);
            --muted: #8b8da8;
            --txt: #12132a;
            --txt2: #40415e;
            --sh: 0 2px 12px rgba(18,19,42,.07);
            --sh-md: 0 4px 24px rgba(18,19,42,.1)
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        body {
            background: var(--bg);
            color: var(--txt);
            font-family: 'Segoe UI', system-ui, sans-serif
        }

        .st-wrap {
            max-width: 860px;
            margin: 0 auto;
            padding: 40px 20px 80px
        }

        /* HERO */
        .hero {
            background: linear-gradient(135deg,#0a0a1a 0%,#1a2332 60%,#0f2744 100%);
            border-radius: 20px;
            padding: 40px 36px;
            margin-bottom: 32px;
            position: relative;
            overflow: hidden
        }

            .hero::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 240px;
                height: 240px;
                border-radius: 50%;
                background: rgba(184,134,42,.07);
                pointer-events: none
            }

        .hero-tag {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2.5px;
            color: rgba(255,255,255,.35);
            text-transform: uppercase;
            margin-bottom: 12px
        }

        .hero h1 {
            font-size: 2rem;
            font-weight: 800;
            color: #fff;
            margin: 0 0 8px;
            letter-spacing: -.5px
        }

        .hero p {
            font-size: 14px;
            color: rgba(255,255,255,.5);
            margin: 0
        }

        /* CARD */
        .order-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--sh-md);
            margin-bottom: 20px;
            transition: transform .2s, box-shadow .2s;
            display: block;
            text-decoration: none;
            color: inherit;
        }

            .order-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 32px rgba(18,19,42,.12);
                color: inherit;
            }

        /* TOP ROW */
        .card-top {
            padding: 22px 24px 18px;
            display: flex;
            align-items: flex-start;
            gap: 16px
        }

        .prod-img {
            width: 80px;
            height: 80px;
            border-radius: 14px;
            object-fit: cover;
            background: var(--surf2);
            flex-shrink: 0;
            border: 1px solid var(--bdr)
        }

        .prod-img-ph {
            width: 80px;
            height: 80px;
            border-radius: 14px;
            background: var(--surf2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            border: 1px solid var(--bdr);
            flex-shrink: 0
        }

        .card-info {
            flex: 1;
            min-width: 0
        }

        .card-oid {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 4px
        }

        .card-title {
            font-size: 17px;
            font-weight: 800;
            color: var(--txt);
            margin-bottom: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        .card-sub {
            font-size: 12px;
            color: var(--muted)
        }

        .card-price {
            font-size: 16px;
            font-weight: 700;
            color: var(--gold);
            white-space: nowrap
        }

        .card-date {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px;
            text-align: right
        }

        /* STATUS BADGE */
        .st-bd {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 11px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700;
            margin-top: 6px
        }

        .st-Pending {
            background: var(--warn-bg);
            color: var(--warn);
            border: 1px solid var(--warn-bdr)
        }

        .st-Processing {
            background: var(--info-bg);
            color: var(--info);
            border: 1px solid var(--info-bdr)
        }

        .st-Ready {
            background: var(--ok-bg);
            color: var(--ok);
            border: 1px solid var(--ok-bdr)
        }

        .st-Done {
            background: rgba(15,23,42,.07);
            color: #0f172a;
            border: 1px solid rgba(15,23,42,.18)
        }

        .st-Cancelled {
            background: var(--err-bg);
            color: var(--err);
            border: 1px solid var(--err-bdr)
        }

        .dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor
        }

        /* STATUS MESSAGE BAR */
        .status-msg {
            margin: 0 24px 16px;
            padding: 10px 16px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px
        }

            .status-msg.Pending {
                background: var(--warn-bg);
                color: var(--warn);
                border: 1px solid var(--warn-bdr)
            }

            .status-msg.Processing {
                background: var(--info-bg);
                color: var(--info);
                border: 1px solid var(--info-bdr)
            }

            .status-msg.Ready {
                background: var(--ok-bg);
                color: var(--ok);
                border: 1px solid var(--ok-bdr)
            }

            .status-msg.Done {
                background: rgba(15,23,42,.05);
                color: #0f172a;
                border: 1px solid rgba(15,23,42,.12)
            }

            .status-msg.Cancelled {
                background: var(--err-bg);
                color: var(--err);
                border: 1px solid var(--err-bdr)
            }

        /* TIMELINE */
        .timeline {
            padding: 18px 24px 22px;
            border-top: 1px solid var(--bdr);
            background: var(--surf2)
        }

        .tl-steps {
            display: flex;
            align-items: center;
            position: relative
        }

        .tl-step {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 1
        }

            .tl-step:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 16px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: #e0e2f0;
                z-index: 0
            }

            .tl-step.done:not(:last-child)::after {
                background: var(--ok)
            }

            .tl-step.active:not(:last-child)::after {
                background: linear-gradient(90deg,var(--ok),#e0e2f0)
            }

        .tl-circle {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            border: 2px solid #dde1f0;
            background: #fff;
            position: relative;
            z-index: 2;
            transition: all .3s
        }

        .tl-step.done .tl-circle {
            background: var(--ok);
            border-color: var(--ok);
            color: #fff
        }

        .tl-step.active .tl-circle {
            background: var(--info);
            border-color: var(--info);
            color: #fff;
            box-shadow: 0 0 0 4px rgba(37,99,235,.15)
        }

        .tl-label {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            margin-top: 7px;
            text-align: center;
            letter-spacing: .5px;
            text-transform: uppercase
        }

        .tl-step.done .tl-label {
            color: var(--ok)
        }

        .tl-step.active .tl-label {
            color: var(--info)
        }

        /* DETAIL GRID */
        .detail-row {
            padding: 16px 24px;
            border-top: 1px solid var(--bdr);
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 12px;
            align-items: center;
            justify-content: space-between;
        }

        .detail-item .dl {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px
        }

        .detail-item .dv {
            font-size: 13px;
            font-weight: 600;
            color: var(--txt)
        }

        /* EMPTY */
        .empty {
            text-align: center;
            padding: 80px 20px
        }

            .empty .ei {
                font-size: 56px;
                opacity: .15;
                display: block;
                margin-bottom: 16px
            }

            .empty h3 {
                font-size: 20px;
                font-weight: 700;
                color: var(--txt);
                margin: 0 0 8px
            }

            .empty p {
                font-size: 14px;
                color: var(--muted);
                margin: 0 0 24px
            }

        .btn-go {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: linear-gradient(135deg,#0a0a1a,#1a2332);
            color: #fff;
            text-decoration: none;
            border-radius: 10px;
            padding: 13px 28px;
            font-size: 14px;
            font-weight: 700;
            transition: all .2s
        }

            .btn-go:hover {
                color: #fff;
                opacity: .88;
                transform: translateY(-1px)
            }

        @@media(max-width:600px) {
            .detail-row {
                grid-template-columns: 1fr 1fr
            }

            .card-top {
                flex-wrap: wrap
            }

            .hero {
                padding: 28px 22px
            }

                .hero h1 {
                    font-size: 1.5rem
                }
        }
    </style>
}

<div class="st-wrap">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert"
             style="border-radius:8px;border-left:4px solid #4CAF50;background:var(--surf);color:var(--txt);">
            <i class="bi bi-check-circle-fill me-2" style="color:#4CAF50;"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert"
             style="border-radius:8px;border-left:4px solid #f44336;background:var(--surf);color:var(--txt);">
            <i class="bi bi-exclamation-triangle-fill me-2" style="color:#f44336;"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="hero">
        <div class="hero-tag">✦ OptiPlus</div>
        <h1>My Orders</h1>
        <p>View and track your order history in real time</p>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="order-card" style="display:block;cursor:default;">
            <div class="empty">
                <span class="ei">📦</span>
                <h3>No orders yet</h3>
                <p>You haven't placed any standard orders yet. Start shopping to see your history.</p>
                <a href="/Index" class="btn-go">
                    <i class="bi bi-shop"></i> Start Shopping
                </a>
            </div>
        </div>
    }
    else
    {
        @foreach (var o in Model.Orders)
        {
            int stepIdx = StepIndex(o.Status ?? "");
            bool isCancelled = o.Status == "Cancelled" || o.Status == "Cancellation_Pending";
            string cssClass = StatusClass(o.Status ?? "");
            string displayStatus = o.Status == "Cancellation_Pending" ? "Cancelling..." : (o.Status ?? "Unknown");

            string imageUrl = GetImageUrl(o);
            int totalItems = o.OrderItems?.Sum(i => i.Quantity) ?? 0;
            string firstItemName = o.OrderItems?.FirstOrDefault()?.Product?.Name ?? "Items";
            if (o.OrderItems != null && o.OrderItems.Count > 1) {
                firstItemName += $" + {o.OrderItems.Count - 1} more";
            }

            <a href="/Orders/Detail?id=@o.OrderId" class="order-card">
                <div class="card-top">
                    @if (!string.IsNullOrEmpty(imageUrl))
                    {
                        <img class="prod-img" src="@imageUrl" alt="Product Image" />
                    }
                    else
                    {
                        <div class="prod-img-ph">📦</div>
                    }
                    <div class="card-info">
                        <div class="card-oid">Order #@o.OrderId</div>
                        <div class="card-title">@firstItemName</div>
                        <div class="card-sub">@totalItems item(s)</div>
                        <span class="st-bd st-@cssClass">
                            <span class="dot"></span> @StepIcon(o.Status ?? "") @displayStatus
                        </span>
                    </div>
                    <div style="text-align:right;flex-shrink:0">
                        <div class="card-price">@o.TotalAmount.ToString("N0") ₫</div>
                        <div class="card-date">@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                </div>

                <!-- Status message -->
                <div class="status-msg @cssClass">
                    <span>@StepIcon(o.Status ?? "")</span>
                    <span>@StatusMsg(o.Status ?? "")</span>
                </div>

                <!-- Timeline -->
                @if (!isCancelled)
                {
                    <div class="timeline">
                        <div class="tl-steps">
                            @for (int i = 0; i < steps.Length; i++)
                            {
                                string cls = i < stepIdx ? "done" : i == stepIdx ? "active" : "";
                                string icon = i < stepIdx ? "✓" : i == stepIdx ? "●" : (i + 1).ToString();
                                <div class="tl-step @cls">
                                    <div class="tl-circle">@icon</div>
                                    <div class="tl-label">@steps[i]</div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="timeline">
                        <div style="display:flex;align-items:center;gap:10px;color:var(--err)">
                            <span style="font-size:20px">❌</span>
                            <span style="font-size:13px;font-weight:700">This order has been cancelled @(o.RefundAmount > 0 ? $"({o.RefundAmount?.ToString("N0")} ₫ refunded)" : "").</span>
                        </div>
                    </div>
                }

                <!-- Detail grid -->
                <div class="detail-row">
                    <div class="detail-item">
                        <div class="dl">Payment Method</div>
                        <div class="dv">@(o.PaymentMethod ?? "—")</div>
                    </div>
                    @if (o.PaymentMethod == "COD" && o.DepositAmount > 0)
                    {
                        <div class="detail-item">
                            <div class="dl">Deposit</div>
                            <div class="dv" style="color:var(--warn)">@o.DepositAmount.ToString("N0") ₫</div>
                        </div>
                    }
                    else if (o.PaymentMethod != "COD" && o.PaymentStatus == "FullyPaid")
                    {
                        <div class="detail-item">
                            <div class="dl">Payment Status</div>
                            <div class="dv" style="color:var(--ok)">Fully Paid</div>
                        </div>
                    }
                    else
                    {
                        <div class="detail-item">
                            <div class="dl">Updates</div>
                            <div class="dv" style="color:var(--info);text-decoration:underline;">View Details →</div>
                        </div>
                    }
                    <div class="detail-item" style="text-align:right;">
                        @if (o.PaymentMethod == "COD" && o.DepositAmount > 0)
                        {
                            <div style="font-size:13px;color:var(--info);font-weight:700;text-decoration:underline;">View Details →</div>
                        }
                    </div>
                </div>
            </a>
        }
    }

    <!-- Pagination Controls -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center" style="gap: 5px;">
                <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index" asp-route-pageIndex="@(Model.PageIndex - 1)" style="border-radius: 8px; border: 1px solid var(--bdr); color: var(--txt);">Previous</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.PageIndex == i ? "active" : "")">
                        <a class="page-link" asp-page="./Index" asp-route-pageIndex="@i" style="border-radius: 8px; @(Model.PageIndex == i ? "background: var(--navy); border-color: var(--navy); color: #fff;" : "border: 1px solid var(--bdr); color: var(--txt);")">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index" asp-route-pageIndex="@(Model.PageIndex + 1)" style="border-radius: 8px; border: 1px solid var(--bdr); color: var(--txt);">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>