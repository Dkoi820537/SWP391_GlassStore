@page "{id:int}"
@model EyewearStore_SWP391.Pages.Products.FrameDetailsModel
@{
    ViewData["Title"] = Model.Frame?.Name ?? "Product Details";
    Layout = "_Layout";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --teal: #00756A;
            --teal-dk: #005a51;
            --teal-lt: #e8f5f4;
            --red: #e53935;
            --gold: #c9a96e;
            --text: #1a1a1a;
            --sub: #6b7280;
            --border: #e5e7eb;
            --bg: #f9fafb;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
        }

        .bc {
            background: #fff;
            border-bottom: 1px solid var(--border);
            padding: 12px 0;
            font-size: 13px;
        }

            .bc ol {
                display: flex;
                align-items: center;
                list-style: none;
                margin: 0 auto;
                padding: 0 24px;
                max-width: 1280px;
                gap: 5px;
                flex-wrap: wrap;
            }

            .bc a {
                color: var(--sub);
                text-decoration: none;
            }

                .bc a:hover {
                    color: var(--teal);
                }

            .bc .sep {
                color: #ccc;
                font-size: 10px;
            }

            .bc .cur {
                color: var(--text);
                font-weight: 600;
            }

        .fd {
            max-width: 1280px;
            margin: 0 auto;
            padding: 32px 24px 80px;
        }

        .fd-grid {
            display: grid;
            grid-template-columns: 55% 1fr;
            gap: 56px;
            align-items: start;
        }

        .gal {
            position: sticky;
            top: 78px;
        }

        .gal-main {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            background: #fff;
            border: 1px solid var(--border);
            box-shadow: 0 4px 24px rgba(0,0,0,.06);
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .gal-main img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: opacity .22s;
            }

        .gal-ph {
            font-size: 90px;
            color: #ddd;
        }

        .brand-badge {
            position: absolute;
            top: 14px;
            right: 14px;
            background: rgba(255,255,255,.95);
            border: 1px solid rgba(0,0,0,.08);
            border-radius: 8px;
            padding: 6px 18px;
            font-size: 13px;
            font-weight: 800;
            color: var(--teal);
            letter-spacing: 1px;
            text-transform: uppercase;
            backdrop-filter: blur(6px);
            text-decoration: none;
            box-shadow: 0 2px 12px rgba(0,0,0,.12);
            transition: box-shadow .2s, background .2s;
        }

            .brand-badge:hover {
                background: #fff;
                box-shadow: 0 4px 20px rgba(0,0,0,.2);
                color: var(--teal);
            }

        .thumbs {
            display: flex;
            gap: 10px;
            margin-top: 12px;
            flex-wrap: wrap;
        }

        .thumb {
            width: 80px;
            height: 80px;
            border-radius: 10px;
            overflow: hidden;
            cursor: pointer;
            border: 2px solid transparent;
            transition: border-color .18s;
            flex-shrink: 0;
        }

            .thumb:hover, .thumb.active {
                border-color: var(--teal);
            }

            .thumb img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .sz-strip {
            display: flex;
            gap: 10px;
            margin-top: 14px;
        }

        .sz-card {
            flex: 1;
            background: #f5f5f5;
            border-radius: 12px;
            padding: 12px 8px 10px;
            text-align: center;
        }

            .sz-card svg {
                width: 100%;
                height: 46px;
            }

        .sz-num {
            font-size: 19px;
            font-weight: 800;
            color: var(--text);
            margin-top: 4px;
            line-height: 1;
        }

        .sz-lbl {
            font-size: 11px;
            color: var(--sub);
            margin-top: 3px;
        }

        .info {
            padding-top: 2px;
        }

        .brand-link {
            display: inline-block;
            font-size: 13px;
            font-weight: 800;
            color: var(--teal);
            letter-spacing: 1.2px;
            text-transform: uppercase;
            text-decoration: none;
            margin-bottom: 10px;
            border-bottom: 2px solid var(--teal);
            padding-bottom: 1px;
        }

            .brand-link:hover {
                color: var(--teal-dk);
            }

        .prod-name {
            font-size: 26px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 10px;
            line-height: 1.3;
        }

        .status-row {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--sub);
            margin-bottom: 14px;
            flex-wrap: wrap;
        }

            .status-row strong {
                color: var(--text);
            }

        .sep-dot {
            color: #ccc;
        }

        .badges {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            background: var(--teal-lt);
            color: var(--teal);
        }

        .price-row {
            display: flex;
            align-items: baseline;
            gap: 8px;
            margin-bottom: 16px;
        }

        .price-lbl {
            font-size: 14px;
            color: var(--sub);
        }

        .price-val {
            font-size: 36px;
            font-weight: 800;
            color: var(--red);
            line-height: 1;
        }

        .price-cur {
            font-size: 18px;
            font-weight: 700;
            color: var(--red);
        }

        .sold-txt {
            font-size: 13px;
            color: var(--sub);
            margin-left: auto;
        }

            .sold-txt strong {
                color: var(--text);
            }

        .stock-row {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 22px;
            flex-wrap: wrap;
        }

        .stock-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 7px 18px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
        }

            .stock-badge.in {
                background: #e8f5e9;
                color: #2e7d32;
            }

            .stock-badge.low {
                background: #fff8e1;
                color: #f57f17;
            }

            .stock-badge.out {
                background: #ffebee;
                color: #c62828;
            }

        .section-lbl {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .section-lbl .cur {
                font-weight: 500;
                color: var(--sub);
            }

        .color-opts {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 22px;
        }

        .color-opt {
            display: flex;
            align-items: center;
            gap: 8px;
            border: 2px solid var(--border);
            border-radius: 8px;
            padding: 7px 14px;
            cursor: pointer;
            background: #fff;
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            transition: border-color .18s, box-shadow .18s;
            white-space: nowrap;
        }

            .color-opt:hover {
                border-color: var(--teal);
            }

            .color-opt.active {
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(0,117,106,.12);
            }

        .c-dot {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            flex-shrink: 0;
            box-shadow: 0 1px 4px rgba(0,0,0,.2);
        }

        .size-opts {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 22px;
        }

        .size-opt {
            border: 2px solid var(--border);
            border-radius: 8px;
            padding: 8px 18px;
            background: #fff;
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
            cursor: pointer;
            transition: border-color .18s;
        }

            .size-opt.active {
                border-color: var(--teal);
                background: var(--teal-lt);
                color: var(--teal);
            }

        .specs {
            margin-bottom: 20px;
        }

        .spec-row {
            display: flex;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

            .spec-row:last-child {
                border-bottom: none;
            }

        .spec-k {
            width: 160px;
            flex-shrink: 0;
            font-weight: 600;
            color: var(--text);
        }

        .spec-v {
            color: var(--sub);
        }

        .promo {
            background: #fff9f0;
            border: 1px dashed #f59e0b;
            border-radius: 12px;
            padding: 16px 20px;
            margin-bottom: 20px;
        }

        .promo-ttl {
            font-size: 14px;
            font-weight: 700;
            color: #d97706;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .promo ul {
            margin: 0;
            padding: 0 0 0 16px;
            font-size: 13px;
            color: var(--sub);
            line-height: 1.9;
        }

            .promo ul li strong {
                color: var(--text);
            }

        .qty-row {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 16px;
        }

        .qty-lbl {
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
        }

        .qty-ctrl {
            display: flex;
            align-items: center;
            border: 2px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
        }

        .qty-btn {
            width: 44px;
            height: 46px;
            background: #fff;
            border: none;
            font-size: 20px;
            font-weight: 700;
            color: var(--teal);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .15s;
        }

            .qty-btn:hover:not(:disabled) {
                background: var(--teal-lt);
            }

            .qty-btn:disabled {
                opacity: .35;
                cursor: not-allowed;
            }

        .qty-inp {
            width: 56px;
            text-align: center;
            font-size: 16px;
            font-weight: 700;
            border: none;
            border-left: 2px solid var(--border);
            border-right: 2px solid var(--border);
            height: 46px;
            outline: none;
            font-family: inherit;
        }

        .cta-row {
            display: flex;
            gap: 12px;
        }

        .btn-buy {
            flex: 1;
            padding: 16px;
            background: var(--red);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: background .2s, transform .15s;
        }

            .btn-buy:hover:not(:disabled) {
                background: #c62828;
                transform: translateY(-2px);
            }

        .btn-cart {
            flex: 1;
            padding: 16px;
            background: #fff;
            color: var(--teal);
            border: 2px solid var(--teal);
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: background .2s, transform .15s;
        }

            .btn-cart:hover:not(:disabled) {
                background: var(--teal-lt);
                transform: translateY(-2px);
            }

            .btn-buy:disabled, .btn-cart:disabled {
                background: #e5e7eb;
                color: #9ca3af;
                border-color: #e5e7eb;
                cursor: not-allowed;
                transform: none;
            }

        /* Notify/Wishlist button — only shown when out of stock */
        .btn-notify {
            width: 100%;
            padding: 13px;
            margin-top: 10px;
            background: #fff;
            color: var(--sub);
            border: 2px solid var(--border);
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: border-color .2s, color .2s, background .2s;
        }

            .btn-notify:hover {
                border-color: var(--gold);
                color: var(--gold);
            }

            .btn-notify.active {
                border-color: var(--gold);
                color: var(--gold);
                background: #fffbf5;
            }

        .alert {
            display: flex;
            align-items: center;
            gap: 8px;
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 14px;
            font-size: 14px;
        }

            .alert.ok {
                background: #f0fff4;
                border: 1px solid #28a745;
                color: #28a745;
            }

            .alert.err {
                background: #fff5f5;
                border: 1px solid var(--red);
                color: var(--red);
            }

        .tabs-wrap {
            max-width: 1280px;
            margin: 0 auto 64px;
            padding: 0 24px;
        }

        .tabs-hdr {
            display: flex;
            border-bottom: 2px solid var(--border);
        }

        .tab-btn {
            padding: 14px 24px;
            background: transparent;
            border: none;
            font-family: inherit;
            font-size: 14px;
            font-weight: 600;
            color: var(--sub);
            cursor: pointer;
            position: relative;
            transition: color .18s;
        }

            .tab-btn:hover {
                color: var(--teal);
            }

            .tab-btn.on {
                color: var(--teal);
            }

                .tab-btn.on::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    right: 0;
                    height: 2px;
                    background: var(--teal);
                }

        .tab-panel {
            display: none;
            background: #fff;
            padding: 28px 32px;
            border-radius: 0 0 14px 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
        }

            .tab-panel.on {
                display: block;
            }

            .tab-panel h3 {
                font-size: 17px;
                font-weight: 700;
                color: var(--teal);
                margin: 0 0 16px;
            }

        .spec-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

            .spec-grid .spec-row:nth-child(odd) {
                padding-right: 24px;
            }

        .care-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .care-list li {
                padding: 11px 0 11px 28px;
                position: relative;
                color: var(--sub);
                border-bottom: 1px solid var(--border);
                font-size: 14px;
            }

                .care-list li:last-child {
                    border-bottom: none;
                }

                .care-list li::before {
                    content: '\F26A';
                    font-family: 'bootstrap-icons';
                    position: absolute;
                    left: 0;
                    color: var(--teal);
                }

        .related {
            max-width: 1280px;
            margin: 0 auto 64px;
            padding: 0 24px;
        }

            .related h2 {
                text-align: center;
                font-size: 24px;
                font-weight: 800;
                color: var(--text);
                margin: 0 0 28px;
            }

        .rel-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 20px;
        }

        .rel-card {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 2px 10px rgba(0,0,0,.07);
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: block;
            transition: transform .2s, box-shadow .2s;
        }

            .rel-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 24px rgba(0,0,0,.13);
            }

        .rel-img {
            aspect-ratio: 1;
            overflow: hidden;
            background: #f5f5f5;
        }

            .rel-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .35s;
            }

        .rel-card:hover .rel-img img {
            transform: scale(1.06);
        }

        .rel-ph {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 38px;
            color: #ccc;
        }

        .rel-info {
            padding: 14px 16px 16px;
        }

            .rel-info h4 {
                font-size: 13px;
                font-weight: 600;
                margin: 0 0 6px;
                color: var(--text);
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            .rel-info p {
                font-size: 15px;
                font-weight: 800;
                color: var(--red);
                margin: 0;
            }

        .sticky-bar {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #fff;
            box-shadow: 0 -4px 20px rgba(0,0,0,.1);
            padding: 12px 16px;
            z-index: 999;
        }

        .sticky-inner {
            max-width: 1280px;
            margin: 0 auto;
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .sticky-price {
            font-size: 18px;
            font-weight: 800;
            color: var(--red);
            white-space: nowrap;
        }

        .sticky-btn {
            flex: 1;
            background: var(--red);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 13px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
        }

        @@media(max-width:991px) {
            .fd-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .gal {
                position: static;
            }

            .rel-grid {
                grid-template-columns: repeat(2,1fr);
            }

            .sticky-bar {
                display: block;
            }

            .fd {
                padding-bottom: 90px;
            }

            .spec-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media(max-width:576px) {
            .prod-name {
                font-size: 20px;
            }

            .price-val {
                font-size: 28px;
            }

            .rel-grid {
                grid-template-columns: repeat(2,1fr);
                gap: 12px;
            }

            .cta-row {
                flex-direction: column;
            }

            .tab-btn {
                font-size: 13px;
                padding: 12px 14px;
            }
        }
    </style>
}

<!-- Breadcrumb -->
<div class="bc">
    <ol>
        <li><a asp-page="/Index">Home</a></li>
        <li><span class="sep"><i class="bi bi-chevron-right"></i></span></li>
        <li><a asp-page="/Products/Index">Shop</a></li>
        <li><span class="sep"><i class="bi bi-chevron-right"></i></span></li>
        <li><a asp-page="/Products/Index" asp-route-productType="Frame">Eyeglass Frames</a></li>
        @if (!string.IsNullOrEmpty(Model.Frame?.Brand))
        {
            <li><span class="sep"><i class="bi bi-chevron-right"></i></span></li>
            <li><a asp-page="/Products/Index" asp-route-BrandFilter="@Model.Frame.Brand">@Model.Frame.Brand</a></li>
        }
        <li><span class="sep"><i class="bi bi-chevron-right"></i></span></li>
        <li><span class="cur">@Model.Frame?.Name</span></li>
    </ol>
</div>

@if (Model.Frame != null)
{
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="fd" style="padding-bottom:0;padding-top:16px;">
            <div class="alert ok"><i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]</div>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="fd" style="padding-bottom:0;padding-top:16px;">
            <div class="alert err"><i class="bi bi-exclamation-circle-fill"></i> @Model.ErrorMessage</div>
        </div>
    }

    <div class="fd">
        <div class="fd-grid">

            <!-- LEFT: Gallery -->
            <div class="gal">
                <div class="gal-main">
                    @if (!string.IsNullOrEmpty(Model.Frame.Brand))
                    {
                        <a class="brand-badge"
                           asp-page="/Products/Index"
                           asp-route-BrandFilter="@Model.Frame.Brand"
                           title="View all @Model.Frame.Brand">
                            @Model.Frame.Brand.ToUpper()
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.Frame.PrimaryImageUrl))
                    {
                        <img id="mainImg" src="@Model.Frame.PrimaryImageUrl" alt="@Model.Frame.Name" />
                    }
                    else
                    {
                        <div class="gal-ph"><i class="bi bi-eyeglasses"></i></div>
                    }
                </div>

                @if (Model.Frame.Images.Count > 1)
                {
                    <div class="thumbs">
                        @foreach (var img in Model.Frame.Images)
                        {
                            <div class="thumb @(img.IsPrimary ? "active" : "")"
                                 onclick="changeImg('@img.ImageUrl',this)">
                                <img src="@img.ImageUrl" alt="@img.AltText" />
                            </div>
                        }
                    </div>
                }

                @if (Model.Frame.LensWidth.HasValue || Model.Frame.BridgeWidth.HasValue || Model.Frame.TempleLength.HasValue)
                {
                    var lensColor = Model.Frame.LensWidth.HasValue ? "#00756A" : "#ccc";
                    var bridgeColor = Model.Frame.BridgeWidth.HasValue ? "#00756A" : "#ccc";
                    var templeColor = Model.Frame.TempleLength.HasValue ? "#00756A" : "#ccc";

                    <div class="sz-strip">
                        <div class="sz-card">
                            <svg viewBox="0 0 70 46" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="3" y="8" width="27" height="28" rx="6" stroke="@lensColor" stroke-width="2.5" />
                                <rect x="40" y="8" width="27" height="28" rx="6" stroke="@lensColor" stroke-width="2.5" />
                                <line x1="30" y1="22" x2="40" y2="22" stroke="#ccc" stroke-width="2" />
                                <line x1="3" y1="42" x2="30" y2="42" stroke="#aaa" stroke-width="1.5" />
                                <polygon points="2,42 6,40 6,44" fill="@lensColor" />
                                <polygon points="31,42 27,40 27,44" fill="@lensColor" />
                            </svg>
                            <div class="sz-num">@(Model.Frame.LensWidth.HasValue? Model.Frame.LensWidth.Value.ToString("0") : "—")</div>
                            <div class="sz-lbl">Lens Width</div>
                        </div>
                        <div class="sz-card">
                            <svg viewBox="0 0 70 46" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="3" y="8" width="27" height="28" rx="6" stroke="#ccc" stroke-width="2" />
                                <rect x="40" y="8" width="27" height="28" rx="6" stroke="#ccc" stroke-width="2" />
                                <line x1="30" y1="22" x2="40" y2="22" stroke="@bridgeColor" stroke-width="2.5" />
                                <line x1="30" y1="42" x2="40" y2="42" stroke="#aaa" stroke-width="1.5" />
                                <polygon points="29,42 33,40 33,44" fill="@bridgeColor" />
                                <polygon points="41,42 37,40 37,44" fill="@bridgeColor" />
                            </svg>
                            <div class="sz-num">@(Model.Frame.BridgeWidth.HasValue? Model.Frame.BridgeWidth.Value.ToString("0") : "—")</div>
                            <div class="sz-lbl">Bridge (mm)</div>
                        </div>
                        <div class="sz-card">
                            <svg viewBox="0 0 70 46" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="3" y="12" width="22" height="20" rx="4" stroke="#ccc" stroke-width="2" />
                                <rect x="30" y="12" width="22" height="20" rx="4" stroke="#ccc" stroke-width="2" />
                                <line x1="52" y1="22" x2="68" y2="22" stroke="@templeColor" stroke-width="2.5" />
                                <line x1="52" y1="42" x2="68" y2="42" stroke="#aaa" stroke-width="1.5" />
                                <polygon points="51,42 55,40 55,44" fill="@templeColor" />
                                <polygon points="69,42 65,40 65,44" fill="@templeColor" />
                            </svg>
                            <div class="sz-num">@(Model.Frame.TempleLength.HasValue? Model.Frame.TempleLength.Value.ToString("0") : "—")</div>
                            <div class="sz-lbl">Temple (mm)</div>
                        </div>
                    </div>
                }
            </div>

            <!-- RIGHT: Info -->
            <div class="info">

                @if (!string.IsNullOrEmpty(Model.Frame.Brand))
                {
                    <a class="brand-link"
                       asp-page="/Products/Index"
                       asp-route-BrandFilter="@Model.Frame.Brand">@Model.Frame.Brand.ToUpper()</a>
                }

                <h1 class="prod-name">@Model.Frame.Name</h1>

                <div class="status-row">
                    <span>Status: <strong>@(Model.Frame.IsInStock ? "In Stock" : "Out of Stock")</strong></span>
                    <span class="sep-dot">·</span>
                    <span>SKU: <strong>@Model.Frame.Sku</strong></span>
                    @if (!string.IsNullOrEmpty(Model.Frame.Origin))
                    {
                        <span class="sep-dot">·</span>
                        <span>Origin: <strong>@Model.Frame.Origin</strong></span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Frame.Gender) || !string.IsNullOrEmpty(Model.Frame.FrameShape) || !string.IsNullOrEmpty(Model.Frame.FrameType))
                {
                    <div class="badges">
                        @if (!string.IsNullOrEmpty(Model.Frame.Gender))
                        {
                            <span class="badge"><i class="bi bi-person"></i> @Model.Frame.Gender</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.Frame.FrameShape))
                        {
                            <span class="badge"><i class="bi bi-circle"></i> @Model.Frame.FrameShape</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.Frame.FrameType))
                        {
                            <span class="badge"><i class="bi bi-eyeglasses"></i> @Model.Frame.FrameType</span>
                        }
                    </div>
                }

                <div class="price-row">
                    <span class="price-lbl">Price:</span>
                    <span class="price-cur">@Model.Frame.Currency</span>
                    <span class="price-val">@Model.Frame.Price.ToString("N0")</span>
                    @if (Model.Frame.SoldCount > 0)
                    {
                        <span class="sold-txt"><strong>@Model.Frame.SoldCount</strong> sold</span>
                    }
                </div>

                @{
                    var sc = Model.Frame.StockStatus == "OutOfStock" ? "out"
                    : Model.Frame.StockStatus == "LowStock" ? "low"
                    : "in";
                    var stockMsg = Model.Frame.StockStatus == "OutOfStock"
                    ? "Out of Stock"
                    : Model.Frame.StockStatus == "LowStock"
                    ? "Low Stock (" + Model.Frame.InventoryQty + " left)"
                    : "In Stock (" + Model.Frame.InventoryQty + " available)";
                }
                <div class="stock-row">
                    <div class="stock-badge @sc">
                        @if (sc == "in")
                        {
                            <i class="bi bi-check-circle-fill"></i>
                        }
                        else if (sc == "low")
                        {
                            <i class="bi bi-exclamation-circle-fill"></i>
                        }
                        else
                        {
                            <i class="bi bi-x-circle-fill"></i>
                        }
                        <span>@stockMsg</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Frame.Color))
                {
                    var cols = Model.Frame.Color
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .ToList();
                    <div class="section-lbl">Color <span class="cur" id="colorLbl">@cols[0]</span></div>
                    <div class="color-opts">
                        @foreach (var c in cols)
                        {
                            <button class="color-opt @(c == cols[0] ? "active" : "")"
                                    data-color="@c" onclick="selColor(this,'@c')">
                                <span class="c-dot" style="@ColorStyle(c)"></span>
                                @c.ToUpper()
                            </button>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Frame.SizeLabel))
                {
                    <div class="section-lbl">Size</div>
                    <div class="size-opts">
                        <button class="size-opt active">@Model.Frame.SizeLabel</button>
                    </div>
                }

                <div class="specs">
                    @if (!string.IsNullOrEmpty(Model.Frame.FrameMaterial))
                    {
                        <div class="spec-row"><span class="spec-k">Material</span><span class="spec-v">@Model.Frame.FrameMaterial</span></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Frame.FrameType))
                    {
                        <div class="spec-row"><span class="spec-k">Frame Type</span><span class="spec-v">@Model.Frame.FrameType</span></div>
                    }
                    @if (Model.Frame.LensWidth.HasValue)
                    {
                        <div class="spec-row"><span class="spec-k">Lens Width</span><span class="spec-v">@Model.Frame.LensWidth.Value.ToString("0.#") mm</span></div>
                    }
                    @if (Model.Frame.BridgeWidth.HasValue)
                    {
                        <div class="spec-row"><span class="spec-k">Bridge</span><span class="spec-v">@Model.Frame.BridgeWidth.Value.ToString("0.#") mm</span></div>
                    }
                    @if (Model.Frame.TempleLength.HasValue)
                    {
                        <div class="spec-row"><span class="spec-k">Temple Length</span><span class="spec-v">@Model.Frame.TempleLength.Value.ToString("0.#") mm</span></div>
                    }
                </div>

                <div class="promo">
                    <div class="promo-ttl"><i class="bi bi-gift-fill"></i> PROMOTIONS</div>
                    <ul>
                        <li><strong>100% refund</strong> if product is not authentic</li>
                        <li>Free shipping on orders over <strong>500,000 VND</strong></li>
                        <li>Official manufacturer warranty <strong>12 months</strong></li>
                    </ul>
                </div>

                @if (Model.Frame.IsInStock)
                {
                    // In stock: show qty + buy/cart buttons
                    <form method="post" asp-page-handler="AddToCart" id="cartForm">
                        <input type="hidden" asp-for="AddToCartInput.ProductId" />
                        <div class="qty-row">
                            <span class="qty-lbl">Quantity:</span>
                            <div class="qty-ctrl">
                                <button type="button" class="qty-btn" id="qMinus" onclick="chQty(-1)">&#8722;</button>
                                <input type="number" asp-for="AddToCartInput.Quantity" class="qty-inp" id="qInput"
                                       min="1" max="@(Model.Frame.InventoryQty ?? 99)" value="1" />
                                <button type="button" class="qty-btn" id="qPlus" onclick="chQty(1)">+</button>
                            </div>
                        </div>
                        <div class="cta-row">
                            <button type="submit" name="handler" value="BuyNow" class="btn-buy">
                                <i class="bi bi-lightning-fill"></i> BUY NOW
                            </button>
                            <button type="submit" class="btn-cart">
                                <i class="bi bi-cart-plus"></i> ADD TO CART
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    // Out of stock: disabled buttons + Notify When Available (wishlist)
                    <div class="qty-row">
                        <span class="qty-lbl">Quantity:</span>
                        <div class="qty-ctrl">
                            <button type="button" class="qty-btn" disabled>&#8722;</button>
                            <input type="number" class="qty-inp" value="1" disabled />
                            <button type="button" class="qty-btn" disabled>+</button>
                        </div>
                    </div>
                    <div class="cta-row">
                        <button class="btn-buy" disabled><i class="bi bi-lightning-fill"></i> BUY NOW</button>
                        <button class="btn-cart" disabled><i class="bi bi-cart-plus"></i> ADD TO CART</button>
                    </div>

                    // Wishlist / notify button — only for out-of-stock items
                    <button type="button" class="btn-notify" id="notifyBtn"
                            data-product-id="@Model.Frame.ProductId"
                            data-in="false">
                        <i class="bi bi-bell" id="notifyIcon"></i>
                        <span id="notifyLabel">Notify When Available</span>
                    </button>
                }

        </div>
    </div>
</div>

<!-- Tabs -->
<div class="tabs-wrap">
    <div class="tabs-hdr">
        <button class="tab-btn on" onclick="switchTab('desc',this)">Description</button>
        <button class="tab-btn" onclick="switchTab('specs',this)">Specifications</button>
        <button class="tab-btn" onclick="switchTab('care',this)">Care Instructions</button>
    </div>

    <div id="tab-desc" class="tab-panel on">
        <h3>Product Description</h3>
        <p style="color:var(--sub);line-height:1.8;font-size:15px;">
            @(string.IsNullOrEmpty(Model.Frame.Description)
                        ? "Meticulously designed eyeglass frames that blend modern style with all-day comfort."
                        : Model.Frame.Description)
        </p>
    </div>

        <div id="tab-specs" class="tab-panel">
            <h3>Technical Specifications</h3>
            <div class="spec-grid">
                <div class="spec-row"><span class="spec-k">SKU</span><span class="spec-v">@Model.Frame.Sku</span></div>
            @if (!string.IsNullOrEmpty(Model.Frame.Brand))
                {
                    <div class="spec-row"><span class="spec-k">Brand</span><span class="spec-v">@Model.Frame.Brand</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Frame.Origin))
                {
                    <div class="spec-row"><span class="spec-k">Origin</span><span class="spec-v">@Model.Frame.Origin</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Frame.Gender))
                {
                    <div class="spec-row"><span class="spec-k">Gender</span><span class="spec-v">@Model.Frame.Gender</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Frame.FrameShape))
                {
                    <div class="spec-row"><span class="spec-k">Frame Shape</span><span class="spec-v">@Model.Frame.FrameShape</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Frame.FrameMaterial))
                {
                    <div class="spec-row"><span class="spec-k">Material</span><span class="spec-v">@Model.Frame.FrameMaterial</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Frame.FrameType))
                {
                    <div class="spec-row"><span class="spec-k">Frame Type</span><span class="spec-v">@Model.Frame.FrameType</span></div>
                }
                @if (Model.Frame.LensWidth.HasValue)
                {
                    <div class="spec-row"><span class="spec-k">Lens Width</span><span class="spec-v">@Model.Frame.LensWidth.Value.ToString("0.#") mm</span></div>
                }
                @if (Model.Frame.BridgeWidth.HasValue)
                {
                    <div class="spec-row"><span class="spec-k">Bridge</span><span class="spec-v">@Model.Frame.BridgeWidth.Value.ToString("0.#") mm</span></div>
                }
                @if (Model.Frame.TempleLength.HasValue)
                {
                    <div class="spec-row"><span class="spec-k">Temple Length</span><span class="spec-v">@Model.Frame.TempleLength.Value.ToString("0.#") mm</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Frame.Color))
                {
                    <div class="spec-row"><span class="spec-k">Colors</span><span class="spec-v">@Model.Frame.Color</span></div>
                }
            </div>
        </div>

        <div id="tab-care" class="tab-panel">
            <h3>Care &amp; Cleaning</h3>
            <ul class="care-list">
                @foreach (var line in (Model.Frame.CareInstructions ?? "Clean gently with a microfiber cloth. Avoid harsh chemicals. Store in the provided case when not in use.").Split('.').Where(s => !string.IsNullOrWhiteSpace(s)))
                {
                    <li>@line.Trim().</li>
                }
            </ul>
        </div>
    </div>

    @if (Model.Frame.RelatedProducts.Any())
    {
        <div class="related">
            <h2>Similar Products</h2>
            <div class="rel-grid">
                @foreach (var r in Model.Frame.RelatedProducts)
                {
                    <a asp-page="/Products/FrameDetails" asp-route-id="@r.ProductId" class="rel-card">
                        <div class="rel-img">
                            @if (!string.IsNullOrEmpty(r.PrimaryImageUrl))
                            {
                                <img src="@r.PrimaryImageUrl" alt="@r.Name" />
                            }
                            else
                            {
                                <div class="rel-ph"><i class="bi bi-eyeglasses"></i></div>
                            }
                        </div>
                        <div class="rel-info">
                            <h4>@r.Name</h4>
                            <p>@r.Currency @r.Price.ToString("N0")</p>
                        </div>
                    </a>
                }
            </div>
        </div>
    }

    <!-- Mobile sticky -->
    <div class="sticky-bar" id="stickyBar">
        <div class="sticky-inner">
            <div class="sticky-price">@Model.Frame.Currency @Model.Frame.Price.ToString("N0")</div>
            @if (Model.Frame.IsInStock)
            {
                <button class="sticky-btn" onclick="document.getElementById('cartForm').submit()">Add to Cart</button>
            }
            else
            {
                <button class="sticky-btn" style="background:#6b7280;" onclick="document.getElementById('notifyBtn')?.click()">
                    <i class="bi bi-bell"></i> Notify Me
                </button>
            }
        </div>
    </div>
}
else
{
    <div style="text-align:center;padding:80px 24px;">
        <i class="bi bi-exclamation-circle" style="font-size:60px;color:#e53935;"></i>
        <h2 style="margin-top:16px;">Product Not Found</h2>
        <a asp-page="/Products/Index" style="color:#00756A;">&#8592; Back to Shop</a>
    </div>
}

@section Scripts {
    <script>
        function changeImg(url, el) {
            var img = document.getElementById('mainImg');
            if (img) {
                img.style.opacity = '0';
                setTimeout(function () { img.src = url; img.style.opacity = '1'; }, 200);
            }
            document.querySelectorAll('.thumb').forEach(function (t) { t.classList.remove('active'); });
            if (el) el.classList.add('active');
        }

        function chQty(d) {
            var inp = document.getElementById('qInput');
            if (!inp) return;
            var max = parseInt(inp.max) || 99;
            var v = Math.max(1, Math.min(max, (parseInt(inp.value) || 1) + d));
            inp.value = v;
            document.getElementById('qMinus').disabled = v <= 1;
            document.getElementById('qPlus').disabled = v >= max;
        }
        document.addEventListener('DOMContentLoaded', function () {
            if (document.getElementById('qInput')) chQty(0);
            initNotifyBtn();
        });

        function selColor(btn, name) {
            document.querySelectorAll('.color-opt').forEach(function (b) { b.classList.remove('active'); });
            btn.classList.add('active');
            var lbl = document.getElementById('colorLbl');
            if (lbl) lbl.textContent = name;
        }

        function switchTab(name, btn) {
            document.querySelectorAll('.tab-panel').forEach(function (p) { p.classList.remove('on'); });
            document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('on'); });
            var panel = document.getElementById('tab-' + name);
            if (panel) panel.classList.add('on');
            btn.classList.add('on');
        }

        // Mobile sticky
        var sb = document.getElementById('stickyBar');
        var cf = document.getElementById('cartForm');
        if (sb && cf) {
            window.addEventListener('scroll', function () {
                if (window.innerWidth <= 991)
                    sb.style.display = cf.getBoundingClientRect().bottom < 0 ? 'block' : 'none';
            });
        }

        // ── Notify / Wishlist (only rendered when out of stock) ──────────────────
        function initNotifyBtn() {
            var btn = document.getElementById('notifyBtn');
            if (!btn) return; // not out of stock, button not rendered

            var pid = parseInt(btn.dataset.productId);

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                    <text>
                    // Check if already wishlisted
                    fetch('/api/wishlist/my').then(function (r) {
                        if (r.ok) return r.json();
                    }).then(function (d) {
                        if (d && d.some(function (i) { return i.productId === pid; })) {
                            setNotifyState(true);
                        }
                    }).catch(function () {});
                    </text>
            }

            btn.addEventListener('click', function () {
                @if (User.Identity == null || !User.Identity.IsAuthenticated)
                {
                        <text>
                        window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                        return;
                        </text>
                }

                var isIn = btn.dataset.in === 'true';
                btn.disabled = true;

                if (isIn) {
                    fetch('/api/wishlist/remove', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId: pid })
                    }).then(function (r) {
                        if (r.ok) {
                            setNotifyState(false);
                            showToast('Removed from wishlist.');
                        } else {
                            showToast('Could not remove. Try again.');
                        }
                    }).catch(function () {
                        showToast('Network error.');
                    }).finally(function () {
                        btn.disabled = false;
                    });
                } else {
                    fetch('/api/wishlist/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId: pid })
                    }).then(function (r) {
                        return r.json().then(function (d) { return { ok: r.ok, data: d }; });
                    }).then(function (res) {
                        if (res.ok) {
                            setNotifyState(true);
                            showToast('Added to wishlist! Go to your wishlist to enable email notifications.');
                        } else {
                            showToast(res.data.message || 'Could not add to wishlist.');
                        }
                    }).catch(function () {
                        showToast('Network error.');
                    }).finally(function () {
                        btn.disabled = false;
                    });
                }
            });
        }

        function setNotifyState(isIn) {
            var btn = document.getElementById('notifyBtn');
            var lbl = document.getElementById('notifyLabel');
            var ico = document.getElementById('notifyIcon');
            if (!btn || !lbl || !ico) return;
            btn.dataset.in = isIn ? 'true' : 'false';
            if (isIn) {
                btn.classList.add('active');
                ico.className = 'bi bi-bell-fill';
                lbl.textContent = 'Added to Wishlist';
            } else {
                btn.classList.remove('active');
                ico.className = 'bi bi-bell';
                lbl.textContent = 'Notify When Available';
            }
        }

        var _toastTimer;
        function showToast(msg) {
            var t = document.getElementById('_toast');
            if (!t) {
                t = document.createElement('div');
                t.id = '_toast';
                t.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(80px);background:#1a1a1a;color:#fff;border-radius:10px;padding:12px 22px;font-size:13px;font-weight:600;box-shadow:0 8px 28px rgba(0,0,0,.25);z-index:9999;transition:transform .3s cubic-bezier(.34,1.56,.64,1);max-width:90vw;white-space:normal;text-align:center;';
                document.body.appendChild(t);
            }
            t.textContent = msg;
            t.style.transform = 'translateX(-50%) translateY(0)';
            clearTimeout(_toastTimer);
            _toastTimer = setTimeout(function () { t.style.transform = 'translateX(-50%) translateY(80px)'; }, 4000);
        }
    </script>
}

@functions {
    string ColorStyle(string color)
    {
        var m = new System.Collections.Generic.Dictionary<string, string>(StringComparer.OrdinalIgnoreCase) {
            { "Black",            "background:#1a1a1a" },
            { "Red",              "background:#cc2200" },
            { "Gold",             "background:#c9a96e" },
            { "Tortoise",         "background:linear-gradient(135deg,#7b4f1e,#c8892a,#1a0e00)" },
            { "Silver",           "background:linear-gradient(135deg,#d0d0d0,#f5f5f5,#b0b0b0)" },
            { "Blue",             "background:#1a4fa0" },
            { "Pink",             "background:#e879a0" },
            { "Green",            "background:#2d7a3a" },
            { "Transparent",      "background:linear-gradient(135deg,rgba(180,220,255,.5),rgba(255,255,255,.9));border:1px solid #ddd" },
            { "White",            "background:#f0f0f0;border:1px solid #ddd" },
            { "Brown",            "background:#8B4513" },
            { "Olive",            "background:#808000" },
            { "Grey",             "background:#808080" },
            { "Gray",             "background:#808080" },
            { "Purple",           "background:#6b21a8" },
            { "Transparent Grey", "background:linear-gradient(135deg,rgba(180,180,180,.5),rgba(240,240,240,.9));border:1px solid #ccc" }
        };
        return m.TryGetValue(color.Trim(), out var s) ? s : "background:#ccc";
    }
}
