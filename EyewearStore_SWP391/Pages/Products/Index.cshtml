@page
@model EyewearStore_SWP391.Pages.Products.IndexModel
@{
    ViewData["Title"] = !string.IsNullOrWhiteSpace(Model.BrandFilter)
        ? $"Mắt Kính {Model.BrandFilter} - OptiPlus"
        : "Shop Eyewear - Browse Frames & Lenses";
    Layout = "_Layout";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />
    <style>
        /* ── Product Card ── */
        .product-card {
            background: #fff;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
            transition: transform .25s,box-shadow .25s;
            display: flex;
            flex-direction: column;
        }

            .product-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 32px rgba(0,0,0,.12);
            }

        .product-image {
            position: relative;
            width: 100%;
            padding-top: 100%;
            overflow: hidden;
            background: #f8f9fb;
        }

            .product-image img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .4s ease;
            }

        .product-card:hover .product-image img {
            transform: scale(1.07);
        }

        .product-image-placeholder {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 56px;
            color: #d1d5db;
        }

        .product-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .4px;
            z-index: 2;
        }

            .product-badge.frame {
                background: rgba(0,117,106,.9);
                color: #fff;
            }

            .product-badge.lens {
                background: rgba(99,102,241,.9);
                color: #fff;
            }

        .oos-overlay {
            position: absolute;
            inset: 0;
            background: rgba(255,255,255,.55);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 3;
        }

        .oos-label {
            background: rgba(30,30,30,.75);
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            padding: 6px 14px;
            border-radius: 20px;
            letter-spacing: .4px;
        }

        .btn-wishlist {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 36px;
            height: 36px;
            background: rgba(255,255,255,.92);
            border: 1px solid rgba(0,0,0,.08);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 15px;
            color: #aaa;
            backdrop-filter: blur(6px);
            transition: color .2s,background .2s,transform .25s,border-color .2s;
            z-index: 5;
            box-shadow: 0 2px 8px rgba(0,0,0,.10);
        }

            .btn-wishlist:hover {
                color: #e05a6a;
                background: #fff;
                border-color: #f5c0c7;
                transform: scale(1.12);
            }

            .btn-wishlist.active, .btn-wishlist[data-in-wishlist="true"] {
                color: #c9a96e;
                background: #fffbf5;
                border-color: #e8d5b0;
            }

            .btn-wishlist.pop {
                animation: heart-pop .28s cubic-bezier(0.34,1.56,0.64,1);
            }

        @@keyframes heart-pop {
            0% {
                transform: scale(1)
            }

            50% {
                transform: scale(1.4)
            }

            100% {
                transform: scale(1)
            }
        }

        .product-info {
            padding: 14px 16px 16px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .product-name {
            font-size: 14px;
            font-weight: 600;
            color: #111827;
            margin: 0 0 6px;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-price {
            font-size: 16px;
            font-weight: 700;
            color: #00756A;
            margin: 0 0 8px;
        }

            .product-price .currency {
                font-size: 13px;
                margin-right: 2px;
            }

        .product-description {
            font-size: 12px;
            color: #6b7280;
            margin: 0 0 8px;
            line-height: 1.5;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-attributes {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin-bottom: 10px;
        }

        .attribute {
            font-size: 11px;
            background: #f3f4f6;
            color: #374151;
            padding: 3px 8px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

            .attribute.prescription {
                background: #ede9fe;
                color: #6d28d9;
            }

        .product-actions {
            display: flex;
            gap: 6px;
            margin-top: auto;
            flex-wrap: wrap;
        }

        .btn-add-cart {
            flex: 1;
            min-width: 0;
            padding: 9px 10px;
            background: #00756A;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            transition: background .2s;
            white-space: nowrap;
        }

            .btn-add-cart:hover {
                background: #005a51;
            }

        .btn-view-details-outline {
            padding: 9px 10px;
            background: #fff;
            color: #374151;
            border: 1.5px solid #e5e7eb;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: border-color .2s,color .2s;
            white-space: nowrap;
        }

            .btn-view-details-outline:hover {
                border-color: #00756A;
                color: #00756A;
            }

        .btn-buy-now {
            width: 100%;
            padding: 9px;
            background: #fff;
            color: #e53935;
            border: 1.5px solid #fecaca;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: background .2s,border-color .2s;
            margin-top: 5px;
        }

            .btn-buy-now:hover {
                background: #fff5f5;
                border-color: #e53935;
            }

        #wl-toast {
            position: fixed;
            bottom: 28px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background: #0f0f0f;
            color: #fff;
            border-radius: 12px;
            padding: 12px 22px;
            font-size: 13px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 8px 28px rgba(0,0,0,.22);
            z-index: 9999;
            white-space: nowrap;
            transition: transform .35s cubic-bezier(0.34,1.56,0.64,1);
            pointer-events: none;
        }

            #wl-toast.show {
                transform: translateX(-50%) translateY(0);
            }

        /* ── Brand page header ── */
        .brand-page-header {
            background: #fff;
            border-bottom: 2px solid #e5e7eb;
            padding: 44px 24px 36px;
            text-align: center;
            position: relative;
            overflow: hidden;
            margin-bottom: 0;
        }

            .brand-page-header::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg,rgba(0,117,106,.05) 0%,rgba(255,255,255,0) 55%);
                pointer-events: none;
            }

            .brand-page-header::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 60px;
                height: 3px;
                background: #00756A;
                border-radius: 3px 3px 0 0;
            }

        .brand-logo-wrap {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            border: 2px solid #e5e7eb;
            border-radius: 14px;
            padding: 12px 36px;
            margin-bottom: 18px;
            box-shadow: 0 4px 24px rgba(0,0,0,.08);
            min-width: 140px;
        }

        .brand-logo-name {
            font-size: 26px;
            font-weight: 900;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: #00756A;
        }

        .brand-page-sub {
            font-size: 11px;
            font-weight: 700;
            color: #9ca3af;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin: 0 0 10px;
        }

        .brand-page-title {
            font-size: 20px;
            font-weight: 800;
            color: #111827;
            margin: 0 0 6px;
            letter-spacing: .3px;
        }

            .brand-page-title .brand-count {
                color: #00756A;
                font-size: 17px;
                font-weight: 700;
            }

        .brand-page-desc {
            font-size: 13px;
            color: #9ca3af;
            margin: 0;
        }

        .brand-back-link {
            position: absolute;
            top: 16px;
            left: 24px;
            font-size: 12px;
            color: #6b7280;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 14px;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            background: #fff;
            transition: all .2s;
        }

            .brand-back-link:hover {
                color: #00756A;
                border-color: #00756A;
            }

        @@media(max-width:576px) {
            .brand-back-link {
                position: static;
                display: inline-flex;
                margin-bottom: 16px;
            }

            .brand-page-header {
                padding: 24px 16px 28px;
            }
        }

        /* ══ SMART SEARCH ══════════════════════════════════════ */
        .smart-search-wrap {
            position: relative;
        }

        .smart-search-row {
            display: flex;
            align-items: center;
            background: #fff;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            overflow: hidden;
            transition: border-color .18s, box-shadow .18s;
        }

            .smart-search-row:focus-within {
                border-color: #00756A;
                box-shadow: 0 0 0 3px rgba(0,117,106,.1);
            }

        .ss-icon {
            padding: 0 10px 0 14px;
            color: #9ca3af;
            font-size: 15px;
            flex-shrink: 0;
            transition: color .18s;
        }

        .smart-search-row:focus-within .ss-icon {
            color: #00756A;
        }

        .ss-input {
            flex: 1;
            border: none;
            outline: none;
            padding: 11px 4px;
            font-size: 13px;
            font-family: inherit;
            color: #111827;
            background: transparent;
            min-width: 0;
        }

            .ss-input::placeholder {
                color: #9ca3af;
            }

        .ss-clear {
            padding: 0 12px;
            background: none;
            border: none;
            color: #9ca3af;
            cursor: pointer;
            font-size: 13px;
            display: none;
            align-items: center;
            transition: color .15s;
            flex-shrink: 0;
        }

            .ss-clear:hover {
                color: #374151;
            }

            .ss-clear.show {
                display: flex;
            }

        /* Dropdown */
        .ss-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 6px);
            left: 0;
            right: 0;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,.13);
            z-index: 9999;
            overflow: hidden;
            max-height: 440px;
            overflow-y: auto;
        }

            .ss-dropdown.open {
                display: block;
            }

            .ss-dropdown::-webkit-scrollbar {
                width: 4px;
            }

            .ss-dropdown::-webkit-scrollbar-track {
                background: #f9fafb;
            }

            .ss-dropdown::-webkit-scrollbar-thumb {
                background: #d1d5db;
                border-radius: 4px;
            }

        .ss-group-title {
            padding: 10px 14px 5px;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 1.2px;
            color: #9ca3af;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 6px;
            background: #fafafa;
            border-bottom: 1px solid #f3f4f6;
        }

        /* Brand row */
        .ss-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            text-decoration: none;
            transition: background .15s;
            border-bottom: 1px solid #f5f5f5;
        }

            .ss-brand:hover {
                background: #f0fdf9;
            }

        .ss-brand-icon {
            width: 34px;
            height: 34px;
            background: #e8f5f4;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #00756A;
            font-weight: 900;
            text-transform: uppercase;
            flex-shrink: 0;
        }

        .ss-brand-name {
            font-size: 13px;
            font-weight: 700;
            color: #111827;
            flex: 1;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .ss-brand-count {
            font-size: 11px;
            color: #6b7280;
            background: #f3f4f6;
            padding: 2px 8px;
            border-radius: 10px;
            white-space: nowrap;
        }

        /* Frame row */
        .ss-frame {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 14px;
            text-decoration: none;
            transition: background .15s;
            border-bottom: 1px solid #f9fafb;
        }

            .ss-frame:hover {
                background: #f9fafb;
            }

        .ss-frame-thumb {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            overflow: hidden;
            background: #f5f5f5;
            flex-shrink: 0;
            border: 1px solid #efefef;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .ss-frame-thumb img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .ss-frame-thumb i {
                font-size: 22px;
                color: #d1d5db;
            }

        .ss-frame-body {
            flex: 1;
            min-width: 0;
        }

        .ss-frame-name {
            font-size: 13px;
            font-weight: 600;
            color: #111827;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ss-frame-meta {
            display: flex;
            gap: 5px;
            align-items: center;
            margin-top: 2px;
        }

        .ss-frame-brand-tag {
            background: #e8f5f4;
            color: #00756A;
            padding: 1px 6px;
            border-radius: 5px;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .ss-frame-sku {
            font-size: 11px;
            color: #9ca3af;
        }

        .ss-frame-price {
            font-size: 13px;
            font-weight: 700;
            color: #00756A;
            flex-shrink: 0;
        }

        /* States */
        .ss-empty, .ss-loading {
            padding: 22px 14px;
            text-align: center;
            font-size: 13px;
            color: #9ca3af;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .ss-spinner {
            width: 16px;
            height: 16px;
            border: 2px solid #e5e7eb;
            border-top-color: #00756A;
            border-radius: 50%;
            animation: ssspin .65s linear infinite;
            flex-shrink: 0;
        }

        @@keyframes ssspin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Footer */
        .ss-footer {
            padding: 9px 14px;
            border-top: 1px solid #e5e7eb;
            text-align: center;
            font-size: 12px;
            color: #9ca3af;
            background: #fafafa;
        }

            .ss-footer a {
                color: #00756A;
                font-weight: 600;
                text-decoration: none;
            }

                .ss-footer a:hover {
                    text-decoration: underline;
                }

        /* Highlight match */
        .ss-hl {
            background: #d1fae5;
            color: #065f46;
            border-radius: 2px;
            padding: 0 1px;
        }

        /* ══ MEGA FILTER BAR ═══════════════════════════════ */
        .brand-mega-bar {
            background: #fff;
            border-bottom: 1.5px solid #e5e7eb;
            border-top: 1px solid #f3f4f6;
            position: relative;
            z-index: 500;
        }

        .brand-mega-inner {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: stretch;
            gap: 0;
        }

        /* Each tab */
        .mega-tab {
            position: relative;
            flex-shrink: 0;
        }

        .mega-tab-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 13px 16px;
            font-size: 12px;
            font-weight: 700;
            color: #374151;
            text-transform: uppercase;
            letter-spacing: .6px;
            border: none;
            background: none;
            cursor: pointer;
            white-space: nowrap;
            transition: color .15s, background .15s;
            border-bottom: 2px solid transparent;
            margin-bottom: -1.5px;
            height: 100%;
        }

            .mega-tab-btn:hover,
            .mega-tab:hover .mega-tab-btn {
                color: #00756A;
                border-bottom-color: #00756A;
            }

            .mega-tab-btn.is-active {
                color: #00756A;
                border-bottom-color: #00756A;
            }

        .mega-chevron {
            font-size: 9px;
            opacity: .6;
            transition: transform .2s;
        }

        .mega-tab:hover .mega-chevron {
            transform: rotate(180deg);
        }

        /* Dropdown */
        .mega-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 1.5px);
            left: 0;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 0 12px 12px 12px;
            box-shadow: 0 12px 40px rgba(0,0,0,.12);
            z-index: 9000;
            animation: megaDrop .15s ease;
        }

        .mega-tab:hover .mega-dropdown {
            display: block;
        }

        @@keyframes megaDrop {
            from {
                opacity: 0;
                transform: translateY(-6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Brands grid dropdown */
        .brands-dropdown {
            padding: 14px;
            min-width: 480px;
        }

        .bmd-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2px;
        }

        /* Simple list dropdown (gender, shape, type) */
        .simple-dropdown {
            padding: 8px 0;
            min-width: 180px;
        }

        /* Items */
        .bmd-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            text-decoration: none;
            transition: background .13s;
            color: #111827;
            border-radius: 8px;
        }

            .bmd-item:hover {
                background: #f0fdf9;
                color: #00756A;
            }

            .bmd-item.active {
                background: #e8f5f4;
                color: #00756A;
                font-weight: 700;
            }

        .bmd-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #00756A;
            flex-shrink: 0;
            opacity: .35;
        }

        .bmd-item:hover .bmd-dot,
        .bmd-item.active .bmd-dot {
            opacity: 1;
        }

        .bmd-name {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .4px;
            flex: 1;
        }

        .bmd-count {
            font-size: 11px;
            color: #9ca3af;
            background: #f3f4f6;
            padding: 1px 7px;
            border-radius: 8px;
        }

        /* All Products button */
        .mega-all-btn {
            margin-left: auto;
            align-self: center;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 7px 16px;
            background: #f3f4f6;
            color: #374151;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: .5px;
            transition: background .18s, color .18s;
            white-space: nowrap;
        }

            .mega-all-btn:hover,
            .mega-all-btn.is-active {
                background: #00756A;
                color: #fff;
            }

        /* shop-container must not clip dropdowns */
        .shop-container {
            overflow: visible !important;
        }

        @@media(max-width: 768px) {
            .brand-mega-bar {
                display: none;
            }
        }
    </style>
}

<div class="shop-container">
    <nav class="shop-breadcrumb" aria-label="Breadcrumb">
        <ol>
            <li><a asp-page="/Index"><i class="bi bi-house-door"></i> Home</a></li>
            <li class="separator"><i class="bi bi-chevron-right"></i></li>
            <li><a asp-page="/Products/Index">Shop</a></li>
            @if (!string.IsNullOrWhiteSpace(Model.BrandFilter))
            {
                <li class="separator"><i class="bi bi-chevron-right"></i></li>
                <li class="current" aria-current="page">@Model.BrandFilter</li>
            }
            else
            {
                <li class="separator"><i class="bi bi-chevron-right"></i></li>
                <li class="current" aria-current="page">Shop</li>
            }
        </ol>
    </nav>

    @if (!string.IsNullOrWhiteSpace(Model.BrandFilter))
    {
        var totalBrandProducts = Model.Catalog.TotalItems;
        <div class="brand-page-header">
            <a asp-page="/Products/Index" class="brand-back-link">
                <i class="bi bi-arrow-left"></i> Tất cả sản phẩm
            </a>
            <div class="brand-logo-wrap">
                <span class="brand-logo-name">@Model.BrandFilter.ToUpper()</span>
            </div>
            <p class="brand-page-sub">Thương Hiệu</p>
            <p class="brand-page-title">
                MẮT KÍNH THƯƠNG HIỆU @Model.BrandFilter.ToUpper()
                <span class="brand-count">(@totalBrandProducts)</span>
            </p>
            <p class="brand-page-desc">Khám phá toàn bộ bộ sưu tập chính hãng từ @Model.BrandFilter</p>
        </div>
    }
    else
    {
        <header class="shop-header">
            <h1>Browse Our Collection</h1>
            <p class="shop-subtitle">Discover premium eyewear crafted for style and comfort</p>
        </header>
    }

    @* ── Mega Filter Bar ── *@
    <div class="brand-mega-bar">
        <div class="brand-mega-inner">

            @* ── Brands ── *@
            <div class="mega-tab">
                <button class="mega-tab-btn @(!string.IsNullOrWhiteSpace(Model.BrandFilter) ? "is-active" : "")">
                    <i class="bi bi-tags"></i> Brands
                    <i class="bi bi-chevron-down mega-chevron"></i>
                </button>
                <div class="mega-dropdown brands-dropdown">
                    @if (Model.AllBrands.Any())
                    {
                        <div class="bmd-grid">
                            @foreach (var b in Model.AllBrands)
                            {
                                <a class="bmd-item @(Model.BrandFilter?.ToLower() == b.Brand.ToLower() ? "active" : "")"
                                   href="/Products?BrandFilter=@Uri.EscapeDataString(b.Brand)">
                                    <span class="bmd-dot"></span>
                                    <span class="bmd-name">@b.Brand</span>
                                    <span class="bmd-count">@b.Count</span>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p style="padding:16px;color:#9ca3af;font-size:13px;">No brands available</p>
                    }
                </div>
            </div>

            @* ── Gender ── *@
            <div class="mega-tab">
                <button class="mega-tab-btn @(!string.IsNullOrWhiteSpace(Model.GenderFilter) ? "is-active" : "")">
                    <i class="bi bi-person"></i> Gender
                    <i class="bi bi-chevron-down mega-chevron"></i>
                </button>
                <div class="mega-dropdown simple-dropdown">
                    <a class="bmd-item @(Model.GenderFilter == "Male" ? "active" : "")"
                       href="/Products?GenderFilter=Male&ProductTypeFilter=Frame@(!string.IsNullOrWhiteSpace(Model.BrandFilter) ? "&BrandFilter=" + Uri.EscapeDataString(Model.BrandFilter) : "")">
                        <span class="bmd-dot"></span><span class="bmd-name">Male</span>
                    </a>
                    <a class="bmd-item @(Model.GenderFilter == "Female" ? "active" : "")"
                       href="/Products?GenderFilter=Female&ProductTypeFilter=Frame@(!string.IsNullOrWhiteSpace(Model.BrandFilter) ? "&BrandFilter=" + Uri.EscapeDataString(Model.BrandFilter) : "")">
                        <span class="bmd-dot"></span><span class="bmd-name">Female</span>
                    </a>
                    <a class="bmd-item @(Model.GenderFilter == "Unisex" ? "active" : "")"
                       href="/Products?GenderFilter=Unisex&ProductTypeFilter=Frame@(!string.IsNullOrWhiteSpace(Model.BrandFilter) ? "&BrandFilter=" + Uri.EscapeDataString(Model.BrandFilter) : "")">
                        <span class="bmd-dot"></span><span class="bmd-name">Unisex</span>
                    </a>
                </div>
            </div>

            @* ── Frame Shape ── *@
            <div class="mega-tab">
                <button class="mega-tab-btn @(!string.IsNullOrWhiteSpace(Model.FrameShapeFilter) ? "is-active" : "")">
                    <i class="bi bi-circle"></i> Frame Shape
                    <i class="bi bi-chevron-down mega-chevron"></i>
                </button>
                <div class="mega-dropdown simple-dropdown">
                    @foreach (var shape in new[] { "Round", "Square", "Rectangle", "Aviator", "Cat-eye", "Oval", "Browline" })
                    {
                        <a class="bmd-item @(Model.FrameShapeFilter == shape ? "active" : "")"
                           href="/Products?FrameShapeFilter=@Uri.EscapeDataString(shape)&ProductTypeFilter=Frame">
                            <span class="bmd-dot"></span><span class="bmd-name">@shape</span>
                        </a>
                    }
                </div>
            </div>

            @* ── Frame Type ── *@
            <div class="mega-tab">
                <button class="mega-tab-btn @(!string.IsNullOrWhiteSpace(Model.FrameTypeFilter) ? "is-active" : "")">
                    <i class="bi bi-eyeglasses"></i> Frame Type
                    <i class="bi bi-chevron-down mega-chevron"></i>
                </button>
                <div class="mega-dropdown simple-dropdown">
                    @foreach (var ft in new[] { "Full-Rim", "Half-Rim", "Rimless" })
                    {
                        <a class="bmd-item @(Model.FrameTypeFilter == ft ? "active" : "")"
                           href="/Products?FrameTypeFilter=@Uri.EscapeDataString(ft)&ProductTypeFilter=Frame">
                            <span class="bmd-dot"></span><span class="bmd-name">@ft</span>
                        </a>
                    }
                </div>
            </div>

            @* ── All Products ── *@
            <a class="mega-all-btn @(string.IsNullOrWhiteSpace(Model.BrandFilter) && string.IsNullOrWhiteSpace(Model.GenderFilter) && string.IsNullOrWhiteSpace(Model.FrameShapeFilter) ? "is-active" : "")"
               href="/Products?ProductTypeFilter=All">
                <i class="bi bi-grid-3x3-gap-fill"></i> All Products
            </a>

        </div>
    </div>

    <div class="shop-content">
        <!-- Filter Sidebar -->
        <aside class="filter-sidebar" id="filterSidebar">
            <div class="filter-header">
                <h3><i class="bi bi-funnel"></i> Filters</h3>
                <a asp-page="/Products/Index" class="clear-filters-link" id="clearFilters">
                    <i class="bi bi-x-circle"></i> Clear All
                </a>
            </div>

            <form method="get" asp-page="/Products/Index" id="filterForm">
                <div class="filter-section">
                    <h4>Product Type</h4>
                    <div class="product-type-pills">
                        <button type="submit" name="ProductTypeFilter" value="All"
                                class="type-pill @(Model.ProductTypeFilter == "All" ? "active" : "")">
                            All
                        </button>
                        <button type="submit" name="ProductTypeFilter" value="Frame"
                                class="type-pill @(Model.ProductTypeFilter == "Frame" ? "active" : "")">
                            <i class="bi bi-eyeglasses"></i> Frames
                        </button>
                        <button type="submit" name="ProductTypeFilter" value="Lens"
                                class="type-pill @(Model.ProductTypeFilter == "Lens" ? "active" : "")">
                            <i class="bi bi-circle"></i> Lenses
                        </button>
                    </div>
                    <input type="hidden" name="SearchTerm" value="@Model.SearchTerm" />
                    <input type="hidden" name="MinPrice" value="@Model.MinPrice" />
                    <input type="hidden" name="MaxPrice" value="@Model.MaxPrice" />
                    <input type="hidden" name="FrameMaterialFilter" value="@Model.FrameMaterialFilter" />
                    <input type="hidden" name="FrameTypeFilter" value="@Model.FrameTypeFilter" />
                    <input type="hidden" name="LensTypeFilter" value="@Model.LensTypeFilter" />
                    <input type="hidden" name="SortBy" value="@Model.SortBy" />
                    @if (!string.IsNullOrWhiteSpace(Model.BrandFilter))
                    {
                        <input type="hidden" name="BrandFilter" value="@Model.BrandFilter" />
                    }
                </div>
            </form>

            <form method="get" asp-page="/Products/Index" id="searchFilterForm">
                <input type="hidden" name="ProductTypeFilter" value="@Model.ProductTypeFilter" />
                @if (!string.IsNullOrWhiteSpace(Model.BrandFilter))
                {
                    <input type="hidden" name="BrandFilter" value="@Model.BrandFilter" />
                }

                <div class="filter-section">
                    <h4>Search</h4>
                    <div class="smart-search-wrap" id="ssWrap">
                        <div class="smart-search-row">
                            <span class="ss-icon"><i class="bi bi-search"></i></span>
                            <input type="text"
                                   id="ssInput"
                                   class="ss-input"
                                   placeholder="Tìm gọng kính, thương hiệu..."
                                   autocomplete="off"
                                   spellcheck="false" />
                            <button type="button" class="ss-clear" id="ssClear" title="Xóa">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <div class="ss-dropdown" id="ssDropdown"></div>
                    </div>
                    <input type="hidden" name="SearchTerm" id="ssHidden" value="@Model.SearchTerm" />
                </div>

                <div class="filter-section">
                    <h4>Price Range</h4>
                    <div class="price-range-inputs">
                        <div class="price-input-group">
                            <label for="minPrice">Min</label>
                            <input type="number" name="MinPrice" value="@Model.MinPrice"
                                   placeholder="0" min="0" step="0.01" class="price-input" id="minPrice" />
                        </div>
                        <span class="price-separator">—</span>
                        <div class="price-input-group">
                            <label for="maxPrice">Max</label>
                            <input type="number" name="MaxPrice" value="@Model.MaxPrice"
                                   placeholder="Any" min="0" step="0.01" class="price-input" id="maxPrice" />
                        </div>
                    </div>
                </div>

                @if (Model.ProductTypeFilter == "All" || Model.ProductTypeFilter == "Frame")
                {
                    <div class="filter-section frame-filters">
                        <h4><i class="bi bi-eyeglasses"></i> Frame Options</h4>
                        @if (Model.Catalog.AvailableFrameMaterials.Any())
                        {
                            <div class="select-wrapper">
                                <label for="frameMaterialFilter">Material</label>
                                <select name="FrameMaterialFilter" id="frameMaterialFilter" class="filter-select">
                                    <option value="">All Materials</option>
                                    @foreach (var m in Model.Catalog.AvailableFrameMaterials)
                                    {
                                        <option value="@m" selected="@(Model.FrameMaterialFilter == m)">@m</option>
                                    }
                                </select>
                                <i class="bi bi-chevron-down select-arrow"></i>
                            </div>
                        }
                        @if (Model.Catalog.AvailableFrameTypes.Any())
                        {
                            <div class="select-wrapper">
                                <label for="frameTypeFilter">Frame Type</label>
                                <select name="FrameTypeFilter" id="frameTypeFilter" class="filter-select">
                                    <option value="">All Types</option>
                                    @foreach (var t in Model.Catalog.AvailableFrameTypes)
                                    {
                                        <option value="@t" selected="@(Model.FrameTypeFilter == t)">@t</option>
                                    }
                                </select>
                                <i class="bi bi-chevron-down select-arrow"></i>
                            </div>
                        }
                    </div>
                }

                @if (Model.ProductTypeFilter == "All" || Model.ProductTypeFilter == "Lens")
                {
                    <div class="filter-section lens-filters">
                        <h4><i class="bi bi-circle"></i> Lens Options</h4>
                        @if (Model.Catalog.AvailableLensTypes.Any())
                        {
                            <div class="select-wrapper">
                                <label for="lensTypeFilter">Lens Type</label>
                                <select name="LensTypeFilter" id="lensTypeFilter" class="filter-select">
                                    <option value="">All Lens Types</option>
                                    @foreach (var t in Model.Catalog.AvailableLensTypes)
                                    {
                                        <option value="@t" selected="@(Model.LensTypeFilter == t)">@t</option>
                                    }
                                </select>
                                <i class="bi bi-chevron-down select-arrow"></i>
                            </div>
                        }
                    </div>
                }

                <input type="hidden" name="SortBy" value="@Model.SortBy" />
                <div class="filter-actions">
                    <button type="submit" class="btn-apply-filters">
                        <i class="bi bi-check-lg"></i> Apply Filters
                    </button>
                </div>
            </form>
        </aside>

        <!-- Products Section -->
        <section class="products-section">
            <div class="results-header">
                <div class="results-count">
                    @if (Model.Catalog.TotalItems > 0)
                    {
                        <span>Showing <strong>@Model.Catalog.StartItem–@Model.Catalog.EndItem</strong> of <strong>@Model.Catalog.TotalItems</strong> products</span>
                    }
                    else
                    {
                        <span>No products found</span>
                    }
                </div>
                <div class="sort-wrapper">
                    <label for="sortSelect">Sort by:</label>
                    <div class="select-wrapper compact">
                        <select id="sortSelect" class="filter-select sort-select" onchange="updateSort(this.value)">
                            <option value="name" selected="@(Model.SortBy == "name")">Name (A-Z)</option>
                            <option value="price-low" selected="@(Model.SortBy == "price-low")">Price: Low to High</option>
                            <option value="price-high" selected="@(Model.SortBy == "price-high")">Price: High to Low</option>
                            <option value="newest" selected="@(Model.SortBy == "newest")">Newest First</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>
            </div>

            <button class="mobile-filter-toggle" id="mobileFilterToggle">
                <i class="bi bi-funnel"></i> Filters
            </button>

            @if (Model.Catalog.Products.Any())
            {
                <div class="product-grid">
                    @foreach (var product in Model.Catalog.Products)
                    {
                        <article class="product-card" id="product-@product.ProductId">
                            <div class="product-image">
                                @if (!string.IsNullOrEmpty(product.PrimaryImageUrl))
                                {
                                    <img src="@product.PrimaryImageUrl" alt="@product.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="product-image-placeholder"><i class="bi bi-eyeglasses"></i></div>
                                }
                                <span class="product-badge @product.ProductType.ToLower()">@product.ProductType</span>
                                @if (product.InventoryQty <= 0)
                                {
                                    <div class="oos-overlay">
                                        <span class="oos-label"><i class="bi bi-x-circle me-1"></i>Out of Stock</span>
                                    </div>
                                    <button class="btn-wishlist"
                                            data-product-id="@product.ProductId"
                                            data-in-wishlist="false"
                                            data-out-of-stock="true"
                                            onclick="toggleWishlist(this)"
                                            title="Notify me when back in stock">
                                        <i class="bi bi-heart"></i>
                                    </button>
                                }
                            </div>
                            <div class="product-info">
                                <h3 class="product-name">@product.Name</h3>
                                <p class="product-price">
                                    <span class="currency">@product.Currency</span>
                                    @product.Price.ToString("N0")
                                </p>
                                @if (!string.IsNullOrEmpty(product.Description))
                                {
                                    <p class="product-description">@product.Description</p>
                                }
                                <div class="product-attributes">
                                    @if (product.ProductType == "Frame")
                                    {
                                        @if (!string.IsNullOrEmpty(product.FrameMaterial))
                                        {
                                            <span class="attribute"><i class="bi bi-gem"></i> @product.FrameMaterial</span>
                                        }
                                        @if (!string.IsNullOrEmpty(product.FrameType))
                                        {
                                            <span class="attribute"><i class="bi bi-tag"></i> @product.FrameType</span>
                                        }
                                    }
                                    else if (product.ProductType == "Lens")
                                    {
                                        @if (!string.IsNullOrEmpty(product.LensType))
                                        {
                                            <span class="attribute"><i class="bi bi-circle"></i> @product.LensType</span>
                                        }
                                        @if (product.IsPrescription == true)
                                        {
                                            <span class="attribute prescription"><i class="bi bi-check-circle"></i> Prescription</span>
                                        }
                                    }
                                </div>
                                <div class="product-actions">
                                    @if (product.InventoryQty <= 0)
                                    {
                                        @if (product.ProductType == "Frame")
                                        {
                                            <a asp-page="/Products/FrameDetails" asp-route-id="@product.ProductId" class="btn-view-details-outline" style="flex:1;">View Details</a>
                                        }
                                        else
                                        {
                                            <a asp-page="/Products/LensDetails" asp-route-id="@product.ProductId" class="btn-view-details-outline" style="flex:1;">View Details</a>
                                        }
                                    }
                                    else
                                    {
                                        @if (product.ProductType == "Frame")
                                        {
                                            <button onclick="addToCart(this, @product.ProductId)" class="btn-add-cart">
                                                <i class="bi bi-cart-plus"></i> Add
                                            </button>
                                            <a asp-page="/Products/FrameDetails" asp-route-id="@product.ProductId" class="btn-view-details-outline">Details</a>
                                        }
                                        else
                                        {
                                            <button onclick="handleAddToCart(this, @product.ProductId, 'Lens', '@Html.Raw(product.Name.Replace("'", "\\'"))', '@product.Price.ToString("N0")', '@product.PrimaryImageUrl')" class="btn-add-cart">
                                                <i class="bi bi-cart-plus"></i> Add
                                            </button>
                                            <a asp-page="/Products/LensDetails" asp-route-id="@product.ProductId" class="btn-view-details-outline">Details</a>
                                        }
                                        <button onclick="handleAddToCart(this, @product.ProductId, '@product.ProductType', '@Html.Raw(product.Name.Replace("'", "\\'"))', '@product.Price.ToString("N0")', '@product.PrimaryImageUrl', true)" class="btn-buy-now">
                                            Buy Now
                                        </button>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>

                @if (Model.Catalog.TotalPages > 1)
                {
                    <nav class="pagination-nav" aria-label="Product pagination">
                        <ul class="pagination">
                            <li class="page-item @(!Model.Catalog.HasPreviousPage ? "disabled" : "")">
                                @if (Model.Catalog.HasPreviousPage)
                                {
                                    <a class="page-link prev" asp-page="/Products/Index"
                                       asp-route-ProductTypeFilter="@Model.ProductTypeFilter" asp-route-SearchTerm="@Model.SearchTerm"
                                       asp-route-MinPrice="@Model.MinPrice" asp-route-MaxPrice="@Model.MaxPrice"
                                       asp-route-FrameMaterialFilter="@Model.FrameMaterialFilter" asp-route-FrameTypeFilter="@Model.FrameTypeFilter"
                                       asp-route-LensTypeFilter="@Model.LensTypeFilter" asp-route-BrandFilter="@Model.BrandFilter"
                                       asp-route-SortBy="@Model.SortBy" asp-route-CurrentPage="@(Model.CurrentPage - 1)">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="page-link prev disabled"><i class="bi bi-chevron-left"></i></span>
                                }
                            </li>
                            @{
                                int startPage = Math.Max(1, Model.CurrentPage - 2);
                                int endPage = Math.Min(Model.Catalog.TotalPages, Model.CurrentPage + 2);
                                if (endPage - startPage < 4)
                                {
                                    if (startPage == 1) endPage = Math.Min(5, Model.Catalog.TotalPages);
                                    else if (endPage == Model.Catalog.TotalPages) startPage = Math.Max(1, Model.Catalog.TotalPages - 4);
                                }
                            }
                            @if (startPage > 1)
                            {
                                <li class="page-item"><a class="page-link" asp-page="/Products/Index" asp-route-CurrentPage="1" asp-route-ProductTypeFilter="@Model.ProductTypeFilter" asp-route-SearchTerm="@Model.SearchTerm" asp-route-SortBy="@Model.SortBy" asp-route-BrandFilter="@Model.BrandFilter">1</a></li>
                                @if (startPage > 2)
                                {
                                    <li class="page-item ellipsis"><span class="page-link">...</span></li>
                                }
                            }
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    @if (i == Model.CurrentPage)
                                    {
                                        <span class="page-link" aria-current="page">@i</span>
                                    }
                                    else
                                    {
                                        <a class="page-link" asp-page="/Products/Index"
                                           asp-route-ProductTypeFilter="@Model.ProductTypeFilter" asp-route-SearchTerm="@Model.SearchTerm"
                                           asp-route-MinPrice="@Model.MinPrice" asp-route-MaxPrice="@Model.MaxPrice"
                                           asp-route-FrameMaterialFilter="@Model.FrameMaterialFilter" asp-route-FrameTypeFilter="@Model.FrameTypeFilter"
                                           asp-route-LensTypeFilter="@Model.LensTypeFilter" asp-route-BrandFilter="@Model.BrandFilter"
                                           asp-route-SortBy="@Model.SortBy" asp-route-CurrentPage="@i">@i</a>
                                    }
                                </li>
                            }
                            @if (endPage < Model.Catalog.TotalPages)
                            {
                                @if (endPage < Model.Catalog.TotalPages - 1)
                                {
                                    <li class="page-item ellipsis"><span class="page-link">...</span></li>
                                }
                                <li class="page-item"><a class="page-link" asp-page="/Products/Index" asp-route-CurrentPage="@Model.Catalog.TotalPages" asp-route-ProductTypeFilter="@Model.ProductTypeFilter" asp-route-SortBy="@Model.SortBy" asp-route-BrandFilter="@Model.BrandFilter">@Model.Catalog.TotalPages</a></li>
                            }
                            <li class="page-item @(!Model.Catalog.HasNextPage ? "disabled" : "")">
                                @if (Model.Catalog.HasNextPage)
                                {
                                    <a class="page-link next" asp-page="/Products/Index"
                                       asp-route-ProductTypeFilter="@Model.ProductTypeFilter" asp-route-SearchTerm="@Model.SearchTerm"
                                       asp-route-MinPrice="@Model.MinPrice" asp-route-MaxPrice="@Model.MaxPrice"
                                       asp-route-FrameMaterialFilter="@Model.FrameMaterialFilter" asp-route-FrameTypeFilter="@Model.FrameTypeFilter"
                                       asp-route-LensTypeFilter="@Model.LensTypeFilter" asp-route-BrandFilter="@Model.BrandFilter"
                                       asp-route-SortBy="@Model.SortBy" asp-route-CurrentPage="@(Model.CurrentPage + 1)">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="page-link next disabled"><i class="bi bi-chevron-right"></i></span>
                                }
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-eyeglasses"></i></div>
                    <h2>No Products Found</h2>
                    <p>We couldn't find any products matching your criteria.</p>
                    <a asp-page="/Products/Index" class="btn-clear-filters">
                        <i class="bi bi-arrow-counterclockwise"></i> Clear All Filters
                    </a>
                </div>
            }
        </section>
    </div>
</div>

@section Scripts {
    <script>
        function updateSort(value) {
            const url = new URL(window.location.href);
            url.searchParams.set('SortBy', value);
            url.searchParams.set('CurrentPage', '1');
            window.location.href = url.toString();
        }

        document.addEventListener('DOMContentLoaded', function () {
            const toggle  = document.getElementById('mobileFilterToggle');
            const sidebar = document.getElementById('filterSidebar');
            if (toggle && sidebar) {
                toggle.addEventListener('click', () => { sidebar.classList.toggle('show'); toggle.classList.toggle('active'); });
            }
            document.addEventListener('click', e => {
                if (window.innerWidth < 992 && sidebar?.classList.contains('show') &&
                    !sidebar.contains(e.target) && !toggle.contains(e.target)) {
                    sidebar.classList.remove('show'); toggle.classList.remove('active');
                }
            });
        });

        /* ── Wishlist ── */
        let _wlToast = null;
        function showWlToast(msg, icon = '<i class="bi bi-heart"></i>') {
            if (!_wlToast) { _wlToast = document.createElement('div'); _wlToast.id = 'wl-toast'; document.body.appendChild(_wlToast); }
            _wlToast.innerHTML = `<span>${icon}</span>${msg}`;
            _wlToast.classList.add('show');
            clearTimeout(_wlToast._t);
            _wlToast._t = setTimeout(() => _wlToast.classList.remove('show'), 2800);
        }
        async function toggleWishlist(btn) {
            @if (!User.Identity.IsAuthenticated)
            {
                        <text>showWlToast('Please login to save items',''); setTimeout(()=>window.location.href='/Account/Login',1200); return;</text>
            }
            const productId = parseInt(btn.dataset.productId);
            const isIn = btn.dataset.inWishlist === 'true';
            btn.disabled = true;
            try {
                if (isIn) {
                    const res = await fetch('/api/wishlist/remove', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ productId }) });
                    if (res.ok) { btn.dataset.inWishlist='false'; btn.querySelector('i').className='bi bi-heart'; btn.classList.remove('active'); showWlToast('Removed from wishlist',''); }
                } else {
                    const res  = await fetch('/api/wishlist/add', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ productId }) });
                    const data = await res.json();
                    if (res.ok) { btn.dataset.inWishlist='true'; btn.querySelector('i').className='bi bi-heart-fill'; btn.classList.add('active','pop'); btn.addEventListener('animationend',()=>btn.classList.remove('pop'),{once:true}); showWlToast("Saved! We'll notify you when it's back",''); }
                    else { showWlToast(data.message||'Something went wrong',''); }
                }
            } catch { showWlToast('Network error. Try again.',''); }
            finally { btn.disabled = false; }
        }
        document.addEventListener('DOMContentLoaded', async () => {
            @if (User.Identity.IsAuthenticated)
            {
                        <text>
                        try {
                            const res = await fetch('/api/wishlist/my'); if (!res.ok) return;
                            const items = await res.json();
                            const ids = new Set(items.map(i => i.productId));
                            document.querySelectorAll('.btn-wishlist').forEach(btn => {
                                if (ids.has(parseInt(btn.dataset.productId))) {
                                    btn.dataset.inWishlist='true';
                                    btn.querySelector('i').className='bi bi-heart-fill';
                                    btn.classList.add('active');
                                }
                            });
                        } catch {}
                        </text>
            }
        });

        /* ════════════════════════════════════════════════
           SMART SEARCH
        ════════════════════════════════════════════════ */
        (function () {
            const inp  = document.getElementById('ssInput');
            const dd   = document.getElementById('ssDropdown');
            const clr  = document.getElementById('ssClear');
            const hid  = document.getElementById('ssHidden');
            if (!inp || !dd) return;

            const cur = '@Html.Raw(Model.SearchTerm?.Replace("'", "\'") ?? "")';
            if (cur) { inp.value = cur; clr.classList.add('show'); }

            let timer = null, lastQ = '';

            inp.addEventListener('input', () => {
                const q = inp.value.trim();
                hid.value = q;
                clr.classList.toggle('show', q.length > 0);
                if (!q) { close(); return; }
                if (q === lastQ) return;
                clearTimeout(timer);
                timer = setTimeout(() => search(q), 280);
            });

            clr.addEventListener('click', () => {
                inp.value = ''; hid.value = '';
                clr.classList.remove('show');
                close(); inp.focus();
            });

            document.addEventListener('click', e => {
                if (!document.getElementById('ssWrap')?.contains(e.target)) close();
            });

            inp.addEventListener('keydown', e => {
                if (e.key === 'Escape') { close(); return; }
                if (e.key === 'Enter') {
                    hid.value = inp.value.trim();
                    document.getElementById('searchFilterForm')?.submit();
                }
            });

            async function search(q) {
                if (q === lastQ) return;
                lastQ = q;
                dd.innerHTML = '<div class="ss-loading"><div class="ss-spinner"></div> Đang tìm...</div>';
                open();
                try {
                    const r = await fetch(`/Products?handler=Search&q=${encodeURIComponent(q)}&limit=6`);
                    render(q, await r.json());
                } catch { close(); }
            }

            function render(q, data) {
                const { frames = [], brands = [] } = data;
                if (!frames.length && !brands.length) {
                    dd.innerHTML = `<div class="ss-empty"><i class="bi bi-search"></i>&nbsp;Không có kết quả cho "<strong>${x(q)}</strong>"</div>`;
                    open(); return;
                }
                let h = '';
                if (brands.length) {
                    h += `<div class="ss-group-title"><i class="bi bi-building"></i> Thương hiệu</div>`;
                    brands.forEach(b => {
                        h += `<a class="ss-brand" href="/Products?BrandFilter=${encodeURIComponent(b.brand)}">
                            <div class="ss-brand-icon">${x((b.brand||'?')[0])}</div>
                            <span class="ss-brand-name">${x(b.brand)}</span>
                            <span class="ss-brand-count">${b.count} sản phẩm</span>
                        </a>`;
                    });
                }
                if (frames.length) {
                    h += `<div class="ss-group-title"><i class="bi bi-eyeglasses"></i> Gọng kính</div>`;
                    frames.forEach(f => {
                        const img = f.imageUrl
                            ? `<img src="${x(f.imageUrl)}" alt="${x(f.name)}" loading="lazy">`
                            : `<i class="bi bi-eyeglasses"></i>`;
                        const br = f.brand ? `<span class="ss-frame-brand-tag">${x(f.brand)}</span>` : '';
                        h += `<a class="ss-frame" href="/Products/FrameDetails/${f.productId}">
                            <div class="ss-frame-thumb">${img}</div>
                            <div class="ss-frame-body">
                                <div class="ss-frame-name">${hl(x(f.name), q)}</div>
                                <div class="ss-frame-meta">${br}<span class="ss-frame-sku">${x(f.sku)}</span></div>
                            </div>
                            <span class="ss-frame-price">${x(f.currency)} ${Number(f.price).toLocaleString('vi-VN')}</span>
                        </a>`;
                    });
                }
                h += `<div class="ss-footer">Xem tất cả kết quả cho <a href="/Products?SearchTerm=${encodeURIComponent(q)}">"${x(q)}"</a></div>`;
                dd.innerHTML = h; open();
            }

            function open()  { dd.classList.add('open'); }
            function close() { dd.classList.remove('open'); lastQ = ''; }
            function hl(t, q) {
                if (!q) return t;
                return t.replace(new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi'),
                    '<span class="ss-hl">$1</span>');
            }
            function x(s) {
                return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }
        })();
    </script>
}
