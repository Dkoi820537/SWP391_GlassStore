@page "{id:int}"
@model EyewearStore_SWP391.Pages.Products.LensDetailsModel
@{
    ViewData["Title"] = Model.Lens?.Name ?? "Lens Details";
    Layout = "_Layout";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --teal: #00756A;
            --teal-dk: #005a51;
            --teal-lt: #e8f5f4;
            --red: #e53935;
            --gold: #c9a96e;
            --text: #1a1a1a;
            --sub: #6b7280;
            --border: #e5e7eb;
            --bg: #f9fafb;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
        }

        .bc {
            background: #fff;
            border-bottom: 1px solid var(--border);
            padding: 12px 0;
            font-size: 13px;
        }

            .bc ol {
                display: flex;
                align-items: center;
                list-style: none;
                margin: 0 auto;
                padding: 0 24px;
                max-width: 1280px;
                gap: 5px;
                flex-wrap: wrap;
            }

            .bc a {
                color: var(--sub);
                text-decoration: none;
            }

                .bc a:hover {
                    color: var(--teal);
                }

            .bc .sep {
                color: #ccc;
                font-size: 10px;
            }

            .bc .cur {
                color: var(--text);
                font-weight: 600;
            }

        .fd {
            max-width: 1280px;
            margin: 0 auto;
            padding: 32px 24px 80px;
        }

        .fd-grid {
            display: grid;
            grid-template-columns: 55% 1fr;
            gap: 56px;
            align-items: start;
        }

        /* Gallery */
        .gal {
            position: sticky;
            top: 78px;
        }

        .gal-inner {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .gal-thumbs {
            display: flex;
            flex-direction: column;
            gap: 8px;
            width: 72px;
            flex-shrink: 0;
            max-height: 480px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: #e0e0e0 transparent;
        }

            .gal-thumbs::-webkit-scrollbar {
                width: 4px;
            }

            .gal-thumbs::-webkit-scrollbar-thumb {
                background: #e0e0e0;
                border-radius: 4px;
            }

        .thumb {
            width: 72px;
            height: 72px;
            border-radius: 8px;
            overflow: hidden;
            cursor: pointer;
            border: 2px solid transparent;
            transition: border-color .18s, box-shadow .18s;
            flex-shrink: 0;
            background: #f5f5f5;
        }

            .thumb:hover {
                border-color: var(--teal);
            }

            .thumb.active {
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(0,117,106,.15);
            }

            .thumb img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }

        .gal-main {
            flex: 1;
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            background: #fff;
            border: 1px solid var(--border);
            box-shadow: 0 4px 24px rgba(0,0,0,.06);
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 0;
        }

            .gal-main img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: opacity .22s;
            }

        .gal-ph {
            font-size: 90px;
            color: #ddd;
        }

        .brand-badge {
            position: absolute;
            top: 14px;
            right: 14px;
            background: rgba(255,255,255,.95);
            border: 1px solid rgba(0,0,0,.08);
            border-radius: 8px;
            padding: 6px 18px;
            font-size: 13px;
            font-weight: 800;
            color: var(--teal);
            letter-spacing: 1px;
            text-transform: uppercase;
            backdrop-filter: blur(6px);
            text-decoration: none;
            box-shadow: 0 2px 12px rgba(0,0,0,.12);
            transition: box-shadow .2s, background .2s;
        }

            .brand-badge:hover {
                background: #fff;
                box-shadow: 0 4px 20px rgba(0,0,0,.2);
                color: var(--teal);
            }

        /* Info panel */
        .info {
            padding-top: 2px;
        }

        .brand-link {
            display: inline-block;
            font-size: 13px;
            font-weight: 800;
            color: var(--teal);
            letter-spacing: 1.2px;
            text-transform: uppercase;
            text-decoration: none;
            margin-bottom: 10px;
            border-bottom: 2px solid var(--teal);
            padding-bottom: 1px;
        }

            .brand-link:hover {
                color: var(--teal-dk);
            }

        .prod-name {
            font-size: 26px;
            font-weight: 800;
            color: var(--text);
            margin: 0 0 10px;
            line-height: 1.3;
        }

        .status-row {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--sub);
            margin-bottom: 14px;
            flex-wrap: wrap;
        }

            .status-row strong {
                color: var(--text);
            }

        .sep-dot {
            color: #ccc;
        }

        .badges {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            background: var(--teal-lt);
            color: var(--teal);
        }

        .badge-rx {
            background: #e0f2fe;
            color: #0369a1;
        }

        .badge-material {
            background: #fef3c7;
            color: #92400e;
        }

        .badge-coating {
            background: #f0fdf4;
            color: #166534;
        }

        .badge-uv {
            background: #ede9fe;
            color: #5b21b6;
        }

        .price-row {
            display: flex;
            align-items: baseline;
            gap: 8px;
            margin-bottom: 16px;
        }

        .price-lbl {
            font-size: 14px;
            color: var(--sub);
        }

        .price-val {
            font-size: 36px;
            font-weight: 800;
            color: var(--red);
            line-height: 1;
        }

        .price-cur {
            font-size: 18px;
            font-weight: 700;
            color: var(--red);
        }

        .sold-txt {
            font-size: 13px;
            color: var(--sub);
            margin-left: auto;
        }

            .sold-txt strong {
                color: var(--text);
            }

        .stock-row {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 22px;
            flex-wrap: wrap;
        }

        .stock-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 7px 18px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
        }

            .stock-badge.in {
                background: #e8f5e9;
                color: #2e7d32;
            }

            .stock-badge.low {
                background: #fff8e1;
                color: #f57f17;
            }

            .stock-badge.out {
                background: #ffebee;
                color: #c62828;
            }

        /* Specs table */
        .specs {
            margin-bottom: 20px;
        }

        .spec-row {
            display: flex;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

            .spec-row:last-child {
                border-bottom: none;
            }

        .spec-k {
            width: 160px;
            flex-shrink: 0;
            font-weight: 600;
            color: var(--text);
        }

        .spec-v {
            color: var(--sub);
        }

        /* Coating pills */
        .coating-pills {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .coating-pill {
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            background: #f0fdf4;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .promo {
            background: #fff9f0;
            border: 1px dashed #f59e0b;
            border-radius: 12px;
            padding: 16px 20px;
            margin-bottom: 20px;
        }

        .promo-ttl {
            font-size: 14px;
            font-weight: 700;
            color: #d97706;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .promo ul {
            margin: 0;
            padding: 0 0 0 16px;
            font-size: 13px;
            color: var(--sub);
            line-height: 1.9;
        }

            .promo ul li strong {
                color: var(--text);
            }

        .qty-row {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 16px;
        }

        .qty-lbl {
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
        }

        .qty-ctrl {
            display: flex;
            align-items: center;
            border: 2px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
        }

        .qty-btn {
            width: 44px;
            height: 46px;
            background: #fff;
            border: none;
            font-size: 20px;
            font-weight: 700;
            color: var(--teal);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .15s;
        }

            .qty-btn:hover:not(:disabled) {
                background: var(--teal-lt);
            }

            .qty-btn:disabled {
                opacity: .35;
                cursor: not-allowed;
            }

        .qty-inp {
            width: 56px;
            text-align: center;
            font-size: 16px;
            font-weight: 700;
            border: none;
            border-left: 2px solid var(--border);
            border-right: 2px solid var(--border);
            height: 46px;
            outline: none;
            font-family: inherit;
        }

        .cta-row {
            display: flex;
            gap: 12px;
        }

        .btn-buy {
            flex: 1;
            padding: 16px;
            background: var(--red);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: background .2s, transform .15s;
        }

            .btn-buy:hover:not(:disabled) {
                background: #c62828;
                transform: translateY(-2px);
            }

        .btn-cart {
            flex: 1;
            padding: 16px;
            background: #fff;
            color: var(--teal);
            border: 2px solid var(--teal);
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: background .2s, transform .15s;
        }

            .btn-cart:hover:not(:disabled) {
                background: var(--teal-lt);
                transform: translateY(-2px);
            }

            .btn-buy:disabled, .btn-cart:disabled {
                background: #e5e7eb;
                color: #9ca3af;
                border-color: #e5e7eb;
                cursor: not-allowed;
                transform: none;
            }

        .btn-notify {
            width: 100%;
            padding: 13px;
            margin-top: 10px;
            background: #fff;
            color: var(--sub);
            border: 2px solid var(--border);
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: border-color .2s, color .2s, background .2s;
        }

            .btn-notify:hover {
                border-color: var(--gold);
                color: var(--gold);
            }

            .btn-notify.active {
                border-color: var(--gold);
                color: var(--gold);
                background: #fffbf5;
            }

        .alert {
            display: flex;
            align-items: center;
            gap: 8px;
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 14px;
            font-size: 14px;
        }

            .alert.ok {
                background: #f0fff4;
                border: 1px solid #28a745;
                color: #28a745;
            }

            .alert.err {
                background: #fff5f5;
                border: 1px solid var(--red);
                color: var(--red);
            }

        /* Tabs */
        .tabs-wrap {
            max-width: 1280px;
            margin: 0 auto 64px;
            padding: 0 24px;
        }

        .tabs-hdr {
            display: flex;
            border-bottom: 2px solid var(--border);
        }

        .tab-btn {
            padding: 14px 24px;
            background: transparent;
            border: none;
            font-family: inherit;
            font-size: 14px;
            font-weight: 600;
            color: var(--sub);
            cursor: pointer;
            position: relative;
            transition: color .18s;
        }

            .tab-btn:hover {
                color: var(--teal);
            }

            .tab-btn.on {
                color: var(--teal);
            }

                .tab-btn.on::after {
                    content: '';
                    position: absolute;
                    bottom: -2px;
                    left: 0;
                    right: 0;
                    height: 2px;
                    background: var(--teal);
                }

        .tab-panel {
            display: none;
            background: #fff;
            padding: 28px 32px;
            border-radius: 0 0 14px 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
        }

            .tab-panel.on {
                display: block;
            }

            .tab-panel h3 {
                font-size: 17px;
                font-weight: 700;
                color: var(--teal);
                margin: 0 0 16px;
            }

        .spec-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

            .spec-grid .spec-row:nth-child(odd) {
                padding-right: 24px;
            }

        .care-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .care-list li {
                padding: 11px 0 11px 28px;
                position: relative;
                color: var(--sub);
                border-bottom: 1px solid var(--border);
                font-size: 14px;
            }

                .care-list li:last-child {
                    border-bottom: none;
                }

                .care-list li::before {
                    content: '\F26A';
                    font-family: 'bootstrap-icons';
                    position: absolute;
                    left: 0;
                    color: var(--teal);
                }

        /* Related */
        .related {
            max-width: 1280px;
            margin: 0 auto 64px;
            padding: 0 24px;
        }

            .related h2 {
                text-align: center;
                font-size: 24px;
                font-weight: 800;
                color: var(--text);
                margin: 0 0 28px;
            }

        .rel-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 20px;
        }

        .rel-card {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 2px 10px rgba(0,0,0,.07);
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            display: block;
            transition: transform .2s, box-shadow .2s;
        }

            .rel-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 24px rgba(0,0,0,.13);
            }

        .rel-img {
            aspect-ratio: 1;
            overflow: hidden;
            background: #f5f5f5;
        }

            .rel-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform .35s;
            }

        .rel-card:hover .rel-img img {
            transform: scale(1.06);
        }

        .rel-ph {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 38px;
            color: #ccc;
        }

        .rel-info {
            padding: 14px 16px 16px;
        }

            .rel-info h4 {
                font-size: 13px;
                font-weight: 600;
                margin: 0 0 6px;
                color: var(--text);
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            .rel-info p {
                font-size: 15px;
                font-weight: 800;
                color: var(--red);
                margin: 0;
            }

        /* Sticky */
        .sticky-bar {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #fff;
            box-shadow: 0 -4px 20px rgba(0,0,0,.1);
            padding: 12px 16px;
            z-index: 999;
        }

        .sticky-inner {
            max-width: 1280px;
            margin: 0 auto;
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .sticky-price {
            font-size: 18px;
            font-weight: 800;
            color: var(--red);
            white-space: nowrap;
        }

        .sticky-btn {
            flex: 1;
            background: var(--red);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 13px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
        }

        @@media(max-width:991px) {
            .fd-grid {
                grid-template-columns: 1fr;
                gap: 32px;
            }

            .gal {
                position: static;
            }

            .gal-inner {
                flex-direction: column;
            }

            .gal-thumbs {
                flex-direction: row;
                width: 100%;
                max-height: none;
                overflow-x: auto;
                overflow-y: visible;
            }

            .thumb {
                width: 64px;
                height: 64px;
                flex-shrink: 0;
            }

            .rel-grid {
                grid-template-columns: repeat(2,1fr);
            }

            .sticky-bar {
                display: block;
            }

            .fd {
                padding-bottom: 90px;
            }

            .spec-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media(max-width:576px) {
            .prod-name {
                font-size: 20px;
            }

            .price-val {
                font-size: 28px;
            }

            .rel-grid {
                grid-template-columns: repeat(2,1fr);
                gap: 12px;
            }

            .cta-row {
                flex-direction: column;
            }

            .tab-btn {
                font-size: 13px;
                padding: 12px 14px;
            }
        }
    </style>
}

<!-- Breadcrumb -->
<div class="bc">
    <ol>
        <li><a asp-page="/Index">Home</a></li>
        <li><span class="sep"><i class="bi bi-chevron-right"></i></span></li>
        <li><a asp-page="/Products/Index">Shop</a></li>
        <li><span class="sep"><i class="bi bi-chevron-right"></i></span></li>
        <li><a asp-page="/Products/Index" asp-route-productType="Lenses">Lenses</a></li>
        @if (!string.IsNullOrEmpty(Model.Lens?.Brand))
        {
            <li><span class="sep"><i class="bi bi-chevron-right"></i></span></li>
            <li><a asp-page="/Products/Index" asp-route-BrandFilter="@Model.Lens.Brand">@Model.Lens.Brand</a></li>
        }
        <li><span class="sep"><i class="bi bi-chevron-right"></i></span></li>
        <li><span class="cur">@Model.Lens?.Name</span></li>
    </ol>
</div>

@if (Model.Lens != null)
{
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="fd" style="padding-bottom:0;padding-top:16px;">
            <div class="alert ok"><i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]</div>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="fd" style="padding-bottom:0;padding-top:16px;">
            <div class="alert err"><i class="bi bi-exclamation-circle-fill"></i> @Model.ErrorMessage</div>
        </div>
    }

    <div class="fd">
        <div class="fd-grid">

            <!-- LEFT: Gallery -->
            <div class="gal">
                <div class="gal-inner">
                    @if (Model.Lens.Images.Count > 1)
                    {
                        <div class="gal-thumbs" id="thumbStrip">
                            @foreach (var (img, i) in Model.Lens.Images.Select((x, i) => (x, i)))
                            {
                                <div class="thumb @(img.IsPrimary ? "active" : "")"
                                     onclick="changeImg('@img.ImageUrl', this)"
                                     title="@(img.AltText ?? Model.Lens.Name)">
                                    <img src="@img.ImageUrl" alt="@(img.AltText ?? Model.Lens.Name)" loading="lazy" />
                                </div>
                            }
                        </div>
                    }
                    <div class="gal-main">
                        @if (!string.IsNullOrEmpty(Model.Lens.Brand))
                        {
                            <span class="brand-badge">@Model.Lens.Brand.ToUpper()</span>
                        }
                        @if (!string.IsNullOrEmpty(Model.Lens.PrimaryImageUrl))
                        {
                            <img id="mainImg" src="@Model.Lens.PrimaryImageUrl" alt="@Model.Lens.Name" />
                        }
                        else
                        {
                            <div class="gal-ph"><i class="bi bi-circle-half"></i></div>
                        }
                    </div>
                </div>
            </div>

            <!-- RIGHT: Info -->
            <div class="info">
                @if (!string.IsNullOrEmpty(Model.Lens.Brand))
                {
                    <a class="brand-link" asp-page="/Products/Index" asp-route-BrandFilter="@Model.Lens.Brand">@Model.Lens.Brand.ToUpper()</a>
                }
                <h1 class="prod-name">@Model.Lens.Name</h1>

                <div class="status-row">
                    <span>Status: <strong>@(Model.Lens.IsInStock ? "In Stock" : "Out of Stock")</strong></span>
                    <span class="sep-dot">·</span>
                    <span>SKU: <strong>@Model.Lens.Sku</strong></span>
                    @if (!string.IsNullOrEmpty(Model.Lens.Origin))
                    {
                        <span class="sep-dot">·</span>
                        <span>Origin: <strong>@Model.Lens.Origin</strong></span>
                    }
                </div>

                <!-- Badges row -->
                <div class="badges">
                    @if (Model.Lens.IsPrescription)
                    {
                        <span class="badge badge-rx"><i class="bi bi-file-earmark-medical"></i> Prescription Required</span>
                    }
                    else
                    {
                        <span class="badge"><i class="bi bi-check2-circle"></i> No Rx Needed</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Lens.LensType))
                    {
                        <span class="badge"><i class="bi bi-circle-half"></i> @Model.Lens.LensType</span>
                    }
                    @if (Model.Lens.LensIndex.HasValue)
                    {
                        <span class="badge badge-material"><i class="bi bi-layers"></i> Index @Model.Lens.LensIndex.Value.ToString("F2")</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.Lens.UVProtection) && Model.Lens.UVProtection != "None")
                    {
                        <span class="badge badge-uv"><i class="bi bi-shield-check"></i> @Model.Lens.UVProtection</span>
                    }
                </div>

                <div class="price-row">
                    <span class="price-lbl">Price:</span>
                    <span class="price-cur">@Model.Lens.Currency</span>
                    <span class="price-val">@Model.Lens.Price.ToString("N0")</span>
                    @if (Model.Lens.SoldCount > 0)
                    {
                        <span class="sold-txt"><strong>@Model.Lens.SoldCount</strong> sold</span>
                    }
                </div>

                @if (Model.Lens.IsPrescription && Model.Lens.PrescriptionFee > 0)
                {
                    <p style="font-size:13px;color:var(--sub);margin:-10px 0 16px;">
                        + <strong style="color:var(--text);">@Model.Lens.PrescriptionFee.ToString("N0") @Model.Lens.Currency</strong> prescription processing fee
                    </p>
                }

                @{
                    var sc = Model.Lens.StockStatus == "OutOfStock" ? "out" : Model.Lens.StockStatus == "LowStock" ? "low" : "in";
                    var stockMsg = Model.Lens.StockStatus == "OutOfStock" ? "Out of Stock"
                    : Model.Lens.StockStatus == "LowStock" ? $"Low Stock ({Model.Lens.QuantityOnHand} left)"
                    : $"In Stock ({Model.Lens.QuantityOnHand} available)";
                }
                <div class="stock-row">
                    <div class="stock-badge @sc">
                        @if (sc == "in")
                        {
                            <i class="bi bi-check-circle-fill"></i>
                        }
                        else if (sc == "low")
                        {

                            <i class="bi bi-exclamation-circle-fill"></i>
                        }
                        else
                        {

                            <i class="bi bi-x-circle-fill"></i>
                        }
                        <span>@stockMsg</span>
                    </div>
                </div>

                <!-- Specs -->
                <div class="specs">
                    @if (!string.IsNullOrEmpty(Model.Lens.LensMaterial))
                    {
                        <div class="spec-row"><span class="spec-k">Material</span><span class="spec-v">@Model.Lens.LensMaterial</span></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Lens.LensThickness))
                    {
                        <div class="spec-row"><span class="spec-k">Thickness</span><span class="spec-v">@Model.Lens.LensThickness</span></div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Lens.LensCoating))
                    {
                        <div class="spec-row">
                            <span class="spec-k">Coatings</span>
                            <span class="spec-v">
                                <div class="coating-pills">
                                    @foreach (var coat in Model.Lens.LensCoating.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                    {
                                        <span class="coating-pill">@coat</span>
                                    }
                                </div>
                            </span>
                        </div>
                    }
                </div>

                <div class="promo">
                    <div class="promo-ttl"><i class="bi bi-gift-fill"></i> PROMOTIONS</div>
                    <ul>
                        <li><strong>100% refund</strong> if product is not authentic</li>
                        <li>Free shipping on orders over <strong>500,000 VND</strong></li>
                        <li>Official manufacturer warranty <strong>12 months</strong></li>
                    </ul>
                </div>

                @if (Model.Lens.IsInStock)
                {
                    <form method="post" id="cartForm">
                        <input type="hidden" asp-for="AddToCartInput.ProductId" />
                        <input type="hidden" asp-for="AddToCartInput.PrescriptionId" id="selectedPrescriptionId" />
                        <div class="qty-row">
                            <span class="qty-lbl">Quantity:</span>
                            <div class="qty-ctrl">
                                <button type="button" class="qty-btn" id="qMinus" onclick="chQty(-1)">&#8722;</button>
                                <input type="number" asp-for="AddToCartInput.Quantity" class="qty-inp" id="qInput"
                                       min="1" max="@(Model.Lens.QuantityOnHand ?? 99)" value="1" />
                                <button type="button" class="qty-btn" id="qPlus" onclick="chQty(1)">+</button>
                            </div>
                        </div>
                        <div class="cta-row">
                            <button type="button" id="btnBuyNow" class="btn-buy">
                                <i class="bi bi-lightning-fill"></i> BUY NOW
                            </button>
                            <button type="button" id="btnAddToCart" class="btn-cart">
                                <i class="bi bi-cart-plus"></i> ADD TO CART
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="qty-row">
                        <span class="qty-lbl">Quantity:</span>
                        <div class="qty-ctrl">
                            <button type="button" class="qty-btn" disabled>&#8722;</button>
                            <input type="number" class="qty-inp" value="1" disabled />
                            <button type="button" class="qty-btn" disabled>+</button>
                        </div>
                    </div>
                    <div class="cta-row">
                        <button class="btn-buy" disabled><i class="bi bi-lightning-fill"></i> BUY NOW</button>
                        <button class="btn-cart" disabled><i class="bi bi-cart-plus"></i> ADD TO CART</button>
                    </div>
                    <button type="button" class="btn-notify" id="notifyBtn"
                            data-product-id="@Model.Lens.ProductId" data-in="false">
                        <i class="bi bi-bell" id="notifyIcon"></i>
                        <span id="notifyLabel">Notify When Available</span>
                    </button>
                }

                @if (Model.Lens.IsPrescription)
                {
                    <div class="modal fade" id="prescriptionModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Add prescription to this lens?</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <p class="text-muted small">
                                        Select a saved prescription or skip.
                                        @if (Model.Lens.PrescriptionFee > 0)
                                        {
                                            <text>+@Model.Lens.PrescriptionFee.ToString("N0") VND will be added.</text>
                                        }
                                    </p>
                                    <label class="form-label">Prescription</label>
                                    <select class="form-select" id="rxSelect">
                                        <option value="">No prescription</option>
                                        @foreach (var p in Model.Prescriptions)
                                        {
                                            <option value="@p.PrescriptionId">@(p.ProfileName ?? "Prescription")</option>
                                        }
                                    </select>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="button" class="btn btn-primary" id="rxConfirm">
                                        <i class="bi bi-cart-plus"></i> Add to Cart
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
        </div>
    </div>
</div>

<!-- Tabs -->
<div class="tabs-wrap">
    <div class="tabs-hdr">
        <button class="tab-btn on" onclick="switchTab('desc',this)">Description</button>
        <button class="tab-btn" onclick="switchTab('specs',this)">Specifications</button>
        <button class="tab-btn" onclick="switchTab('care',this)">Care Instructions</button>
    </div>
    <div id="tab-desc" class="tab-panel on">
        <h3>Product Description</h3>
        <p style="color:var(--sub);line-height:1.8;font-size:15px;">
            @(string.IsNullOrEmpty(Model.Lens.Description)
                        ? "Premium quality lens designed for exceptional clarity, comfort and durability."
                        : Model.Lens.Description)
        </p>
    </div>
    <div id="tab-specs" class="tab-panel">
        <h3>Technical Specifications</h3>
        <div class="spec-grid">
            <div class="spec-row"><span class="spec-k">SKU</span><span class="spec-v">@Model.Lens.Sku</span></div>
            @if (!string.IsNullOrEmpty(Model.Lens.Brand))
                {
                    <div class="spec-row"><span class="spec-k">Brand</span><span class="spec-v">@Model.Lens.Brand</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Lens.Origin))
                {
                    <div class="spec-row"><span class="spec-k">Origin</span><span class="spec-v">@Model.Lens.Origin</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Lens.LensType))
                {
                    <div class="spec-row"><span class="spec-k">Lens Type</span><span class="spec-v">@Model.Lens.LensType</span></div>
                }
                @if (Model.Lens.LensIndex.HasValue)
                {
                    <div class="spec-row"><span class="spec-k">Lens Index</span><span class="spec-v">@Model.Lens.LensIndex.Value.ToString("F2")</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Lens.LensMaterial))
                {
                    <div class="spec-row"><span class="spec-k">Material</span><span class="spec-v">@Model.Lens.LensMaterial</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Lens.LensThickness))
                {
                    <div class="spec-row"><span class="spec-k">Thickness</span><span class="spec-v">@Model.Lens.LensThickness</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Lens.LensCoating))
                {
                    <div class="spec-row"><span class="spec-k">Coatings</span><span class="spec-v">@Model.Lens.LensCoating</span></div>
                }
                @if (!string.IsNullOrEmpty(Model.Lens.UVProtection))
                {
                    <div class="spec-row"><span class="spec-k">UV Protection</span><span class="spec-v">@Model.Lens.UVProtection</span></div>
                }
                <div class="spec-row"><span class="spec-k">Prescription</span><span class="spec-v">@(Model.Lens.IsPrescription ? "Required" : "Not Required")</span></div>
            </div>
        </div>
        <div id="tab-care" class="tab-panel">
            <h3>Care &amp; Maintenance</h3>
            <ul class="care-list">
                @foreach (var line in (Model.Lens.CareInstructions ?? "Clean gently with a microfiber cloth. Store in the provided case when not in use. Avoid touching the lens surface with fingers.").Split('.').Where(s => !string.IsNullOrWhiteSpace(s)))
                {
                    <li>@line.Trim().</li>
                }
            </ul>
        </div>
    </div>

    @if (Model.Lens.RelatedProducts.Any())
    {
        <div class="related">
            <h2>You May Also Like</h2>
            <div class="rel-grid">
                @foreach (var r in Model.Lens.RelatedProducts)
                {
                    <a asp-page="/Products/LensDetails" asp-route-id="@r.ProductId" class="rel-card">
                        <div class="rel-img">
                            @if (!string.IsNullOrEmpty(r.PrimaryImageUrl))
                            {
                                <img src="@r.PrimaryImageUrl" alt="@r.Name" />
                            }
                            else
                            {

                                <div class="rel-ph"><i class="bi bi-circle-half"></i></div>
                            }
                        </div>
                        <div class="rel-info">
                            <h4>@r.Name</h4>
                            <p>@r.Currency @r.Price.ToString("N0")</p>
                        </div>
                    </a>
                }
            </div>
        </div>
    }

    <!-- Mobile sticky -->
    <div class="sticky-bar" id="stickyBar">
        <div class="sticky-inner">
            <div class="sticky-price">@Model.Lens.Currency @Model.Lens.Price.ToString("N0")</div>
            @if (Model.Lens.IsInStock)
            {
                <button class="sticky-btn" onclick="triggerAddToCart()"><i class="bi bi-cart-plus"></i> Add to Cart</button>
            }
            else
            {

                <button class="sticky-btn" style="background:#6b7280;" onclick="document.getElementById('notifyBtn')?.click()"><i class="bi bi-bell"></i> Notify Me</button>
            }
        </div>
    </div>
}
else
{
    <div style="text-align:center;padding:80px 24px;">
        <i class="bi bi-exclamation-circle" style="font-size:60px;color:#e53935;"></i>
        <h2 style="margin-top:16px;">Product Not Found</h2>
        <a asp-page="/Products/Index" style="color:#00756A;">&#8592; Back to Shop</a>
    </div>
}

@section Scripts {
    <script>
        // Gallery
        function changeImg(url, el) {
            var img = document.getElementById('mainImg');
            if (img) { img.style.opacity='0'; setTimeout(function(){ img.src=url; img.style.opacity='1'; }, 200); }
            document.querySelectorAll('.thumb').forEach(function(t){ t.classList.remove('active'); });
            if (el) el.classList.add('active');
        }
        // Qty
        function chQty(d) {
            var inp=document.getElementById('qInput'); if(!inp) return;
            var max=parseInt(inp.max)||99;
            var v=Math.max(1, Math.min(max, (parseInt(inp.value)||1)+d));
            inp.value=v;
            document.getElementById('qMinus').disabled=v<=1;
            document.getElementById('qPlus').disabled=v>=max;
        }
        // Tabs
        function switchTab(name, btn) {
            document.querySelectorAll('.tab-panel').forEach(function(p){ p.classList.remove('on'); });
            document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('on'); });
            var panel=document.getElementById('tab-'+name);
            if(panel) panel.classList.add('on');
            btn.classList.add('on');
        }
        // Sticky
        var sb=document.getElementById('stickyBar'), cf=document.getElementById('cartForm');
        if(sb&&cf){ window.addEventListener('scroll', function(){ if(window.innerWidth<=991) sb.style.display=cf.getBoundingClientRect().bottom<0?'block':'none'; }); }

        // Cart / prescription modal
        var prescriptionModal = document.getElementById('prescriptionModal');
        function triggerAddToCart() { doAddToCart(false); }
        function doAddToCart(isBuyNow) {
            var handlerValue = isBuyNow ? 'BuyNow' : 'AddToCart';
            if (prescriptionModal) {
                var modal = new bootstrap.Modal(prescriptionModal);
                document.getElementById('rxConfirm').onclick = function() {
                    var sel = document.getElementById('rxSelect');
                    var hidden = document.getElementById('selectedPrescriptionId');
                    if (hidden) hidden.value = sel ? (sel.value || '') : '';
                    var form = document.getElementById('cartForm');
                    var existing = form.querySelector('input[name="handler"]');
                    if (existing) existing.remove();
                    var inp = document.createElement('input');
                    inp.type='hidden'; inp.name='handler'; inp.value=handlerValue;
                    form.appendChild(inp);
                    form.submit();
                };
                modal.show();
            } else {
                var form = document.getElementById('cartForm');
                var existing = form.querySelector('input[name="handler"]');
                if (existing) existing.remove();
                var inp = document.createElement('input');
                inp.type='hidden'; inp.name='handler'; inp.value=handlerValue;
                form.appendChild(inp);
                form.submit();
            }
        }
        var btnBuyNow = document.getElementById('btnBuyNow');
        var btnAddToCart = document.getElementById('btnAddToCart');
        if (btnBuyNow)    btnBuyNow.addEventListener('click', function(){ doAddToCart(true); });
        if (btnAddToCart) btnAddToCart.addEventListener('click', function(){ doAddToCart(false); });

        document.addEventListener('DOMContentLoaded', function(){
            if(document.getElementById('qInput')) chQty(0);
            initNotifyBtn();
        });

        // Notify / wishlist
        function initNotifyBtn() {
            var btn=document.getElementById('notifyBtn'); if(!btn) return;
            var pid=parseInt(btn.dataset.productId);
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                    <text>
                    fetch('/api/wishlist/my').then(function(r){ if(r.ok) return r.json(); }).then(function(d){
                        if(d&&d.some(function(i){ return i.productId===pid; })) setNotifyState(true);
                    }).catch(function(){});
                    </text>
            }
            btn.addEventListener('click', function(){
                @if (User.Identity == null || !User.Identity.IsAuthenticated)
                {
                        <text>window.location.href='/Account/Login?returnUrl='+encodeURIComponent(window.location.pathname); return;</text>
                }
                var isIn=btn.dataset.in==='true'; btn.disabled=true;
                var url=isIn?'/api/wishlist/remove':'/api/wishlist/add';
                fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({productId:pid})})
                .then(function(r){ return r.json().then(function(d){ return {ok:r.ok,data:d}; }); })
                .then(function(res){
                    if(res.ok){ setNotifyState(!isIn); showToast(isIn?'Removed from wishlist.':'Added! We\'ll notify you when back in stock.'); }
                    else { showToast(res.data.message||'Something went wrong.'); }
                })
                .catch(function(){ showToast('Network error.'); })
                .finally(function(){ btn.disabled=false; });
            });
        }
        function setNotifyState(isIn) {
            var btn=document.getElementById('notifyBtn'), lbl=document.getElementById('notifyLabel'), ico=document.getElementById('notifyIcon');
            if(!btn||!lbl||!ico) return;
            btn.dataset.in=isIn?'true':'false';
            if(isIn){ btn.classList.add('active'); ico.className='bi bi-bell-fill'; lbl.textContent='Added to Wishlist'; }
            else { btn.classList.remove('active'); ico.className='bi bi-bell'; lbl.textContent='Notify When Available'; }
        }
        var _toastTimer;
        function showToast(msg) {
            var t=document.getElementById('_toast');
            if(!t){ t=document.createElement('div'); t.id='_toast'; t.style.cssText='position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(80px);background:#1a1a1a;color:#fff;border-radius:10px;padding:12px 22px;font-size:13px;font-weight:600;box-shadow:0 8px 28px rgba(0,0,0,.25);z-index:9999;transition:transform .3s cubic-bezier(.34,1.56,.64,1);max-width:90vw;text-align:center;'; document.body.appendChild(t); }
            t.textContent=msg; t.style.transform='translateX(-50%) translateY(0)';
            clearTimeout(_toastTimer); _toastTimer=setTimeout(function(){ t.style.transform='translateX(-50%) translateY(80px)'; }, 4000);
        }
    </script>
}
