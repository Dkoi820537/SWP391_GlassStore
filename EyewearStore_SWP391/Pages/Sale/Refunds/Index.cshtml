@page
@model EyewearStore_SWP391.Pages.Sale.Refunds.IndexModel
@{
    ViewData["Title"] = "Refund Requests";
}

<div class="refund-container">

    <!-- Page Header -->
    <div class="page-header">
        <nav class="refund-breadcrumb" aria-label="Breadcrumb">
            <ol>
                <li><a asp-page="/Index">Home</a></li>
                <li class="sep">›</li>
                <li><a asp-page="/Support/Orders/Index">Orders</a></li>
                <li class="sep">›</li>
                <li class="current">Refund Requests</li>
            </ol>
        </nav>

        <div class="header-banner">
            <div class="header-banner-left">
                <div class="header-icon-wrap">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </div>
                <div>
                    <h1 class="page-title">Refund Requests</h1>
                    <p class="page-sub">Review and manage customer refund requests</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-ok" role="alert">
            <i class="bi bi-check-circle"></i>
            <span>@TempData["SuccessMessage"]</span>
            <button class="alert-close" onclick="this.parentElement.remove()">×</button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-err" role="alert">
            <i class="bi bi-exclamation-circle"></i>
            <span>@TempData["ErrorMessage"]</span>
            <button class="alert-close" onclick="this.parentElement.remove()">×</button>
        </div>
    }

    <!-- Stats -->
    <div class="stats-row">
        <div class="stat-item">
            <span class="stat-num">@Model.PendingCount</span>
            <span class="stat-label">Pending</span>
            <span class="stat-dot dot-pending"></span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item stat-item-green">
            <span class="stat-num">@Model.ApprovedCount</span>
            <span class="stat-label">Approved</span>
            <span class="stat-dot dot-approved"></span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-num">@Model.RejectedCount</span>
            <span class="stat-label">Rejected</span>
            <span class="stat-dot dot-rejected"></span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-num">@Model.TotalCount</span>
            <span class="stat-label">Total</span>
            <span class="stat-dot dot-total"></span>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="filter-tabs">
        <a asp-page="/Sale/Refunds/Index" asp-route-filter="Pending"
           class="tab @(Model.CurrentFilter == "Pending" ? "tab-active" : "")">
            Pending
            <span class="tab-badge">@Model.PendingCount</span>
        </a>
        <a asp-page="/Sale/Refunds/Index" asp-route-filter="Approved"
           class="tab @(Model.CurrentFilter == "Approved" ? "tab-active" : "")">
            Approved
            <span class="tab-badge">@Model.ApprovedCount</span>
        </a>
        <a asp-page="/Sale/Refunds/Index" asp-route-filter="Rejected"
           class="tab @(Model.CurrentFilter == "Rejected" ? "tab-active" : "")">
            Rejected
            <span class="tab-badge">@Model.RejectedCount</span>
        </a>
        <a asp-page="/Sale/Refunds/Index" asp-route-filter="All"
           class="tab @(Model.CurrentFilter == "All" ? "tab-active" : "")">
            All
            <span class="tab-badge">@Model.TotalCount</span>
        </a>
    </div>

    <!-- Table Card -->
    <div class="table-card">
        <div class="table-card-header">
            <span class="table-title">@Model.CurrentFilter Requests</span>
            @if (Model.RefundRequests.Any())
            {
                <span class="table-count">@Model.RefundRequests.Count result@(Model.RefundRequests.Count == 1 ? "" : "s")</span>
            }
        </div>

        @if (Model.RefundRequests.Any())
        {
            <div class="table-wrap">
                <table class="refund-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Customer</th>
                            <th>Product</th>
                            <th>Order</th>
                            <th>Amount</th>
                            <th>Reason</th>
                            <th>Requested</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RefundRequests)
                        {
                            <tr>
                                <td>
                                    <span class="id-cell">#@item.ReturnId</span>
                                </td>
                                <td>
                                    <span class="customer-name">@item.CustomerName</span>
                                    <span class="customer-email">@item.CustomerEmail</span>
                                </td>
                                <td>
                                    <span class="product-name">@item.ProductName</span>
                                    <span class="product-qty">Qty: @item.Quantity</span>
                                </td>
                                <td>
                                    <a asp-page="/Support/Orders/Details" asp-route-id="@item.OrderId" class="order-link">
                                        #@item.OrderId
                                    </a>
                                </td>
                                <td>
                                    <span class="amount-cell">@item.RefundAmount.ToString("N0")</span>
                                    <span class="amount-currency">VND</span>
                                </td>
                                <td>
                                    <span class="reason-cell" title="@item.Reason">
                                        @(item.Reason?.Length > 50 ? item.Reason.Substring(0, 50) + "…" : item.Reason)
                                    </span>
                                </td>
                                <td>
                                    <span class="date-cell">@item.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    <span class="date-ago">@(item.DaysAgo == 0 ? "Today" : $"{item.DaysAgo}d ago")</span>
                                </td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="status-badge status-pending">Pending</span>
                                    }
                                    else if (item.Status == "Approved")
                                    {
                                        <span class="status-badge status-approved">Approved</span>
                                        @if (item.RefundResolvedAt.HasValue)
                                        {
                                            <span class="status-date">@item.RefundResolvedAt.Value.ToString("MMM dd")</span>
                                        }
                                    }
                                    else if (item.Status == "Rejected")
                                    {
                                        <span class="status-badge status-rejected">Rejected</span>
                                        @if (item.RefundResolvedAt.HasValue)
                                        {
                                            <span class="status-date">@item.RefundResolvedAt.Value.ToString("MMM dd")</span>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <div class="action-group">
                                            <form method="post" asp-page-handler="Approve" style="display:inline;">
                                                <input type="hidden" name="returnId" value="@item.ReturnId" />
                                                <button type="button" class="btn-action btn-approve"
                                                        onclick="confirmApprove(this.closest('form'), @item.ReturnId, '@item.CustomerName.Replace("'", "\\'")', '@item.RefundAmount.ToString("N0")')">
                                                    Approve
                                                </button>
                                            </form>
                                            <button type="button" class="btn-action btn-reject"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#rejectModal"
                                                    onclick="setRejectId(@item.ReturnId, '@item.CustomerName.Replace("'", "\\'")' )">
                                                Reject
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="action-done">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="bi bi-inbox"></i>
                </div>
                <p class="empty-title">No @Model.CurrentFilter.ToLower() requests</p>
                <p class="empty-sub">There are no refund requests matching this filter.</p>
            </div>
        }
    </div>
</div>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm-custom">
        <div class="modal-content modal-clean">
            <div class="modal-clean-header">
                <h5>Confirm Approval</h5>
                <button type="button" class="modal-close-btn" data-bs-dismiss="modal">×</button>
            </div>
            <div class="modal-clean-body">
                <p class="modal-desc">You are about to approve this refund request. A Stripe refund will be initiated automatically.</p>
                <div class="modal-info-block">
                    <div class="modal-info-row">
                        <span class="modal-info-label">Customer</span>
                        <span class="modal-info-val" id="approveCustomerName"></span>
                    </div>
                    <div class="modal-info-row">
                        <span class="modal-info-label">Refund Amount</span>
                        <span class="modal-info-val modal-amount"><span id="approveAmount"></span> VND</span>
                    </div>
                </div>
            </div>
            <div class="modal-clean-footer">
                <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn-modal-confirm btn-modal-approve" id="confirmApproveBtn">
                    Approve Refund
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm-custom">
        <div class="modal-content modal-clean">
            <div class="modal-clean-header">
                <h5>Reject Request — <span id="rejectCustomerName" style="font-weight:400;color:#6b7280;"></span></h5>
                <button type="button" class="modal-close-btn" data-bs-dismiss="modal">×</button>
            </div>
            <form method="post" asp-page-handler="Reject">
                <input type="hidden" name="returnId" id="rejectReturnId" />
                <div class="modal-clean-body">
                    <p class="modal-desc">The customer will be notified via email about this decision.</p>
                    <div class="form-field">
                        <label class="field-label">Reason for rejection <span style="font-weight:400;color:#9ca3af;">(optional)</span></label>
                        <textarea name="rejectionReason" class="field-textarea" rows="3"
                                  placeholder="Explain why this refund is being rejected..."></textarea>
                    </div>
                </div>
                <div class="modal-clean-footer">
                    <button type="button" class="btn-modal-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-modal-confirm btn-modal-reject">Reject Refund</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* ── Base ── */
    .refund-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 32px 24px 60px;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    /* ── Breadcrumb ── */
    .refund-breadcrumb ol {
        display: flex;
        align-items: center;
        gap: 6px;
        list-style: none;
        padding: 0;
        margin: 0 0 16px;
        font-size: 13px;
    }

    .refund-breadcrumb a {
        color: #00756A;
        text-decoration: none;
    }

        .refund-breadcrumb a:hover {
            text-decoration: underline;
        }

    .refund-breadcrumb .sep {
        color: #d1d5db;
    }

    .refund-breadcrumb .current {
        color: #6b7280;
    }

    /* ── Header Banner ── */
    .page-header {
        margin-bottom: 24px;
    }

    .header-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg, #00756A 0%, #009688 100%);
        border-radius: 12px;
        padding: 24px 28px;
        position: relative;
        overflow: hidden;
    }

        .header-banner::after {
            content: '';
            position: absolute;
            right: -20px;
            top: -20px;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: rgba(255,255,255,0.06);
        }

        .header-banner::before {
            content: '';
            position: absolute;
            right: 60px;
            bottom: -30px;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
        }

    .header-banner-left {
        display: flex;
        align-items: center;
        gap: 16px;
        position: relative;
        z-index: 1;
    }

    .header-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(255,255,255,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #fff;
        flex-shrink: 0;
    }

    .page-title {
        font-size: 22px;
        font-weight: 700;
        color: #fff;
        margin: 0 0 3px;
        letter-spacing: -0.2px;
    }

    .page-sub {
        font-size: 13.5px;
        color: rgba(255,255,255,0.75);
        margin: 0;
    }

    /* ── Alerts ── */
    .alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        border-radius: 8px;
        font-size: 14px;
        margin-bottom: 20px;
        border: 1px solid transparent;
    }

        .alert span {
            flex: 1;
        }

    .alert-ok {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #15803d;
    }

    .alert-err {
        background: #fef2f2;
        border-color: #fecaca;
        color: #dc2626;
    }

    .alert-close {
        background: none;
        border: none;
        font-size: 18px;
        cursor: pointer;
        color: inherit;
        opacity: 0.6;
        line-height: 1;
        padding: 0;
    }

        .alert-close:hover {
            opacity: 1;
        }

    /* ── Stats Row ── */
    .stats-row {
        display: flex;
        align-items: center;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 18px 28px;
        margin-bottom: 24px;
        gap: 0;
        border-top: 3px solid #00756A;
    }

    .stat-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        position: relative;
    }

    .stat-item-green .stat-num {
        color: #00756A;
    }

    .stat-num {
        font-size: 28px;
        font-weight: 700;
        color: #111827;
        letter-spacing: -0.5px;
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        font-weight: 500;
    }

    .stat-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        margin-top: 2px;
    }

    .dot-pending {
        background: #f59e0b;
    }

    .dot-approved {
        background: #00756A;
    }

    .dot-rejected {
        background: #ef4444;
    }

    .dot-total {
        background: #9ca3af;
    }

    .stat-divider {
        width: 1px;
        height: 40px;
        background: #e5e7eb;
        flex-shrink: 0;
    }

    /* ── Filter Tabs ── */
    .filter-tabs {
        display: flex;
        gap: 2px;
        border-bottom: 2px solid #e5e7eb;
        margin-bottom: 20px;
    }

    .tab {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 18px;
        font-size: 14px;
        font-weight: 500;
        color: #6b7280;
        text-decoration: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: color .2s, border-color .2s;
        white-space: nowrap;
    }

        .tab:hover {
            color: #111827;
        }

    .tab-active {
        color: #00756A;
        border-bottom-color: #00756A;
        font-weight: 600;
    }

    .tab-badge {
        background: #f3f4f6;
        color: #374151;
        font-size: 11px;
        font-weight: 600;
        padding: 2px 7px;
        border-radius: 10px;
        min-width: 22px;
        text-align: center;
    }

    .tab-active .tab-badge {
        background: #e6f4f2;
        color: #00756A;
    }

    /* ── Table Card ── */
    .table-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
    }

    .table-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        background: #00756A;
    }

    .table-title {
        font-size: 13.5px;
        font-weight: 600;
        color: #fff;
    }

    .table-count {
        font-size: 12.5px;
        color: rgba(255,255,255,0.65);
    }

    /* ── Table ── */
    .table-wrap {
        overflow-x: auto;
    }

    .refund-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13.5px;
    }

        .refund-table thead tr {
            background: #f0fdf9;
        }

        .refund-table th {
            padding: 11px 16px;
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #00756A;
            white-space: nowrap;
            border-bottom: 1px solid #d1fae5;
        }

        .refund-table td {
            padding: 14px 16px;
            vertical-align: middle;
            border-bottom: 1px solid #f3f4f6;
        }

        .refund-table tbody tr:last-child td {
            border-bottom: none;
        }

        .refund-table tbody tr:hover {
            background: #f9fffe;
        }

    /* ── Cell Styles ── */
    .id-cell {
        font-weight: 600;
        color: #374151;
        font-variant-numeric: tabular-nums;
    }

    .customer-name {
        display: block;
        font-weight: 600;
        color: #111827;
        margin-bottom: 2px;
    }

    .customer-email {
        display: block;
        font-size: 12px;
        color: #9ca3af;
    }

    .product-name {
        display: block;
        font-weight: 500;
        color: #374151;
        margin-bottom: 2px;
    }

    .product-qty {
        display: block;
        font-size: 12px;
        color: #9ca3af;
    }

    .order-link {
        color: #00756A;
        font-weight: 600;
        text-decoration: none;
        font-size: 13px;
    }

        .order-link:hover {
            text-decoration: underline;
        }

    .amount-cell {
        font-weight: 700;
        color: #00756A;
        font-variant-numeric: tabular-nums;
    }

    .amount-currency {
        font-size: 11px;
        color: #9ca3af;
        margin-left: 3px;
    }

    .reason-cell {
        color: #4b5563;
        max-width: 180px;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .date-cell {
        display: block;
        color: #374151;
        margin-bottom: 2px;
    }

    .date-ago {
        display: block;
        font-size: 12px;
        color: #9ca3af;
    }

    /* ── Status Badges ── */
    .status-badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 600;
        letter-spacing: 0.2px;
    }

    .status-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-approved {
        background: #d1fae5;
        color: #065f46;
    }

    .status-rejected {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-date {
        display: block;
        font-size: 11px;
        color: #9ca3af;
        margin-top: 3px;
    }

    /* ── Action Buttons ── */
    .action-group {
        display: flex;
        gap: 6px;
    }

    .btn-action {
        padding: 6px 14px;
        border-radius: 6px;
        font-size: 12.5px;
        font-weight: 600;
        border: 1.5px solid transparent;
        cursor: pointer;
        transition: all .15s ease;
        white-space: nowrap;
    }

    .btn-approve {
        background: #00756A;
        color: #fff;
        border-color: #00756A;
    }

        .btn-approve:hover {
            background: #005a51;
            border-color: #005a51;
        }

    .btn-reject {
        background: #fff;
        color: #374151;
        border-color: #d1d5db;
    }

        .btn-reject:hover {
            border-color: #9ca3af;
            color: #111827;
        }

    .action-done {
        color: #d1d5db;
        font-size: 14px;
    }

    /* ── Empty State ── */
    .empty-state {
        padding: 60px 24px;
        text-align: center;
    }

    .empty-icon {
        font-size: 40px;
        color: #e5e7eb;
        margin-bottom: 14px;
    }

    .empty-title {
        font-size: 15px;
        font-weight: 600;
        color: #374151;
        margin: 0 0 6px;
    }

    .empty-sub {
        font-size: 13px;
        color: #9ca3af;
        margin: 0;
    }

    /* ── Modals ── */
    .modal-sm-custom {
        max-width: 420px;
    }

    .modal-clean {
        border: none;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,.15);
    }

    .modal-clean-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 22px 14px;
        border-bottom: 1px solid #f3f4f6;
    }

        .modal-clean-header h5 {
            font-size: 15px;
            font-weight: 700;
            color: #111827;
            margin: 0;
        }

    .modal-close-btn {
        background: none;
        border: none;
        font-size: 20px;
        color: #9ca3af;
        cursor: pointer;
        line-height: 1;
        padding: 0;
    }

        .modal-close-btn:hover {
            color: #374151;
        }

    .modal-clean-body {
        padding: 20px 22px;
    }

    .modal-desc {
        font-size: 13.5px;
        color: #6b7280;
        margin: 0 0 16px;
        line-height: 1.6;
    }

    .modal-info-block {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .modal-info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px;
        font-size: 13.5px;
    }

        .modal-info-row + .modal-info-row {
            border-top: 1px solid #e5e7eb;
        }

    .modal-info-label {
        color: #6b7280;
        font-weight: 500;
    }

    .modal-info-val {
        color: #111827;
        font-weight: 600;
    }

    .modal-amount {
