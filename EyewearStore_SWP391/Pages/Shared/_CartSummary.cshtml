@using System.Security.Claims
@inject EyewearStore_SWP391.Services.ICartService CartService

@{
    int itemCount = 0;
    decimal subtotal = 0m;

    if (User?.Identity?.IsAuthenticated ?? false)
    {
        var uidStr = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(uidStr, out var uid))
        {
            try
            {
                var (count, sub) = await CartService.GetCartSummaryAsync(uid);
                itemCount = count;
                subtotal = sub;
            }
            catch { /* degrade gracefully — badge shows 0 */ }
        }
    }
}

<li class="nav-item dropdown ms-3">
    <a class="nav-link d-flex align-items-center position-relative" href="#" id="cartDropdown" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" aria-label="Cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25" class="me-1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12l-1 12H7L6 7z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 7V6a3 3 0 116 0v1" />
        </svg>
        <span class="cart-badge badge bg-danger position-absolute">@itemCount</span>
    </a>

    <ul class="dropdown-menu dropdown-menu-end p-3 shadow" aria-labelledby="cartDropdown" style="min-width:320px; max-width:420px;">
        <li>
            <div class="d-flex justify-content-between align-items-center mb-2">
                <strong>Cart</strong>
                <div class="d-flex align-items-center gap-2">
                    @if (itemCount > 0)
                    {
                        <button type="button"
                                class="btn-cart-clear btn btn-sm btn-outline-danger py-0 px-2"
                                style="font-size:11px; border-radius:4px;"
                                aria-label="Clear all items from cart">
                            Clear All
                        </button>
                    }
                    <small class="text-muted cart-item-count-label">@itemCount item(s)</small>
                </div>
            </div>
        </li>

        @if (itemCount == 0)
        {
            <li class="py-3 text-center text-muted">
                <div>Your cart is empty</div>
                <div class="small">Add products to get started</div>
            </li>
        }
        else
        {
            <li>
                <div id="cart-dropdown-items" style="max-height:300px; overflow-y:auto; overflow-x:visible; padding-right:4px;">
                    <div class="text-center py-3 text-muted" id="cart-dropdown-loading">
                        <div class="spinner-border spinner-border-sm me-1" role="status"></div>
                        Loading items...
                    </div>
                </div>
            </li>

            <li><hr class="dropdown-divider" /></li>
            <li class="d-flex justify-content-between align-items-center mb-2">
                <div><small class="text-muted">Total</small></div>
                <div class="fw-bold">@subtotal.ToString("N0") VND</div>
            </li>

            <li class="d-flex gap-2">
                <a class="btn btn-sm flex-grow-1"
                   asp-page="/Cart/Index"
                   style="background:#1a2332; color:#fff; border:1px solid #1a2332;">View Cart</a>
                <a class="btn btn-sm flex-grow-1"
                   asp-page="/Checkout/Index"
                   style="background:#c9a96e; color:#fff; border:1px solid #c9a96e;">Checkout</a>
            </li>
        }
    </ul>
</li>

@if (itemCount > 0)
{
<script>
(function() {
    var loaded = false;
    var dropdown = document.getElementById('cartDropdown');
    if (!dropdown) return;

    dropdown.addEventListener('show.bs.dropdown', function() {
        if (loaded) return;
        loaded = true;
        fetch('/api/cart/dropdown-items', { credentials: 'same-origin' })
            .then(function(r) { return r.ok ? r.text() : ''; })
            .then(function(html) {
                var container = document.getElementById('cart-dropdown-items');
                if (container) container.innerHTML = html || '<div class="text-center py-2 text-muted small">Could not load items</div>';
            })
            .catch(function() {
                var container = document.getElementById('cart-dropdown-items');
                if (container) container.innerHTML = '<div class="text-center py-2 text-muted small">Could not load items</div>';
            });
    });
})();
</script>
}
