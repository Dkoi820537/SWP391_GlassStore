    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/shop-cart.js" asp-append-version="true"></script>
    <script src="~/js/recently-viewed.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity.IsAuthenticated)
    {
        <script>
            (async () => {
                try {
                    const res = await fetch('/api/wishlist/my');
                    if (!res.ok) return;
                    const items = await res.json();
                    const count = items.length;
                    if (count === 0) return;
                    const navBadge = document.getElementById('navWlCount');
                    if (navBadge) { navBadge.textContent = count > 99 ? '99+' : count; navBadge.style.display = 'flex'; }
                    const dropBadge = document.getElementById('dropdownWlCount');
                    if (dropBadge) { dropBadge.textContent = count > 99 ? '99+' : count; dropBadge.style.display = 'inline-flex'; }
                    const heartIcon = document.querySelector('.nav-wishlist-btn i');
                    if (heartIcon) heartIcon.className = 'bi bi-heart-fill';
                } catch { }
            })();
        </script>
    }

    <script>
        (function () {
            const input = document.getElementById('navSearchInput');
            const filter = document.getElementById('navSearchFilter');
            const btn = document.getElementById('navSearchBtn');
            const sugg = document.getElementById('navSearchSuggestions');
            const empty = document.getElementById('navSearchEmpty');
            if (!input || !btn || !sugg) return;

            function doSearch() {
                const q = input.value.trim();
                const type = filter.value;
                const params = new URLSearchParams();
                if (type) params.set('ProductTypeFilter', type);
                if (q) params.set('SearchTerm', q);
                window.location.href = '/Products?' + params.toString();
            }

            function openSugg() { sugg.classList.add('show'); filterSugg(); }
            function closeSugg() { setTimeout(() => sugg.classList.remove('show'), 160); }

            function filterSugg() {
                const q = input.value.toLowerCase().trim();
                const type = filter.value;
                const items = sugg.querySelectorAll('.nss-item');
                const labels = sugg.querySelectorAll('.nss-label');
                let anyVisible = false;

                items.forEach(el => {
                    const matchType = !type || el.dataset.type === type;
                    const matchText = !q || el.dataset.q.toLowerCase().includes(q)
                        || el.querySelector('span:first-of-type').textContent.toLowerCase().includes(q);
                    el.style.display = (matchType && matchText) ? 'flex' : 'none';
                    if (matchType && matchText) anyVisible = true;
                });

                labels.forEach(lbl => {
                    const group = lbl.dataset.group;
                    const visible = [...items].some(el =>
                        el.dataset.type === group && el.style.display !== 'none');
                    lbl.style.display = visible ? 'block' : 'none';
                });

                empty.style.display = anyVisible ? 'none' : 'block';
            }

            input.addEventListener('focus', openSugg);
            input.addEventListener('blur', closeSugg);
            input.addEventListener('input', filterSugg);
            filter.addEventListener('change', filterSugg);
            btn.addEventListener('click', doSearch);
            input.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); });

            const urlParams = new URLSearchParams(window.location.search);
            const st = urlParams.get('SearchTerm');
            const pt = urlParams.get('ProductTypeFilter');
            if (st) input.value = st;
            if (pt) filter.value = pt;
        })();
    </script>
</body>
</html>