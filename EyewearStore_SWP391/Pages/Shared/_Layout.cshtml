                                                <svg class="icon-svg-md text-dark-gray" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                            </div>
                                            <span>My Orders</span>
                                        </a>

                                        <a class="profile-nav-link" asp-page="/Customer/ServiceTracking">
                                            <div class="profile-nav-icon">
                                                <svg class="icon-svg-md text-dark-gray" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" stroke-linecap="round" stroke-linejoin="round"></path><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                            </div>
                                            <span class="d-flex align-items-center justify-content-between w-100">My Service Orders</span>
                                        </a>

                                        <a class="profile-nav-link" asp-page="/Customer/Wishlist">
                                            <div class="profile-nav-icon">
                                                <svg class="icon-svg-md text-dark-gray" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path></svg>
                                            </div>
                                            <span>My Wishlist</span>
                                            <span class="wl-badge-new" id="dropdownWlCount" style="display:none; margin-left: auto;"></span>
                                        </a>

                                        <a class="profile-nav-link" asp-page="/Customer/Prescriptions/Index">
                                            <div class="profile-nav-icon">
                                                <svg class="icon-svg-md text-dark-gray" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-linecap="round" stroke-linejoin="round"></path><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                            </div>
                                            <span>My Prescriptions</span>
                                        </a>

                                        <a class="profile-nav-link" asp-page="/Customer/MyRefunds">
                                            <div class="profile-nav-icon">
                                                <svg class="icon-svg-md text-dark-gray" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 10h10a5 5 0 010 10H9M3 10l4-4M3 10l4 4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                            </div>
                                            <span>My Refunds</span>
                                        </a>
                                    </nav>

                                    <hr class="border-gray-300 my-4" />

                                    <form method="post" asp-page="/Account/Logout" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="profile-nav-link text-uppercase mt-2 flex items-center">
                                            <div class="profile-nav-icon">
                                                <svg class="icon-svg-md text-dark-gray" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                                            </div>
                                            <span class="fw-bold">Logout</span>
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="stitch-auth-group">
                            <a class="stitch-btn-login" asp-page="/Account/Login">Login</a>
                            <a class="stitch-btn-register" asp-page="/Account/Register">Register</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="footer-optiplus" id="footer">
