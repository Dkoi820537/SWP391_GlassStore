                            </button>
                            <ul class="dropdown-menu dropdown-menu-end user-menu" aria-labelledby="userDropdown">
                                <li class="profile-topbar">
                                    <div class="profile-avatar-small">
                                        <svg class="icon-svg-small" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path clip-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" fill-rule="evenodd"></path></svg>
                                    </div>
                                    <span class="text-white fw-bold fs-5">@User.Identity.Name</span>
