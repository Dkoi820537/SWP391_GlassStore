@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OptiPlus Eyewear</title>
    <meta name="description" content="Premium eyewear store offering quality glasses, frames, and lenses. Find your perfect style." />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/homepage.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EyewearStore_SWP391.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        /* ── Wishlist nav icon ── */
        .nav-wishlist-btn {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            color: inherit;
            text-decoration: none;
            transition: background .2s, color .2s, transform .2s;
        }

            .nav-wishlist-btn:hover {
                background: rgba(201,169,110,0.12);
                color: #c9a96e;
                transform: scale(1.08);
            }

            .nav-wishlist-btn i {
                font-size: 18px;
            }

            .nav-wishlist-btn .wl-count {
                position: absolute;
                top: 2px;
                right: 2px;
                min-width: 16px;
                height: 16px;
                background: #c9a96e;
                color: #fff;
                font-size: 10px;
                font-weight: 700;
                border-radius: 100px;
                display: none;
                align-items: center;
                justify-content: center;
                padding: 0 3px;
                line-height: 1;
            }

        /* ── Shop dropdown ── */
        .shop-dropdown-menu {
            min-width: 250px;
            padding: 8px;
            border-radius: 12px;
            border: none;
            background: #2d6e6e;
            box-shadow: 0 8px 28px rgba(0,0,0,0.25);
            margin-top: 8px !important;
        }

        .shop-drop-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 14px;
            border-radius: 8px;
            text-decoration: none;
            color: rgba(255,255,255,0.92);
            transition: background .15s, color .15s;
            cursor: pointer;
        }

            .shop-drop-item:hover {
                background: rgba(255,255,255,0.12);
                color: #fff;
            }

        .shop-drop-icon {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

            .shop-drop-icon.frames,
            .shop-drop-icon.lenses,
            .shop-drop-icon.rx {
                background: rgba(255,255,255,0.13);
                color: #fff;
            }

        .shop-drop-text {
            line-height: 1.2;
        }

        .shop-drop-name {
            font-size: 13px;
            font-weight: 700;
            color: #fff;
        }

        .shop-drop-desc {
            font-size: 11px;
            color: rgba(255,255,255,0.55);
            margin-top: 1px;
        }

        .shop-drop-divider {
            height: 1px;
            background: rgba(255,255,255,0.15);
            margin: 6px 0;
        }

        .shop-chevron {
            font-size: 10px;
            margin-left: 2px;
            transition: transform .2s;
        }

        .nav-item.dropdown.show .shop-chevron {
            transform: rotate(180deg);
        }

        /* ── User dropdown ── */
        .user-menu .dropdown-item {
            border-radius: 8px;
            margin: 2px 0;
            padding: .7rem 1rem !important;
            transition: background .15s;
        }

        /* ── My Service Orders item — special gradient ── */
        .dropdown-item-service {
            background: linear-gradient(135deg, rgba(124,58,237,.06) 0%, rgba(79,70,229,.06) 100%);
            border: 1px solid rgba(124,58,237,.12);
            border-radius: 10px !important;
            margin: 4px 0 !important;
        }

            .dropdown-item-service:hover {
                background: linear-gradient(135deg, rgba(124,58,237,.14) 0%, rgba(79,70,229,.14) 100%) !important;
                border-color: rgba(124,58,237,.25);
            }

            .dropdown-item-service .svc-icon-wrap {
                width: 28px;
                height: 28px;
                background: linear-gradient(135deg, #7c3aed, #4f46e5);
                border-radius: 7px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 13px;
                flex-shrink: 0;
            }

            .dropdown-item-service .svc-label {
                font-weight: 700;
                color: #5b21b6;
            }

            .dropdown-item-service .svc-sub {
                font-size: 10px;
                color: #8b5cf6;
                display: block;
                margin-top: 1px;
            }

        /* ── Wishlist item ── */
        .dropdown-item-wishlist {
            padding: 0.75rem 1rem;
            background: linear-gradient(135deg, rgba(201,169,110,0.06) 0%, rgba(232,208,176,0.06) 100%);
        }

            .dropdown-item-wishlist:hover {
                background: linear-gradient(135deg, rgba(201,169,110,0.15) 0%, rgba(232,208,176,0.15) 100%);
            }

            .dropdown-item-wishlist .wl-label {
                font-weight: 600;
                color: #9a7840;
            }

            .dropdown-item-wishlist .wl-badge {
                font-size: 10px;
                padding: 2px 7px;
                border-radius: 100px;
                background: linear-gradient(135deg, #c9a96e 0%, #e8d5b0 100%);
                color: #fff;
                font-weight: 700;
                margin-left: auto;
                display: none;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-optiplus">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">
                    <i class="bi bi-eyeglasses me-2"></i>OptiPlus
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0 align-items-center">

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">
                                <i class="bi bi-house-door me-1"></i>Home
                            </a>
                        </li>

                        <!-- ══ SHOP DROPDOWN ══ -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#"
                               id="shopDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-shop me-1"></i>Shop
                                <i class="bi bi-chevron-down shop-chevron"></i>
                            </a>
                            <ul class="dropdown-menu shop-dropdown-menu p-2" aria-labelledby="shopDropdown">
                                <li>
                                    <a class="shop-drop-item" href="/Products?ProductTypeFilter=Frame">
                                        <div class="shop-drop-icon frames"><i class="bi bi-eyeglasses"></i></div>
                                        <div class="shop-drop-text">
                                            <div class="shop-drop-name">Frames</div>
                                            <div class="shop-drop-desc">Browse all eyeglass frames</div>
                                        </div>
                                    </a>
                                </li>
                                <li><div class="shop-drop-divider"></div></li>
                                <li>
                                    <a class="shop-drop-item" href="/Products?ProductTypeFilter=Lens">
                                        <div class="shop-drop-icon lenses"><i class="bi bi-circle"></i></div>
                                        <div class="shop-drop-text">
                                            <div class="shop-drop-name">Lenses</div>
                                            <div class="shop-drop-desc">Prescription & specialty lenses</div>
                                        </div>
                                    </a>
                                </li>
                                @if (User.Identity.IsAuthenticated)
                                {
                                    <li><div class="shop-drop-divider"></div></li>
                                    <li>
                                        <a class="shop-drop-item" asp-page="/Customer/Prescriptions/Index">
                                            <div class="shop-drop-icon rx"><i class="bi bi-clipboard2-pulse"></i></div>
                                            <div class="shop-drop-text">
                                                <div class="shop-drop-name">Prescription Profile</div>
                                                <div class="shop-drop-desc">View & manage your prescriptions</div>
                                            </div>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>

                        <!-- ══ SERVICES DROPDOWN ══ -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#"
                               id="servicesDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-gear me-1"></i>Services
                                <i class="bi bi-chevron-down shop-chevron"></i>
                            </a>
                            <ul class="dropdown-menu shop-dropdown-menu p-2" aria-labelledby="servicesDropdown">
                                <li>
                                    <a class="shop-drop-item" asp-page="/Customer/Services/CustomGlasses">
                                        <div class="shop-drop-icon frames"><i class="bi bi-eyeglasses"></i></div>
                                        <div class="shop-drop-text">
                                            <div class="shop-drop-name">Custom Glasses</div>
                                            <div class="shop-drop-desc">Frame + Lens, fitted your way</div>
                                        </div>
                                    </a>
                                </li>
                                <li><div class="shop-drop-divider"></div></li>
                                <li>
                                    <a class="shop-drop-item" asp-page="/Customer/Services/FrameRepair">
                                        <div class="shop-drop-icon lenses"><i class="bi bi-tools"></i></div>
                                        <div class="shop-drop-text">
                                            <div class="shop-drop-name">Frame Repair</div>
                                            <div class="shop-drop-desc">Fix bent frames &amp; loose hinges</div>
                                        </div>
                                    </a>
                                </li>
                                <li><div class="shop-drop-divider"></div></li>
                                <li>
                                    <a class="shop-drop-item" asp-page="/Customer/Services/LensReplacement">
                                        <div class="shop-drop-icon rx"><i class="bi bi-arrow-repeat"></i></div>
                                        <div class="shop-drop-text">
                                            <div class="shop-drop-name">Lens Replacement</div>
                                            <div class="shop-drop-desc">New lenses into your existing frame</div>
                                        </div>
                                    </a>
                                </li>
                                <li><div class="shop-drop-divider"></div></li>
                                <li>
                                    <a class="shop-drop-item" asp-page="/Customer/Services/EyeExam">
                                        <div class="shop-drop-icon frames"><i class="bi bi-eye"></i></div>
                                        <div class="shop-drop-text">
                                            <div class="shop-drop-name">Eye Exam</div>
                                            <div class="shop-drop-desc">Book a professional exam &amp; prescription</div>
                                        </div>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#footer">
                                <i class="bi bi-envelope me-1"></i>Contact
                            </a>
                        </li>

                        @* ADMIN DROPDOWN *@
                        @if (User.IsInRole("admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-danger fw-semibold" href="#"
                                   id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock me-1"></i>Admin
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="adminDropdown">
                                    <li><a class="dropdown-item" asp-page="/Admin/Index"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li class="dropdown-header text-muted small">Products</li>
                                    <li><a class="dropdown-item" asp-page="/Lenses/Index"><i class="bi bi-eye me-2"></i>Lens Management</a></li>
                                    <li><a class="dropdown-item" asp-page="/Frames/Index"><i class="bi bi-eyeglasses me-2"></i>Frame Management</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-page="/Sale/Orders/Index"><i class="bi bi-cart-check me-2"></i>Order Management</a></li>
                                    <li><a class="dropdown-item" asp-page="/Sale/Refunds/Index"><i class="bi bi-arrow-return-left me-2"></i>Refund Requests</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-page="/Support/Orders/Index"><i class="bi bi-people me-2"></i>Sale Staff</a></li>
                                    <li><a class="dropdown-item" asp-page="/Staff/Orders/Index"><i class="bi bi-people-fill me-2"></i>Staff</a></li>
                                    <li><a class="dropdown-item" asp-page="/Manager/Index"><i class="bi bi-person-badge me-2"></i>Managers</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Users/Index"><i class="bi bi-people me-2"></i>User Management</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/AdminRole"><i class="bi bi-key me-2"></i>Admin Roles</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-1">
                                <a class="nav-wishlist-btn nav-link" asp-page="/Customer/Wishlist" title="My Wishlist">
                                    <i class="bi bi-heart"></i>
                                    <span class="wl-count" id="navWlCount"></span>
                                </a>
                            </li>
                        }

                        @await Html.PartialAsync("_CartSummary")

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#"
                                   id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="me-2 avatar-inline" aria-hidden="true">
                                        <i class="bi bi-person-circle fs-4"></i>
                                    </span>
                                    <span class="user-name">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end user-menu shadow" aria-labelledby="userDropdown" style="min-width:300px;padding:8px">

                                    <!-- User info header -->
                                    <li class="px-3 py-2">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3"
                                                 style="width:50px;height:50px">
                                                <i class="bi bi-person-circle fs-3"></i>
                                            </div>
                                            <div class="user-meta">
                                                <div class="fw-bold user-fullname">@User.Identity.Name</div>
                                                <div class="text-muted small">
                                                    Role: <span class="badge bg-secondary">@User.FindFirst(ClaimTypes.Role)?.Value</span>
                                                </div>
                                            </div>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>

                                    <!-- Profile -->
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center" asp-page="/Profile/Index">
                                            <i class="bi bi-person-lines-fill me-2 text-primary"></i>
                                            <span>My Profile</span>
                                        </a>
                                    </li>

                                    <!-- My Orders -->
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center" asp-page="/Customer/MyOrders">
                                            <i class="bi bi-box-seam me-2 text-success"></i>
                                            <span>My Orders</span>
                                        </a>
                                    </li>

                                    <!-- ── MY SERVICE ORDERS ── -->
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center dropdown-item-service"
                                           asp-page="/Customer/ServiceTracking">
                                            <span class="svc-icon-wrap me-2"><i class="bi bi-nut"></i></span>
                                            <span>
                                                <span class="svc-label">My Service Orders</span>
                                                <span class="svc-sub">Track eyewear fitting &amp; repairs</span>
                                            </span>
                                            <i class="bi bi-chevron-right ms-auto" style="font-size:10px;color:#8b5cf6;opacity:.7"></i>
                                        </a>
                                    </li>

                                    <!-- Wishlist -->
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center dropdown-item-wishlist" asp-page="/Customer/Wishlist">
                                            <i class="bi bi-heart-fill me-2" style="color:#c9a96e"></i>
                                            <span class="wl-label">My Wishlist</span>
                                            <span class="wl-badge" id="dropdownWlCount"></span>
                                        </a>
                                    </li>

                                    <!-- Prescriptions -->
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center" asp-page="/Customer/Prescriptions/Index"
                                           style="background:linear-gradient(135deg,rgba(156,39,176,0.05),rgba(186,104,200,0.05));border-radius:8px">
                                            <i class="bi bi-eyeglasses me-2" style="color:#9c27b0"></i>
                                            <span style="font-weight:600;color:#9c27b0">My Prescriptions</span>
                                            <span class="badge ms-auto" style="background:linear-gradient(135deg,#9c27b0,#ba68c8)">New</span>
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    <!-- Logout -->
                                    <li>
                                        <form method="post" asp-page="/Account/Logout" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-link dropdown-item text-danger p-0 d-flex align-items-center"
                                                    style="width:100%;text-decoration:none;padding:.7rem 1rem!important;border-radius:8px">
                                                <i class="bi bi-box-arrow-right me-2"></i><span>Logout</span>
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Account/Login"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a></li>
                            <li class="nav-item"><a class="nav-link btn btn-primary text-white ms-2" asp-page="/Account/Register"><i class="bi bi-person-plus me-1"></i>Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="footer-optiplus" id="footer">
        <div class="footer-container">
            <div class="footer-content">
                <div class="footer-brand">
                    <h3>OptiPlus</h3>
                    <p>Your trusted destination for premium eyewear. We combine style, quality, and affordability to help you see the world better.</p>
                    <div class="social-icons">
                        <a href="#" class="social-icon" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" /></svg></a>
                        <a href="#" class="social-icon" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" /><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg></a>
                        <a href="#" class="social-icon" aria-label="Twitter"><svg viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" /></svg></a>
                    </div>
                </div>
                <div class="footer-column">
                    <h4>Navigation</h4>
                    <ul>
                        <li><a href="/Index">Home</a></li>
                        <li><a href="/Products">Shop</a></li>
                        <li><a href="/Customer/Services/CustomGlasses">Services</a></li>
                        <li><a href="#footer">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Services</h4>
                    <ul>
                        <li><a href="/Customer/Services/CustomGlasses">Custom Glasses</a></li>
                        <li><a href="/Customer/Services/FrameRepair">Frame Repair</a></li>
                        <li><a href="/Customer/Services/LensReplacement">Lens Replacement</a></li>
                        <li><a href="/Customer/Services/EyeExam">Eye Exam</a></li>
                    </ul>
                </div>
                <div class="footer-column">
                    <h4>Contact Us</h4>
                    <ul>
                        <li><a href="mailto:info@optiplus.com">info@optiplus.com</a></li>
                        <li><a href="tel:+1234567890">+1 (234) 567-890</a></li>
                        <li><a href="#">123 Vision Street, New York</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year OptiPlus. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @Html.AntiForgeryToken()
    <script src="~/js/shop-cart.js" asp-append-version="true"></script>
    <script src="~/js/recently-viewed.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity.IsAuthenticated)
    {
        <script>
            (async () => {
                try {
                    const res = await fetch('/api/wishlist/my');
                    if (!res.ok) return;
                    const items = await res.json();
                    const count = items.length;
                    if (count === 0) return;
                    const navBadge = document.getElementById('navWlCount');
                    if (navBadge) { navBadge.textContent = count > 99 ? '99+' : count; navBadge.style.display = 'flex'; }
                    const dropBadge = document.getElementById('dropdownWlCount');
                    if (dropBadge) { dropBadge.textContent = count > 99 ? '99+' : count; dropBadge.style.display = 'inline-flex'; }
                    const heartIcon = document.querySelector('.nav-wishlist-btn i');
                    if (heartIcon) heartIcon.className = 'bi bi-heart-fill';
                } catch {}
            })();
        </script>
    }
</body>
</html>
