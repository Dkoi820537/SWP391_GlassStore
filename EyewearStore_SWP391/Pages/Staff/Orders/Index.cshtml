@page
@model EyewearStore_SWP391.Pages.Staff.Orders.IndexModel
@{
    ViewData["Title"] = "Operations Dashboard";
}

@section Styles {
    <style>
        :root {
            --navy: #0d1b2a;
            --navy2: #1a2f54;
            --teal: #0f766e;
            --teal2: #0d9488;
            --red: #dc2626;
            --red-s: rgba(220,38,38,.08);
            --ok: #059669;
            --ok-s: rgba(5,150,105,.08);
            --warn: #d97706;
            --purp: #7c3aed;
            --txt: #0f172a;
            --txt2: #475569;
            --muted: #94a3b8;
            --surf: #fff;
            --bg: #f1f5f9;
            --bg2: #e8edf4;
            --bdr: #e2e8f0;
            --bdr2: #cbd5e1;
            --sh: 0 1px 4px rgba(0,0,0,.06), 0 2px 10px rgba(0,0,0,.04);
            --sh-md: 0 4px 20px rgba(0,0,0,.09);
            --r: 12px;
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        body {
            background: var(--bg);
            font-family: 'Segoe UI', system-ui, sans-serif
        }

        .ops-pg {
            max-width: 1320px;
            margin: 0 auto;
            padding: 28px 20px 80px
        }

        .ops-hdr {
            background: linear-gradient(135deg,var(--navy) 0%,var(--navy2) 100%);
            border-radius: 16px;
            padding: 24px 28px;
            margin-bottom: 22px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap
        }

        .ops-hdr-left h1 {
            font-size: 1.55rem;
            font-weight: 900;
            color: #fff;
            margin: 0 0 3px;
            letter-spacing: -.5px
        }

        .ops-hdr-left p {
            font-size: 13px;
            color: rgba(255,255,255,.45);
            margin: 0
        }

        .hdr-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap
        }

        .btn-refresh {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.18);
            color: rgba(255,255,255,.85);
            padding: 10px 18px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all .22s
        }

            .btn-refresh:hover {
                background: rgba(255,255,255,.18);
                color: #fff
            }

        .al {
            display: flex;
            align-items: center;
            gap: 8px;
            border-radius: 10px;
            padding: 11px 16px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 16px
        }

        .al-ok {
            background: var(--ok-s);
            border: 1px solid rgba(5,150,105,.2);
            color: var(--ok);
            animation: sIn .3s ease
        }

        .al-err {
            background: var(--red-s);
            border: 1px solid rgba(220,38,38,.2);
            color: var(--red)
        }

        @@keyframes sIn {
            from {
                opacity: 0;
                transform: translateY(-4px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        /* Stats — now 3 cards (removed ServiceCount) */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 14px;
            margin-bottom: 22px
        }

        .stat-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            padding: 18px 20px;
            box-shadow: var(--sh);
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            gap: 14px
        }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px
            }

        .stat-c1::before {
            background: var(--warn)
        }

        .stat-c2::before {
            background: var(--teal)
        }

        .stat-c4::before {
            background: var(--ok)
        }

        .stat-ico {
            width: 44px;
            height: 44px;
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0
        }

        .ico-warn {
            background: rgba(217,119,6,.1);
            color: var(--warn)
        }

        .ico-teal {
            background: var(--ok-s);
            color: var(--teal)
        }

        .ico-ok {
            background: var(--ok-s);
            color: var(--ok)
        }

        .stat-lbl {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 4px
        }

        .stat-val {
            font-size: 1.9rem;
            font-weight: 900;
            color: var(--navy);
            line-height: 1
        }

        .stat-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 3px
        }

        .filter-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            padding: 16px 18px;
            margin-bottom: 16px;
            box-shadow: var(--sh)
        }

            .filter-card h6 {
                font-size: 11px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: .8px;
                color: var(--muted);
                margin: 0 0 12px
            }

        .filter-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: flex-end
        }

        .fi {
            background: var(--bg);
            border: 1.5px solid var(--bdr);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 13px;
            color: var(--txt);
            font-family: inherit;
            transition: border-color .2s;
            flex: 1;
            min-width: 150px
        }

            .fi:focus {
                outline: none;
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(15,118,110,.1)
            }

        .fi-search {
            flex: 2;
            min-width: 220px
        }

        .fi-sm {
            width: 90px;
            flex: none
        }

        .btn-filter {
            padding: 9px 20px;
            background: linear-gradient(135deg,var(--navy),var(--navy2));
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            white-space: nowrap;
            transition: all .2s;
            display: flex;
            align-items: center;
            gap: 6px
        }

            .btn-filter:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(13,27,42,.25)
            }

        .qf-row {
            display: flex;
            gap: 7px;
            flex-wrap: wrap;
            margin-top: 10px
        }

        .qf {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-decoration: none;
            border: 1.5px solid;
            transition: all .15s
        }

        .qf-navy {
            color: var(--navy);
            border-color: var(--navy)
        }

            .qf-navy:hover {
                background: var(--navy);
                color: #fff
            }

        .qf-teal {
            color: var(--teal);
            border-color: var(--teal)
        }

            .qf-teal:hover {
                background: var(--teal);
                color: #fff
            }

        .qf-warn {
            color: var(--warn);
            border-color: var(--warn)
        }

            .qf-warn:hover {
                background: var(--warn);
                color: #fff
            }

        .tbl-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            overflow: hidden;
            box-shadow: var(--sh-md)
        }

        .tbl-top {
            padding: 14px 20px;
            background: linear-gradient(135deg,var(--navy),var(--navy2));
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px
        }

            .tbl-top h5 {
                font-size: 13px;
                font-weight: 800;
                color: #fff;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 8px
            }

        .tbl-badge {
            background: rgba(255,255,255,.15);
            border-radius: 6px;
            padding: 2px 10px;
            font-size: 11px;
            font-weight: 700
        }

        .tbl-info {
            font-size: 12px;
            color: rgba(255,255,255,.55)
        }

            .tbl-info strong {
                color: rgba(255,255,255,.9)
            }

        .ops-tbl {
            width: 100%;
            border-collapse: collapse
        }

            .ops-tbl th {
                font-size: 10px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: .9px;
                color: var(--muted);
                padding: 11px 16px;
                background: var(--bg2);
                border-bottom: 1px solid var(--bdr);
                text-align: left;
                white-space: nowrap
            }

            .ops-tbl td {
                padding: 13px 16px;
                border-bottom: 1px solid var(--bdr);
                font-size: 13px;
                color: var(--txt2);
                vertical-align: middle
            }

            .ops-tbl tbody tr:last-child td {
                border-bottom: none
            }

            .ops-tbl tbody tr:hover td {
                background: rgba(15,118,110,.025)
            }

            .ops-tbl tbody tr.urgent-row td {
                background: rgba(220,38,38,.018)
            }

        .cell-id {
            font-weight: 800;
            color: var(--navy);
            font-size: 14px
        }

        .cell-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px
        }

        .cust-name {
            font-weight: 700;
            color: var(--txt);
            font-size: 13px
        }

        .cust-email {
            font-size: 11px;
            color: var(--muted)
        }

        .price-val {
            font-size: 14px;
            font-weight: 800;
            color: var(--red)
        }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700
        }

        .p-pending {
            background: rgba(217,119,6,.1);
            color: #b45309;
            border: 1px solid rgba(217,119,6,.2)
        }

        .p-confirmed {
            background: rgba(15,118,110,.1);
            color: var(--teal);
            border: 1px solid rgba(15,118,110,.2)
        }

        .p-processing {
            background: rgba(13,27,42,.08);
            color: var(--navy2);
            border: 1px solid rgba(13,27,42,.15)
        }

        .p-shipped {
            background: var(--ok-s);
            color: #065f46;
            border: 1px solid rgba(15,118,110,.15)
        }

        .p-delivered {
            background: var(--ok-s);
            color: #065f46;
            border: 1px solid rgba(15,118,110,.15)
        }

        .p-completed {
            background: rgba(13,27,42,.07);
            color: var(--navy);
            border: 1px solid rgba(13,27,42,.12)
        }

        .p-cancelled {
            background: var(--red-s);
            color: var(--red);
            border: 1px solid rgba(220,38,38,.2)
        }

        .p-rx {
            background: rgba(13,27,42,.07);
            color: var(--navy2);
            border: 1px solid rgba(13,27,42,.12)
        }

        .p-pre {
            background: var(--bg2);
            color: var(--txt2);
            border: 1px solid var(--bdr)
        }

        .p-std {
            background: var(--ok-s);
            color: var(--teal);
            border: 1px solid rgba(15,118,110,.15)
        }

        .p-urgent {
            background: var(--red-s);
            color: var(--red);
            border: 1px solid rgba(220,38,38,.2)
        }

        .btn-process {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 7px 16px;
            background: linear-gradient(135deg,var(--teal),var(--teal2));
            color: #fff;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            transition: all .2s;
            white-space: nowrap
        }

            .btn-process:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(15,118,110,.3);
                color: #fff
            }

        .empty {
            text-align: center;
            padding: 60px 20px
        }

        .empty-icon {
            font-size: 52px;
            color: var(--muted);
            opacity: .25;
            margin-bottom: 16px
        }

        .empty h4 {
            font-size: 16px;
            font-weight: 700;
            color: var(--txt2);
            margin: 0 0 6px
        }

        .empty p {
            font-size: 13px;
            color: var(--muted);
            margin: 0
        }

        .pag-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 13px 18px;
            border-top: 1px solid var(--bdr);
            background: var(--bg2)
        }

        .pag-info {
            font-size: 12px;
            color: var(--muted);
            font-weight: 600
        }

        .pag {
            display: flex;
            gap: 4px;
            list-style: none;
            margin: 0;
            padding: 0
        }

        .pag-item a, .pag-item span {
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 34px;
            height: 34px;
            padding: 0 8px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            border: 1.5px solid var(--bdr);
            color: var(--txt2);
            background: var(--surf);
            transition: all .15s
        }

            .pag-item a:hover {
                border-color: var(--teal);
                color: var(--teal)
            }

        .pag-item.active span {
            background: var(--navy);
            border-color: var(--navy);
            color: #fff
        }

        .pag-item.disabled span {
            opacity: .35;
            pointer-events: none
        }

        @@media(max-width:960px) {
            .stats-row {
                grid-template-columns: 1fr 1fr
            }
        }

        @@media(max-width:600px) {
            .filter-row {
                flex-direction: column
            }

            .fi {
                min-width: 100%
            }
        }
    </style>
}

<div class="ops-pg">

    <div class="ops-hdr">
        <div class="ops-hdr-left">
            <h1><i class="bi bi-box-seam me-2"></i>Operations Dashboard</h1>
            <p>Đóng gói · Vận chuyển · Cập nhật tracking · Xử lý đơn kính thuốc</p>
        </div>
        <div class="hdr-actions">
            <button class="btn-refresh" onclick="window.location.reload()">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </div>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="al al-ok"><i class="bi bi-check-circle-fill"></i> @ok</div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="al al-err"><i class="bi bi-exclamation-circle-fill"></i> @err</div>
    }

    <!-- Stats: 3 cards — ServiceCount removed -->
    <div class="stats-row">
        <div class="stat-card stat-c1">
            <div class="stat-ico ico-warn"><i class="bi bi-hourglass-split"></i></div>
            <div>
                <div class="stat-lbl">Processing</div>
                <div class="stat-val">@Model.Stats.ProcessingCount</div>
                <div class="stat-sub">Chờ đóng gói</div>
            </div>
        </div>
        <div class="stat-card stat-c2">
            <div class="stat-ico ico-teal"><i class="bi bi-truck"></i></div>
            <div>
                <div class="stat-lbl">Shipped Today</div>
                <div class="stat-val">@Model.Stats.ShippedTodayCount</div>
                <div class="stat-sub">Đã giao hôm nay</div>
            </div>
        </div>
        <div class="stat-card stat-c4">
            <div class="stat-ico ico-ok"><i class="bi bi-eyeglasses"></i></div>
            <div>
                <div class="stat-lbl">Prescription</div>
                <div class="stat-val">@Model.Stats.PrescriptionCount</div>
                <div class="stat-sub">Đơn kính thuốc</div>
            </div>
        </div>
    </div>

    <div class="filter-card">
        <h6><i class="bi bi-funnel me-1"></i>Tìm kiếm & Lọc</h6>
        <form method="get" class="filter-row">
            <input type="text" class="fi fi-search" name="Search" value="@Model.Search" placeholder="Order ID, email, tên khách hàng…" />
            <select class="fi" name="StatusFilter">
                <option value="">Tất cả trạng thái</option>
                @foreach (var s in Model.Statuses)
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
            <select class="fi" name="TypeFilter">
                <option value="">Tất cả loại</option>
                <option value="Prescription" selected="@(Model.TypeFilter == "Prescription")">Prescription (Rx)</option>
                <option value="PreOrder" selected="@(Model.TypeFilter == "PreOrder")">Pre-Order</option>
                <option value="Standard" selected="@(Model.TypeFilter == "Standard")">Standard</option>
            </select>
            <select class="fi" name="PriorityFilter">
                <option value="">Tất cả ưu tiên</option>
                <option value="High" selected="@(Model.PriorityFilter == "High")">Ưu tiên cao</option>
                <option value="Normal" selected="@(Model.PriorityFilter == "Normal")">Bình thường</option>
            </select>
            <select class="fi fi-sm" name="pageSize">
                <option value="10" selected="@(Model.PageSize == 10)">10</option>
                <option value="25" selected="@(Model.PageSize == 25)">25</option>
                <option value="50" selected="@(Model.PageSize == 50)">50</option>
            </select>
            <input type="hidden" name="pageNumber" value="1" />
            <button type="submit" class="btn-filter"><i class="bi bi-funnel-fill"></i> Lọc</button>
        </form>
        <div class="qf-row">
            <a href="?StatusFilter=Processing" class="qf qf-warn"><i class="bi bi-hourglass-split"></i> Processing</a>
            <a href="?StatusFilter=Shipped" class="qf qf-teal"><i class="bi bi-truck"></i> Shipped</a>
            <a href="?TypeFilter=Prescription" class="qf qf-navy"><i class="bi bi-eyeglasses"></i> Prescription</a>
        </div>
    </div>

    <div class="tbl-card">
        <div class="tbl-top">
            <h5>
                <i class="bi bi-list-check"></i> Hàng đợi Operations
                <span class="tbl-badge">@Model.TotalOrders đơn</span>
            </h5>
            <div class="tbl-info">Hiển thị <strong>@Model.FirstItemIndex–@Model.LastItemIndex</strong> / <strong>@Model.TotalOrders</strong></div>
        </div>

        @if (!Model.Orders.Any())
        {
            <div class="empty">
                <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                <h4>Không có đơn hàng</h4>
                <p>Không có đơn nào khớp với bộ lọc hiện tại.</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto">
                <table class="ops-tbl">
                    <thead>
                        <tr>
                            <th>Đơn hàng</th>
                            <th>Khách hàng</th>
                            <th>Ngày tạo</th>
                            <th>Trạng thái</th>
                            <th>Loại đơn</th>
                            <th>Vận chuyển</th>
                            <th style="text-align:right">Tổng tiền</th>
                            <th style="text-align:center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.Orders)
                        {
                            bool isUrgent = o.HasPrescription || o.CreatedAt < DateTime.UtcNow.AddDays(-2);
                            string sCss = o.Status switch
                            {
                                "Pending Confirmation" => "p-pending",
                                "Confirmed" => "p-confirmed",
                                "Processing" => "p-processing",
                                "Shipped" => "p-shipped",
                                "Delivered" => "p-delivered",
                                "Completed" => "p-completed",
                                "Cancelled" => "p-cancelled",
                                _ => ""
                            };
                            <tr class="@(isUrgent ? "urgent-row" : "")">
                                <td>
                                    <div class="cell-id">#@o.OrderId</div>
                                    @if (isUrgent)
                                    {
                                        <span class="pill p-urgent" style="font-size:10px;margin-top:3px"><i class="bi bi-exclamation-triangle"></i> Urgent</span>
                                    }
                                </td>
                                <td>
                                    <div class="cust-name">@o.UserFullName</div>
                                    <div class="cust-email">@o.UserEmail</div>
                                </td>
                                <td>
                                    <div style="font-size:13px;color:var(--txt)">@o.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="cell-sub">@o.CreatedAt.ToString("HH:mm")</div>
                                </td>
                                <td><span class="pill @sCss">@o.Status</span></td>
                                <td>
                                    @if (o.HasPrescription)
                                    {
                                        <span class="pill p-rx"><i class="bi bi-eyeglasses"></i> Rx</span>
                                    }
                                    else if (o.IsPreOrder)
                                    {

                                        <span class="pill p-pre"><i class="bi bi-hourglass-split"></i> Pre-Order</span>
                                    }
                                    else
                                    {

                                        <span class="pill p-std"><i class="bi bi-check-circle"></i> Standard</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(o.TrackingNumber))
                                    {
                                        <div style="font-size:13px;font-weight:600;color:var(--txt)">
                                            <i class="bi bi-box-seam me-1" style="color:var(--teal)"></i>@o.TrackingNumber
                                        </div>
                                        <div class="cell-sub">@o.Carrier</div>
                                    }
                                    else
                                    {

                                        <span style="color:var(--muted);font-size:12px">Chưa có</span>
                                    }
                                </td>
                                <td style="text-align:right">
                                    <span class="price-val">@o.TotalAmount.ToString("N0") ₫</span>
                                </td>
                                <td style="text-align:center">
                                    <a asp-page="./Details" asp-route-id="@o.OrderId" class="btn-process">
                                        <i class="bi bi-arrow-right-circle"></i> Xử lý
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="pag-row">
                <div class="pag-info">Trang @Model.PageNumber / @Model.TotalPages</div>
                <ul class="pag">
                    <li class="pag-item @(Model.PageNumber == 1 ? "disabled" : "")"><a asp-page="./Index" asp-route-pageNumber="1" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">«</a></li>
                    <li class="pag-item @(Model.PageNumber == 1 ? "disabled" : "")"><a asp-page="./Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">‹</a></li>
                    @foreach (var p in Model.DisplayPageNumbers)
                    {
                        <li class="pag-item @(p == Model.PageNumber ? "active" : "")">
                            @if (p == Model.PageNumber)
                            {
                                <span>@p</span>
                            }
                            else
                            {

                                <a asp-page="./Index" asp-route-pageNumber="@p" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">@p</a>
                            }
                        </li>
                    }
                    <li class="pag-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")"><a asp-page="./Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">›</a></li>
                    <li class="pag-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")"><a asp-page="./Index" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">»</a></li>
                </ul>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(() => {
            document.querySelectorAll('.al-ok').forEach(a => {
                a.style.transition = 'opacity .5s';
                setTimeout(() => a.style.opacity = '0', 3500);
            });
        }, 100);
    </script>
}
