@page "{orderId:int}"
@model EyewearStore_SWP391.Pages.Staff.ServiceOrders.DetailModel
@using EyewearStore_SWP391.Pages.Staff.ServiceOrders
@using System.Text.Json
@{
    ViewData["Title"] = $"Update Job — Order #{Model.Order?.OrderId}";
    Layout = "_Layout";

    var snap = Model.Snap;
    var order = Model.Order;
    var item = Model.Item;
    var curStatus = snap?.ServiceStatus ?? "Pending";

    string StatusBg(string s) => s switch
    {
        "Pending" => "#fef3c7",
        "Processing" => "#dbeafe",
        "Ready" => "#d1fae5",
        "Done" => "#f0fdf4",
        "Cancelled" => "#fee2e2",
        _ => "#f3f4f6"
    };
    string StatusFg(string s) => s switch
    {
        "Pending" => "#92400e",
        "Processing" => "#1e40af",
        "Ready" => "#065f46",
        "Done" => "#14532d",
        "Cancelled" => "#991b1b",
        _ => "#374151"
    };
    string StatusBdr(string s) => s switch
    {
        "Pending" => "#fcd34d",
        "Processing" => "#93c5fd",
        "Ready" => "#6ee7b7",
        "Done" => "#86efac",
        "Cancelled" => "#fca5a5",
        _ => "#d1d5db"
    };
    string StatusIcon(string s) => s switch
    {
        "Pending" => "bi-hourglass-split",
        "Processing" => "bi-gear-wide-connected",
        "Ready" => "bi-check-circle-fill",
        "Done" => "bi-bag-check-fill",
        "Cancelled" => "bi-x-circle-fill",
        _ => "bi-hourglass-split"
    };

    string[] steps = { "Pending", "Processing", "Ready", "Done" };
    int stepIdx = curStatus switch { "Processing" => 1, "Ready" => 2, "Done" => 3, _ => 0 };
    bool isCancelled = curStatus == "Cancelled";

    string nextStatus = curStatus switch
    {
        "Pending" => "Processing",
        "Processing" => "Ready",
        "Ready" => "Done",
        _ => ""
    };

    // Parse service timeline
    var svcTimeline = new List<(string status, string assignedTo, string note, DateTime timestamp)>();
    if (!string.IsNullOrEmpty(snap?.ServiceTimeline))
    {
        try
        {
            var tlDoc = JsonDocument.Parse(snap.ServiceTimeline);
            foreach (var entry in tlDoc.RootElement.EnumerateArray())
            {
                var s = entry.TryGetProperty("status", out var sv) ? sv.GetString() ?? "" : "";
                var a = entry.TryGetProperty("assignedTo", out var av) ? av.GetString() ?? "" : "";
                var n = entry.TryGetProperty("note", out var nv) ? nv.GetString() ?? "" : "";
                var ts = entry.TryGetProperty("timestamp", out var tv)
                         && DateTime.TryParse(tv.GetString(), out var dt) ? dt : DateTime.UtcNow;
                svcTimeline.Add((s, a, n, ts));
            }
        }
        catch { }
    }
}

@section Styles {
    <style>
        :root {
            --navy: #0d1b2a;
            --navy2: #1a2f54;
            --acc: #2563eb;
            --teal: #0f766e;
            --teal2: #0d9488;
            --gold: #b8862a;
            --ok: #059669;
            --warn: #d97706;
            --err: #dc2626;
            --txt: #0f172a;
            --txt2: #475569;
            --muted: #94a3b8;
            --surf: #fff;
            --bg: #f1f5f9;
            --bg2: #e8edf4;
            --bdr: #e2e8f0;
            --sh: 0 2px 12px rgba(0,0,0,.07);
            --sh-md: 0 4px 20px rgba(0,0,0,.1);
            --r: 14px
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        body {
            background: var(--bg)
        }

        .wrap {
            max-width: 1050px;
            margin: 0 auto;
            padding: 28px 20px 80px
        }

        /* breadcrumb */
        .bc {
            display: flex;
            gap: 6px;
            align-items: center;
            margin-bottom: 20px;
            font-size: 12px;
            color: var(--muted)
        }

            .bc a {
                color: var(--muted);
                text-decoration: none;
                font-weight: 600
            }

                .bc a:hover {
                    color: var(--acc)
                }

        /* page header */
        .pg-hdr {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 24px
        }

            .pg-hdr h1 {
                font-size: 1.55rem;
                font-weight: 900;
                color: var(--navy);
                margin: 0 0 4px;
                letter-spacing: -.5px
            }

            .pg-hdr p {
                font-size: 13px;
                color: var(--muted);
                margin: 0
            }

        .spill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 18px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 800;
            flex-shrink: 0
        }

        /* alerts */
        .al-ok {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(5,150,105,.08);
            border: 1px solid rgba(5,150,105,.22);
            color: #059669;
            border-radius: 10px;
            padding: 11px 15px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 18px;
            animation: sIn .3s ease
        }

        .al-err {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(220,38,38,.08);
            border: 1px solid rgba(220,38,38,.22);
            color: #dc2626;
            border-radius: 10px;
            padding: 11px 15px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 18px
        }

        @@keyframes sIn {
            from {
                opacity: 0;
                transform: translateY(-5px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        /* layout */
        .grid {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 18px
        }

        /* card */
        .dc {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            overflow: hidden;
            box-shadow: var(--sh);
            margin-bottom: 16px
        }

            .dc:last-child {
                margin-bottom: 0
            }

        .dc-hdr {
            background: linear-gradient(135deg,var(--navy),var(--navy2));
            padding: 13px 18px;
            display: flex;
            align-items: center;
            gap: 9px
        }

            .dc-hdr h3 {
                font-size: 13px;
                font-weight: 800;
                color: #fff;
                margin: 0
            }

            .dc-hdr i {
                font-size: 15px;
                color: rgba(255,255,255,.7)
            }

        .dc-body {
            padding: 18px
        }

        /* breakdown rows */
        .bd-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 11px 0;
            border-bottom: 1px solid var(--bdr)
        }

            .bd-row:last-child {
                border-bottom: none
            }

        .bd-left {
            display: flex;
            align-items: center;
            gap: 11px
        }

        .bd-ico {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            background: var(--bg2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0
        }

        .bd-lbl {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 2px
        }

        .bd-val {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt)
        }

        .bd-prc {
            font-size: 13px;
            font-weight: 700;
            color: var(--navy);
            white-space: nowrap
        }

        .bd-tot {
            padding: 13px 0 2px;
            display: flex;
            justify-content: space-between;
            align-items: center
        }

        .bd-tot-lbl {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt2)
        }

        .bd-tot-val {
            font-size: 18px;
            font-weight: 900;
            color: var(--gold)
        }

        /* horizontal stepper */
        .tl {
            display: flex;
            align-items: center;
            padding: 4px 0
        }

        .tl-s {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 1
        }

            .tl-s:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 15px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: #e0e2f0;
                z-index: 0
            }

            .tl-s.done:not(:last-child)::after {
                background: #059669
            }

            .tl-s.active:not(:last-child)::after {
                background: linear-gradient(90deg,#059669,#e0e2f0)
            }

        .tl-c {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            border: 2px solid #dde1f0;
            background: #fff;
            position: relative;
            z-index: 2;
            transition: all .3s
        }

        .tl-s.done .tl-c {
            background: #059669;
            border-color: #059669;
            color: #fff
        }

        .tl-s.active .tl-c {
            background: var(--acc);
            border-color: var(--acc);
            color: #fff;
            box-shadow: 0 0 0 4px rgba(37,99,235,.15)
        }

        .tl-l {
            font-size: 9px;
            font-weight: 700;
            color: var(--muted);
            margin-top: 6px;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: .5px
        }

        .tl-s.done .tl-l {
            color: #059669
        }

        .tl-s.active .tl-l {
            color: var(--acc)
        }

        /* info grid */
        .info-g {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px
        }

        .ii {
            background: var(--bg);
            border-radius: 9px;
            padding: 11px 13px
        }

        .ii-l {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 3px
        }

        .ii-v {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt);
            line-height: 1.4
        }

        .ii-s {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px
        }

        /* form */
        .form-lbl {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 7px;
            display: block
        }

        .fi-inp {
            width: 100%;
            background: var(--bg);
            border: 1.5px solid var(--bdr);
            border-radius: 9px;
            padding: 9px 12px;
            font-size: 13px;
            color: var(--txt);
            font-family: inherit;
            transition: border-color .2s
        }

            .fi-inp:focus {
                outline: none;
                border-color: var(--acc);
                box-shadow: 0 0 0 3px rgba(37,99,235,.1)
            }

            .fi-inp.error {
                border-color: var(--err)
            }

        .field-err {
            font-size: 11px;
            color: var(--err);
            margin-top: 4px;
            display: none
        }

        /* advance button */
        .btn-advance {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            background: linear-gradient(135deg,var(--navy),var(--navy2));
            color: #fff;
            font-size: 15px;
            font-weight: 900;
            letter-spacing: .3px;
            transition: all .22s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px
        }

            .btn-advance:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(13,27,42,.3)
            }

            .btn-advance:disabled {
                opacity: .45;
                cursor: not-allowed;
                transform: none
            }

            .btn-advance .arrow-icon {
                width: 30px;
                height: 30px;
                background: rgba(255,255,255,.18);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 16px
            }

        .next-status-label {
            font-size: 11px;
            color: var(--muted);
            text-align: center;
            margin-top: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px
        }

        /* cancel button */
        .btn-cancel {
            width: 100%;
            padding: 11px;
            border: 1.5px solid rgba(220,38,38,.4);
            border-radius: 10px;
            cursor: pointer;
            background: rgba(220,38,38,.06);
            color: #dc2626;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: .2px;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 10px
        }

            .btn-cancel:hover {
                background: rgba(220,38,38,.12);
                border-color: #dc2626
            }

        /* back links */
        .back-l {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 9px;
            border: 1.5px solid var(--bdr);
            border-radius: 9px;
            color: var(--txt2);
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            transition: all .18s;
            background: var(--surf);
            margin-top: 10px
        }

            .back-l:hover {
                background: var(--bg2);
                color: var(--txt)
            }

        /* done banner */
        .done-banner {
            background: rgba(5,150,105,.08);
            border: 1.5px solid rgba(5,150,105,.25);
            border-radius: 10px;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px
        }

            .done-banner i {
                color: #059669;
                font-size: 18px;
                flex-shrink: 0
            }

        .done-banner-txt {
            font-size: 13px;
            font-weight: 600;
            color: #065f46
        }

            .done-banner-txt strong {
                font-weight: 800
            }

        /* vertical service timeline */
        .svc-tl-item {
            display: flex;
            gap: 10px;
            padding-bottom: 14px;
            position: relative
        }

            .svc-tl-item:not(:last-child)::before {
                content: '';
                position: absolute;
                left: 13px;
                top: 28px;
                bottom: 0;
                width: 2px;
                background: var(--bdr)
            }

        .svc-tl-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            position: relative;
            z-index: 1;
            border: 1.5px solid
        }

        /* divider */
        .section-divider {
            border: none;
            border-top: 1px solid var(--bdr);
            margin: 14px 0
        }

        @@media(max-width:860px) {
            .grid {
                grid-template-columns: 1fr
            }

            .info-g {
                grid-template-columns: 1fr
            }
        }

        @@media(max-width:600px) {
            .wrap {
                padding: 14px 12px 60px
            }
        }
    </style>
}

<div class="wrap">
    <!-- Breadcrumb -->
    <div class="bc">
        <a asp-page="/Staff/Orders/Index">Orders</a>
        <span style="opacity:.4">›</span>
        <a asp-page="/Staff/ServiceOrders/Index">Service Jobs</a>
        <span style="opacity:.4">›</span>
        <span>Order #@Model.Order?.OrderId</span>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="al-ok"><i class="bi bi-check-circle-fill"></i> @ok</div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="al-err"><i class="bi bi-exclamation-circle-fill"></i> @err</div>
    }

    @if (order == null || snap == null || item == null)
    {
        <div class="al-err"><i class="bi bi-exclamation-circle-fill"></i> Service order not found.</div>
    }
    else
    {
        <div class="pg-hdr">
            <div>
                <h1><i class="bi bi-wrench me-2"></i>Job #@order.OrderId</h1>
                <p>@order.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm")</p>
            </div>
            <span class="spill"
                  style="background:@StatusBg(curStatus);color:@StatusFg(curStatus);border:1.5px solid @StatusBdr(curStatus)">
                <i class="bi @StatusIcon(curStatus)"></i> @curStatus
            </span>
        </div>

        <div class="grid">
            <!-- ── LEFT COLUMN ── -->
            <div>
                <!-- Service Breakdown -->
                <div class="dc">
                    <div class="dc-hdr"><i class="bi bi-tools"></i><h3>Service Breakdown</h3></div>
                    <div class="dc-body">
                        <div class="bd-row">
                            <div class="bd-left">
                                <div class="bd-ico"><i class="bi bi-eyeglasses"></i></div>
                                <div><div class="bd-lbl">Frame</div><div class="bd-val">@(snap.FrameName ?? snap.ProductName ?? "N/A")</div></div>
                            </div>
                            <div class="bd-prc">@snap.FramePrice.ToString("N0") ₫</div>
                        </div>

                        @if (!string.IsNullOrEmpty(snap.LensProductName))
                        {
                            <div class="bd-row">
                                <div class="bd-left">
                                    <div class="bd-ico">⭕</div>
                                    <div><div class="bd-lbl">Lens</div><div class="bd-val">@snap.LensProductName</div></div>
                                </div>
                                <div class="bd-prc">@snap.LensPrice.ToString("N0") ₫</div>
                            </div>
                        }

                        <div class="bd-row">
                            <div class="bd-left">
                                <div class="bd-ico"><i class="bi bi-gear"></i></div>
                                <div><div class="bd-lbl">Service</div><div class="bd-val">@(snap.ServiceName ?? "N/A")</div></div>
                            </div>
                            <div class="bd-prc">@snap.ServicePrice.ToString("N0") ₫</div>
                        </div>

                        <div class="bd-tot">
                            <div class="bd-tot-lbl">Total</div>
                            <div class="bd-tot-val">@((item.UnitPrice * item.Quantity).ToString("N0")) ₫</div>
                        </div>
                    </div>
                </div>

                <!-- Progress stepper -->
                <div class="dc">
                    <div class="dc-hdr"><i class="bi bi-map"></i><h3>Progress</h3></div>
                    <div class="dc-body">
                        @if (isCancelled)
                        {
                            <div style="display:flex;align-items:center;gap:10px;color:#dc2626">
                                <i class="bi bi-x-circle" style="font-size:1.4rem"></i>
                                <strong>This service order has been cancelled.</strong>
                            </div>
                        }
                        else
                        {
                            <div class="tl">
                                @for (int i = 0; i < steps.Length; i++)
                                {
                                    string cls = i < stepIdx ? "done" : i == stepIdx ? "active" : "";
                                    string ic = i < stepIdx ? "✓" : i == stepIdx ? "●" : (i + 1).ToString();
                                    <div class="tl-s @cls">
                                        <div class="tl-c">@ic</div>
                                        <div class="tl-l">@steps[i]</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Workshop Timeline (vertical milestones) -->
                @if (svcTimeline.Any())
                {
                    <div class="dc">
                        <div class="dc-hdr">
                            <i class="bi bi-clock-history"></i>
                            <h3>Workshop Timeline</h3>
                            <span style="background:rgba(255,255,255,.15);border-radius:5px;padding:2px 8px;font-size:10px;font-weight:700;color:rgba(255,255,255,.9)">
                                @svcTimeline.Count milestone@(svcTimeline.Count > 1 ? "s" : "")
                            </span>
                        </div>
                        <div class="dc-body">
                            @foreach (var (s, a, n, ts) in svcTimeline.OrderBy(x => x.timestamp))
                            {
                                string dotColor = s switch
                                {
                                    "Processing" => "#2563eb",
                                    "Ready" => "#059669",
                                    "Done" => "#14532d",
                                    "Cancelled" => "#dc2626",
                                    _ => "#d97706"
                                };
                                string dotIcon = s switch
                                {
                                    "Processing" => "bi-gear-fill",
                                    "Ready" => "bi-check-circle-fill",
                                    "Done" => "bi-bag-check-fill",
                                    "Cancelled" => "bi-x-circle-fill",
                                    _ => "bi-hourglass-split"
                                };
                                <div class="svc-tl-item">
                                    <div class="svc-tl-dot" style="background:@(dotColor)1a;border-color:@dotColor;">
                                        <i class="bi @dotIcon" style="color:@dotColor;font-size:11px;"></i>
                                    </div>
                                    <div style="flex:1;padding-top:3px;">
                                        <div style="font-weight:700;font-size:13px;color:var(--txt)">@s</div>
                                        @if (!string.IsNullOrEmpty(a))
                                        {
                                            <div style="font-size:11px;color:#7c3aed;font-weight:600;margin-top:2px;">
                                                <i class="bi bi-person-fill" style="font-size:10px;"></i> @a
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(n))
                                        {
                                            <div style="font-size:11px;color:var(--txt2);margin-top:2px;line-height:1.5">@n</div>
                                        }
                                        <div style="font-size:10px;color:var(--muted);margin-top:3px;">
                                            <i class="bi bi-clock" style="font-size:9px;"></i>
                                            @ts.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Customer Info -->
                <div class="dc">
                    <div class="dc-hdr"><i class="bi bi-person-fill"></i><h3>Customer Info</h3></div>
                    <div class="dc-body">
                        <div class="info-g">
                            <div class="ii">
                                <div class="ii-l">Customer</div>
                                <div class="ii-v">@(order.User?.FullName ?? "N/A")</div>
                                <div class="ii-s">@(order.User?.Email ?? "")</div>
                            </div>
                            <div class="ii">
                                <div class="ii-l">Order Status</div>
                                <div class="ii-v">@order.Status</div>
                                <div class="ii-s">@order.PaymentMethod</div>
                            </div>
                            <div class="ii">
                                <div class="ii-l">Date</div>
                                <div class="ii-v">@order.CreatedAt.ToString("dd/MM/yyyy")</div>
                                <div class="ii-s">@order.CreatedAt.ToString("HH:mm")</div>
                            </div>
                            <div class="ii">
                                <div class="ii-l">Total Paid</div>
                                <div class="ii-v" style="color:var(--gold)">@order.TotalAmount.ToString("N0") ₫</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── RIGHT COLUMN ── -->
            <div>
                <div class="dc" style="position:sticky;top:80px">
                    <div class="dc-hdr">
                        <i class="bi bi-arrow-right-circle-fill"></i>
                        <h3>Update Job</h3>
                    </div>
                    <div class="dc-body">

                        @if (isCancelled)
                        {
                            <div style="display:flex;align-items:center;gap:10px;color:#dc2626;padding:8px 0">
                                <i class="bi bi-x-circle" style="font-size:1.8rem"></i>
                                <div>
                                    <strong style="font-size:14px">Đơn đã bị huỷ</strong>
                                    <div style="font-size:11px;color:var(--muted);margin-top:2px">Không thể thực hiện thêm thao tác.</div>
                                </div>
                            </div>
                        }
                        else if (curStatus == "Done")
                        {
                            <div class="done-banner">
                                <i class="bi bi-check-circle-fill"></i>
                                <div class="done-banner-txt">
                                    Service hoàn thành! <strong>Chờ bộ phận Sale</strong> advance Order sang bước tiếp theo.
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Advance Form -->
                            <form method="post" asp-page-handler="Update" asp-route-orderId="@order.OrderId" id="svcForm">
                                <input type="hidden" name="OrderItemId" value="@item.OrderItemId" />

                                <div style="margin-bottom:13px">
                                    <label class="form-lbl" for="at">
                                        <i class="bi bi-person me-1"></i> Assign Technician
                                        <span style="color:var(--err);margin-left:2px">*</span>
                                    </label>
                                    <input type="text" id="at" name="AssignedTo"
                                           value="@snap.AssignedTo" class="fi-inp"
                                           placeholder="Tên kỹ thuật viên hoặc mã nhân viên…" />
                                    <div class="field-err" id="at-err">
                                        <i class="bi bi-exclamation-circle me-1"></i> Vui lòng nhập tên kỹ thuật viên.
                                    </div>
                                </div>

                                <div style="margin-bottom:20px">
                                    <label class="form-lbl" for="note">
                                        <i class="bi bi-pencil me-1"></i> Ghi chú
                                        <span style="font-size:10px;color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0">(tuỳ chọn)</span>
                                    </label>
                                    <textarea id="note" name="InternalNote" rows="3"
                                      class="fi-inp" style="resize:vertical"
                                      placeholder="e.g. Lens đang cắt, dự kiến 2 giờ…">@snap.InternalNote</textarea>
                                </div>

                                @if (!string.IsNullOrEmpty(nextStatus))
                                {
                                    <button type="submit" class="btn-advance" id="btnAdvance">
                                        <span>Advance to <strong>@nextStatus</strong></span>
                                        <div class="arrow-icon"><i class="bi bi-arrow-right"></i></div>
                                    </button>
                                    <div class="next-status-label">
                                        Current: <span style="color:var(--txt2);font-weight:700">@curStatus</span>
                                        &nbsp;→&nbsp; Next: <strong style="color:var(--acc)">@nextStatus</strong>
                                    </div>
                                }
                            </form>

                            <hr class="section-divider" />

                            <!-- Cancel Form -->
                            <form method="post" asp-page-handler="Cancel" asp-route-orderId="@order.OrderId" id="cancelForm">
                                <button type="button" class="btn-cancel" id="btnCancelTrigger">
                                    <i class="bi bi-x-circle"></i> Huỷ Service Order
                                </button>
                            </form>
                        }

                        <a asp-page="/Staff/ServiceOrders/Index" class="back-l" style="margin-top:14px">
                            ← Danh sách Service Jobs
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Confirm cancel modal (lightweight) -->
<div id="cancelModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:16px;padding:28px 28px 22px;max-width:380px;width:90%;box-shadow:0 12px 40px rgba(0,0,0,.18);">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
            <div style="width:40px;height:40px;border-radius:50%;background:rgba(220,38,38,.1);display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-exclamation-triangle-fill" style="color:#dc2626;font-size:18px;"></i>
            </div>
            <div>
                <div style="font-size:15px;font-weight:800;color:#0f172a">Xác nhận huỷ?</div>
                <div style="font-size:12px;color:#94a3b8;margin-top:1px">Hành động này không thể hoàn tác.</div>
            </div>
        </div>
        <p style="font-size:13px;color:#475569;margin:0 0 20px;line-height:1.6">
            Bạn có chắc muốn huỷ service order này không? Khách hàng sẽ nhận được email thông báo.
        </p>
        <div style="display:flex;gap:10px;">
            <button id="cancelModalNo"
                    style="flex:1;padding:10px;border:1.5px solid #e2e8f0;border-radius:9px;background:#f1f5f9;color:#475569;font-size:13px;font-weight:700;cursor:pointer;">
                Không, giữ lại
            </button>
            <button id="cancelModalYes"
                    style="flex:1;padding:10px;border:none;border-radius:9px;background:#dc2626;color:#fff;font-size:13px;font-weight:700;cursor:pointer;">
                Huỷ ngay
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Validate AssignedTo trước khi submit ──
        document.getElementById('svcForm')?.addEventListener('submit', function (e) {
            const inp = document.getElementById('at');
            const err = document.getElementById('at-err');
            if (!inp || inp.value.trim()) return;
            e.preventDefault();
            err.style.display = 'block';
            inp.classList.add('error');
            inp.focus();
            inp.addEventListener('input', function () {
                if (inp.value.trim()) { err.style.display = 'none'; inp.classList.remove('error'); }
            });
        });

        // ── Cancel confirmation modal ──
        const modal   = document.getElementById('cancelModal');
        const trigger = document.getElementById('btnCancelTrigger');
        const no      = document.getElementById('cancelModalNo');
        const yes     = document.getElementById('cancelModalYes');

        trigger?.addEventListener('click', () => { modal.style.display = 'flex'; });
        no?.addEventListener('click',      () => { modal.style.display = 'none'; });
        modal?.addEventListener('click', e => { if (e.target === modal) modal.style.display = 'none'; });
        yes?.addEventListener('click', () => { document.getElementById('cancelForm')?.submit(); });

        // ── Auto-hide success alert ──
        const alOk = document.querySelector('.al-ok');
        if (alOk) setTimeout(() => { alOk.style.transition = 'opacity .5s'; alOk.style.opacity = '0'; }, 4000);
    </script>
}
