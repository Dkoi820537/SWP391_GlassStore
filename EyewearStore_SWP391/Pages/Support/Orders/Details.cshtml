@page "{id:int}"
@model EyewearStore_SWP391.Pages.Support.Orders.DetailsModel
@using System.Text.Json
@{
    ViewData["Title"] = $"Process Order #{Model.OrderId}";
    Layout = "_Layout";

    bool serviceDone = Model.ServiceStatus == "Done";
    bool serviceCancelled = Model.ServiceStatus == "Cancelled";
    var blockedStatuses = new[] { "Shipped", "Delivered", "Completed" };
}

@section Styles {
    <style>
        :root {
            --navy: #0d1b2a;
            --navy2: #1a2f54;
            --teal: #0f766e;
            --teal2: #0d9488;
            --red: #dc2626;
            --red-s: rgba(220,38,38,.08);
            --ok: #059669;
            --ok-s: rgba(5,150,105,.08);
            --warn: #d97706;
            --txt: #0f172a;
            --txt2: #475569;
            --muted: #94a3b8;
            --surf: #fff;
            --bg: #f1f5f9;
            --bg2: #e8edf4;
            --bdr: #e2e8f0;
            --bdr2: #cbd5e1;
            --sh: 0 1px 4px rgba(0,0,0,.06), 0 2px 10px rgba(0,0,0,.04);
            --r: 12px;
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        body {
            background: var(--bg);
            font-family: 'Segoe UI', system-ui, sans-serif
        }

        .pg {
            max-width: 1200px;
            margin: 0 auto;
            padding: 28px 20px 80px
        }

        /* Breadcrumb */
        .bc {
            display: flex;
            gap: 6px;
            align-items: center;
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 20px
        }

            .bc a {
                color: var(--muted);
                text-decoration: none;
                font-weight: 600
            }

                .bc a:hover {
                    color: var(--teal)
                }

        /* Alerts */
        .al {
            display: flex;
            align-items: center;
            gap: 8px;
            border-radius: 10px;
            padding: 11px 16px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 16px
        }

        .al-ok {
            background: var(--ok-s);
            border: 1px solid rgba(5,150,105,.2);
            color: var(--ok);
            animation: sIn .3s ease
        }

        .al-err {
            background: var(--red-s);
            border: 1px solid rgba(220,38,38,.2);
            color: var(--red)
        }

        @@keyframes sIn {
            from {
                opacity: 0;
                transform: translateY(-4px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        /* Header */
        .pg-hdr {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 20px
        }

            .pg-hdr h1 {
                font-size: 1.5rem;
                font-weight: 900;
                color: var(--navy);
                margin: 0 0 6px;
                letter-spacing: -.4px
            }

        .hdr-meta {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap
        }

        .priority-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            background: var(--red-s);
            border: 1px solid rgba(220,38,38,.2);
            color: var(--red);
            border-radius: 100px;
            font-size: 11px;
            font-weight: 800
        }

        .date-info {
            font-size: 12px;
            color: var(--muted)
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 16px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 800
        }

        /* Service Banner */
        .svc-banner {
            border-radius: var(--r);
            padding: 16px 20px;
            margin-bottom: 18px;
            display: flex;
            align-items: flex-start;
            gap: 14px;
            flex-wrap: wrap;
            border: 1.5px solid
        }

            .svc-banner.locked {
                background: rgba(220,38,38,.04);
                border-color: rgba(220,38,38,.2)
            }

            .svc-banner.done {
                background: var(--ok-s);
                border-color: rgba(5,150,105,.2)
            }

            .svc-banner.cancelled {
                background: var(--bg2);
                border-color: var(--bdr)
            }

        .svc-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0
        }

        .locked .svc-icon {
            background: var(--red-s);
            color: var(--red)
        }

        .done .svc-icon {
            background: var(--ok-s);
            color: var(--ok)
        }

        .cancelled.svc-icon-wrap .svc-icon {
            background: var(--bg2);
            color: var(--muted)
        }

        .svc-body {
            flex: 1;
            min-width: 0
        }

        .svc-title {
            font-size: 13px;
            font-weight: 800;
            margin: 0 0 4px
        }

        .locked .svc-title {
            color: var(--red)
        }

        .done .svc-title {
            color: var(--ok)
        }

        .cancelled.svc-title {
            color: var(--txt2)
        }

        .svc-desc {
            font-size: 12px;
            color: var(--txt2);
            margin: 0 0 10px;
            line-height: 1.55
        }

        .svc-steps {
            display: flex;
            gap: 5px;
            align-items: center;
            flex-wrap: wrap
        }

        .svc-step {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 9px;
            border-radius: 100px;
            font-size: 10px;
            font-weight: 700
        }

            .svc-step.done-s {
                background: var(--ok-s);
                color: var(--ok);
                border: 1px solid rgba(5,150,105,.2)
            }

            .svc-step.active-s {
                background: rgba(13,27,42,.08);
                color: var(--navy2);
                border: 1px solid rgba(13,27,42,.15)
            }

            .svc-step.idle-s {
                background: var(--bg2);
                color: var(--muted);
                border: 1px solid var(--bdr)
            }

        .svc-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 13px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            flex-shrink: 0;
            align-self: center
        }

            .svc-badge.lock {
                background: var(--red-s);
                border: 1px solid rgba(220,38,38,.18);
                color: var(--red)
            }

            .svc-badge.ready {
                background: var(--ok-s);
                border: 1px solid rgba(5,150,105,.18);
                color: var(--ok)
            }

        /* Grid */
        .det-grid {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 16px
        }

        /* Card */
        .dc {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            overflow: hidden;
            box-shadow: var(--sh);
            margin-bottom: 14px
        }

            .dc:last-child {
                margin-bottom: 0
            }

        .dc-hdr {
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 8px
        }

            .dc-hdr h3 {
                font-size: 12px;
                font-weight: 800;
                color: #fff;
                margin: 0;
                flex: 1;
                text-transform: uppercase;
                letter-spacing: .5px
            }

            .dc-hdr.navy {
                background: linear-gradient(135deg,var(--navy),var(--navy2))
            }

            .dc-hdr.teal {
                background: linear-gradient(135deg,var(--teal),var(--teal2))
            }

            .dc-hdr.dark {
                background: linear-gradient(135deg,#1e293b,#334155)
            }

        .dc-body {
            padding: 16px
        }

        /* Info grid */
        .info-g {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 9px
        }

        .ii {
            background: var(--bg);
            border-radius: 8px;
            padding: 10px 12px
        }

        .ii-l {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .7px;
            margin-bottom: 3px
        }

        .ii-v {
            font-size: 13px;
            font-weight: 700;
            color: var(--txt);
            line-height: 1.4
        }

        .ii-s {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px
        }

        /* Pills */
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 9px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700
        }

        .pill-rx {
            background: rgba(13,27,42,.07);
            color: var(--navy2);
            border: 1px solid rgba(13,27,42,.12)
        }

        .pill-preorder {
            background: var(--bg2);
            color: var(--txt2);
            border: 1px solid var(--bdr)
        }

        .pill-ok {
            background: var(--ok-s);
            color: var(--ok);
            border: 1px solid rgba(5,150,105,.18)
        }

        .pill-out {
            background: var(--red-s);
            color: var(--red);
            border: 1px solid rgba(220,38,38,.15)
        }

        .pill-return {
            background: rgba(217,119,6,.08);
            color: var(--warn);
            border: 1px solid rgba(217,119,6,.15)
        }

        .svc-ind {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(13,27,42,.06);
            border: 1px solid rgba(13,27,42,.1);
            color: var(--navy2);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 10px;
            font-weight: 700;
            margin-top: 3px
        }

        /* Items table */
        .item-tbl {
            width: 100%;
            border-collapse: collapse
        }

            .item-tbl th {
                font-size: 10px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .8px;
                color: var(--muted);
                padding: 9px 12px;
                background: var(--bg2);
                border-bottom: 1px solid var(--bdr);
                text-align: left
            }

            .item-tbl td {
                padding: 11px 12px;
                border-bottom: 1px solid var(--bdr);
                font-size: 13px;
                color: var(--txt2);
                vertical-align: middle
            }

            .item-tbl tbody tr:last-child td {
                border-bottom: none
            }

            .item-tbl tbody tr:hover td {
                background: var(--bg)
            }

        .svc-row td {
            background: rgba(13,27,42,.02) !important
        }

        .price-val {
            font-weight: 700;
            color: var(--red)
        }

        /* Rx */
        .rx-section {
            background: var(--bg);
            border-top: 1px solid var(--bdr)
        }

        .rx-inner {
            margin: 0 12px 12px 28px;
            padding: 13px;
            background: var(--surf);
            border-radius: 9px;
            border: 1px solid var(--bdr2)
        }

        .rx-title {
            font-size: 12px;
            font-weight: 800;
            color: var(--navy2);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 7px
        }

        .rx-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 9px;
            margin-bottom: 10px
        }

        .rx-eye {
            padding: 11px;
            background: var(--bg);
            border-radius: 8px;
            border-left: 3px solid var(--teal)
        }

        .rx-eye-t {
            font-size: 10px;
            font-weight: 800;
            color: var(--teal);
            text-transform: uppercase;
            letter-spacing: .7px;
            margin-bottom: 6px
        }

        .rx-row {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            margin-bottom: 3px
        }

            .rx-row span:first-child {
                color: var(--muted);
                font-weight: 600
            }

            .rx-row span:last-child {
                color: var(--txt);
                font-weight: 700
            }

        /* Status form */
        .form-lbl {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .7px;
            margin-bottom: 6px;
            display: block
        }

        .fi {
            width: 100%;
            background: var(--bg);
            border: 1.5px solid var(--bdr);
            border-radius: 8px;
            padding: 9px 12px;
            font-size: 13px;
            color: var(--txt);
            font-family: inherit;
            transition: border-color .2s
        }

            .fi:focus {
                outline: none;
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(15,118,110,.1)
            }

            .fi:disabled {
                opacity: .5;
                cursor: not-allowed
            }

        .lock-hint {
            font-size: 11px;
            color: var(--red);
            background: var(--red-s);
            border: 1px solid rgba(220,38,38,.15);
            border-radius: 7px;
            padding: 8px 12px;
            margin-top: 7px;
            display: flex;
            align-items: flex-start;
            gap: 6px;
            line-height: 1.5
        }

        .btn-update {
            width: 100%;
            padding: 10px;
            font-size: 13px;
            font-weight: 800;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            background: linear-gradient(135deg,var(--navy),var(--navy2));
            color: #fff;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            margin-top: 11px
        }

            .btn-update:hover:not(:disabled) {
                transform: translateY(-1px);
                box-shadow: 0 5px 14px rgba(13,27,42,.25)
            }

            .btn-update:disabled {
                opacity: .4;
                cursor: not-allowed;
                transform: none
            }

        /* Action buttons */
        .act-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 7px;
            margin-top: 12px
        }

        .act-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 9px 11px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: all .18s;
            text-decoration: none
        }

            .act-btn:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 10px rgba(0,0,0,.12)
            }

            .act-btn.confirm {
                background: linear-gradient(135deg,#15803d,#16a34a);
                color: #fff;
                grid-column: 1/-1
            }

            .act-btn.contact {
                background: rgba(15,118,110,.08);
                border: 1.5px solid rgba(15,118,110,.2);
                color: var(--teal)
            }

            .act-btn.escalate {
                background: rgba(217,119,6,.08);
                border: 1.5px solid rgba(217,119,6,.2);
                color: var(--warn)
            }

            .act-btn.cancel {
                background: var(--red-s);
                border: 1.5px solid rgba(220,38,38,.18);
                color: var(--red);
                grid-column: 1/-1
            }

            .act-btn.svc {
                background: linear-gradient(135deg,var(--navy),var(--navy2));
                color: #fff;
                grid-column: 1/-1
            }

        .divider {
            height: 1px;
            background: var(--bdr);
            margin: 14px 0
        }

        .back-l {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 9px;
            border: 1.5px solid var(--bdr);
            border-radius: 9px;
            color: var(--txt2);
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            transition: all .18s;
            background: var(--surf);
            margin-top: 10px
        }

            .back-l:hover {
                background: var(--bg2);
                color: var(--txt)
            }

        .hist-link {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 9px 13px;
            background: var(--bg);
            border: 1.5px solid var(--bdr2);
            border-radius: 9px;
            color: var(--txt2);
            text-decoration: none;
            font-size: 12px;
            font-weight: 700;
            margin-top: 9px;
            transition: all .18s
        }

            .hist-link:hover {
                background: var(--bg2);
                color: var(--txt)
            }

            .hist-link i:last-child {
                margin-left: auto
            }

        /* Verify badge */
        .verify-badge {
            background: #ff9800;
            color: #fff;
            padding: 2px 7px;
            border-radius: 5px;
            font-size: 10px;
            font-weight: 700
        }

        .verified-badge {
            background: var(--ok);
            color: #fff;
            padding: 2px 7px;
            border-radius: 5px;
            font-size: 10px;
            font-weight: 700
        }

        @@media(max-width:960px) {
            .det-grid {
                grid-template-columns: 1fr
            }
        }

        @@media(max-width:600px) {
            .info-g {
                grid-template-columns: 1fr
            }

            .act-grid {
                grid-template-columns: 1fr
            }
        }
    </style>
}

<div class="pg">
    <!-- Breadcrumb -->
    <div class="bc">
        <a asp-page="/Index">Home</a>
        <span style="opacity:.4">›</span>
        <a asp-page="./Index">Support Dashboard</a>
        <span style="opacity:.4">›</span>
        <span>Order #@Model.OrderId</span>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="al al-ok"><i class="bi bi-check-circle-fill"></i> @ok</div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="al al-err"><i class="bi bi-exclamation-circle-fill"></i> @err</div>
    }

    <!-- Header -->
    <div class="pg-hdr">
        <div>
            <h1><i class="bi bi-briefcase me-2"></i>Process Order #@Model.OrderId</h1>
            <div class="hdr-meta">
                @if (Model.IsHighPriority)
                {
                    <span class="priority-pill"><i class="bi bi-exclamation-triangle-fill"></i> HIGH PRIORITY</span>
                }
                <span class="date-info">Created: @Model.Order.CreatedAt.ToString("MMM dd, yyyy 'at' HH:mm")</span>
            </div>
        </div>
        @{
            var (spBg, spFg, spBdr) = Model.Order.Status switch
            {
                "Pending Confirmation" => ("#fef9ec", "#92400e", "#fcd34d"),
                "Confirmed" => ("rgba(15,118,110,.08)", "#065f46", "rgba(15,118,110,.25)"),
                "Processing" => ("rgba(13,27,42,.07)", "#1a2f54", "rgba(13,27,42,.2)"),
                "Shipped" => ("rgba(15,118,110,.06)", "#065f46", "rgba(15,118,110,.18)"),
                "Delivered" => ("rgba(15,118,110,.06)", "#065f46", "rgba(15,118,110,.18)"),
                "Completed" => ("rgba(13,27,42,.07)", "var(--navy)", "rgba(13,27,42,.15)"),
                "Cancelled" => ("var(--red-s)", "var(--red)", "rgba(220,38,38,.22)"),
                _ => ("var(--bg2)", "var(--txt2)", "var(--bdr)")
            };
        }
        <span class="status-pill" style="background:@spBg;color:@spFg;border:1.5px solid @spBdr">
            @Model.Order.Status
        </span>
    </div>

    <!-- Service Banner -->
    @if (Model.HasServiceItem)
    {
        string bannerCls = serviceDone ? "done" : serviceCancelled ? "cancelled" : "locked";
        <div class="svc-banner @bannerCls">
            <div class="svc-icon">
                <i class="bi @(serviceDone ? "bi-check-circle-fill" : serviceCancelled ? "bi-x-circle-fill" : "bi-lock-fill")"></i>
            </div>
            <div class="svc-body">
                @if (serviceDone)
                {
                    <p class="svc-title done svc-title" style="color:var(--ok)">Service Completed — Order ready to fulfil</p>
                    <p class="svc-desc">
                        The service job for <strong>@Model.FrameName</strong>
                        (@(string.IsNullOrEmpty(Model.ServiceName) ? "eyewear service" : Model.ServiceName))
                        is marked <strong>Done</strong>. You may now set Shipped / Delivered / Completed.
                    </p>
                }
                else if (serviceCancelled)
                {
                    <p class="svc-title" style="color:var(--txt2)">Service Cancelled</p>
                    <p class="svc-desc">The service job was cancelled. Contact the customer or escalate if needed.</p>
                }
                else
                {
                    <p class="svc-title locked" style="color:var(--red)">Waiting for Service Completion</p>
                    <p class="svc-desc">
                        Order contains a <strong>custom eyewear service</strong>
                        (@(string.IsNullOrEmpty(Model.ServiceName) ? "fitting/customization" : Model.ServiceName)
                        @(string.IsNullOrEmpty(Model.FrameName) ? "" : $"for \"{Model.FrameName}\"")).
                        <strong>Shipped, Delivered</strong> and <strong>Completed</strong> are locked until the technician marks the job <strong>Done</strong>.
                    </p>
                    <div class="svc-steps">
                        @{
                            string[] steps = { "Pending", "Processing", "Ready", "Done" }; int curIdx = Array.IndexOf(steps, Model.ServiceStatus);
                        }
                        @for (int i = 0; i < steps.Length; i++)
                        {
                            string cls = i < curIdx ? "done-s" : i == curIdx ? "active-s" : "idle-s";
                            <span class="svc-step @cls">@steps[i]</span>
                            if (i < steps.Length - 1)
                            {

                                <span style="color:var(--muted);font-size:9px">›</span>
                            }
                        }
                    </div>
                }
            </div>
            @if (serviceDone)
            {
                <div class="svc-badge ready"><i class="bi bi-check-circle-fill"></i> Ready to Ship</div>
            }
            else if (!serviceCancelled)
            {

                <div class="svc-badge lock"><i class="bi bi-lock-fill"></i> Partially Locked</div>
            }
        </div>
    }

    <div class="det-grid">
        <!-- ── LEFT ── -->
        <div>
            <!-- Customer & Shipping -->
            <div class="dc">
                <div class="dc-hdr teal"><i class="bi bi-person-fill" style="color:rgba(255,255,255,.7)"></i><h3>Customer & Shipping</h3></div>
                <div class="dc-body">
                    <div class="info-g">
                        <div class="ii">
                            <div class="ii-l">Customer</div>
                            <div class="ii-v">@Model.CustomerName</div>
                            <div class="ii-s"><a href="mailto:@Model.CustomerEmail" style="color:var(--teal);text-decoration:none">@Model.CustomerEmail</a></div>
                        </div>
                        <div class="ii">
                            <div class="ii-l">Phone</div>
                            <div class="ii-v">
                                @if (!string.IsNullOrWhiteSpace(Model.CustomerPhone))
                                {
                                    <a href="tel:@Model.CustomerPhone" style="color:var(--teal);text-decoration:none">@Model.CustomerPhone</a>
                                }
                                else
                                {

                                    <span style="color:var(--muted)">—</span>
                                }
                            </div>
                            <div class="ii-s">Since @Model.CustomerSince.ToString("MMM yyyy")</div>
                        </div>
                        <div class="ii">
                            <div class="ii-l">Payment</div>
                            <div class="ii-v">
                                @if (Model.Order.PaymentMethod == "COD")
                                {
                                    <span><i class="bi bi-cash me-1"></i>Cash on Delivery</span>
                                }
                                else
                                {

                                    <span><i class="bi bi-credit-card me-1"></i>@Model.Order.PaymentMethod</span>
                                }
                            </div>
                        </div>
                        <div class="ii">
                            <div class="ii-l">Order Type</div>
                            <div class="ii-v">
                                @if (Model.HasPrescriptionItems)
                                {
                                    <span class="pill pill-rx"><i class="bi bi-eyeglasses"></i> Prescription</span>
                                }
                                else if (Model.IsPreOrder)
                                {

                                    <span class="pill pill-preorder"><i class="bi bi-clock"></i> Pre-Order</span>
                                }
                                else
                                {

                                    <span class="pill pill-ok">✓ Ready Stock</span>
                                }
                            </div>
                        </div>
                        <div class="ii" style="grid-column:1/-1">
                            <div class="ii-l">Shipping Address</div>
                            <div class="ii-v">@Model.ShippingAddress</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Items -->
            <div class="dc">
                <div class="dc-hdr navy">
                    <i class="bi bi-cart3" style="color:rgba(255,255,255,.7)"></i>
                    <h3>Order Items</h3>
                    <span style="background:rgba(255,255,255,.15);border-radius:5px;padding:2px 8px;font-size:10px;font-weight:700;color:rgba(255,255,255,.9)">
                        @Model.OrderItems.Count
                    </span>
                </div>
                <div class="dc-body" style="padding:0">
                    <table class="item-tbl">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>SKU</th>
                                <th style="text-align:center">Qty</th>
                                <th style="text-align:right">Unit Price</th>
                                <th style="text-align:right">Subtotal</th>
                                <th style="text-align:center">Stock</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                bool isSvc = !string.IsNullOrEmpty(item.SnapshotJson) &&
                                (item.SnapshotJson.Contains("\"isServiceOrder\":true") ||
                                item.SnapshotJson.Contains("\"lensProductId\":"));
                                string svcSt = Model.ServiceStatus;

                                <tr class="@(isSvc ? "svc-row" : "")">
                                    <td>
                                        <div style="font-weight:700;color:var(--txt);font-size:13px">@item.ProductName</div>
                                        @if (item.PrescriptionId != null)
                                        {
                                            <span class="pill pill-rx" style="margin-top:3px"><i class="bi bi-eyeglasses"></i> Rx</span>
                                        }
                                        @if (isSvc)
                                        {
                                            <div class="svc-ind"><i class="bi bi-nut"></i> Service — @svcSt</div>
                                        }
                                        @if (item.HasReturn)
                                        {
                                            <span class="pill pill-return" style="margin-top:3px"><i class="bi bi-arrow-repeat"></i> Return</span>
                                        }
                                    </td>
                                    <td style="font-family:monospace;font-size:12px;color:var(--muted)">@item.Sku</td>
                                    <td style="text-align:center">
                                        <span style="background:var(--bg2);border-radius:5px;padding:2px 8px;font-weight:700;font-size:12px">×@item.Quantity</span>
                                    </td>
                                    <td style="text-align:right;font-size:13px">@item.UnitPrice.ToString("N0") ₫</td>
                                    <td style="text-align:right"><span class="price-val">@((item.UnitPrice * item.Quantity).ToString("N0")) ₫</span></td>
                                    <td style="text-align:center">
                                        @if ((item.ProductInventory ?? 0) < item.Quantity && !isSvc)
                                        {
                                            <span class="pill pill-out"><i class="bi bi-exclamation-triangle"></i> Low</span>
                                        }
                                        else if (!isSvc)
                                        {

                                            <span class="pill pill-ok">✓ OK</span>
                                        }
                                        else
                                        {

                                            <span style="color:var(--muted);font-size:11px">—</span>
                                        }
                                    </td>
                                </tr>

                                @if (item.PrescriptionDetails != null)
                                {
                                    <tr class="rx-section">
                                        <td colspan="6" style="padding:0 12px 13px">
                                            <div class="rx-inner">
                                                <div class="rx-title">
                                                    <i class="bi bi-eyeglasses"></i> Prescription
                                                    @if (!item.IsPrescriptionVerified)
                                                    {
                                                        <span class="verify-badge">Needs Verification</span>
                                                    }
                                                    else
                                                    {

                                                        <span class="verified-badge">✓ Verified</span>
                                                    }
                                                </div>
                                                <div class="rx-grid">
                                                    <div class="rx-eye">
                                                        <div class="rx-eye-t">Left Eye (OS)</div>
                                                        <div class="rx-row"><span>SPH</span><span>@item.PrescriptionDetails.LeftSph</span></div>
                                                        <div class="rx-row"><span>CYL</span><span>@item.PrescriptionDetails.LeftCyl</span></div>
                                                        <div class="rx-row"><span>AXIS</span><span>@item.PrescriptionDetails.LeftAxis°</span></div>
                                                    </div>
                                                    <div class="rx-eye">
                                                        <div class="rx-eye-t">Right Eye (OD)</div>
                                                        <div class="rx-row"><span>SPH</span><span>@item.PrescriptionDetails.RightSph</span></div>
                                                        <div class="rx-row"><span>CYL</span><span>@item.PrescriptionDetails.RightCyl</span></div>
                                                        <div class="rx-row"><span>AXIS</span><span>@item.PrescriptionDetails.RightAxis°</span></div>
                                                    </div>
                                                </div>
                                                @if (!item.IsPrescriptionVerified)
                                                {
                                                    <div style="display:flex;gap:7px;flex-wrap:wrap">
                                                        <form method="post" asp-page-handler="VerifyPrescription" style="display:inline">
                                                            <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                                                            <button type="submit" class="act-btn" style="background:linear-gradient(135deg,#15803d,#16a34a);color:#fff;padding:7px 14px;border-radius:7px;font-size:12px;font-weight:700;border:none;cursor:pointer">
                                                                ✓ Verify Prescription
                                                            </button>
                                                        </form>
                                                        <button type="button" class="act-btn contact"
                                                                onclick="contactCustomerAboutPrescription(@item.OrderItemId)"
                                                                style="padding:7px 14px;border-radius:7px;font-size:12px">
                                                            <i class="bi bi-envelope"></i> Request Correction
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr style="border-top:2px solid var(--bdr2)">
                                <td colspan="4" style="text-align:right;font-weight:700;font-size:13px;padding:12px;color:var(--txt2)">Total</td>
                                <td colspan="2" style="text-align:right;font-weight:900;font-size:17px;padding:12px">
                                    <span class="price-val">@Model.Order.TotalAmount.ToString("N0") ₫</span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- ── RIGHT ── -->
        <div>
            <div class="dc" style="position:sticky;top:80px">
                <div class="dc-hdr dark"><i class="bi bi-tools" style="color:rgba(255,255,255,.7)"></i><h3>Support Actions</h3></div>
                <div class="dc-body">
                    <!-- Status Update -->
                    <form method="post" asp-page-handler="UpdateStatus" id="statusForm">
                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                        <span class="form-lbl">Update Status</span>

                        @if (Model.HasServiceItem && !serviceDone && !serviceCancelled)
                        {
                            <select name="newStatus" class="fi" id="statusSelect" onchange="checkLock(this)" style="margin-bottom:7px">
                                @foreach (var s in Model.AllStatuses)
                                {
                                    <option value="@s" selected="@(s == Model.Order.Status)"
                                            data-locked="@(blockedStatuses.Contains(s) ? "true" : "false")">
                                        @(blockedStatuses.Contains(s) ? "[Locked] " : "")@s
                                    </option>
                                }
                            </select>
                            <div class="lock-hint" id="lockHint" style="display:none">
                                <i class="bi bi-lock-fill" style="flex-shrink:0;margin-top:1px"></i>
                                <span>This status requires the service job to be <strong>Done</strong> first.</span>
                            </div>
                            <button type="submit" class="btn-update" id="submitBtn">
                                <i class="bi bi-arrow-repeat"></i> Update Status
                            </button>
                        }
                        else
                        {
                            <select name="newStatus" class="fi" style="margin-bottom:11px">
                                @foreach (var s in Model.AllStatuses)
                                {
                                    <option value="@s" selected="@(s == Model.Order.Status)">@s</option>
                                }
                            </select>
                            <button type="submit" class="btn-update">
                                <i class="bi bi-arrow-repeat"></i> Update Status
                            </button>
                        }
                    </form>

                    <div class="divider"></div>

                    <!-- Actions -->
                    <div class="act-grid">
                        @if (Model.Order.Status == "Pending Confirmation")
                        {
                            <button type="button" class="act-btn confirm" onclick="confirmOrder()">
                                <i class="bi bi-check-circle-fill"></i> Confirm Order
                            </button>
                        }
                        @if (Model.HasServiceItem)
                        {
                            <a asp-page="/Staff/ServiceOrders/Detail" asp-route-orderId="@Model.OrderId" class="act-btn svc">
                                <i class="bi bi-tools"></i> View Service Job
                                <i class="bi bi-arrow-right" style="margin-left:auto"></i>
                            </a>
                        }
                        <button type="button" class="act-btn contact" onclick="contactCustomer()">
                            <i class="bi bi-envelope-fill"></i> Contact
                        </button>
                        <button type="button" class="act-btn escalate" onclick="escalateToManager()">
                            <i class="bi bi-arrow-up-circle-fill"></i> Escalate
                        </button>
                        @if (Model.Order.Status != "Cancelled")
                        {
                            <button type="button" class="act-btn cancel" onclick="cancelOrder()">
                                <i class="bi bi-x-circle-fill"></i> Cancel Order
                            </button>
                        }
                    </div>

                    <a asp-page="/Support/Customers/OrderHistory" asp-route-userId="@Model.Order.UserId" class="hist-link">
                        <i class="bi bi-clock-history"></i> Customer Order History
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>

            <a asp-page="./Index" class="back-l">
                <i class="bi bi-arrow-left"></i> Back to Support Queue
            </a>
        </div>
    </div>
</div>

<!-- Hidden Forms -->
<form id="confirmForm" method="post" asp-page-handler="Confirm" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="orderId" value="@Model.OrderId" />
</form>
<form id="escalateForm" method="post" asp-page-handler="Escalate" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="orderId" value="@Model.OrderId" />
</form>

@section Scripts {
    <script>
        var BLOCKED      = @Json.Serialize(new[] { "Shipped", "Delivered", "Completed" });
        var SERVICE_DONE = @Json.Serialize(serviceDone);
        var HAS_SERVICE  = @Json.Serialize(Model.HasServiceItem);

        function checkLock(sel) {
            if (!HAS_SERVICE || SERVICE_DONE) return;
            var locked = BLOCKED.indexOf(sel.value) !== -1;
            var hint   = document.getElementById('lockHint');
            var btn    = document.getElementById('submitBtn');
            if (hint) hint.style.display = locked ? 'flex' : 'none';
            if (btn) {
                btn.disabled = locked;
                btn.innerHTML = locked
                    ? '<i class="bi bi-lock-fill"></i> Locked — Service Not Done'
                    : '<i class="bi bi-arrow-repeat"></i> Update Status';
            }
            sel.style.borderColor = locked ? '#dc2626' : '';
            sel.style.background  = locked ? 'rgba(220,38,38,.04)' : '';
        }
        var sel = document.getElementById('statusSelect');
        if (sel) checkLock(sel);

        function confirmOrder() {
            if (confirm('Confirm this order?\n\nThis will notify the customer and send to Operations team.'))
                document.getElementById('confirmForm').submit();
        }
        function contactCustomer() {
            window.location.href = 'mailto:@Model.CustomerEmail?subject=Regarding Order #@Model.OrderId';
        }
        function contactCustomerAboutPrescription(itemId) {
            var sub  = encodeURIComponent('Prescription Correction Needed — Order #@Model.OrderId');
            var body = encodeURIComponent('Dear Customer,\n\nWe need clarification on your prescription values for Order #@Model.OrderId.\n\nPlease reply with the correct prescription.\n\nThank you!');
            window.location.href = 'mailto:@Model.CustomerEmail?subject=' + sub + '&body=' + body;
        }
        function escalateToManager() {
            if (confirm('Escalate to Manager?\n\nThis order will be flagged for manager review.'))
                document.getElementById('escalateForm').submit();
        }
        function cancelOrder() {
            if (confirm('Cancel Order #@Model.OrderId?\n\nThis action cannot be undone!'))
                alert('Cancel order feature — To be implemented');
        }

        var alOk = document.querySelector('.al-ok');
        if (alOk) setTimeout(() => { alOk.style.transition='opacity .5s'; alOk.style.opacity='0'; }, 4000);
    </script>
}
