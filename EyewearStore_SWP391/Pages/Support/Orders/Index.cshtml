@page
@model EyewearStore_SWP391.Pages.Support.Orders.IndexModel
@{
    ViewData["Title"] = "Support Staff - Order Management";
}

@section Styles {
    <style>
        :root {
            --navy: #0d1b2a;
            --navy2: #1a2f54;
            --teal: #0f766e;
            --teal2: #0d9488;
            --red: #dc2626;
            --red-s: rgba(220,38,38,.08);
            --txt: #0f172a;
            --txt2: #475569;
            --muted: #94a3b8;
            --surf: #fff;
            --bg: #f1f5f9;
            --bg2: #e8edf4;
            --bdr: #e2e8f0;
            --r: 12px;
            --sh: 0 1px 4px rgba(0,0,0,.06), 0 2px 10px rgba(0,0,0,.04);
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        body {
            background: var(--bg);
            font-family: 'Segoe UI', system-ui, sans-serif
        }

        .sp-pg {
            max-width: 1280px;
            margin: 0 auto;
            padding: 28px 20px 80px
        }

        .bc {
            display: flex;
            gap: 6px;
            align-items: center;
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 20px
        }

            .bc a {
                color: var(--muted);
                text-decoration: none;
                font-weight: 600
            }

                .bc a:hover {
                    color: var(--teal)
                }

        .pg-hdr {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 24px
        }

            .pg-hdr h1 {
                font-size: 1.5rem;
                font-weight: 900;
                color: var(--navy);
                margin: 0 0 4px;
                letter-spacing: -.4px
            }

            .pg-hdr p {
                font-size: 13px;
                color: var(--txt2);
                margin: 0
            }

        .hdr-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center
        }

        .al {
            display: flex;
            align-items: center;
            gap: 8px;
            border-radius: 10px;
            padding: 11px 16px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 16px
        }

        .al-ok {
            background: rgba(5,150,105,.08);
            border: 1px solid rgba(5,150,105,.2);
            color: #059669
        }

        .al-err {
            background: var(--red-s);
            border: 1px solid rgba(220,38,38,.2);
            color: var(--red)
        }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 22px
        }

        .stat-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            padding: 16px 18px;
            box-shadow: var(--sh);
            position: relative;
            overflow: hidden
        }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px
            }

            .stat-card.c1::before {
                background: var(--navy)
            }

            .stat-card.c2::before {
                background: var(--teal)
            }

            .stat-card.c3::before {
                background: var(--red)
            }

            .stat-card.c4::before {
                background: var(--navy2)
            }

        .stat-label {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 6px
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 900;
            color: var(--navy);
            line-height: 1
        }

        .stat-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 4px
        }

        .filter-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            padding: 16px 18px;
            margin-bottom: 16px;
            box-shadow: var(--sh)
        }

            .filter-card h6 {
                font-size: 11px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: .8px;
                color: var(--muted);
                margin: 0 0 12px
            }

        .filter-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: flex-end
        }

        .fi {
            background: var(--bg);
            border: 1.5px solid var(--bdr);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 13px;
            color: var(--txt);
            font-family: inherit;
            transition: border-color .2s;
            flex: 1;
            min-width: 160px
        }

            .fi:focus {
                outline: none;
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(15,118,110,.1)
            }

        .fi-search {
            flex: 2;
            min-width: 220px
        }

        .btn-apply {
            padding: 9px 20px;
            background: linear-gradient(135deg,var(--navy),var(--navy2));
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            white-space: nowrap;
            transition: all .2s;
            display: flex;
            align-items: center;
            gap: 6px
        }

            .btn-apply:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(13,27,42,.25)
            }

        .quick-links {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 10px
        }

        .ql {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-decoration: none;
            border: 1.5px solid;
            transition: all .15s
        }

        .ql-navy {
            color: var(--navy);
            border-color: var(--navy)
        }

            .ql-navy:hover {
                background: var(--navy);
                color: #fff
            }

        .ql-teal {
            color: var(--teal);
            border-color: var(--teal)
        }

            .ql-teal:hover {
                background: var(--teal);
                color: #fff
            }

        .ql-red {
            color: var(--red);
            border-color: var(--red)
        }

            .ql-red:hover {
                background: var(--red);
                color: #fff
            }

        .ps-sel {
            width: 90px;
            flex: none
        }

        .tbl-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            overflow: hidden;
            box-shadow: var(--sh)
        }

        .tbl-hdr {
            padding: 13px 18px;
            background: linear-gradient(135deg,var(--navy),var(--navy2));
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px
        }

            .tbl-hdr h5 {
                font-size: 13px;
                font-weight: 800;
                color: #fff;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 7px
            }

        .tbl-hdr-info {
            font-size: 12px;
            color: rgba(255,255,255,.6)
        }

            .tbl-hdr-info strong {
                color: rgba(255,255,255,.9)
            }

        .sp-tbl {
            width: 100%;
            border-collapse: collapse
        }

            .sp-tbl th {
                font-size: 10px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: .8px;
                color: var(--muted);
                padding: 10px 14px;
                background: var(--bg2);
                border-bottom: 1px solid var(--bdr);
                text-align: left
            }

            .sp-tbl td {
                padding: 12px 14px;
                border-bottom: 1px solid var(--bdr);
                font-size: 13px;
                color: var(--txt2);
                vertical-align: middle
            }

            .sp-tbl tbody tr:last-child td {
                border-bottom: none
            }

            .sp-tbl tbody tr:hover td {
                background: rgba(15,118,110,.03)
            }

            .sp-tbl tbody tr.high-priority td {
                background: rgba(220,38,38,.025)
            }

        .order-id {
            font-weight: 800;
            color: var(--navy);
            font-size: 14px
        }

        .cust-name {
            font-weight: 700;
            color: var(--txt);
            font-size: 13px
        }

        .cust-email {
            font-size: 11px;
            color: var(--muted)
        }

        .date-main {
            font-size: 13px;
            color: var(--txt)
        }

        .date-sub {
            font-size: 11px;
            color: var(--muted)
        }

        .total-val {
            font-size: 14px;
            font-weight: 800;
            color: var(--red)
        }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700
        }

        .pill-pending {
            background: rgba(217,119,6,.1);
            color: #b45309;
            border: 1px solid rgba(217,119,6,.2)
        }

        .pill-confirmed {
            background: rgba(15,118,110,.1);
            color: var(--teal);
            border: 1px solid rgba(15,118,110,.2)
        }

        .pill-processing {
            background: rgba(13,27,42,.08);
            color: var(--navy2);
            border: 1px solid rgba(13,27,42,.15)
        }

        .pill-shipped {
            background: rgba(15,118,110,.08);
            color: #065f46;
            border: 1px solid rgba(15,118,110,.15)
        }

        .pill-delivered {
            background: rgba(15,118,110,.08);
            color: #065f46;
            border: 1px solid rgba(15,118,110,.15)
        }

        .pill-completed {
            background: rgba(13,27,42,.08);
            color: var(--navy);
            border: 1px solid rgba(13,27,42,.12)
        }

        .pill-cancelled {
            background: var(--red-s);
            color: var(--red);
            border: 1px solid rgba(220,38,38,.2)
        }

        .pill-rx {
            background: rgba(13,27,42,.07);
            color: var(--navy2);
            border: 1px solid rgba(13,27,42,.12)
        }

        .pill-preorder {
            background: var(--bg2);
            color: var(--txt2);
            border: 1px solid var(--bdr)
        }

        .pill-ready {
            background: rgba(15,118,110,.08);
            color: var(--teal);
            border: 1px solid rgba(15,118,110,.15)
        }

        .pill-urgent {
            background: var(--red-s);
            color: var(--red);
            border: 1px solid rgba(220,38,38,.2)
        }

        .pill-return {
            background: rgba(217,119,6,.08);
            color: #b45309;
            border: 1px solid rgba(217,119,6,.15)
        }

        .act-process {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 14px;
            background: linear-gradient(135deg,var(--teal),var(--teal2));
            color: #fff;
            border-radius: 7px;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: all .2s
        }

            .act-process:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 10px rgba(15,118,110,.3)
            }

        .act-confirm-quick {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            background: rgba(15,118,110,.1);
            border: 1.5px solid rgba(15,118,110,.25);
            color: var(--teal);
            border-radius: 7px;
            font-size: 14px;
            cursor: pointer;
            transition: all .15s;
            margin-left: 4px
        }

            .act-confirm-quick:hover {
                background: var(--teal);
                color: #fff
            }

        .empty {
            text-align: center;
            padding: 60px 20px
        }

        .empty-icon {
            font-size: 56px;
            color: var(--muted);
            opacity: .3;
            margin-bottom: 16px
        }

        .empty h4 {
            font-size: 16px;
            font-weight: 700;
            color: var(--txt2);
            margin: 0 0 6px
        }

        .empty p {
            font-size: 13px;
            color: var(--muted);
            margin: 0
        }

        .pag-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 18px;
            border-top: 1px solid var(--bdr)
        }

        .pag-info {
            font-size: 12px;
            color: var(--muted)
        }

        .pag {
            display: flex;
            gap: 4px;
            list-style: none;
            margin: 0;
            padding: 0
        }

        .pag-item a, .pag-item span {
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 34px;
            height: 34px;
            padding: 0 8px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            border: 1.5px solid var(--bdr);
            color: var(--txt2);
            background: var(--surf);
            transition: all .15s
        }

            .pag-item a:hover {
                border-color: var(--teal);
                color: var(--teal)
            }

        .pag-item.active span {
            background: var(--navy);
            border-color: var(--navy);
            color: #fff
        }

        .pag-item.disabled span {
            opacity: .4;
            pointer-events: none
        }
        /* ADDED */
        .btn-svc-jobs {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg,var(--navy),var(--navy2));
            color: #fff;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            transition: all .2s;
            white-space: nowrap
        }

            .btn-svc-jobs:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(13,27,42,.3);
                color: #fff
            }

        .btn-returns {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            background: rgba(220,38,38,.08);
            border: 1.5px solid rgba(220,38,38,.2);
            color: var(--red);
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            transition: all .15s
        }

            .btn-returns:hover {
                background: var(--red);
                color: #fff
            }

        .btn-refresh {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            background: var(--bg2);
            border: 1.5px solid var(--bdr);
            color: var(--txt2);
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: all .15s
        }

            .btn-refresh:hover {
                background: var(--bg);
                color: var(--txt)
            }

        @@media(max-width:960px) {
            .stats-row {
                grid-template-columns: 1fr 1fr
            }
        }

        @@media(max-width:600px) {
            .stats-row {
                grid-template-columns: 1fr 1fr
            }

            .filter-row {
                flex-direction: column
            }

            .fi {
                min-width: 100%
            }
        }
    </style>
}

<div class="sp-pg">
    <div class="bc">
        <a asp-page="/Index">Home</a>
        <span style="opacity:.4">›</span>
        <span>Support Dashboard</span>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="al al-ok"><i class="bi bi-check-circle-fill"></i> @ok</div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="al al-err"><i class="bi bi-exclamation-circle-fill"></i> @err</div>
    }

    <div class="pg-hdr">
        <div>
            <h1><i class="bi bi-chat-dots me-2"></i>Support Dashboard</h1>
            <p>Process orders, verify prescriptions, and handle customer requests</p>
        </div>
        <div class="hdr-actions">
            <button class="btn-refresh" onclick="window.location.reload()">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
            <a asp-page="/Support/ServiceOrders/Index" class="btn-svc-jobs">
                <i class="bi bi-wrench"></i> Service Jobs <i class="bi bi-arrow-right"></i>
            </a>
            <a asp-page="/Support/Returns/Index" class="btn-returns">
                <i class="bi bi-arrow-return-left"></i> Returns Queue
            </a>
        </div>
    </div>

    <div class="stats-row">
        <div class="stat-card c1">
            <div class="stat-label">Pending Confirmation</div>
            <div class="stat-value">@Model.Stats.PendingCount</div>
            <div class="stat-sub">Requires attention</div>
        </div>
        <div class="stat-card c2">
            <div class="stat-label">Confirmed</div>
            <div class="stat-value">@Model.Stats.ConfirmedCount</div>
            <div class="stat-sub">Ready for processing</div>
        </div>
        <div class="stat-card c3">
            <div class="stat-label">Returns Queue</div>
            <div class="stat-value">@Model.Stats.ReturnCount</div>
            <div class="stat-sub">Pending processing</div>
        </div>
        <div class="stat-card c4">
            <div class="stat-label">Today's Confirmed</div>
            <div class="stat-value">@Model.Stats.TodayConfirmedCount</div>
            <div class="stat-sub">Orders processed</div>
        </div>
    </div>

    <div class="filter-card">
        <h6><i class="bi bi-funnel me-1"></i> Search & Filter</h6>
        <form method="get" class="filter-row">
            <input type="text" class="fi fi-search" name="Search" value="@Model.Search" placeholder="Order ID, email, customer name..." />
            <select class="fi" name="StatusFilter">
                <option value="">All Statuses</option>
                @foreach (var s in Model.Statuses)
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
            <select class="fi" name="TypeFilter">
                <option value="">All Types</option>
                <option value="Prescription" selected="@(Model.TypeFilter == "Prescription")">Prescription</option>
                <option value="ReadyStock" selected="@(Model.TypeFilter == "ReadyStock")">Ready Stock</option>
                <option value="PreOrder" selected="@(Model.TypeFilter == "PreOrder")">Pre-Order</option>
            </select>
            <select class="fi" name="PriorityFilter">
                <option value="">All Priority</option>
                <option value="High" selected="@(Model.PriorityFilter == "High")">High Priority</option>
                <option value="Normal" selected="@(Model.PriorityFilter == "Normal")">Normal</option>
            </select>
            <select class="fi ps-sel" name="pageSize">
                <option value="10" selected="@(Model.PageSize == 10)">10</option>
                <option value="25" selected="@(Model.PageSize == 25)">25</option>
                <option value="50" selected="@(Model.PageSize == 50)">50</option>
            </select>
            <input type="hidden" name="pageNumber" value="1" />
            <button type="submit" class="btn-apply"><i class="bi bi-funnel-fill"></i> Filter</button>
        </form>
        <div class="quick-links">
            <a href="?StatusFilter=Pending+Confirmation" class="ql ql-navy"><i class="bi bi-exclamation-circle"></i> Pending</a>
            <a href="?StatusFilter=Confirmed" class="ql ql-teal"><i class="bi bi-check-circle"></i> Confirmed</a>
            <a href="?TypeFilter=Prescription" class="ql ql-teal"><i class="bi bi-eyeglasses"></i> Prescription</a>
            <a href="?TypeFilter=PreOrder" class="ql ql-navy"><i class="bi bi-hourglass"></i> Pre-Orders</a>
            <a asp-page="/Support/Returns/Index" class="ql ql-red"><i class="bi bi-arrow-return-left"></i> Returns</a>
            <a asp-page="/Support/ServiceOrders/Index" class="ql ql-navy"><i class="bi bi-wrench"></i> Service Jobs</a>
        </div>
    </div>

    <div class="tbl-card">
        <div class="tbl-hdr">
            <h5><i class="bi bi-list-check"></i> Support Queue (@Model.TotalOrders orders)</h5>
            <div class="tbl-hdr-info">Showing <strong>@Model.FirstItemIndex–@Model.LastItemIndex</strong> of <strong>@Model.TotalOrders</strong></div>
        </div>

        @if (!Model.Orders.Any())
        {
            <div class="empty">
                <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                <h4>No Orders in Queue</h4>
                <p>All caught up! Great job.</p>
            </div>
        }
        else
        {
            <div style="overflow-x:auto">
                <table class="sp-tbl">
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Customer</th>
                            <th>Created</th>
                            <th>Status</th>
                            <th>Type</th>
                            <th style="text-align:right">Total</th>
                            <th style="text-align:center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            bool isHigh = order.HasPrescription || order.CreatedAt < DateTime.UtcNow.AddDays(-2) || order.HasReturn;
                            string sPill = order.Status switch
                            {
                                "Pending Confirmation" => "pill-pending",
                                "Confirmed" => "pill-confirmed",
                                "Processing" => "pill-processing",
                                "Shipped" => "pill-shipped",
                                "Delivered" => "pill-delivered",
                                "Completed" => "pill-completed",
                                "Cancelled" => "pill-cancelled",
                                _ => ""
                            };
                            <tr class="@(isHigh ? "high-priority" : "")">
                                <td>
                                    <div class="order-id">#@order.OrderId</div>
                                    @if (isHigh)
                                    {
                                        <span class="pill pill-urgent" style="margin-top:3px"><i class="bi bi-exclamation-triangle"></i> Urgent</span>
                                    }
                                    @if (order.HasReturn)
                                    {
                                        <span class="pill pill-return" style="margin-top:3px"><i class="bi bi-arrow-return-left"></i> Return</span>
                                    }
                                </td>
                                <td>
                                    <div class="cust-name">@order.UserFullName</div>
                                    <div class="cust-email">@order.UserEmail</div>
                                </td>
                                <td>
                                    <div class="date-main">@order.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    <div class="date-sub">@order.CreatedAt.ToString("HH:mm")</div>
                                </td>
                                <td><span class="pill @sPill">@order.Status</span></td>
                                <td>
                                    @if (order.HasPrescription)
                                    {
                                        <span class="pill pill-rx"><i class="bi bi-eyeglasses"></i> Rx</span>
                                    }
                                    else if (order.IsLowStock)
                                    {

                                        <span class="pill pill-preorder"><i class="bi bi-hourglass-split"></i> Pre-Order</span>
                                    }
                                    else
                                    {

                                        <span class="pill pill-ready"><i class="bi bi-check-circle"></i> Ready</span>
                                    }
                                </td>
                                <td style="text-align:right">
                                    <span class="total-val">@order.TotalAmount.ToString("C", new System.Globalization.CultureInfo("en-US"))</span>
                                </td>
                                <td style="text-align:center">
                                    <a asp-page="./Details" asp-route-id="@order.OrderId" class="act-process">
                                        <i class="bi bi-eye"></i> Process
                                    </a>
                                    @if (order.Status == "Pending Confirmation")
                                    {
                                        <button type="button" class="act-confirm-quick" onclick="quickConfirm(@order.OrderId)" title="Quick confirm">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="pag-row">
                <div class="pag-info">Page @Model.PageNumber of @Model.TotalPages</div>
                <ul class="pag">
                    <li class="pag-item @(Model.PageNumber == 1 ? "disabled" : "")"><a asp-page="./Index" asp-route-pageNumber="1" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">«</a></li>
                    <li class="pag-item @(Model.PageNumber == 1 ? "disabled" : "")"><a asp-page="./Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">‹</a></li>
                    @foreach (var p in Model.DisplayPageNumbers)
                    {
                        <li class="pag-item @(p == Model.PageNumber ? "active" : "")">
                            @if (p == Model.PageNumber)
                            {
                                <span>@p</span>
                            }
                            else
                            {

                                <a asp-page="./Index" asp-route-pageNumber="@p" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">@p</a>
                            }
                        </li>
                    }
                    <li class="pag-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")"><a asp-page="./Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">›</a></li>
                    <li class="pag-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")"><a asp-page="./Index" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="@Model.PageSize" asp-route-Search="@Model.Search" asp-route-StatusFilter="@Model.StatusFilter" asp-route-TypeFilter="@Model.TypeFilter" asp-route-PriorityFilter="@Model.PriorityFilter">»</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<form id="quickConfirmForm" method="post" asp-page-handler="QuickConfirm" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="orderId" id="quickConfirmOrderId" />
</form>

@section Scripts {
    <script>
        function quickConfirm(orderId) {
            if (!confirm(`Quick confirm Order #${orderId}?`)) return;
            document.getElementById('quickConfirmOrderId').value = orderId;
            document.getElementById('quickConfirmForm').submit();
        }
        setTimeout(() => location.reload(), 120000);
    </script>
}
