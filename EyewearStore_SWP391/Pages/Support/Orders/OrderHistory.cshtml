@page "{userId:int}"
@model EyewearStore_SWP391.Pages.Support.Customers.OrderHistoryModel
@{
    ViewData["Title"] = $"Order History - {Model.CustomerName}";
}

@section Styles {
    <style>
        :root {
            --navy: #0d1b2a;
            --navy2: #1a2f54;
            --teal: #0f766e;
            --teal2: #0d9488;
            --red: #dc2626;
            --red-s: rgba(220,38,38,.08);
            --txt: #0f172a;
            --txt2: #475569;
            --muted: #94a3b8;
            --surf: #fff;
            --bg: #f1f5f9;
            --bg2: #e8edf4;
            --bdr: #e2e8f0;
            --sh: 0 1px 4px rgba(0,0,0,.06), 0 2px 10px rgba(0,0,0,.04);
            --r: 12px;
        }

        *, *::before, *::after {
            box-sizing: border-box
        }

        .oh-pg {
            max-width: 1100px;
            margin: 0 auto;
            padding: 28px 20px 80px
        }

        /* Breadcrumb */
        .bc {
            display: flex;
            gap: 6px;
            align-items: center;
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 20px
        }

            .bc a {
                color: var(--muted);
                text-decoration: none;
                font-weight: 600
            }

                .bc a:hover {
                    color: var(--teal)
                }

        /* Header */
        .pg-hdr {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 22px
        }

            .pg-hdr h1 {
                font-size: 1.5rem;
                font-weight: 900;
                color: var(--navy);
                margin: 0 0 4px;
                letter-spacing: -.4px
            }

            .pg-hdr p {
                font-size: 13px;
                color: var(--txt2);
                margin: 0
            }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            background: var(--bg2);
            border: 1.5px solid var(--bdr);
            color: var(--txt2);
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
            transition: all .15s
        }

            .btn-back:hover {
                background: var(--bg);
                color: var(--txt)
            }

        /* Stats */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 13px;
            margin-bottom: 22px
        }

        .stat-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            padding: 16px 18px;
            box-shadow: var(--sh);
            position: relative;
            overflow: hidden
        }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: var(--navy)
            }

            .stat-card.c-teal::before {
                background: var(--teal)
            }

            .stat-card.c-red::before {
                background: var(--red)
            }

        .stat-label {
            font-size: 10px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 5px
        }

        .stat-value {
            font-size: 1.9rem;
            font-weight: 900;
            color: var(--navy);
            line-height: 1
        }

            .stat-value.red {
                color: var(--red)
            }

        /* Table card */
        .tbl-card {
            background: var(--surf);
            border: 1px solid var(--bdr);
            border-radius: var(--r);
            overflow: hidden;
            box-shadow: var(--sh)
        }

        .tbl-hdr {
            padding: 13px 18px;
            background: linear-gradient(135deg,var(--navy),var(--navy2));
            display: flex;
            align-items: center;
            gap: 8px
        }

            .tbl-hdr h5 {
                font-size: 13px;
                font-weight: 800;
                color: #fff;
                margin: 0
            }

        .oh-tbl {
            width: 100%;
            border-collapse: collapse
        }

            .oh-tbl th {
                font-size: 10px;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: .8px;
                color: var(--muted);
                padding: 10px 14px;
                background: var(--bg2);
                border-bottom: 1px solid var(--bdr);
                text-align: left
            }

            .oh-tbl td {
                padding: 12px 14px;
                border-bottom: 1px solid var(--bdr);
                font-size: 13px;
                color: var(--txt2);
                vertical-align: middle
            }

            .oh-tbl tbody tr:last-child td {
                border-bottom: none
            }

            .oh-tbl tbody tr:hover td {
                background: rgba(15,118,110,.03)
            }

        .order-id {
            font-weight: 800;
            color: var(--navy);
            font-size: 14px
        }

        .date-main {
            font-size: 13px;
            color: var(--txt)
        }

        .date-sub {
            font-size: 11px;
            color: var(--muted)
        }

        .total-val {
            font-size: 14px;
            font-weight: 800;
            color: var(--red)
        }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 10px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 700
        }

        .pill-pending {
            background: rgba(217,119,6,.1);
            color: #b45309;
            border: 1px solid rgba(217,119,6,.2)
        }

        .pill-confirmed {
            background: rgba(15,118,110,.1);
            color: var(--teal);
            border: 1px solid rgba(15,118,110,.2)
        }

        .pill-processing {
            background: rgba(13,27,42,.07);
            color: var(--navy2);
            border: 1px solid rgba(13,27,42,.14)
        }

        .pill-shipped {
            background: rgba(15,118,110,.07);
            color: #065f46;
            border: 1px solid rgba(15,118,110,.15)
        }

        .pill-delivered {
            background: rgba(15,118,110,.07);
            color: #065f46;
            border: 1px solid rgba(15,118,110,.15)
        }

        .pill-completed {
            background: rgba(13,27,42,.07);
            color: var(--navy);
            border: 1px solid rgba(13,27,42,.12)
        }

        .pill-cancelled {
            background: var(--red-s);
            color: var(--red);
            border: 1px solid rgba(220,38,38,.18)
        }

        .act-view {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 14px;
            background: linear-gradient(135deg,var(--teal),var(--teal2));
            color: #fff;
            border-radius: 7px;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            transition: all .15s
        }

            .act-view:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 10px rgba(15,118,110,.3)
            }

        /* Empty */
        .empty {
            text-align: center;
            padding: 60px 20px
        }

        .empty-icon {
            font-size: 56px;
            color: var(--muted);
            opacity: .25;
            margin-bottom: 16px
        }

        .empty h4 {
            font-size: 16px;
            font-weight: 700;
            color: var(--txt2);
            margin: 0 0 6px
        }

        .empty p {
            font-size: 13px;
            color: var(--muted);
            margin: 0
        }

        @@media(max-width:800px) {
            .stats-row {
                grid-template-columns: 1fr 1fr
            }
        }

        @@media(max-width:480px) {
            .stats-row {
                grid-template-columns: 1fr 1fr
            }
        }
    </style>
}

<div class="oh-pg">
    <!-- Breadcrumb -->
    <div class="bc">
        <a asp-page="/Index">Home</a>
        <span style="opacity:.4">›</span>
        <a asp-page="/Support/Orders/Index">Support Dashboard</a>
        <span style="opacity:.4">›</span>
        <span>Order History</span>
    </div>

    <!-- Header -->
    <div class="pg-hdr">
        <div>
            <h1><i class="bi bi-clock-history me-2"></i>Order History</h1>
            <p>Customer: <strong>@Model.CustomerName</strong> · @Model.CustomerEmail</p>
        </div>
        <button class="btn-back" onclick="window.history.back()"><i class="bi bi-arrow-left"></i> Back</button>
    </div>

    <!-- Stats -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-label">Total Orders</div>
            <div class="stat-value">@Model.Stats.TotalOrders</div>
        </div>
        <div class="stat-card c-teal">
            <div class="stat-label">Completed</div>
            <div class="stat-value">@Model.Stats.CompletedOrders</div>
        </div>
        <div class="stat-card c-red">
            <div class="stat-label">Cancelled</div>
            <div class="stat-value">@Model.Stats.CancelledOrders</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Spent</div>
            <div class="stat-value red" style="font-size:1.35rem">@Model.Stats.TotalSpent.ToString("N0") ₫</div>
        </div>
    </div>

    <!-- Table -->
    @if (!Model.Orders.Any())
    {
        <div class="tbl-card">
            <div class="empty">
                <div class="empty-icon"><i class="bi bi-box-seam"></i></div>
                <h4>No Order History</h4>
                <p>This customer has not placed any orders yet.</p>
            </div>
        </div>
    }
    else
    {
        <div class="tbl-card">
            <div class="tbl-hdr">
                <i class="bi bi-card-list" style="color:rgba(255,255,255,.7)"></i>
                <h5>All Orders (@Model.Orders.Count)</h5>
            </div>
            <div style="overflow-x:auto">
                <table class="oh-tbl">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Items</th>
                            <th style="text-align:right">Total</th>
                            <th style="text-align:center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            string pillCls = order.Status switch
                            {
                                "Pending Confirmation" => "pill-pending",
                                "Confirmed" => "pill-confirmed",
                                "Processing" => "pill-processing",
                                "Shipped" => "pill-shipped",
                                "Delivered" => "pill-delivered",
                                "Completed" => "pill-completed",
                                "Cancelled" => "pill-cancelled",
                                _ => ""
                            };
                            <tr>
                                <td><span class="order-id">#@order.OrderId</span></td>
                                <td>
                                    <div class="date-main">@order.CreatedAt.ToString("MMM dd, yyyy")</div>
                                    <div class="date-sub">@order.CreatedAt.ToString("HH:mm")</div>
                                </td>
                                <td><span class="pill @pillCls">@order.Status</span></td>
                                <td style="color:var(--muted);font-size:12px">@order.ItemCount item(s)</td>
                                <td style="text-align:right"><span class="total-val">@order.TotalAmount.ToString("N0") ₫</span></td>
                                <td style="text-align:center">
                                    <a asp-page="/Support/Orders/Details" asp-route-id="@order.OrderId" class="act-view">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
